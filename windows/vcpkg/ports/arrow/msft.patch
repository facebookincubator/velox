+// way to prevent that other than redefining __FILE__ here.
+// Note: MSVC doesn't allow overriding __FILE__
+#ifndef _MSC_VER
+#define __FILE__ "parquet-shuffle"
+#endif
+
+#ifdef ARROW_WITH_SNAPPY
+constexpr auto DEFAULT_COMPRESSION = parquet::Compression::SNAPPY;
+#else
