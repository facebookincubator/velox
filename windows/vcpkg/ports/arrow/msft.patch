diff --git a/cpp/src/parquet/schema_util.cc b/cpp/src/parquet/schema_util.cc
new file mode 100644
index 0000000000..32ce2c92ee
--- /dev/null
+++ b/cpp/src/parquet/schema_util.cc
@@ -0,0 +1,45 @@
+// NOLINT legal/copyright
+
+#include "parquet/schema_util.h"
+#include "parquet/schema_internal.h"
+#include "parquet/thrift_internal.h"
+
+namespace parquet {
+namespace util {
+namespace {
+
+struct SchemaElementVector {
+  std::vector<format::SchemaElement> fields;
+
+  void read(apache::thrift::protocol::TProtocol* tproto) {
+    int32_t num_fields;
+    tproto->readI32(num_fields);
+    fields.resize(static_cast<size_t>(num_fields));
+    for (auto& field : fields) {
+      field.read(tproto);
+    }
+  }
+};
+
+}  // namespace
+
+std::shared_ptr<schema::GroupNode> DeserializeSchema(const Buffer& buffer) {
+  if (buffer.size() > std::numeric_limits<uint32_t>::max()) {
+    throw ParquetException("Buffer length should not exceed UINT32_MAX: " +
+                           std::to_string(buffer.size()));
+  }
+  SchemaElementVector schema;
+  auto len = static_cast<uint32_t>(buffer.size());
+  const auto data = buffer.data();
+  if (len == 0 || data == nullptr) {
+    throw ParquetException("Buffer is empty");
+  }
+  const auto& properties = default_reader_properties();
+  ThriftDeserializer deserializer(properties);
+  deserializer.DeserializeMessage(data, &len, &schema);
+  auto schema_descr = schema::FromParquet(schema.fields);
+  return std::static_pointer_cast<schema::GroupNode>(schema_descr->schema_root());
+}
+
+}  // namespace util
+}  // namespace parquet
