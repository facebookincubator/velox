+
+void CheckNonEmpty(const std::vector<std::shared_ptr<ParquetFileReader>>& files) {
+  if (files.empty()) {
+    throw ParquetException("At least one file must be specified");
+  }
+}
+
+void CheckCompatibleSchema(const std::vector<std::shared_ptr<ParquetFileReader>>& files) {
+  if (files.empty()) return;
+  const auto& schema = files[0]->metadata()->schema();
+  for (const auto& file : AsSpan(files).subspan(1)) {
+    if (!schema->Equals(*file->metadata()->schema())) {
+      throw ParquetException("Schema mismatch detected");
+    }
+  }
+}
+
+std::unique_ptr<SchemaDescriptor> CutSchema(const SchemaDescriptor& schema,
+                                            const std::vector<int>& columns) {
+  const auto& group_node = *schema.group_node();
+  schema::NodeVector fields;
+  fields.reserve(columns.size());
+  for (const auto c : columns) {
+    if (c >= 0 && c < group_node.field_count()) {
+      fields.emplace_back(group_node.field(c));
+    }
+  }
+  auto cut_schema = std::make_unique<SchemaDescriptor>();
+  cut_schema->Init(schema::GroupNode::Make(group_node.name(), group_node.repetition(),
+                                           fields, nullptr, group_node.field_id()));
+  return cut_schema;
+}
+
+void CheckNonNegative(int64_t value) {
+  if (value < 0) {
+    throw ParquetException("Negative value is not allowed");
+  }
+}
+
+ParquetFileReaderSlice::Impl::Impl(std::vector<std::shared_ptr<ParquetFileReader>> files,
+                                   const ParquetFileReaderSliceRange& range,
+                                   bool metadata_only, bool pre_buffer)
+    : files_(std::move(files)),
+      curr_row_group_index_(0),
+      first_row_group_row_offset_(0),
+      last_row_group_row_count_(0),
+      num_rows_(0),
+      pre_buffer_(pre_buffer) {
+  CheckNonEmpty(files_);
+  CheckCompatibleSchema(files_);
+  metadata_.emplace_back(files_[0]->metadata());
+  if (range.columns.empty()) {
+    cols_.resize(files_[0]->metadata()->num_columns());
+    std::iota(cols_.begin(), cols_.end(), 0);
+  } else {
+    cols_ = range.columns;
+    schema_ = CutSchema(*files_[0]->metadata()->schema(), cols_);
+  }
+  ParquetFileReaderSliceRange r = range;
+  CheckNonNegative(r.row_group_offset);
+  CheckNonNegative(r.row_group_count);
+  CheckNonNegative(r.row_offset);
+  CheckNonNegative(r.row_count);
+  RemoveEmptyFiles();
+  if (r.row_group_offset > 0) {
+    SkipRowGroups(r);
+  }
+  if (files_.empty()) {
+    row_group_indices_.push_back(0);
+    return;
+  }
+  int last_file_row_group_count = 0;
+  if (r.row_group_count > 0) {
+    DropRowGroups(r, last_file_row_group_count);
+  }
+  if (r.row_offset > 0) {
+    SkipRows(r);
+  }
+  if (files_.empty()) {
+    row_group_indices_.push_back(0);
+    return;
+  }
+  first_row_group_row_offset_ = r.row_offset;
+  if (r.row_count == 0) {
+    r.row_count = std::numeric_limits<int64_t>::max();
+  }
+  DropRows(r, last_file_row_group_count, last_row_group_row_count_);
+  num_rows_ = r.row_count;
+
+  row_group_indices_.push_back(-r.row_group_offset);
+  if (files_.size() == 1 && r.row_group_count > 0) {
+    row_group_indices_.push_back(r.row_group_count);
+  } else {
+    metadata_.clear();
+    metadata_.reserve(files_.size());
+    for (size_t i = 0; i < files_.size(); ++i) {
+      auto metadata = files_[i]->metadata();
+      int n = metadata->num_row_groups();
+      metadata_.emplace_back(std::move(metadata));
+      if (i == files_.size() - 1 && last_file_row_group_count > 0) {
+        n = last_file_row_group_count;
+      }
+      if (r.row_group_count > 0 && row_group_indices_.back() + n >= r.row_group_count) {
+        row_group_indices_.push_back(r.row_group_count);
+        break;
+      } else {
+        row_group_indices_.push_back(row_group_indices_.back() + n);
+      }
+    }
+  }
+  if (pre_buffer_ && !metadata_only) {
+    const auto first_file_row_group_count =
+        files_.size() == 1 && r.row_group_count > 0
+            ? r.row_group_count
+            : metadata_[0]->num_row_groups() - r.row_group_offset;
+    PreBuffer(*files_[0], first_file_row_group_count, r.row_group_offset);
+  }
+  if (metadata_only) {
+    files_.clear();
+  }
+}
