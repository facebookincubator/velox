+
+bool IsAllDigits(std::string_view s) {
+  return std::all_of(s.begin(), s.end(),
+                     [](const auto c) { return c >= '0' && c <= '9'; });
+}
+
+std::string ConvertFloatingPointNumberString(std::string s) {
+  const auto is_whole_number =
+      !s.empty() && ((s[0] != '-' && IsAllDigits(s)) ||
+                     (s[0] == '-' && IsAllDigits(std::string_view(s).substr(1))));
+  if (is_whole_number) {
+    return std::move(s) + ".0";
+  } else if (s == "inf") {
+    return "Infinity";
+  } else if (s == "-inf") {
+    return "-Infinity";
+  } else if (s == "nan") {
+    return "NaN";
+  } else {
+    return s;
+  }
+}
+
+::arrow::Result<std::string> ToString(float value, const ColumnDescriptor& descr) {
+  return ConvertFloatingPointNumberString(::arrow::internal::ToChars(value));
+}
+
+::arrow::Result<std::string> ToString(double value, const ColumnDescriptor& descr) {
+  return ConvertFloatingPointNumberString(::arrow::internal::ToChars(value));
+}
+
+::arrow::Result<std::string> ToString(const ByteArray& value,
+                                      const ColumnDescriptor& descr) {
+  const auto logical_type = descr.logical_type();
+  if (logical_type->is_string()) {
+    if (value.ptr == nullptr) {
+      return "";
+    } else {
+      return std::string(reinterpret_cast<const char*>(value.ptr), value.len);
+    }
+  }
+  return ::arrow::Status::Invalid("unsupported logical type for BYTE_ARRAY: " +
+                                  logical_type->ToString());
+}
+
+::arrow::Result<std::string> ToString(const FLBA& value, const ColumnDescriptor& descr) {
+  const auto logical_type = descr.logical_type();
+  if (logical_type->is_decimal()) {
+    return internal::DecimalToString(value.ptr, descr.type_length(),
+                                     AsDecimalType(*logical_type));
+  }
+  return ::arrow::Status::Invalid("unsupported logical type for FLBA: " +
+                                  logical_type->ToString());
+}
+
+enum class SkippingEligibleDataType {
+  IntegralType,
+  FloatingPointType,
+  DecimalType,
+  DateType,
+  TimestampType,
+  StringType,
+  UnsupportedType,
+};
+
+// Reference: org.apache.spark.sql.delta.stats.SkippingEligibleDataType
+SkippingEligibleDataType GetSkippingEligibleDataType(const ColumnDescriptor& descr) {
+  switch (descr.physical_type()) {
+    case Type::INT32: {
+      auto logical_type = descr.logical_type();
+      if (logical_type->is_none() || logical_type->is_int()) {
+        return SkippingEligibleDataType::IntegralType;
+      } else if (logical_type->is_decimal()) {
+        return SkippingEligibleDataType::DecimalType;
+      } else if (logical_type->is_date()) {
+        return SkippingEligibleDataType::DateType;
+      }
+      break;
+    }
+    case Type::INT64: {
+      auto logical_type = descr.logical_type();
+      if (logical_type->is_none()) {
+        return SkippingEligibleDataType::IntegralType;
+      } else if (logical_type->is_decimal()) {
+        return SkippingEligibleDataType::DecimalType;
+      } else if (logical_type->is_timestamp()) {
+        return SkippingEligibleDataType::TimestampType;
+      }
+      break;
+    }
+    case Type::INT96:
+      return SkippingEligibleDataType::TimestampType;
+    case Type::FLOAT:
+      return SkippingEligibleDataType::FloatingPointType;
+    case Type::DOUBLE:
+      return SkippingEligibleDataType::FloatingPointType;
+    case Type::BYTE_ARRAY: {
+      auto logical_type = descr.logical_type();
+      if (logical_type->is_string()) {
+        return SkippingEligibleDataType::StringType;
+      }
+      break;
+    }
+    case Type::FIXED_LEN_BYTE_ARRAY: {
+      auto logical_type = descr.logical_type();
+      if (logical_type->is_decimal()) {
+        return SkippingEligibleDataType::DecimalType;
+      }
+      break;
+    }
+    default:
+      break;
+  }
+  return SkippingEligibleDataType::UnsupportedType;
+}
+
+template <typename T, typename Truncate>
+std::optional<std::string> ToStatsString(T value, const ColumnDescriptor& descr,
+                                         int string_prefix_length, Truncate truncate) {
+  std::optional<std::string> str_opt;
+  auto str_result = ToString(std::move(value), descr);
+  if (str_result.ok()) {
+    str_opt = std::move(str_result).ValueOrDie();
+  } else {
+    // If there was any issue, don't set the value.
+    ARROW_LOG(INFO) << "ToString failed for " << descr.ToString() << ": "
+                    << str_result.status().ToString();
+  }
+  if (str_opt && descr.logical_type()->is_string()) {
+    auto truncated_result = truncate(*std::move(str_opt), string_prefix_length);
+    if (truncated_result.ok()) {
+      str_opt = std::move(truncated_result).ValueOrDie();
+    } else {
+      // Do not set the min/max if it's invalid UTF8 sequence.
+      // Delta Spark sets it, but it leads to wrong results
+      // due to data skipping not working correctly.
+      ARROW_LOG(INFO) << "truncate failed for " << descr.ToString() << ": "
+                      << truncated_result.status().ToString();
+      str_opt = std::nullopt;
+    }
+  }
+  return str_opt;
+}
+
+struct ColumnStats {
+  std::vector<std::string> path;
+  SkippingEligibleDataType type{SkippingEligibleDataType::UnsupportedType};
+  std::optional<std::string> min_opt;
+  std::optional<std::string> max_opt;
+  std::optional<int64_t> null_count_opt;
+};
+
+template <typename DType>
+void GetMinMax(ColumnStats& col_stats, const TypedStatistics<DType>& stats,
+               const ColumnDescriptor& descr, int string_prefix_length) {
+  col_stats.min_opt = ToStatsString(stats.min(), descr, string_prefix_length,
+                                    internal::TruncateMinString);
+  col_stats.max_opt = ToStatsString(stats.max(), descr, string_prefix_length,
+                                    internal::TruncateMaxString);
+}
+
+void GetMinMax(ColumnStats& col_stats, const Statistics& stats,
+               const ColumnDescriptor& descr, int string_prefix_length) {
+  switch (descr.physical_type()) {
+    case Type::INT32:
+      return GetMinMax(col_stats, static_cast<const TypedStatistics<Int32Type>&>(stats),
+                       descr, string_prefix_length);
+    case Type::INT64:
+      return GetMinMax(col_stats, static_cast<const TypedStatistics<Int64Type>&>(stats),
+                       descr, string_prefix_length);
+    case Type::INT96:
+      return GetMinMax(col_stats, static_cast<const TypedStatistics<Int96Type>&>(stats),
+                       descr, string_prefix_length);
+    case Type::FLOAT:
+      return GetMinMax(col_stats, static_cast<const TypedStatistics<FloatType>&>(stats),
+                       descr, string_prefix_length);
+    case Type::DOUBLE:
+      return GetMinMax(col_stats, static_cast<const TypedStatistics<DoubleType>&>(stats),
+                       descr, string_prefix_length);
+    case Type::BYTE_ARRAY:
+      return GetMinMax(col_stats,
+                       static_cast<const TypedStatistics<ByteArrayType>&>(stats), descr,
+                       string_prefix_length);
+    case Type::FIXED_LEN_BYTE_ARRAY:
+      return GetMinMax(col_stats, static_cast<const TypedStatistics<FLBAType>&>(stats),
+                       descr, string_prefix_length);
+    default:
+      ParquetException::NYI("not implemented");
+  }
+}
+
+std::vector<ColumnStats> MakeColumnStats(DeltaStatsCollector&& collector,
+                                         int64_t num_rows) {
+  const auto string_prefix_length = collector.string_prefix_length;
+  const auto num_columns = collector.schema->num_columns();
+  std::vector<ColumnStats> column_stats;
+  for (int i = 0; i < num_columns; ++i) {
+    auto stats_opt = std::move(collector.columns[i]);
+    if (stats_opt.has_value()) {
+      auto& col_stats = column_stats.emplace_back();
+      const auto descr = collector.schema->Column(static_cast<int>(i));
+      col_stats.type = GetSkippingEligibleDataType(*descr);
+      std::visit(overload{
+                     [&](std::shared_ptr<Statistics> stats) {
+                       col_stats.path = descr->path()->ToDotVector();
+                       if (col_stats.type != SkippingEligibleDataType::UnsupportedType) {
+                         if (stats->HasMinMax()) {
+                           GetMinMax(col_stats, *stats, *descr, string_prefix_length);
+                         }
+                         if (stats->HasNan()) {
+                           col_stats.max_opt = "NaN";
+                           if (!col_stats.min_opt) {
+                             col_stats.min_opt = "NaN";
+                           }
+                         }
+                       }
+                       if (stats->HasNullCount()) {
+                         col_stats.null_count_opt = stats->null_count();
+                       }
+                     },
+                     [&](std::shared_ptr<CollectionTypeStatistics> stats) {
+                       col_stats.path = std::move(stats->path);
+                       col_stats.null_count_opt = stats->null_count;
+                     },
+                 },
+                 std::move(stats_opt).value());
+    }
+  }
+
+  // Handle unmatched column paths. Delta may pass column paths
+  // that don't exist in the schema. In this case, we need to build
+  // nullCounts for those missing columns.
+  const auto num_column_path = collector.column_paths.size();
+  for (size_t i = 0; i < num_column_path; ++i) {
+    if (!collector.column_paths_matched[i]) {
+      auto& col_stats = column_stats.emplace_back();
+      col_stats.path = std::move(collector.column_paths[i]);
+      col_stats.type = SkippingEligibleDataType::UnsupportedType;
+      col_stats.null_count_opt = num_rows;
+    }
+  }
+  return column_stats;
+}
