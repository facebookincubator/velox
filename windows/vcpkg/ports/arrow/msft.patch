+// NOLINT legal/copyright
+
+#pragma once
+
+#include <cstring>
+#include <unordered_map>
+#include <vector>
+
+#include "arrow/util/hashing.h"
+#include "parquet/types.h"
+
+namespace parquet {
+namespace test {
+
+template <typename T>
+class Hash {
+ public:
+  explicit Hash(int) {}
+  size_t operator()(const T& value) const {
+    return ::arrow::internal::ComputeStringHash<0>(&value, sizeof(value));
+  }
+};
+
+template <>
+class Hash<ByteArray> {
+ public:
+  explicit Hash(int) {}
+  size_t operator()(const ByteArray& value) const {
+    return ::arrow::internal::ComputeStringHash<0>(value.ptr, value.len);
+  }
+};
+
+template <>
+class Hash<FLBA> {
+ public:
+  explicit Hash(int length) : length_(length) {}
+  size_t operator()(const FLBA& value) const {
+    return ::arrow::internal::ComputeStringHash<0>(value.ptr, length_);
+  }
+
+ private:
+  int length_;
+};
+
+template <typename T>
+class EqualTo {
+ public:
+  explicit EqualTo(int) {}
+  bool operator()(const T& lhs, const T& rhs) const { return lhs == rhs; }
+};
+
+template <>
+class EqualTo<FLBA> {
+ public:
+  explicit EqualTo(int length) : length_(length) {}
+  bool operator()(const FLBA& lhs, const FLBA& rhs) const {
+    return std::memcmp(lhs.ptr, rhs.ptr, static_cast<size_t>(length_)) == 0;
+  }
+
+ private:
+  int length_;
+};
+
+class Boolean {
+ public:
+  Boolean() : value_() {}
+  Boolean(bool value) : value_(value) {}  // NOLINT implicit construction
+  operator bool() const { return value_; }
+
+ private:
+  bool value_;
+};
+
+template <typename T>
+class Vec : public std::vector<T> {
+ public:
+  using std::vector<T>::vector;
+};
+
+template <>
+class Vec<bool> : public std::vector<Boolean> {
+  using Base = std::vector<Boolean>;
+
+ public:
+  using Base::Base;
+
+  const bool* data() const { return reinterpret_cast<const bool*>(Base::data()); }
+  bool* data() { return reinterpret_cast<bool*>(Base::data()); }
+};
+
+template <typename T>
+int64_t GetValuesSize(const std::unordered_map<T, int32_t, Hash<T>, EqualTo<T>>& table,
+                      int) {
+  return table.size() * sizeof(T);
+}
+
+template <>
+inline int64_t GetValuesSize(const std::unordered_map<ByteArray, int32_t, Hash<ByteArray>,
+                                                      EqualTo<ByteArray>>& table,
+                             int) {
+  int64_t values_size = 0;
+  for (const auto& p : table) {
+    values_size += p.first.len;
+  }
+  return values_size;
+}
+
+template <>
+inline int64_t GetValuesSize(
+    const std::unordered_map<FLBA, int32_t, Hash<FLBA>, EqualTo<FLBA>>& table,
+    int length) {
+  return table.size() * length;
+}
+
+template <typename T>
+int64_t GetOffsetsSize(const std::unordered_map<T, int32_t, Hash<T>, EqualTo<T>>&) {
+  return 0;
+}
+
+template <>
+inline int64_t GetOffsetsSize(
+    const std::unordered_map<ByteArray, int32_t, Hash<ByteArray>, EqualTo<ByteArray>>&
+        table) {
+  return (table.size() + 1) * sizeof(int32_t);
+}
+
+template <typename T>
+void CopyValue(uint8_t*& ptr, const T& value, int) {
+  *reinterpret_cast<T*>(ptr) = value;
+  ptr = reinterpret_cast<uint8_t*>(reinterpret_cast<T*>(ptr) + 1);
+}
+
+template <>
+inline void CopyValue(uint8_t*& ptr, const ByteArray& value, int) {
+  std::memcpy(ptr, value.ptr, value.len);
+  ptr += value.len;
+}
+
+template <>
+inline void CopyValue(uint8_t*& ptr, const FLBA& value, int flba_len) {
+  std::memcpy(ptr, value.ptr, flba_len);
+  ptr += flba_len;
+}
+
+template <typename T>
+void SetOffset(int32_t*&, const T&) {}
+
+template <>
+inline void SetOffset(int32_t*& ptr, const ByteArray& value) {
+  const auto prev_offset = ptr[-1];
+  *ptr++ = prev_offset + value.len;
+}
+
+template <typename T>
+void DictionaryEncode(const std::vector<T>& values, std::vector<int32_t>& indices,
+                      std::shared_ptr<Buffer>& dict_values_buffer,
+                      std::shared_ptr<Buffer>& dict_offsets_buffer, int32_t& dict_size,
+                      int flba_length = -1) {
+  std::unordered_map<T, int32_t, Hash<T>, EqualTo<T>> table(8, Hash<T>(flba_length),
+                                                            EqualTo<T>(flba_length));
+  for (const auto& v : values) {
+    const auto result = table.emplace(v, static_cast<int32_t>(table.size()));
+    indices.emplace_back(result.first->second);
+  }
+  const auto values_size = GetValuesSize(table, flba_length);
+  dict_values_buffer = AllocateBuffer(::arrow::default_memory_pool(), values_size);
+  auto dict_values_ptr = dict_values_buffer->mutable_data();
+  const auto offsets_size = GetOffsetsSize(table);
+  int32_t* dict_offsets_ptr = nullptr;
+  if (offsets_size > 0) {
+    dict_offsets_buffer = AllocateBuffer(::arrow::default_memory_pool(), offsets_size);
+    dict_offsets_ptr = reinterpret_cast<int32_t*>(dict_offsets_buffer->mutable_data());
+    *dict_offsets_ptr++ = 0;
+  }
+  std::vector<T> dict_values(table.size());
+  for (const auto& p : table) {
+    dict_values[p.second] = p.first;
+  }
+  for (const auto& v : dict_values) {
+    CopyValue(dict_values_ptr, v, flba_length);
+    SetOffset(dict_offsets_ptr, v);
+  }
+  dict_size = static_cast<int32_t>(table.size());
+}
+
+}  // namespace test
+}  // namespace parquet
