@@ -0,0 +1,98 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <type_traits>
+#include <vector>
+
+#include "arrow/buffer_builder.h"
+#include "parquet/platform.h"
+
+namespace parquet {
+namespace shuffle {
+
+template <typename T>
+class Span {
+ public:
+  using value_type = typename std::remove_cv<T>::type;
+  using const_iterator = const T*;
+
+  Span() : data_(nullptr), size_(0) {}
+
+  Span(T* data, size_t size) : data_(data), size_(size) {}
+
+  template <typename U>
+  Span(Span<U> rhs) : data_(rhs.data()), size_(rhs.size()) {}
+
+  Span(const Span& rhs) = default;
+
+  Span& operator=(const Span& rhs) = default;
+
+  bool empty() const { return size_ == 0; }
+
+  size_t size() const { return size_; }
+
+  T* data() const { return data_; }
+
+  T* begin() const { return data_; }
+
+  T* end() const { return data_ + size_; }
+
+  T& operator[](size_t index) const { return data_[index]; }
+
+  Span subspan(size_t offset) const { return {data_ + offset, size_ - offset}; }
+
+  Span subspan(size_t offset, size_t count) const { return {data_ + offset, count}; }
+
+ private:
+  T* data_;
+  size_t size_;
+};
+
+template <typename T>
+Span<T> AsSpan(Buffer& buffer) {
+  return {reinterpret_cast<T*>(buffer.mutable_data()), buffer.size() / sizeof(T)};
+}
+
+template <typename T>
+Span<const T> AsSpan(const Buffer& buffer) {
+  return {reinterpret_cast<const T*>(buffer.data()), buffer.size() / sizeof(T)};
+}
+
+template <typename T>
+Span<T> AsSpan(::arrow::BufferBuilder& buffer) {
+  return {reinterpret_cast<T*>(buffer.mutable_data()), buffer.length() / sizeof(T)};
+}
+
+template <typename T>
+Span<const T> AsSpan(const ::arrow::BufferBuilder& buffer) {
+  return {reinterpret_cast<const T*>(buffer.data()), buffer.length() / sizeof(T)};
+}
+
+template <typename T>
+Span<T> AsSpan(::arrow::TypedBufferBuilder<T>& buffer) {
+  return {buffer.mutable_data(), static_cast<size_t>(buffer.length())};
+}
+
+template <typename T>
+Span<const T> AsSpan(const ::arrow::TypedBufferBuilder<T>& buffer) {
+  return {buffer.data(), static_cast<size_t>(buffer.length())};
+}
+
+template <typename T, typename Alloc>
+Span<T> AsSpan(std::vector<T, Alloc>& buffer) {
+  return {buffer.data(), buffer.size()};
+}
+
+template <typename T, typename Alloc>
+Span<const T> AsSpan(const std::vector<T, Alloc>& buffer) {
+  return {buffer.data(), buffer.size()};
+}
+
+template <typename T, size_t N>
+Span<T> AsSpan(T (&array)[N]) {
+  return {array, N};
+}
+
