diff --git a/cpp/tools/parquet/commandline_util.h b/cpp/tools/parquet/commandline_util.h
new file mode 100644
index 0000000000..2314ae759b
--- /dev/null
+++ b/cpp/tools/parquet/commandline_util.h
@@ -0,0 +1,60 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <iostream>
+#include <string>
+#include <vector>
+
+#include <gflags/gflags.h>
+
+#include "arrow/result.h"
+#include "arrow/status.h"
+#include "arrow/util/compression.h"
+#include "parquet/type_fwd.h"
+
+inline std::ostream& PrintError() {
+  return std::cerr << gflags::ProgramInvocationShortName() << ": ";
+}
+
+template <typename T>
+bool ValidatePositiveInteger(const char* _flag, T value) {
+  if (value > 0) return true;
+  PrintError() << "Expected a positive integer; got " << value << std::endl;
+  return false;
+}
+
+template <typename T>
+bool ValidateNonNegativeInteger(const char* _flag, T value) {
+  if (value >= 0) return true;
+  PrintError() << "Expected a non-negative integer; got " << value << std::endl;
+  return false;
+}
+
+inline ::arrow::Result<parquet::ParquetVersion::type> ParseParquetVersion(
+    const std::string& v) {
+  if (v == "1.0") {
+    return parquet::ParquetVersion::PARQUET_1_0;
+  } else if (v == "2.4") {
+    return parquet::ParquetVersion::PARQUET_2_4;
+  } else if (v == "2.6") {
+    return parquet::ParquetVersion::PARQUET_2_6;
+  } else {
+    return ::arrow::Status::Invalid("Unsupported version: ", v);
+  }
+}
+
+template <typename T>
+bool ValidateResult(const ::arrow::Result<T>& result) {
+  if (result.ok()) return true;
+  PrintError() << result.status().message() << std::endl;
+  return false;
+}
+
+inline bool ValidateParquetVersion(const char* _flag, const std::string& version_string) {
+  return ValidateResult(ParseParquetVersion(version_string));
+}
+
+inline bool ValidateCompressionCodec(const char* _flag, const std::string& codec_string) {
+  return ValidateResult(parquet::Codec::GetCompressionType(codec_string));
+}
diff --git a/cpp/tools/parquet/file_slice_range_flags.cc b/cpp/tools/parquet/file_slice_range_flags.cc
new file mode 100644
index 0000000000..4641f02239
--- /dev/null
+++ b/cpp/tools/parquet/file_slice_range_flags.cc
@@ -0,0 +1,77 @@
+// NOLINT legal/copyright
+
+#include "file_slice_range_flags.h"
+
+#include <iostream>
+#include <limits>
+#include <string>
+#include <string_view>
+#include <vector>
+
+#include <gflags/gflags.h>
+
+#include "arrow/util/value_parsing.h"
+
+#include "parquet/shuffle/util/string_util.h"
+
+#include "commandline_util.h"
+
+DEFINE_int32(row_group_offset, 0, "row group offset");
+DEFINE_validator(row_group_offset, &ValidateNonNegativeInteger);
+DEFINE_int32(row_group_count, 0, "row group count");
+DEFINE_validator(row_group_count, &ValidateNonNegativeInteger);
+DEFINE_int64(row_offset, 0, "row offset");
+DEFINE_validator(row_offset, &ValidateNonNegativeInteger);
+DEFINE_int64(row_count, 0, "row count");
+DEFINE_validator(row_count, &ValidateNonNegativeInteger);
+DEFINE_string(columns, "", "comma separated list of column indices");
+
+namespace {
+
+std::optional<int> ParseInt(std::string_view s) {
+  uint32_t v;
+  if (!::arrow::internal::ParseUnsigned(s.data(), s.size(), &v) ||
+      v > static_cast<uint32_t>(std::numeric_limits<int>::max())) {
+    return {};
+  }
+  return static_cast<int>(v);
+}
+
+std::optional<std::vector<int>> ParseIntRangeList(const std::string& s) {
+  std::vector<int> values;
+  if (!s.empty()) {
+    for (const auto t : parquet::shuffle::split(s, ",")) {
+      const auto dash_index = t.find("-");
+      if (dash_index == std::string_view::npos) {
+        const auto v = ParseInt(t);
+        if (!v) return {};
+        values.push_back(*v);
+      } else {
+        const auto start = ParseInt(t.substr(0, dash_index));
+        const auto end = ParseInt(t.substr(dash_index + 1));
+        if (!start || !end) return {};
+        for (int v = *start; v <= *end; ++v) {
+          values.push_back(v);
+        }
+      }
+    }
+  }
+  return values;
+}
+
+}  // namespace
+
+std::optional<parquet::shuffle::ParquetFileReaderSliceRange> GetParquetFileSliceRange() {
+  parquet::shuffle::ParquetFileReaderSliceRange range;
+  range.row_group_offset = FLAGS_row_group_offset;
+  range.row_group_count = FLAGS_row_group_count;
+  range.row_offset = FLAGS_row_offset;
+  range.row_count = FLAGS_row_count;
+  auto columns = ParseIntRangeList(FLAGS_columns);
+  if (!columns) {
+    PrintError() << "failed to parse slice range: " << FLAGS_columns << std::endl;
+    return {};
+  }
+  range.columns = std::move(columns.value());
+  return range;
+}
