+  std::shared_ptr<GroupNode> schema =
+      MakeSimpleSchema(*values->type(), Repetition::REQUIRED);
+  SchemaDescriptor descriptor;
+  ASSERT_NO_THROW(descriptor.Init(schema));
+  std::shared_ptr<::arrow::Schema> arrow_schema;
+  ASSERT_OK_NO_THROW(
+      FromParquetSchema(&descriptor, ArrowReaderProperties{}, &arrow_schema));
+  auto batch = ::arrow::RecordBatch::Make(arrow_schema, data_size, {values});
