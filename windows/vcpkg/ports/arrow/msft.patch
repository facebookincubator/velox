+
+namespace parquet {
+namespace shuffle {
+namespace test {
+
+inline std::shared_ptr<schema::GroupNode> CreateSingleIntColumnSchema() {
+  schema::NodeVector fields;
+  fields.emplace_back(schema::PrimitiveNode::Make(
+      "col", Repetition::REQUIRED, Type::INT32, ConvertedType::NONE, -1, -1, -1, 1));
+  return std::static_pointer_cast<schema::GroupNode>(schema::GroupNode::Make(
+      "schema", Repetition::REQUIRED, fields, ConvertedType::NONE, 0));
+}
+
+inline std::shared_ptr<schema::GroupNode> CreateSingleStringColumnSchema() {
+  schema::NodeVector fields;
+  fields.emplace_back(schema::PrimitiveNode::Make(
+      "col", Repetition::REQUIRED, Type::BYTE_ARRAY, ConvertedType::UTF8, -1, -1, -1, 1));
+  return std::static_pointer_cast<schema::GroupNode>(schema::GroupNode::Make(
+      "schema", Repetition::REQUIRED, fields, ConvertedType::NONE, 0));
+}
+
+inline std::shared_ptr<Buffer> CreateParquetFile(
+    int row_groups_per_file, int rows_per_row_group, int value_start,
+    std::shared_ptr<const KeyValueMetadata> key_value_metadata = nullptr) {
+  auto out = CreateOutputStream();
+  auto writer = ParquetFileWriter::Open(
+      out, CreateSingleIntColumnSchema(),
+      WriterProperties::Builder().enable_dictionary()->build(), key_value_metadata);
+  for (int i = 0; i < row_groups_per_file; ++i) {
+    auto rg_writer = writer->AppendBufferedRowGroup();
+    auto& col_writer = static_cast<TypedColumnWriter<Int32Type>&>(*rg_writer->column(0));
+    std::vector<int> values(rows_per_row_group);
+    std::iota(values.begin(), values.end(), value_start);
+    col_writer.WriteBatch(rows_per_row_group, nullptr, nullptr, values.data());
+    col_writer.Close();
+    rg_writer->Close();
+    value_start += rows_per_row_group;
+  }
+  writer->Close();
+  PARQUET_ASSIGN_OR_THROW(auto data, out->Finish());
+  return data;
+}
+
+inline std::shared_ptr<Buffer> CreateParquetFile(
+    const std::vector<std::vector<std::string>>& row_group_values) {
+  auto out = CreateOutputStream();
+  auto writer =
+      ParquetFileWriter::Open(out, CreateSingleStringColumnSchema(),
+                              WriterProperties::Builder().enable_dictionary()->build());
+  for (const auto& values : row_group_values) {
+    auto rg_writer = writer->AppendBufferedRowGroup();
+    auto& col_writer =
+        static_cast<TypedColumnWriter<ByteArrayType>&>(*rg_writer->column(0));
+    std::vector<ByteArray> converted_values;
+    converted_values.reserve(values.size());
+    for (const auto& value : values) {
+      converted_values.emplace_back(static_cast<uint32_t>(value.size()),
+                                    reinterpret_cast<const uint8_t*>(value.data()));
+    }
+    col_writer.WriteBatch(static_cast<int64_t>(values.size()), nullptr, nullptr,
+                          converted_values.data());
+    col_writer.Close();
+    rg_writer->Close();
+  }
+  writer->Close();
+  PARQUET_ASSIGN_OR_THROW(auto data, out->Finish());
+  return data;
+}
+
+inline std::pair<std::vector<std::shared_ptr<Buffer>>, std::shared_ptr<schema::GroupNode>>
+CreateParquetFiles(int num_files, int row_groups_per_file, int rows_per_row_group) {
+  std::vector<std::shared_ptr<Buffer>> files;
+  int value_start = 0;
+  for (int i = 0; i < num_files; ++i) {
+    files.emplace_back(
+        CreateParquetFile(row_groups_per_file, rows_per_row_group, value_start));
+    value_start += row_groups_per_file * rows_per_row_group;
+  }
+  return {std::move(files), CreateSingleIntColumnSchema()};
+}
+
+inline ParquetFileReaderSlice MakeParquetFileReaderSlice(
+    std::vector<std::shared_ptr<Buffer>> files,
+    const ParquetFileReaderSliceRange& range = ParquetFileReaderSlice::All,
+    bool pre_buffer = false) {
+  std::vector<std::shared_ptr<ParquetFileReader>> readers;
+  for (auto& file : files) {
+    readers.emplace_back(ParquetFileReader::Open(
+        std::make_shared<::arrow::io::BufferReader>(std::move(file))));
+  }
+  return {std::move(readers), range, false, pre_buffer};
+}
+
+inline std::vector<int> ReadAll(ParquetFileReaderSlice& slice) {
+  std::vector<int> values;
+  while (slice.HasNextRowGroup()) {
+    auto rg_slice = slice.NextRowGroup();
+    auto col_reader = rg_slice.row_group->Column(0);
+    Skip(*col_reader, rg_slice.row_offset);
+    std::vector<int> buffer(rg_slice.row_count);
+    int64_t values_read;
+    static_cast<TypedColumnReader<Int32Type>&>(*col_reader)
+        .ReadBatch(rg_slice.row_count, nullptr, nullptr, buffer.data(), &values_read);
+    values.insert(values.end(), buffer.begin(), buffer.end());
+  }
+  return values;
+}
+
+inline std::vector<int> MakeRange(int start, int end) {
+  std::vector<int> values(end - start);
+  std::iota(values.begin(), values.end(), start);
+  return values;
+}
+
+struct OutputRange {
+  int num_row_groups;
+  int num_rows;
+  int value_start;
+  int value_end;
+};
+
+inline OutputRange ComputeOutputRange(int num_row_groups, int rows_per_row_group,
+                                      const ParquetFileReaderSliceRange& range) {
+  if (rows_per_row_group == 0) {
+    if (range.row_group_offset == 0 && range.row_offset == 0) {
+      return {range.row_group_count > 0 ? range.row_group_count : num_row_groups, 0, 0,
+              0};
+    } else {
+      return {0, 0, 0, 0};
+    }
+  }
+  const int64_t row_group_offset = std::min(range.row_group_offset, num_row_groups);
+  const auto row_group_count = range.row_group_count > 0
+                                   ? std::min(static_cast<int64_t>(range.row_group_count),
+                                              num_row_groups - row_group_offset)
+                                   : num_row_groups - row_group_offset;
+  const auto row_offset =
+      std::min(range.row_offset, row_group_count * rows_per_row_group);
+  const auto row_count =
+      range.row_count > 0
+          ? std::min(range.row_count, row_group_count * rows_per_row_group - row_offset)
+          : row_group_count * rows_per_row_group - row_offset;
+  const auto value_start = row_group_offset * rows_per_row_group + row_offset;
+  const auto value_end = value_start + row_count;
+  const auto num_output_row_groups =
+      (value_end + rows_per_row_group - 1) / rows_per_row_group -
+      value_start / rows_per_row_group;
+  return {static_cast<int>(num_output_row_groups), static_cast<int>(row_count),
+          static_cast<int>(value_start), static_cast<int>(value_end)};
+}
+
