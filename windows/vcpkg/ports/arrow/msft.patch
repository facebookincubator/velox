+/// Strict equal_to and hash deistinguish differences between special values like 0.0
+/// and -0.0, std::nan("1") and std::nan("2").
+template <typename DataType>
+struct StrictEqualityTraits : EqualityTraits<DataType> {};
+
+template <>
+struct StrictEqualityTraits<parquet::DoubleType> : EqualityTraits<parquet::DoubleType> {
+  struct equal_to {
+    size_t operator()(const double& l, const double& r) const {
+      auto ret = std::memcmp(reinterpret_cast<const void*>(&l),
+                             reinterpret_cast<const void*>(&r), sizeof(double)) == 0;
+      if (ret && hash()(l) != hash()(r)) {
+        throw std::runtime_error("Inconsistent hash and equal_to");
+      }
+      return ret;
+    }
+  };
+
+  struct less {
+    bool operator()(const c_type& a, const c_type& b) = delete;
+  };
+};
+
+template <>
+struct StrictEqualityTraits<parquet::FloatType> : EqualityTraits<parquet::FloatType> {
+  struct equal_to {
+    size_t operator()(const float& l, const float& r) const {
+      return std::memcmp(reinterpret_cast<void*>(const_cast<float*>(&l)),
+                         reinterpret_cast<void*>(const_cast<float*>(&r)),
+                         sizeof(float)) == 0;
+    }
+  };
+
+  struct less {
+    bool operator()(const c_type& a, const c_type& b) = delete;
+  };
+};
