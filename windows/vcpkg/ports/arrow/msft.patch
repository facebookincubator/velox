+class TestDeltaStatsStringTruncate
+    : public ::testing::TestWithParam<
+          std::tuple<std::string, std::optional<std::string>, int>> {
+ public:
+  std::string GetStats() {
+    const auto input = std::get<0>(GetParam());
+    const auto prefix_len = std::get<2>(GetParam());
+    auto kv_meta = WriteAndGetKeyValueMetadata<ByteArrayType>(
+        "col", {std::string_view(input)}, LogicalType::String(), prefix_len);
+    PARQUET_ASSIGN_OR_THROW(auto stats, kv_meta->Get(DELTA_STATS_JSON_KEY));
+    return stats;
+  }
+
+  void GetMinValue(std::string stats_json, std::string col_name,
+                   std::optional<std::string>& min_value) {
+    GetMinMaxInternal(stats_json, col_name, "minValues", min_value);
+  }
+
+  void GetMaxValue(std::string stats_json, std::string col_name,
+                   std::optional<std::string>& min_value) {
+    GetMinMaxInternal(stats_json, col_name, "maxValues", min_value);
+  }
+
+  void GetMinMaxInternal(std::string stats_json, std::string col_name, const char* type,
+                         std::optional<std::string>& value) {
+    auto json = rapidjson::Document();
+    json.Parse(stats_json.c_str());
+    ASSERT_FALSE(json.HasParseError()) << "Statistics JSON: " << stats_json;
+    ASSERT_TRUE(json.IsObject()) << "Statistics JSON: " << stats_json;
+    if (!json.HasMember(type)) {
+      value = std::nullopt;
+    } else {
+      ASSERT_TRUE(json[type].IsObject()) << "Statistics JSON: " << stats_json;
+      if (json[type].HasMember("col")) {
+        ASSERT_TRUE(json[type]["col"].IsString()) << "Statistics JSON: " << stats_json;
+        value = json[type]["col"].GetString();
+      } else {
+        value = std::nullopt;
+      }
+    }
+  }
+};
