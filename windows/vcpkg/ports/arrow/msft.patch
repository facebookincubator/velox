+struct ValueDictionary {
+  virtual parquet::Type::type GetType() const = 0;
+  virtual size_t DistinctCount() const = 0;
+  virtual ~ValueDictionary(){};
+};
+
+template <typename DataType>
+struct TypedValueDictionary : ValueDictionary {
+  using c_type = typename DataType::c_type;
+
+  using hash = typename StrictEqualityTraits<DataType>::hash;
+  using equal_to = typename StrictEqualityTraits<DataType>::equal_to;
+  using less_t = typename EqualityTraits<DataType>::less;
+
+  TypedValueDictionary() : less() {}
+  TypedValueDictionary(const int len) = delete;
+  std::unordered_map<c_type, size_t, hash, equal_to> map;
+  const less_t less;
+  optional<std::tuple<c_type, c_type>> min_max;
+
+  parquet::Type::type GetType() const { return DataType::type_num; }
+
+  size_t GetOrAddInternal(const c_type& value) {
+    const auto iter = map.find(value);
+    if (iter == map.end()) {
+      size_t result = map.size();
+      map[value] = result;
+      return result;
+    }
+
+    return iter->second;
+  }
+
+  size_t DistinctCount() const { return map.size(); }
+
+  size_t GetOrAdd(const c_type& value) {
+    const auto ret = GetOrAddInternal(value);
+
+    if (EqualityTraits<DataType>::IsAccountedForStats(value)) {
+      if (min_max.has_value()) {
+        auto& current_min = std::get<0>(min_max.value());
+        if (less(value, current_min)) {
+          current_min = value;
+        }
+
+        auto& current_max = std::get<1>(min_max.value());
+        if (less(current_max, value)) {
+          current_max = value;
+        }
+      } else {
+        min_max = std::make_tuple(value, value);
+      }
+    }
+
+    return ret;
+  }
+
+  size_t GetOrThrow(const c_type& value) {
+    const auto iter = map.find(value);
+    if (iter == map.end()) {
+      throw std::out_of_range("Value not found in the dictionary.");
+    }
+
+    return iter->second;
+  }
+
+  virtual ~TypedValueDictionary() {}
+};
+
+template <>
+TypedValueDictionary<parquet::FLBAType>::TypedValueDictionary(int len)
+    : map(10, hash(len), equal_to(len)), less(len) {}
+
+template <>
+TypedValueDictionary<parquet::FLBAType>::TypedValueDictionary() = delete;
+
+struct RowGroupAggregator {
+  struct Column {
+    Column(def_levels_t max_def_level) : max_def_level(max_def_level) {}
+
+    const def_levels_t max_def_level;
+    Vec<def_levels_t> def_levels;
+    Vec<rep_levels_t> rep_levels;
+    Vec<size_t> dictionary_indices;
+
+    int CompareRecords(const size_t& a, const size_t& b) const {
+      if (def_levels.at(a) < def_levels.at(b)) {
+        return 1;
+      } else if (def_levels.at(a) > def_levels.at(b)) {
+        return -1;
+      }
+
+      if (rep_levels.at(a) < rep_levels.at(b)) {
+        return 1;
+      } else if (rep_levels.at(a) > rep_levels.at(b)) {
+        return -1;
+      }
+
+      if (dictionary_indices.at(a) < dictionary_indices.at(b)) {
+        return 1;
+      } else if (dictionary_indices.at(a) > dictionary_indices.at(b)) {
+        return -1;
+      }
+
+      return 0;
+    }
+  };
+
+  Vec<Column> columns;
+  Vec<std::shared_ptr<ValueDictionary>> dictionaries;
+
+  static Vec<std::shared_ptr<ValueDictionary>> CreateDictionaries(
+      const Vec<std::tuple<parquet::Type::type, int>>& col_types_lens) {
+    Vec<std::shared_ptr<ValueDictionary>> result;
+
+    for (const auto& type_len : col_types_lens) {
+      const auto& type = std::get<0>(type_len);
+      const auto& flba_len = std::get<1>(type_len);
+      switch (type) {
+        case parquet::Type::type::BOOLEAN:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::BooleanType>>());
+          break;
+        case parquet::Type::type::INT32:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::Int32Type>>());
+          break;
+        case parquet::Type::type::INT64:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::Int64Type>>());
+          break;
+        case parquet::Type::type::INT96:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::Int96Type>>());
+          break;
+        case parquet::Type::type::FLOAT:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::FloatType>>());
+          break;
+        case parquet::Type::type::DOUBLE:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::DoubleType>>());
+          break;
+        case parquet::Type::type::BYTE_ARRAY:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::ByteArrayType>>());
+          break;
+        case parquet::Type::type::FIXED_LEN_BYTE_ARRAY:
+          result.emplace_back(
+              std::make_shared<TypedValueDictionary<parquet::FLBAType>>(flba_len));
+          break;
+        default:
+          throw std::runtime_error("");
+      }
+    }
+
+    return result;
+  }
+
+  RowGroupAggregator(const Vec<std::tuple<parquet::Type::type, int>>& col_types_lens,
+                     const Vec<def_levels_t>& max_def_levels_per_column)
+      : RowGroupAggregator(CreateDictionaries(col_types_lens),
+                           max_def_levels_per_column) {}
+
+  RowGroupAggregator(const Vec<std::shared_ptr<ValueDictionary>>& dictionaries,
+                     const Vec<def_levels_t>& max_def_levels_per_column)
+      : dictionaries(dictionaries) {
+    std::transform(max_def_levels_per_column.begin(), max_def_levels_per_column.end(),
+                   std::back_insert_iterator<Vec<Column>>(columns),
+                   [](def_levels_t l) { return Column(l); });
+  }
+
+  template <typename DataType>
+  optional<std::tuple<typename DataType::c_type, typename DataType::c_type>> GetMinMax(
+      const size_t& col_index) const {
+    auto dictionary = std::dynamic_pointer_cast<TypedValueDictionary<DataType>>(
+        dictionaries.at(col_index));
+    return dictionary->min_max;
+  }
+
+  template <typename DataType, bool can_modify_dictionaries>
+  void SubmitBatch(const size_t& col_index, const Vec<def_levels_t>& def_levels,
+                   const Vec<rep_levels_t>& rep_levels,
+                   const Vec<typename DataType::c_type>& values) {
+    constexpr auto type_num = DataType::type_num;
+    ASSERT_EQ(dictionaries.at(col_index)->GetType(), type_num);
+    auto dictionary = std::dynamic_pointer_cast<TypedValueDictionary<DataType>>(
+        dictionaries.at(col_index));
+
+    auto& column = columns.at(col_index);
+
+    for (size_t li = 0, vi = 0; li < def_levels.size(); li++) {
+      column.def_levels.emplace_back(def_levels.at(li));
+      column.rep_levels.emplace_back(rep_levels.at(li));
+      column.dictionary_indices.emplace_back(
+          def_levels.at(li) == column.max_def_level
+              ? can_modify_dictionaries ? dictionary->GetOrAdd(values.at(vi++))
+                                        : dictionary->GetOrThrow(values.at(vi++))
+              : SIZE_MAX);
+    }
+  }
+
+  bool RowLessThan(const size_t& a, const size_t& b) const {
+    for (const auto& col : columns) {
+      auto cmp = col.CompareRecords(a, b);
+      if (cmp < 0) {
+        return true;
+      } else if (cmp > 0) {
+        return false;
+      }
+    }
+
+    return a < b;
+  }
+
+  struct RowRef {
+    RowGroupAggregator* aggregator;
+    size_t row_index;
+    // This operator works only for Rows belonging to the same aggregator.
+    bool operator<(const RowRef& other) const {
+      if (aggregator != other.aggregator) {
+        throw std::runtime_error(
+            "Cannot compare rows belonging to different aggregators.");
+      }
+      auto ret = this->aggregator->RowLessThan(row_index, other.row_index);
+      auto anti_ret = this->aggregator->RowLessThan(other.row_index, row_index);
+
+      if (ret && anti_ret) {
+        throw std::runtime_error("Invalid operator<.");
+      }
+
+      return ret;
+    }
+
+    bool operator==(const RowRef& other) const {
+      for (size_t ci = 0; ci < this->aggregator->columns.size(); ci++) {
+        const auto& this_col = this->aggregator->columns.at(ci);
+        const auto& other_col = other.aggregator->columns.at(ci);
+        auto ret = this_col.def_levels.at(this->row_index) ==
+                       other_col.def_levels.at(other.row_index) &&
+                   this_col.rep_levels.at(this->row_index) ==
+                       other_col.rep_levels.at(other.row_index) &&
+                   this_col.dictionary_indices.at(this->row_index) ==
+                       other_col.dictionary_indices.at(other.row_index);
+        if (!ret) {
+          return false;
+        }
+      }
+      return true;
+    }
+
+    friend void PrintTo(const RowGroupAggregator::RowRef& row, std::ostream* os) {
+      *os << "{";
+      for (size_t ci = 0; ci < row.aggregator->columns.size(); ci++) {
+        const auto& this_col = row.aggregator->columns.at(ci);
+        const auto def_level = this_col.def_levels.at(row.row_index);
+        const auto rep_level = this_col.rep_levels.at(row.row_index);
+        const auto dict_index = this_col.dictionary_indices.at(row.row_index);
+        if (ci != 0) {
+          *os << ", ";
+        }
+        *os << "(" << def_level << ", " << rep_level << ", " << dict_index << ")";
+      }
+      *os << "}";
+    }
+  };
+
+  Vec<RowRef> Aggregate() {
+    if (columns.empty()) {
+      return Vec<RowRef>();
+    }
+
+    auto num_rows = columns.at(0).def_levels.size();
+    for (const auto& col : columns) {
+      if (col.def_levels.size() != num_rows || col.rep_levels.size() != num_rows ||
+          col.dictionary_indices.size() != num_rows) {
+        throw std::runtime_error("Inconsistent column sizes.");
+      }
+    }
+    Vec<RowRef> result;
+    result.reserve(num_rows);
+    size_t row_index = 0;
+    std::generate_n(std::back_inserter(result), num_rows, [&row_index, this]() {
+      return RowRef{this, row_index++};
+    });
+    return result;
+  }
+};
+
+class UnsupportedTestScenarioError : public std::runtime_error {
+ public:
+  UnsupportedTestScenarioError(std::string message) : std::runtime_error(message){};
+};
