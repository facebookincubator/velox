+// NOLINT legal/copyright
+
+#pragma once
+
+#include <ostream>
+#include <string>
+
+#include "parquet/platform.h"
+
+namespace parquet {
+namespace shuffle {
+
+static constexpr bool kDefaultCompatibleApi = false;
+static constexpr bool kDefaultDirectDictionaryWrite = true;
+static constexpr bool kDefaultSplitRowGroupOutput = false;
+static constexpr bool kDefaultAutoEncoding = true;
+static constexpr int32_t kRawEncodingThreshold = 100000;
+
+class PARQUET_EXPORT ShuffleWriterProperties {
+ public:
+  ShuffleWriterProperties()
+      : compatible_api_(kDefaultCompatibleApi),
+        direct_dictionary_write_(kDefaultDirectDictionaryWrite),
+        split_output_row_group_(kDefaultSplitRowGroupOutput),
+        auto_encoding_(kDefaultAutoEncoding),
+        debug_(false),
+        raw_encoding_threshold_(kRawEncodingThreshold) {}
+
+  void compatible_api(bool compatible_api) { compatible_api_ = compatible_api; }
+
+  bool compatible_api() const { return compatible_api_; }
+
+  void direct_dictionary_write(bool direct_dictionary_write) {
+    direct_dictionary_write_ = direct_dictionary_write;
+  }
+
+  bool direct_dictionary_write() const { return direct_dictionary_write_; }
+
+  void split_output_row_group(bool split_output_row_group) {
+    split_output_row_group_ = split_output_row_group;
+  }
+
+  bool split_output_row_group() const { return split_output_row_group_; }
+
+  void auto_encoding(bool auto_encoding) { auto_encoding_ = auto_encoding; }
+
+  bool auto_encoding() const { return auto_encoding_; }
+
+  void debug(bool debug) { debug_ = debug; }
+
+  bool debug() const { return debug_; }
+
+  void raw_encoding_threshold(int32_t raw_encoding_threshold) {
+    raw_encoding_threshold_ = raw_encoding_threshold;
+  }
+
+  int32_t raw_encoding_threshold() const { return raw_encoding_threshold_; }
+
+ private:
+  bool compatible_api_;
+  bool direct_dictionary_write_;
+  bool split_output_row_group_;
+  bool auto_encoding_;
+  bool debug_;
+  int32_t raw_encoding_threshold_;
+};
+
+PARQUET_EXPORT
+std::ostream& operator<<(std::ostream& os, const ShuffleWriterProperties& properties);
+
+}  // namespace shuffle
+}  // namespace parquet
