+parameters:
+- name: executables
+- name: ignoreFilenameRegex
+  default: (^/usr|/src/arrow/|/src/generated/)
+- name: artifactName
+  default: CoverageReport
+
+steps:
+- script: |
+    echo $LLVM_PROFILE_FILE
+    find $(COVERAGE_DATA_DIR)
+    which llvm-profdata
+    llvm-profdata merge --version
+    llvm-profdata merge \
+      -sparse \
+      -o "$(COVERAGE_DATA_DIR)/default.profdata" \
+      $(COVERAGE_DATA_DIR)/*.profraw
+    llvm-cov show \
+      -instr-profile="$(COVERAGE_DATA_DIR)/default.profdata" \
+      -format=html \
+      -output-dir="$(COVERAGE_REPORT_DIR)" \
+      -Xdemangler=c++filt \
+      -ignore-filename-regex='${{ parameters.ignoreFilenameRegex }}' \
+      -object="$(BUILD_DIR)/debug/libparquet.so" \
+      -object="$(BUILD_DIR)/debug/libarrow.so" \
+      $(for b in ${{ parameters.executables }}; do echo "-object=$b"; done)
+  displayName: Create coverage report
+- task: PublishPipelineArtifact@1
+  displayName: Publish coverage report
+  inputs:
+    targetPath: $(COVERAGE_REPORT_DIR)
+    artifact: ${{ parameters.artifactName }}
