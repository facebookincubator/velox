+template <typename DataType>
+typename EqualityTraits<DataType>::equal_to GetEqualTo(int len) {
+  return typename EqualityTraits<DataType>::equal_to();
+}
+
+template <>
+typename EqualityTraits<FLBAType>::equal_to GetEqualTo<FLBAType>(int len) {
+  return typename EqualityTraits<FLBAType>::equal_to(len);
+}
+
+template <typename DataType>
+void ReadColumn(const size_t col_index, RowGroupAggregator& agg,
+                std::shared_ptr<parquet::ColumnReader> non_typed_col_reader,
+                const int64_t rg_metadata_num_rows,
+                const std::unique_ptr<parquet::ColumnChunkMetaData> column_metadata) {
+  using c_type = typename DataType::c_type;
+  constexpr auto type = DataType::type_num;
+  SCOPED_TRACE(boost::format("type=%1%") % type);
+  ASSERT_EQ(non_typed_col_reader->type(), type);
+
+  auto col_reader = std::static_pointer_cast<parquet::TypedColumnReader<DataType>>(
+      non_typed_col_reader);
+
+  int64_t levels_read = 0;
+  int64_t values_read = 0;
+  int64_t max_def_levls_count = 0;
+  auto max_definition_level = non_typed_col_reader->descr()->max_definition_level();
+  int64_t zer_rep_levls_count = 0;
+  bool found_values_for_stats = false;
+
+  while (col_reader->HasNext()) {
+    Vec<def_levels_t> def_levels(rg_metadata_num_rows);
+    Vec<rep_levels_t> rep_levels(rg_metadata_num_rows);
+    Vec<c_type> values(rg_metadata_num_rows);
+    int64_t cur_values_read;
+
+    int64_t cur_levels_read =
+        col_reader->ReadBatch(rg_metadata_num_rows, def_levels.data(), rep_levels.data(),
+                              values.data(), &cur_values_read);
+    def_levels.resize(cur_levels_read);
+    rep_levels.resize(cur_levels_read);
+
+    agg.SubmitBatch<DataType, false>(col_index, def_levels, rep_levels, values);
+
+    auto cur_max_def_levls_count = std::count_if(
+        def_levels.data(), def_levels.data() + cur_levels_read,
+        [max_definition_level](def_levels_t x) { return x == max_definition_level; });
+
+    auto cur_zer_rep_levls_count =
+        std::count_if(rep_levels.data(), rep_levels.data() + cur_levels_read,
+                      [](rep_levels_t x) { return x == 0; });
+
+    max_def_levls_count += cur_max_def_levls_count;
+
+    found_values_for_stats |=
+        std::any_of(values.begin(), values.begin() + cur_max_def_levls_count,
+                    EqualityTraits<DataType>::IsAccountedForStats);
+
+    zer_rep_levls_count += cur_zer_rep_levls_count;
+    levels_read += cur_levels_read;
+    values_read += cur_values_read;
+  }
+
+  SCOPED_TRACE(boost::format("values_read=%1%") % values_read);
+  SCOPED_TRACE(boost::format("is_stats_set=%1%") % column_metadata->is_stats_set());
+  SCOPED_TRACE(boost::format("is_null_count_set=%1%") %
+               column_metadata->is_null_count_set());
+  SCOPED_TRACE(
+      boost::format("HasNullCount=%1%") %
+      (column_metadata->is_stats_set() && column_metadata->statistics()->HasNullCount()));
+  SCOPED_TRACE(boost::format("HasDistinctCount=%1%") %
+               (column_metadata->is_stats_set() &&
+                column_metadata->statistics()->HasDistinctCount()));
+  SCOPED_TRACE(boost::format("is_null_count_set=%1%") %
+               column_metadata->is_null_count_set());
+  SCOPED_TRACE(
+      boost::format("HasMinMax=%1%") %
+      (column_metadata->is_stats_set() && column_metadata->statistics()->HasMinMax()));
+
+  auto col_metadata_num_values = column_metadata->num_values();
+  ASSERT_EQ(col_metadata_num_values, levels_read);
+  ASSERT_EQ(zer_rep_levls_count, rg_metadata_num_rows);
+  ASSERT_EQ(column_metadata->num_values(), levels_read);
+
+  if (DataType::type_num == parquet::Type::type::INT96) {
+    ASSERT_FALSE(column_metadata->is_stats_set());
+    ASSERT_FALSE(column_metadata->is_null_count_set());
+  } else {
+    ASSERT_EQ(levels_read != 0, column_metadata->is_stats_set());
+    ASSERT_EQ(levels_read != 0, column_metadata->is_null_count_set());
+    if (levels_read != 0) {
+      const auto statistics = column_metadata->statistics();
+      ASSERT_EQ(found_values_for_stats, statistics->HasMinMax());
+      if (column_metadata->statistics()->HasMinMax()) {
+        const auto& typed_statistcs =
+            std::dynamic_pointer_cast<TypedStatistics<DataType>>(statistics);
+        auto expected_min_max = agg.GetMinMax<DataType>(col_index);
+        ASSERT_TRUE(expected_min_max.has_value());
+        c_type expected_min;
+        c_type expected_max;
+        auto actual_min = typed_statistcs->min();
+        auto actual_max = typed_statistcs->max();
+        std::tie(expected_min, expected_max) = expected_min_max.value();
+        auto const equal_to =
+            GetEqualTo<DataType>(non_typed_col_reader->descr()->type_length());
+
+        ASSERT_TRUE(equal_to(actual_min, expected_min));
+        ASSERT_TRUE(equal_to(actual_max, expected_max));
+      }
+
+      ASSERT_TRUE(statistics->HasNullCount());
+      int64_t col_stat_num_values = statistics->num_values();
+      int64_t col_stat_null_count = statistics->null_count();
+      ASSERT_EQ(col_stat_null_count + col_stat_num_values, levels_read);
+      ASSERT_EQ(max_def_levls_count, col_stat_num_values);
+
+      if (statistics->HasDistinctCount() && statistics->distinct_count() != 0) {
+        ASSERT_EQ(statistics->distinct_count(),
+                  agg.dictionaries.at(col_index)->DistinctCount());
+      }
+    }
+  }
+}
