+// ----------------------------------------------------------------------
+// API for shuffle
+
+void ColumnWriterImpl::Flush() {
+  std::optional<int64_t> distinct_count;
+  if (!config_.shuffle_buffering_mode && !dictionary_page_written_ && has_dictionary_ &&
+      !fallback_) {
+    distinct_count = WriteDictionaryPage(false);
+  }
+  FlushBufferedDataPages();
+  if (distinct_count) {
+    SetDistinctCount(*distinct_count);
+  }
+}
+
+template <typename DType>
+int64_t TypedColumnWriterImpl<DType>::WriteBatchWithDictionary(
+    shuffle::Span<const int16_t> def_levels, shuffle::Span<const int16_t> rep_levels,
+    const shuffle::CompactIndexVector& indices, std::shared_ptr<Buffer> values_buffer,
+    shuffle::Span<const int32_t> offsets, int32_t num_values) {
+  if (!IsDictionaryEncoding(current_encoder_->encoding())) {
+    throw ParquetException("Cannot write dictionary to non-dictionary encoder");
+  }
+
+  const auto num_indices = static_cast<int64_t>(indices.size());
+  const auto num_levels =
+      def_levels.empty() ? num_indices : static_cast<int64_t>(def_levels.size());
+
+  // WriteBatchWithDictionary can be called only once per column chunk (row group).
+  // If it's called more than once, PutRawDictionary() will throw an exception.
+  auto& dict_encoder = dynamic_cast<DictEncoder<DType>&>(*current_encoder_);
+  if (page_statistics_ != nullptr) {
+    page_statistics_->Update(values_buffer->data(), offsets, num_values,
+                             num_levels - num_indices);
+  }
+  dict_encoder.PutRawDictionary(std::move(values_buffer), offsets, num_values);
+
+  // Write data pages (indices).
+  int64_t index_offset = 0;
+  auto WriteChunk = [&](int64_t offset, int64_t batch_size, bool check_page) {
+    int64_t indices_to_write =
+        WriteLevels(batch_size, AddIfNotNull(def_levels.data(), offset),
+                    AddIfNotNull(rep_levels.data(), offset));
+    dict_encoder.PutRawIndices(indices, index_offset, indices_to_write);
+    const int64_t num_nulls = batch_size - indices_to_write;
+    CommitWriteAndCheckPageLimit(batch_size, indices_to_write, num_nulls, check_page);
+    index_offset += indices_to_write;
+  };
+  DoInBatches(def_levels.data(), rep_levels.data(), num_levels,
+              properties_->write_batch_size(), WriteChunk,
+              pages_change_on_record_boundaries());
+  return index_offset;
+}
+
+template <typename DType>
+void TypedColumnWriterImpl<DType>::ResetEncoding(Encoding::type encoding,
+                                                 bool use_dictionary) {
+  if (rows_written_ > 0) {
+    throw ParquetException("ResetEncoding can be called on empty writer only");
+  }
+  has_dictionary_ = use_dictionary;
+  encoding_ = encoding;
+  current_encoder_ = MakeEncoder(DType::type_num, encoding, use_dictionary, descr_,
+                                 properties_->memory_pool());
+  current_value_encoder_ = dynamic_cast<ValueEncoderType*>(current_encoder_.get());
+  current_dict_encoder_ = dynamic_cast<DictEncoder<DType>*>(current_encoder_.get());
+}
+
+template <typename DType>
+void TypedColumnWriterImpl<DType>::Flush() {
+  ColumnWriterImpl::Flush();
+}
+
+template <typename DType>
+TypedStatistics<DType>* TypedColumnWriterImpl<DType>::page_statistics() {
+  return page_statistics_.get();
+}
+
+template <typename DType>
+bool TypedColumnWriterImpl<DType>::OutputEmptyStringIndex() const {
+  return false;
+}
+
+template <>
+bool TypedColumnWriterImpl<ByteArrayType>::OutputEmptyStringIndex() const {
+  return descr_->converted_type() == ConvertedType::UTF8 ||
+         descr_->converted_type() == ConvertedType::NONE ||
+         descr_->converted_type() == ConvertedType::JSON ||
+         descr_->converted_type() == ConvertedType::ENUM;
+}
+
+template <typename DType>
+bool TypedColumnWriterImpl<DType>::IsIntegerColumn() const {
+  return false;
+}
+
+template <>
+bool TypedColumnWriterImpl<Int32Type>::IsIntegerColumn() const {
+  return true;
+}
+
+template <>
+bool TypedColumnWriterImpl<Int64Type>::IsIntegerColumn() const {
+  return true;
+}
+
+template <typename DType>
+std::optional<std::pair<typename DType::c_type, typename DType::c_type>> GetMinMax(
+    TypedColumnWriter<DType>& col) {
+  auto statistics = col.page_statistics();
+  if (statistics != nullptr) {
+    return std::make_pair(statistics->min(), statistics->max());
+  } else {
+    return {};
+  }
+}
+
+template <typename ComputeType, typename DType>
+std::optional<int> GetTrailingZerosImpl(TypedColumnWriter<DType>& col,
+                                        const Buffer& values_buffer) {
+  using T = typename DType::c_type;
+  const auto values = shuffle::AsSpan<T>(values_buffer);
+  const auto min_max = GetMinMax(col);
+  if (min_max) {
+    return shuffle::ComputeTrailingZeros<ComputeType, T>(values, min_max->first,
+                                                         min_max->second);
+  } else {
+    return shuffle::ComputeTrailingZeros<ComputeType, T>(values);
+  }
+}
+
+template <typename DType>
+std::optional<int> TypedColumnWriterImpl<DType>::GetTrailingZeros(const Buffer&) {
+  return {};
+}
+
+template <>
+std::optional<int> TypedColumnWriterImpl<Int32Type>::GetTrailingZeros(
+    const Buffer& values_buffer) {
+  return GetTrailingZerosImpl<uint64_t>(*this, values_buffer);
+}
+
+template <>
+std::optional<int> TypedColumnWriterImpl<Int64Type>::GetTrailingZeros(
+    const Buffer& values_buffer) {
+  return GetTrailingZerosImpl<uint64_t>(*this, values_buffer);
+}
