+std::ostream& operator<<(std::ostream& os, const TestParquetFileReaderSliceParam& param) {
+  return os << "_num_files_" << param.num_files << "_row_groups_per_file_"
+            << param.row_groups_per_file << "_rows_per_row_group_"
+            << param.rows_per_row_group << "_pre_buffer_" << param.pre_buffer << "_";
+}
+
+class TestParquetFileReaderSlice : public TestWithParam<TestParquetFileReaderSliceParam> {
+};
+
+TEST_P(TestParquetFileReaderSlice, RangeAllCombinations) {
+  const auto num_files = GetParam().num_files;
+  const auto row_groups_per_file = GetParam().row_groups_per_file;
+  const auto rows_per_row_group = GetParam().rows_per_row_group;
+  const auto pre_buffer = GetParam().pre_buffer;
+  const auto num_row_groups = num_files * row_groups_per_file;
+  const auto num_rows = num_row_groups * rows_per_row_group;
+  const auto files_and_schema =
+      CreateParquetFiles(num_files, row_groups_per_file, rows_per_row_group);
+  const auto& files = files_and_schema.first;
+  const auto& schema = files_and_schema.second;
+  // Use <= instead of < to test offset/count values past ends
+  for (int row_group_offset = 0; row_group_offset <= num_row_groups; ++row_group_offset) {
+    for (int row_group_count = 0; row_group_count <= num_row_groups; ++row_group_count) {
+      for (int row_offset = 0; row_offset <= num_rows; ++row_offset) {
+        for (int row_count = 0; row_count <= num_rows; ++row_count) {
+          const ParquetFileReaderSliceRange range{
+              row_group_offset, row_group_count, row_offset, row_count, {}};
+          SCOPED_TRACE(Message() << "range = " << range);
+          const auto output_range =
+              ComputeOutputRange(num_row_groups, rows_per_row_group, range);
+          auto slice = MakeParquetFileReaderSlice(files, range, pre_buffer);
+          EXPECT_THAT(slice.empty(), output_range.num_rows == 0);
+          EXPECT_THAT(slice.num_columns(), 1);
+          EXPECT_THAT(slice.num_row_groups(), output_range.num_row_groups);
+          EXPECT_THAT(slice.num_rows(), output_range.num_rows);
+          EXPECT_TRUE(slice.schema().schema_root()->Equals(schema.get()));
+          const auto values = ReadAll(slice);
+          const auto expected_values =
+              MakeRange(output_range.value_start, output_range.value_end);
+          ASSERT_THAT(values, ElementsAreArray(expected_values));
+        }
+      }
+    }
+  }
+}
