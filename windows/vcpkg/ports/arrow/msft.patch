+  ASSERT_THAT(field, NotNull());
+  EXPECT_THAT(field->is_primitive(), true);
+  EXPECT_THAT(field->name(), StrEq("id"));
+  EXPECT_THAT(static_cast<const schema::PrimitiveNode&>(*field).physical_type(),
+              Type::INT64);
+}
+
+TEST(TestDeserializeSchema, InvalidData) {
+  EXPECT_THROW(DeserializeSchema(Buffer(
