+  EXPECT_THAT(u.type_length(), 1);
+  EXPECT_THAT(u.values1(), ElementsAre(1, 2));
+  EXPECT_THAT(u.capacity(), 4);
+  EXPECT_THAT(v, IsEmpty());
+  EXPECT_THAT(v, SizeIs(0));
+  EXPECT_THAT(v.type_length(), 1);
+  EXPECT_THAT(v.values1(), ElementsAre());
+  EXPECT_THAT(v.capacity(), 0);
+  v.push_back(23);
+  v.push_back(24);
+  u.push_back(3);
+  u.push_back(4);
+  EXPECT_THAT(v.values1(), ElementsAre(23, 24));
+  EXPECT_THAT(u.values1(), ElementsAre(1, 2, 3, 4));
+}
