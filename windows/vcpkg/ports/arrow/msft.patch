+      << "Column: " << col_name << ", Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json["maxValues"][col_name].IsInt())
+      << "Column: " << col_name << ", Statistics JSON: " << stats_str;
+  ASSERT_EQ(expected_max, json["maxValues"][col_name].GetInt())
+      << "Column: " << col_name << ", Statistics JSON: " << stats_str;
