+template <typename DataType>
+struct BaseEqualityTraits {
+  using c_type = typename DataType::c_type;
+  using equal_to = typename std::equal_to<c_type>;
+  using hash = typename std::hash<c_type>;
+  struct less {
+    bool operator()(const c_type& a, const c_type& b) const { return a < b; }
+  };
+  static bool IsAccountedForStats(const c_type& val) { return true; }
+};
+
+template <typename DataType>
+struct EqualityTraits : BaseEqualityTraits<DataType> {};
+
+template <>
+struct EqualityTraits<parquet::FLBAType> : BaseEqualityTraits<parquet::FLBAType> {
+  struct equal_to {
+    const int len;
+    equal_to() = delete;
+    equal_to(int len) : len(len) {}
+
+    size_t operator()(const parquet::FixedLenByteArray& l,
+                      const parquet::FixedLenByteArray& r) const {
+      return std::memcmp(l.ptr, r.ptr, len) == 0;
+    }
+  };
+
+  struct hash {
+    const int len;
+    hash(int len) : len(len) {}
+
+    size_t operator()(const parquet::FixedLenByteArray& x) const {
+      size_t seed = 0;
+      boost::hash_range(seed, x.ptr, x.ptr + len);
+
+      return seed;
+    }
+  };
+
+  struct less {
+    const int len;
+    less() = delete;
+    less(int len) : len(len) {}
+
+    bool operator()(const parquet::FixedLenByteArray& a,
+                    const parquet::FixedLenByteArray& b) const {
+      return std::memcmp(a.ptr, b.ptr, len) < 0;
+    }
+  };
+};
+
+template <>
+struct EqualityTraits<parquet::ByteArrayType>
+    : BaseEqualityTraits<parquet::ByteArrayType> {
+  struct hash {
+    size_t operator()(const parquet::ByteArray& other) const {
+      size_t seed = other.len;
+      boost::hash_range(seed, other.ptr, other.ptr + other.len);
+      return seed;
+    }
+  };
+
+  struct less {
+    bool operator()(const c_type& a, const c_type& b) const {
+      auto min_len = std::min(a.len, b.len);
+      auto cmp = std::memcmp(a.ptr, b.ptr, min_len);
+      if (cmp != 0) {
+        return cmp < 0;
+      }
+
+      return a.len < b.len;
+    }
+  };
+};
+
+template <>
+struct EqualityTraits<parquet::Int96Type> : BaseEqualityTraits<parquet::Int96Type> {
+  struct hash {
+    size_t operator()(const parquet::Int96& x) const {
+      size_t seed = 0;
+      boost::hash_range(seed, x.value, x.value + 3);
+
+      return seed;
+    }
+  };
+
+  struct less {
+    bool operator()(const c_type& a, const c_type& b) const {
+      for (size_t i = 0; i < 3; i++) {
+        if (a.value[i] != b.value[i]) {
+          return a.value[i] < b.value[i];
+        }
+      }
+
+      return false;
+    }
+  };
+};
+
+template <>
+struct EqualityTraits<parquet::DoubleType> : BaseEqualityTraits<parquet::DoubleType> {
+  static bool IsAccountedForStats(const double& val) { return !std::isnan(val); }
+};
+
+template <>
+struct EqualityTraits<parquet::FloatType> : BaseEqualityTraits<parquet::FloatType> {
+  static bool IsAccountedForStats(const float& val) { return !std::isnan(val); }
+};
