+// For min, Delta uses substring SQL function which operates on the Unicode characters.
+::arrow::Result<std::string> TruncateMinString(std::string value,
+                                               int string_prefix_length) {
+  const auto start = value.data();
+  auto ptr = start;
+  const auto end = ptr + value.size();
+  int parsed = 0;
+  while (ptr < end && parsed < string_prefix_length) {
+    uint32_t cp;
+    const auto error_code = ::utf8::internal::validate_next(ptr, end, cp);
+    if (error_code != ::utf8::internal::UTF8_OK) {
+      return ::arrow::Status::Invalid("invalid UTF8 sequence");
+    }
+    parsed += 1;
+  }
+  return std::move(value).substr(0, ptr - start);
