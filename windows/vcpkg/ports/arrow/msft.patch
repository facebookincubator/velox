+// NOLINT legal/copyright
+
+#pragma once
+
+#include <memory>
+#include <ostream>
+
+#include "parquet/platform.h"
+
+#include "parquet/shuffle/shuffle_algorithm.h"
+#include "parquet/shuffle/shuffle_algorithm_properties.h"
+
+namespace parquet {
+namespace shuffle {
+
+class ShuffleProperties;
+
+struct PARQUET_EXPORT VorderShuffleProperties : public ShuffleAlgorithmProperties {
+  // Minimum estimated number of rows having the most frequent value (pure) in a
+  // column to make a split. If the most frequent value is not frequent enough,
+  // we don't make a split with the column in the partition (and child
+  // partitions). Increasing this value can result in faster execution and less
+  // compression.
+  int32_t min_pure_frequency = 8;
+
+  // Minimum estimated amount of bits saved for the chosen pure value a column
+  // to make a split. Increasing this value can result in faster execution and
+  // less compression.
+  double min_pure_bits = 32;
+
+  // Minimum size of a pure partition to commit a split. If a split doesn't
+  // yield a pure partition larger than this value, the split is abandoned.
+  int32_t min_pure_size = 8;
+
+  // Inverse of minium ratio of pure partition size / parent partition size to
+  // commit a split. If a split doesn't yield a pure partition whose size is
+  // larger than 1 / min_pure_ratio_inverse of parent, the split is abandoned.
+  int32_t min_pure_ratio_inverse = 128;
+
+  // Minimum size of a partition to be considered for a split.
+  int32_t min_partition_size = 16;
+
+  // Minimum average number of rows per run to consider a column for a split.
+  // If there are already too many runs for a column, we don't make any further
+  // splits in any partition. Increasing this value can result in faster
+  // execution and less compression.
+  int32_t min_partition_density = 128;
+
+  // Number of samples to estimate the most frequent value in a column.
+  // Increasing this value can result in slower execution and more compression.
+  // sample_size should be in the range [0, 32768].
+  int32_t sample_size = 512;
+
+  int32_t dense_histogram_width = 20;
+
+  uint16_t dense_histogram_scratch_size = 1024;
+
+  int32_t depth_first_threshold = 4194304;
+
+  bool use_adjusted_column_widths = false;
+
+  void PrintTo(std::ostream& os) const override;
+};
+
+static VorderShuffleProperties DefaultVorderShuffleProperties;
+
+PARQUET_EXPORT
+VorderShuffleProperties GetVorderShuffleProperties(int shuffle_level);
+
+PARQUET_EXPORT
+void ValidateVorderShuffleProperties(const VorderShuffleProperties& props);
+
+PARQUET_EXPORT
+std::ostream& operator<<(std::ostream& os, const VorderShuffleProperties& props);
+
+/// A shuffle algorithm that tries to maximize the RLE compression.
+/// Original algorithm from Marius Dumitru's C# code, adapted and modified by Terry Kim
+/// and Chungmin Lee. Reference: Reordering Rows for Better Compression: Beyond the
+/// Lexicographic Order by Daniel Lemire et al.
+class PARQUET_EXPORT VorderShuffle : public ShuffleAlgorithm {
+ public:
+  static std::unique_ptr<VorderShuffle> Make(const ShuffleProperties& properties);
+
+  explicit VorderShuffle(const ShuffleProperties& properties);
+
+  bool Apply(Span<ColumnData> columns, Span<int32_t> permutation,
+             Span<int32_t>& complete_permutation) override;
+
+ private:
+  const ShuffleProperties& properties_;
+  const VorderShuffleProperties verti_properties_;
+};
+
+}  // namespace shuffle
+}  // namespace parquet
