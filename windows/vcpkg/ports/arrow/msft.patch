+ParquetFileReaderSlice Shuffle(
+    ParquetFileReaderSlice&& source, const ShuffleFileArgs& args = {},
+    std::shared_ptr<WriterProperties> writer_properties = default_writer_properties()) {
+  auto out = CreateOutputStream();
+  {
+    auto writer =
+        ParquetFileWriter::Open(out, CopySchema(source.schema()), writer_properties);
+    ShuffleFile(source, *writer, args);
+    writer->Close();
+  }
+  PARQUET_ASSIGN_OR_THROW(auto data, out->Finish());
+  std::shared_ptr<ParquetFileReader> output_reader =
+      ParquetFileReader::Open(std::make_shared<BufferReader>(data));
+  return {{output_reader}};
+}
+
+uint64_t GetHashShuffled(std::shared_ptr<ParquetFileReader> reader, int num_threads,
+                         std::shared_ptr<::arrow::internal::ThreadPool> thread_pool,
+                         int64_t batch_size = 0) {
+  parquet::WriterProperties::Builder props_builder;
+  props_builder.enable_shuffle();
+  props_builder.shuffle_threads(num_threads);
+  props_builder.shuffle_thread_pool(thread_pool);
+  ShuffleFileArgs args;
+  args.num_threads = num_threads;
+  args.shuffle_row_group_wise = batch_size == 0;
+  args.shuffle_batch_size = batch_size;
+  auto shuffled = Shuffle({{reader}}, args, props_builder.build());
+  return HashSum(shuffled, thread_pool.get());
+}
+
+#ifdef ARROW_FILESYSTEM
+TEST(TestVorderShuffle, TestData) {
+  std::shared_ptr<::arrow::internal::ThreadPool> thread_pool;
+  PARQUET_ASSIGN_OR_THROW(thread_pool, ::arrow::internal::ThreadPool::Make(4));
+  auto fs_and_files = parquet::test::get_data_files();
+  auto& fs = *fs_and_files.first;
+  for (const auto& file : fs_and_files.second) {
+    SCOPED_TRACE(Message() << "file = " << file.path());
+    // TODO fixed_length_byte_array.parquet cannot be read; need to check
+    if (file.base_name() == "fixed_length_byte_array.parquet") {
+      std::cout << "Skipping " << file.base_name() << std::endl;
+      continue;
+    }
+    PARQUET_ASSIGN_OR_THROW(auto in, fs.OpenInputFile(file.path()));
+    std::shared_ptr<ParquetFileReader> reader = ParquetFileReader::Open(in);
+    if (reader->metadata()->schema()->HasRepeatedFields()) {
+      std::cout << "Skipping " << file.base_name() << ": repeated fields" << std::endl;
+      continue;
+    }
+    if (!reader->metadata()->can_decompress()) {
+      std::cout << "Skipping " << file.base_name() << ": unsupported compression"
+                << std::endl;
+      continue;
+    }
+    ParquetFileReaderSlice slice({reader});
+    const auto hash_original = HashSum(slice, thread_pool.get());
+    const auto hash_shuffled1 = GetHashShuffled(reader, 1, nullptr);
+    const auto hash_shuffled4 = GetHashShuffled(reader, 4, thread_pool);
+    const auto hash_shuffled1_batch = GetHashShuffled(reader, 4, thread_pool, 4194304);
+    const auto hash_shuffled4_batch = GetHashShuffled(reader, 4, thread_pool, 4194304);
+    EXPECT_THAT(hash_shuffled1, hash_original);
+    EXPECT_THAT(hash_shuffled4, hash_original);
+    EXPECT_THAT(hash_shuffled1_batch, hash_original);
+    EXPECT_THAT(hash_shuffled4_batch, hash_original);
+  }
+}
+#endif
+
+class TestShuffleTool
+    : public TestWithParam<std::tuple<int, bool, int, bool, bool, bool, int>> {
+ protected:
+  static std::vector<std::shared_ptr<Buffer>> GetParquetFiles() {
+    static const auto files_and_schema = CreateParquetFiles(3, 3, 3);
+    return files_and_schema.first;
+  }
+
+  static const ParquetFileReaderSliceRange range;
+
+  static uint64_t GetHashOriginal() {
+    static auto original = MakeParquetFileReaderSlice(GetParquetFiles(), range);
+    static const auto hash_original = HashSum(original);
+    return hash_original;
+  }
+};
+
+const ParquetFileReaderSliceRange TestShuffleTool::range{1, 7, 2, 17, {}};
+
+TEST_P(TestShuffleTool, VariousPropertiesAndArgs) {
+  const auto param = GetParam();
+  const auto read_batch_size = std::get<0>(param);
+  const auto read_dictionary = std::get<1>(param);
+  const auto shuffle_batch_size = std::get<2>(param);
+  const auto shuffle_row_group_wise = std::get<3>(param);
+  const auto use_dictionary = std::get<4>(param);
+  const auto write_dictionary = std::get<5>(param);
+  const auto output_row_group_size = std::get<6>(param);
+
+  parquet::WriterProperties::Builder props_builder;
+  props_builder.enable_shuffle();
+  props_builder.shuffle_auto_encoding(false);
+  if (use_dictionary) {
+    props_builder.enable_dictionary();
+  } else {
+    props_builder.disable_dictionary();
+  }
+  props_builder.shuffle_direct_dictionary_write(write_dictionary);
+  if (output_row_group_size > 0) {
+    props_builder.max_row_group_length(output_row_group_size);
+    props_builder.shuffle_split_output_row_group(true);
+  }
+  ShuffleFileArgs args;
+  args.read_batch_size = read_batch_size;
+  args.read_dictionary = read_dictionary;
+  args.shuffle_batch_size = shuffle_batch_size;
+  args.shuffle_row_group_wise = shuffle_row_group_wise;
+  auto shuffled = Shuffle(MakeParquetFileReaderSlice(GetParquetFiles(), range), args,
+                          props_builder.build());
+  const auto hash_shuffled = HashSum(shuffled);
+  EXPECT_THAT(hash_shuffled, GetHashOriginal());
+}
