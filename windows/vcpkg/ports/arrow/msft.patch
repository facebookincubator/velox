+// `string_prefix_length` Unicode characters. The string must be valid UTF-8
+// encoded bytes up to the given prefix length. Otherwise, an error is
+// returned. `string_prefix_length` must be non-negative.
+::arrow::Result<std::string> TruncateMinString(std::string value,
+                                               int string_prefix_length);
+
+// Returns a prefix of the given string by taking the first
+// `string_prefix_length` UTF-16 code units (one more if the last code unit is
+// a high surrogate), and then incrementally increasing it by taking more
+// Unicode characters if the last character is the max code point (0x10FFFF),
+// and finally appending a tie-breaker (either 0x7F or 0x10FFFF depending on
+// the following Unicode character). The given string must be valid UTF-8
+// encoded bytes. Otherwise, an error is returned. `string_prefix_length` must
+// be positive.
+::arrow::Result<std::string> TruncateMaxString(std::string value,
+                                               int string_prefix_length);
