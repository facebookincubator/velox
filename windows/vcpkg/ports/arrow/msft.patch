+namespace json {
+
+class Writer {
+  static constexpr const char kObjectStart = '{';
+  static constexpr const char kObjectEnd = '}';
+  static constexpr const char kMemberDelimiter = ',';
+  static constexpr const char kKeyValueDelimiter = ':';
+
+ public:
+  explicit Writer(std::ostringstream& sink) : sink_(sink) {}
+
+  void StartObject() {
+    sink_ << kObjectStart;
+    objects_.push(false);
+  }
+
+  void EndObject() {
+    sink_ << kObjectEnd;
+    objects_.pop();
+  }
+
+  void Key(std::string_view key) {
+    if (objects_.top()) {
+      sink_ << kMemberDelimiter;
+    } else {
+      objects_.top() = true;
+    }
+    StringValue(key);
+    sink_ << kKeyValueDelimiter;
+  }
+
+  void StringValue(std::string_view value) {
+    sink_ << '"';
+    for (const auto c : value) {
+      PutEscaped(c);
+    }
+    sink_ << '"';
+  }
+
+  template <typename T>
+  void RawValue(T&& value) {
+    sink_ << std::forward<T>(value);
+  }
+
+ private:
+  void PutEscaped(char c) {
+    if (c >= 0 && c < 0x20) {
+      const auto old_flags = sink_.flags();
+      const auto old_fill = sink_.fill();
+      const auto old_width = sink_.width();
+      sink_ << "\\u" << std::setfill('0') << std::setw(4) << std::hex
+            << static_cast<int>(c);
+      sink_.flags(old_flags);
+      sink_.fill(old_fill);
+      sink_.width(old_width);
+    } else if (c == '"' || c == '\\') {
+      sink_ << '\\' << c;
+    } else {
+      sink_ << c;
+    }
+  }
+
+  std::ostringstream& sink_;
+  std::stack<bool> objects_;
+};
+
+}  // namespace json
+
+void WriteFloatingPointValue(json::Writer& writer, std::string_view value) {
+  if (value == "NaN" || value == "Infinity" || value == "-Infinity") {
+    writer.StringValue(value);
+  } else {
+    writer.RawValue(value);
+  }
+}
+
+void WriteValue(json::Writer& writer, std::string_view value,
+                SkippingEligibleDataType type) {
+  switch (type) {
+    case SkippingEligibleDataType::IntegralType:
+      return writer.RawValue(value);
+    case SkippingEligibleDataType::FloatingPointType:
+      return WriteFloatingPointValue(writer, value);
+    case SkippingEligibleDataType::DecimalType:
+      return writer.RawValue(value);
+    case SkippingEligibleDataType::DateType:
+      return writer.StringValue(value);
+    case SkippingEligibleDataType::TimestampType:
+      return writer.StringValue(value);
+    case SkippingEligibleDataType::StringType:
+      return writer.StringValue(value);
+    default:
+      break;
+  }
+  ::arrow::Unreachable("WriteValue");
+}
+
+template <typename ValueWriter, typename Filter>
+void WriteStatsJson(json::Writer& writer, std::string_view stats_name,
+                    const std::vector<ColumnStats>& column_stats,
+                    ValueWriter&& value_writer, Filter&& filter) {
+  writer.Key(stats_name);
+  writer.StartObject();
+  size_t depth = 0;
+  const std::vector<std::string>* prev_path = nullptr;
+  for (auto& col_stats : column_stats) {
+    if (!filter(col_stats)) {
+      continue;
+    }
+    const auto common_prefix =
+        prev_path == nullptr ? 0 : FindCommonPrefix(*prev_path, col_stats.path);
+    while (common_prefix < depth) {
+      writer.EndObject();
+      depth -= 1;
+    }
+    size_t i = common_prefix;
+    for (; i + 1 < col_stats.path.size(); ++i) {
+      writer.Key(col_stats.path[i]);
+      writer.StartObject();
+      depth += 1;
+    }
+    writer.Key(col_stats.path[i]);
+    value_writer(writer, col_stats);
+    prev_path = &col_stats.path;
+  }
+  while (depth > 0) {
+    writer.EndObject();
+    depth -= 1;
+  }
+  writer.EndObject();
+}
+
+std::string MakeStatsJson(std::vector<ColumnStats> column_stats, int64_t num_rows,
+                          bool add_tight_bounds) {
+  std::ostringstream oss;
+  json::Writer writer(oss);
+  writer.StartObject();
+
+  writer.Key("numRecords");
+  writer.RawValue(num_rows);
+
+  // Sort column stats by column path lexicographically for linear json output
+  std::sort(column_stats.begin(), column_stats.end(),
+            [](const ColumnStats& a, const ColumnStats& b) { return a.path < b.path; });
+
+  WriteStatsJson(
+      writer, "minValues", column_stats,
+      [](json::Writer& writer, const ColumnStats& col_stats) {
+        WriteValue(writer, *col_stats.min_opt, col_stats.type);
+      },
+      [](const ColumnStats& col_stats) { return col_stats.min_opt.has_value(); });
+
+  WriteStatsJson(
+      writer, "maxValues", column_stats,
+      [](json::Writer& writer, const ColumnStats& col_stats) {
+        WriteValue(writer, *col_stats.max_opt, col_stats.type);
+      },
+      [](const ColumnStats& col_stats) { return col_stats.max_opt.has_value(); });
+
+  WriteStatsJson(
+      writer, "nullCount", column_stats,
+      [](json::Writer& writer, const ColumnStats& col_stats) {
+        writer.RawValue(*col_stats.null_count_opt);
+      },
+      [](const ColumnStats& col_stats) { return col_stats.null_count_opt.has_value(); });
+
+  if (add_tight_bounds) {
+    writer.Key("tightBounds");
+    writer.RawValue("true");
+  }
+
+  writer.EndObject();
+  return std::move(oss).str();
+}
+
+}  // namespace
+
+void SetDeltaStats(::arrow::KeyValueMetadata& kv_meta, int64_t num_rows,
+                   DeltaStatsCollector&& collector) {
+  const auto add_tight_bounds = collector.add_tight_bounds;
+  const auto string_prefix_length = collector.string_prefix_length;
+  auto column_stats = MakeColumnStats(std::move(collector), num_rows);
+  auto stats_json = MakeStatsJson(std::move(column_stats), num_rows, add_tight_bounds);
+  kv_meta.Append(DELTA_STATS_JSON_KEY, std::move(stats_json));
+  kv_meta.Append(DELTA_STATS_STRING_PREFIX_LENGTH_KEY,
+                 std::to_string(string_prefix_length));
+}
