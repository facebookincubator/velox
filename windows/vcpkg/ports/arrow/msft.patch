+static void AssertMinMaxEquals(const rapidjson::Document& json,
+                               const std::string& stats_str, const char* col_name,
+                               int32_t expected_min, int32_t expected_max) {
+  ASSERT_TRUE(json["minValues"].HasMember(col_name))
+      << "Column: " << col_name << ", Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json["minValues"][col_name].IsInt())
+      << "Column: " << col_name << ", Statistics JSON: " << stats_str;
+  ASSERT_EQ(expected_min, json["minValues"][col_name].GetInt())
+      << "Column: " << col_name << ", Statistics JSON: " << stats_str;
