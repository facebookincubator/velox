+#include "parquet/shuffle/shuffle_properties.h"
+
+namespace parquet {
+namespace shuffle {
+
+using ::arrow::internal::JoinStrings;
+
+Shuffle::Shuffle(std::shared_ptr<const ShuffleProperties> properties,
+                 std::unique_ptr<ShuffleAlgorithm> algorithm)
+    : properties_(std::move(properties)), algorithm_(std::move(algorithm)) {}
+
+Shuffle::~Shuffle() {}
+
+const std::vector<std::string>& GetAvailableAlgorithms() {
+  static const std::vector<std::string>& available = {"vorder", "lexicographic",
+                                                      "no_shuffle", "random"};
+  return available;
+}
+
+std::unique_ptr<Shuffle> Shuffle::Make(
+    std::shared_ptr<const ShuffleProperties> properties) {
+  if (!properties) {
+    auto new_properties = std::make_shared<ShuffleProperties>();
+    new_properties->memory_pool(::arrow::default_memory_pool());
+    properties = std::move(new_properties);
+  }
+  const auto& props = *properties;
+  std::unique_ptr<ShuffleAlgorithm> algorithm =
+      [&]() -> std::unique_ptr<ShuffleAlgorithm> {
+    if (props.shuffle_algorithm() == "vorder") {
+      return VorderShuffle::Make(props);
+    } else if (props.shuffle_algorithm() == "lexicographic") {
+      return LexicographicSort::Make(props);
+    } else if (props.shuffle_algorithm() == "no_shuffle") {
+      return NoShuffle::Make(props);
+    } else if (props.shuffle_algorithm() == "random") {
+      return RandomShuffle::Make(props);
+    } else {
+      std::ostringstream buffer;
+      buffer << "Invalid shuffle algorithm: " + props.shuffle_algorithm()
+             << " (available: " << JoinStrings(GetAvailableAlgorithms(), ", ") << ")";
+      throw ParquetException(buffer.str());
+    }
+  }();
+  return std::make_unique<Shuffle>(std::move(properties), std::move(algorithm));
+}
+
+}  // namespace shuffle
+}  // namespace parquet
