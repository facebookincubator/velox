+template <typename DType>
+void CopyColumn(int col, TypedColumnReader<DType>& col_reader,
+                TypedColumnWriter<DType>& col_writer, int64_t num_rows,
+                const ShuffleFileArgs& args) {
+  auto dict_writer = dynamic_cast<DictionaryColumnWriter<DType>*>(&col_writer);
+  using T = typename DType::c_type;
+  std::vector<int16_t> def_levels(args.read_batch_size);
+  auto values =
+      AllocateBuffer(::arrow::default_memory_pool(), args.read_batch_size * sizeof(T));
+  auto values_ptr = reinterpret_cast<T*>(values->mutable_data());
+  std::vector<int32_t> indices(args.read_batch_size);
+  const T* dict = nullptr;
+  int32_t dict_len = 0;
+  const bool read_dictionary =
+      args.shuffle_row_group_wise && args.read_dictionary && dict_writer &&
+      col_reader.GetExposedEncoding() == ExposedEncoding::DICTIONARY;
+  if (read_dictionary) {
+    PRINTLN("Reading dictionary directly for column " << col);
+  }
+  while (num_rows > 0 && col_reader.HasNext()) {
+    int64_t values_read = 0;
+    int64_t levels_read = 0;
+    if (read_dictionary) {
+      const T* curr_dict = nullptr;
+      int32_t curr_dict_len = 0;
+      levels_read = col_reader.ReadBatchWithDictionary(
+          std::min(args.read_batch_size, num_rows), def_levels.data(), nullptr,
+          indices.data(), &values_read, &curr_dict, &curr_dict_len);
+      if (curr_dict != nullptr) {
+        if (dict == nullptr) {
+          dict_writer->SetDictionary(curr_dict, curr_dict_len);
+          dict = curr_dict;
+          dict_len = curr_dict_len;
+        } else if (dict != curr_dict || dict_len != curr_dict_len) {
+          throw ParquetException("Different dictionaries read");
+        }
+      }
+      dict_writer->WriteIndices(levels_read, def_levels.data(), indices.data());
+    } else {
+      levels_read =
+          col_reader.ReadBatch(std::min(args.read_batch_size, num_rows),
+                               def_levels.data(), nullptr, values_ptr, &values_read);
+      col_writer.WriteBatch(levels_read, def_levels.data(), nullptr, values_ptr);
+    }
+    num_rows -= levels_read;
+  }
+}
+
+void CopyColumn(int col, ColumnReader& col_reader, ColumnWriter& col_writer,
+                int64_t num_rows, const ShuffleFileArgs& args) {
+  PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+      col_reader.type(),
+      CopyColumn<DType>(col, dynamic_cast<TypedColumnReader<DType>&>(col_reader),
+                        dynamic_cast<TypedColumnWriter<DType>&>(col_writer), num_rows,
+                        args));
+}
+
+void CopyRowGroup(std::vector<std::shared_ptr<ColumnReader>>& col_readers,
+                  RowGroupWriter& rg_writer, int64_t num_rows,
+                  const ShuffleFileArgs& args, Executor* executor) {
+  OptionalParallelFor(
+      static_cast<int>(col_readers.size()),
+      [&](int i) {
+        auto col_writer = rg_writer.column(i);
+        CopyColumn(i, *col_readers[i], *col_writer, num_rows, args);
+      },
+      executor);
+}
+
+void ShuffleFileImpl(ParquetFileReaderSlice& source, ParquetFileWriter& writer,
+                     const ShuffleFileArgs& args, ShuffleMetrics* metrics) {
+  const auto& writer_properties = *writer.properties();
+  auto thread_pool = writer_properties.shuffle_properties()->thread_pool();
+  if (args.num_threads > 1 && !thread_pool) {
+    PARQUET_ASSIGN_OR_THROW(thread_pool, ThreadPool::Make(args.num_threads));
+  }
+  std::shared_ptr<RowGroupReader> rg_reader;
+  const auto columns = source.columns();
+  const auto num_columns = columns.size();
+  std::vector<std::shared_ptr<ColumnReader>> col_readers(num_columns);
+  RowGroupWriter* rg_writer = nullptr;
+  int64_t remaining_rows = 0;
+  int64_t buffered_rows = 0;
+  int64_t buffered_rows_since_last_row_group_check = 0;
+  const auto num_row_groups = source.num_row_groups();
+  int64_t row_group_index = 0;
+
+  auto CloseRowGroupWriter = [&] {
+    Measure(metrics, &ShuffleMetrics::row_group_close_time, [&] { rg_writer->Close(); });
+    PRINTLN("Closed shuffled row group (" << buffered_rows << " rows)");
+    rg_writer = nullptr;
+    buffered_rows = 0;
+    buffered_rows_since_last_row_group_check = 0;
+  };
+  auto ShouldCloseRowGroupWriter = [&] {
+    buffered_rows_since_last_row_group_check = 0;
+    const auto estimated_memory_usage =
+        rg_writer->estimated_memory_usage(args.row_group_check_batch_size);
+    const auto estimated_size = rg_writer->estimated_size();
+    PRINTLN("Estimated memory usage: " << estimated_memory_usage);
+    PRINTLN("Estimated row group size: " << estimated_size);
+    return estimated_memory_usage >= args.row_group_writer_memory_threshold ||
+           estimated_size >= args.row_group_target_size;
+  };
+
+  while (true) {
+    if (!rg_reader) {
+      if (row_group_index == num_row_groups) break;
+      auto rg_slice = source.NextRowGroup();
+      ++row_group_index;
+      rg_reader = std::move(rg_slice.row_group);
+      for (size_t i = 0; i < num_columns; ++i) {
+        col_readers[i] =
+            rg_reader->ColumnWithExposeEncoding(columns[i], ExposedEncoding::DICTIONARY);
+      }
+      if (rg_slice.row_offset > 0) {
+        for (size_t i = 0; i < num_columns; ++i) {
+          Skip(*col_readers[i], rg_slice.row_offset);
+        }
+      }
+      remaining_rows = rg_slice.row_count;
+      PRINTLN("Opened row group " << (row_group_index - 1) << " (" << remaining_rows
+                                  << " rows)");
+    }
+    if (rg_writer == nullptr) {
+      rg_writer =
+          !writer_properties.shuffle_enabled()
+              ? writer.AppendBufferedRowGroup()
+              : writer.AppendShuffledRowGroup(
+                    Shuffle::Make(writer_properties.shuffle_properties()), metrics);
+      PRINTLN("Appended row group for shuffle");
+    }
+    const auto num_rows =
+        args.shuffle_row_group_wise ? remaining_rows
+        : args.shuffle_batch_size > 0
+            ? std::min(remaining_rows, args.shuffle_batch_size - buffered_rows)
+        : args.row_group_check_batch_size > 0
+            ? std::min(remaining_rows, args.row_group_check_batch_size -
+                                           buffered_rows_since_last_row_group_check)
+            : remaining_rows;
+    Measure(metrics, &ShuffleMetrics::dictionary_build_time, [&] {
+      CopyRowGroup(col_readers, *rg_writer, num_rows, args, thread_pool.get());
+    });
+    PRINTLN("Buffered " << num_rows << " rows");
+    remaining_rows -= num_rows;
+    buffered_rows += num_rows;
+    buffered_rows_since_last_row_group_check += num_rows;
+    if (remaining_rows == 0) {
+      std::for_each(
+          col_readers.begin(), col_readers.end(),
+          [](std::shared_ptr<ColumnReader>& col_reader) { col_reader.reset(); });
+      rg_reader.reset();
+      PRINTLN("Closed row group " << (row_group_index - 1));
+    }
+    if (args.shuffle_row_group_wise ||
+        (args.shuffle_batch_size > 0 && buffered_rows == args.shuffle_batch_size) ||
+        (args.row_group_check_batch_size > 0 &&
+         buffered_rows_since_last_row_group_check == args.row_group_check_batch_size &&
+         ShouldCloseRowGroupWriter())) {
+      CloseRowGroupWriter();
+    }
+  }
+  if (rg_writer != nullptr) {
+    CloseRowGroupWriter();
+  }
+  if (args.verbose && metrics != nullptr) {
+    PrintShuffleMetrics(*metrics);
+  }
+}
+
+void WriteEmptyRowGroup(ParquetFileWriter& output) {
+  output.AppendBufferedRowGroup()->Close();
+}
+
+void ShuffleFile(ParquetFileReaderSlice& source, ParquetFileWriter& output,
+                 const ShuffleFileArgs& args, ShuffleMetrics* metrics) {
+  if (args.verbose) {
+    PrintTo(args, *output.properties(), std::cout);
+  }
+  const auto start = std::chrono::high_resolution_clock::now();
+  if (!source.empty()) {
+    if (source.schema().HasRepeatedFields()) {
+      throw ParquetException("Repeated fields are not supported yet.");
+    }
+    ShuffleFileImpl(source, output, args, metrics);
+  } else if (args.write_empty_row_group) {
+    WriteEmptyRowGroup(output);
+  }
+  output.Close();
+  const auto end = std::chrono::high_resolution_clock::now();
+  const auto elapsed_time =
+      static_cast<std::chrono::duration<double>>(end - start).count();
+  if (metrics != nullptr) {
+    metrics->elapsed_time = elapsed_time;
+  }
+  if (args.verbose) {
+    std::cout << "Elapsed time: " << elapsed_time << " seconds" << std::endl;
+  }
+  const bool print_summary = args.verbose && !args.output_filename.empty();
+  if (print_summary || metrics != nullptr) {
+    auto output_reader = ParquetFileReaderSlice::OpenFile(
+        args.output_filename, ParquetFileReaderSlice::All, true);
+    if (print_summary) {
+      PrintSummary(source, *output_reader);
+    }
+    if (metrics != nullptr) {
+      metrics->uncompressed_size =
+          static_cast<double>(GetUncompressedSize(*output_reader));
+      metrics->compressed_size = static_cast<double>(GetCompressedSize(*output_reader));
+    }
+  }
+}
+
+}  // namespace shuffle
+}  // namespace parquet
