+struct DataPointers {
+ public:
+  DataPointers(const CircularMemoryStream def_levels,
+               const CircularMemoryStream rep_levels, const CircularMemoryStream values)
+      : def_levels(def_levels), rep_levels(rep_levels), values(values) {}
+
+  CircularMemoryStream def_levels;
+  CircularMemoryStream rep_levels;
+  CircularMemoryStream values;
+};
