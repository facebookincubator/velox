+::arrow::Result<std::string> FormatTimestamp(int64_t value, int64_t scale) {
+  if (scale != 1 && scale != 1000 && scale != 1000000 && scale != 1000000000) {
+    return ::arrow::Status::Invalid("invalid scale", scale);
+  }
+  int64_t epoch_seconds = value / scale;
+  int64_t remainder = value % scale;
+  if (remainder < 0) {
+    remainder += scale;
+    epoch_seconds -= 1;
+  }
+  const int millis = scale == 1 ? 0 : static_cast<int>(remainder / (scale / 1000));
+  int64_t epoch_days = epoch_seconds / 86400;
+  int64_t seconds_of_day = epoch_seconds % 86400;
+  if (seconds_of_day < 0) {
+    seconds_of_day += 86400;
+    epoch_days -= 1;
+  }
+  const auto [year, month, day] = GetYearMonthDay(epoch_days);
+  const int hour = static_cast<int>(seconds_of_day / 3600);
+  const int minute = static_cast<int>((seconds_of_day % 3600) / 60);
+  const int second = static_cast<int>(seconds_of_day % 60);
+  char buf[32];
+  const auto format = year >= 0 && year <= 9999 ? "%04d-%02d-%02dT%02d:%02d:%02d.%03d"
+                                                : "%+05d-%02d-%02dT%02d:%02d:%02d.%03d";
+  const auto len =
+      snprintf(buf, sizeof(buf), format, year, month, day, hour, minute, second, millis);
+  if (len < 0 || len >= static_cast<int>(sizeof(buf))) {
+    return ::arrow::Status::UnknownError("snprintf failed: ", len);
+  } else {
+    std::string result;
+    result.reserve(len + 1);  // Room for Z at the end
+    result.assign(buf, len);
+    return result;
+  }
+}
+
+::arrow::Result<std::string> DateToString(int32_t value, bool legacy_mode) {
+  if (legacy_mode) {
+    return ::arrow::Status::NotImplemented("LEGACY mode for date");
+  } else {
+    return FormatDate(value);
+  }
+}
+
+::arrow::Result<std::string> TimestampToString(int64_t value,
+                                               const parquet::TimestampLogicalType& type,
+                                               bool legacy_mode) {
+  ARROW_ASSIGN_OR_RAISE(const auto scale, GetScale(type.time_unit()));
+  if (legacy_mode) {
+    return ::arrow::Status::NotImplemented("LEGACY mode for timestamp");
+  } else {
+    auto result = FormatTimestamp(value, scale);
+    if (type.is_adjusted_to_utc()) {  // TIMESTAMP_LTZ
+      return std::move(result).Map([](std::string&& s) {
+        s.append(1, 'Z');
+        return s;
+      });
+    } else {  // TIMESTAMP_NTZ
+      return result;
+    }
+  }
+}
