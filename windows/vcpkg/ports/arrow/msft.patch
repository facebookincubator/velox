+// NOLINT legal/copyright
+
+#pragma once
+
+#include "parquet/encoding.h"
+
+namespace parquet {
+namespace shuffle {
+
+class ShuffleWriterProperties;
+
+class ShuffleEncoder {
+ public:
+  virtual ~ShuffleEncoder() {}
+
+  struct Data {
+    // indices may be null if the internal encoding is switched to plain.
+    // Internal encoding can be switched to plain if the memory consumption exceeds the
+    // configured threshold and every value is distinct.
+    std::shared_ptr<shuffle::CompactIndexVector> indices;
+
+    // values_buffer contains the dictionary if indices is not null, and plain encode
+    // values if indices is null.
+    std::shared_ptr<ResizableBuffer> values_buffer;
+
+    // offset_buffer is only used for BYTE_ARRAY.
+    std::shared_ptr<ResizableBuffer> offsets_buffer;
+
+    // Number of values in values_buffer.
+    int32_t num_values;
+  };
+
+  virtual Data Finish() = 0;
+};
+
+template <typename DType>
+class PARQUET_EXPORT TypedShuffleEncoder : public TypedEncoder<DType>,
+                                           public ShuffleEncoder {};
+
+PARQUET_EXPORT
+std::unique_ptr<Encoder> MakeShuffleEncoder(Type::type type_num, bool use_dictionary,
+                                            const ColumnDescriptor* descr,
+                                            MemoryPool* pool,
+                                            const ShuffleWriterProperties* writer_props);
+
+}  // namespace shuffle
+}  // namespace parquet
