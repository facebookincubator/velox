+void PrintStatistics(const ParquetFileReaderSlice& source) {
+  const auto num_row_groups = source.num_row_groups();
+  const auto num_rows = source.num_rows();
+  const auto rows_per_row_groups = num_rows == 0 ? 0 : num_rows / num_row_groups;
+  const auto uncompressed_size = GetUncompressedSize(source);
+  const auto compressed_size = GetCompressedSize(source);
+  std::cout << "- Rows: " << num_rows << std::endl
+            << "- Row groups: " << num_row_groups << std::endl
+            << "- Rows per row group: " << rows_per_row_groups << std::endl
+            << "- Uncompressed size: " << PrintBytes(uncompressed_size) << std::endl
+            << "- Compressed size: " << PrintBytes(compressed_size) << std::endl;
+}
