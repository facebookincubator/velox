@@ -0,0 +1,96 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <iterator>
+#include <utility>
+
+namespace parquet {
+namespace shuffle {
+namespace range_util {
+
+template <typename Range>
+struct RangeTraits {
+  using iterator = decltype(std::declval<Range>().begin());
+  using const_iterator = decltype(std::declval<const Range>().begin());
+};
+
+template <typename BaseIterator, typename Range, typename Predicate>
+class FilterIterator;
+
+template <typename Range, typename Predicate>
+class FilterRange {
+ public:
+  using range_type = typename std::remove_reference<Range>::type;
+  using iterator =
+      FilterIterator<typename RangeTraits<range_type>::iterator, Range, Predicate>;
+  using const_iterator =
+      FilterIterator<typename RangeTraits<range_type>::const_iterator, Range, Predicate>;
+
+  FilterRange(Range range, Predicate predicate)
+      : range_(std::forward<Range>(range)),
+        predicate_(std::forward<Predicate>(predicate)) {}
+
+  iterator begin() { return iterator{this, range_.begin(), range_.end()}; }
+  iterator end() { return iterator{this, range_.end(), range_.end()}; }
+
+  const_iterator begin() const {
+    return const_iterator{this, range_.begin(), range_.end()};
+  }
+  const_iterator end() const { return const_iterator{this, range_.end(), range_.end()}; }
+
+ private:
+  Range range_;
+  Predicate predicate_;
+
+  friend iterator;
+  friend const_iterator;
+};
+
+template <typename BaseIterator, typename Range, typename Predicate>
+class FilterIterator {
+ public:
+  using difference_type = void;
+  using value_type = typename std::iterator_traits<BaseIterator>::value_type;
+  using pointer = typename std::iterator_traits<BaseIterator>::pointer;
+  using reference = typename std::iterator_traits<BaseIterator>::reference;
+  using iterator_category = std::input_iterator_tag;
+
+  FilterIterator(const FilterRange<Range, Predicate>* range, BaseIterator curr,
+                 BaseIterator last)
+      : range_(range), curr_(std::move(curr)), last_(std::move(last)) {
+    Next();
+  }
+
+  bool operator==(const FilterIterator& rhs) const { return curr_ == rhs.curr_; }
+  bool operator!=(const FilterIterator& rhs) const { return curr_ != rhs.curr_; }
+
+  decltype(*std::declval<BaseIterator>()) operator*() const { return *curr_; }
+
+  FilterIterator& operator++() {
+    ++curr_;
+    Next();
+    return *this;
+  }
+
+ private:
+  void Next() {
+    while (curr_ != last_) {
+      if (range_->predicate_(*curr_)) return;
+      ++curr_;
+    }
+  }
+
+  const FilterRange<Range, Predicate>* range_;
+  BaseIterator curr_;
+  BaseIterator last_;
+};
+
+template <typename Range, typename Predicate>
+FilterRange<Range, Predicate> filter(Predicate&& predicate, Range&& range) {
+  return {std::forward<Range>(range), std::forward<Predicate>(predicate)};
+}
+
+}  // namespace range_util
+}  // namespace shuffle
+}  // namespace parquet
