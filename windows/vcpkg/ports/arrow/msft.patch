@@ -0,0 +1,64 @@
+// NOLINT legal/copyright
+
+#include "parquet/shuffle/algorithms/lexicographic_sort.h"
+
+#include <algorithm>
+#include <numeric>
+
+#include "arrow/util/unreachable.h"
+
+#include "parquet/shuffle/util/compact_index_util.h"
+
+namespace parquet {
+namespace shuffle {
+
+std::unique_ptr<LexicographicSort> LexicographicSort::Make(const ShuffleProperties&) {
+  return std::make_unique<LexicographicSort>();
+}
+
+int32_t GetIndex(const uint8_t* data, int type_length, int32_t i) {
+  switch (type_length) {
+    case 1:
+      return data[i];
+    case 2:
+      return As2ByteArray(data)[i];
+    case 3:
+      return As3ByteArray(data)[i];
+    case 4:
+      return As4ByteArray(data)[i];
+  }
+  ::arrow::Unreachable();
+}
+
+bool LexicographicSort::Apply(Span<ColumnData> columns, Span<int32_t> permutation,
+                              Span<int32_t>& complete_permutation) {
+  std::iota(permutation.begin(), permutation.end(), 0);
+  std::sort(columns.begin(), columns.end(),
+            [&](const ColumnData& a, const ColumnData& b) {
+              return a.num_distinct_values < b.num_distinct_values;
+            });
+  std::sort(permutation.begin(), permutation.end(), [&](int32_t i, int32_t j) {
+    for (const auto& col : columns) {
+      const auto null_index = GetNullIndex(col.type_length);
+      const int32_t index_i = GetIndex(col.data, col.type_length, i);
+      const int32_t index_j = GetIndex(col.data, col.type_length, j);
+      // Compare indices by its value, but always treat null_index as the lowest
+      // (to preserve old test results that were created when null_index was always -1).
+      if (index_i == null_index) {
+        return index_j != null_index;
+      } else if (index_j == null_index) {
+        return false;
+      } else if (index_i < index_j) {
+        return true;
+      } else if (index_i > index_j) {
+        return false;
+      }
+    }
+    return false;
+  });
+  complete_permutation = Span<int32_t>();
+  return true;
+}
+
+}  // namespace shuffle
+}  // namespace parquet
