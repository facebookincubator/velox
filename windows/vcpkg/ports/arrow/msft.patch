diff --git a/cpp/tools/parquet/parquet_hash.cc b/cpp/tools/parquet/parquet_hash.cc
new file mode 100644
index 0000000000..c3a1919b05
--- /dev/null
+++ b/cpp/tools/parquet/parquet_hash.cc
@@ -0,0 +1,142 @@
+// NOLINT legal/copyright
+
+#include <iomanip>
+#include <iostream>
+#include <sstream>
+
+#include <gflags/gflags.h>
+
+#include "arrow/util/config.h"
+#include "arrow/util/parallel.h"
+#include "arrow/util/thread_pool.h"
+#include "parquet/exception.h"
+
+#include "parquet/shuffle/file_hash.h"
+#include "parquet/shuffle/file_reader_slice.h"
+#include "parquet/shuffle/util/iomanip.h"
+
+#include "commandline_util.h"
+#include "file_slice_range_flags.h"
+
+// gflags shows the full path of this source file in the help message, which
+// looks bad because it contains the path where the build happened. There is no
+// way to prevent that other than redefining __FILE__ here.
+// Note: MSVC doesn't allow overriding __FILE__
+#ifndef _MSC_VER
+#define __FILE__ "parquet-hash"
+#endif
+
+DECLARE_bool(help);
+
+DEFINE_bool(combine, false,
+            "print the sum of all hashsums; use this option if you want to treat the "
+            "specified files as a "
+            "single big file");
+
+DEFINE_int32(num_threads, std::max(::arrow::GetCpuThreadPoolCapacity() / 2, 1),
+             "number of threads");
+DEFINE_validator(num_threads, &ValidatePositiveInteger);
+
+// Error codes
+constexpr int RETURN_CODE_OK = 0;
+constexpr int RETURN_CODE_USAGE_ERROR = 1;
+constexpr int RETURN_CODE_INTERNAL_ERROR = 2;
+
+template <typename T>
+std::function<std::ostream&(std::ostream&)> PrintHex(T hash) {
+  return [hash](std::ostream& os) -> std::ostream& {
+    return os << std::hex << std::setw(sizeof(T) << 1) << std::setfill('0') << hash;
+  };
+}
+
+void SetUsageMessage() {
+  std::stringstream ss;
+  ss << "[<options>] <file>..." << std::endl
+     << std::endl
+     << "Print the hashsum of the Parquet file(s). A hashsum is a sum of hashes of rows."
+     << std::endl
+     << "A hashsum can be used to check the equality of Parquet files ignoring the order"
+     << std::endl
+     << "of rows.";
+  gflags::SetUsageMessage(ss.str());
+}
+
+int main(int argc, char** argv) {
+  SetUsageMessage();
+  gflags::SetVersionString(ARROW_VERSION_STRING);
+  gflags::ParseCommandLineNonHelpFlags(&argc, &argv, true);
+  if (FLAGS_help) {
+    gflags::ShowUsageWithFlags(argv[0]);
+    return RETURN_CODE_OK;
+  }
+  if (argc < 2) {
+    PrintError() << "file is not specified" << std::endl;
+    return RETURN_CODE_USAGE_ERROR;
+  }
+  int return_code = RETURN_CODE_OK;
+  std::shared_ptr<::arrow::internal::ThreadPool> compute_pool;
+  if (FLAGS_num_threads > 1) {
+    PARQUET_ASSIGN_OR_THROW(compute_pool,
+                            ::arrow::internal::ThreadPool::Make(FLAGS_num_threads));
+  }
+  const auto range = GetParquetFileSliceRange();
+  if (!range) {
+    return RETURN_CODE_USAGE_ERROR;
+  }
+  PARQUET_ASSIGN_OR_THROW(auto io_pool,
+                          ::arrow::internal::ThreadPool::Make(std::min(argc - 1, 32)));
+  if (FLAGS_combine) {
+    uint64_t hash = 0;
+    try {
+      std::vector<std::string> filenames;
+      filenames.reserve(argc - 1);
+      for (int i = 1; i < argc; ++i) {
+        filenames.emplace_back(argv[i]);
+      }
+      auto slice = parquet::shuffle::ParquetFileReaderSlice::OpenFiles(
+          filenames, *range, false, io_pool.get());
+      hash = parquet::shuffle::HashSum(*slice, compute_pool.get());
+    } catch (const std::exception& e) {
+      PrintError() << "Parquet error: " << e.what() << std::endl;
+      return_code = RETURN_CODE_INTERNAL_ERROR;
+    }
+    std::cout << PrintHex(hash) << std::endl;
+  } else {
+    struct File {
+      std::string filename;
+      std::unique_ptr<parquet::shuffle::ParquetFileReaderSlice> slice;
+      const char* error;
+    };
+    std::vector<File> files(argc - 1);
+    PARQUET_THROW_NOT_OK(ParallelFor(
+        argc - 1,
+        [&](int i) {
+          const auto filename = argv[i + 1];
+          try {
+            auto slice =
+                parquet::shuffle::ParquetFileReaderSlice::OpenFile(filename, *range);
+            files[i] = {filename, std::move(slice), ""};
+          } catch (const std::exception& e) {
+            files[i] = {filename, nullptr, e.what()};
+          }
+        },
+        io_pool.get()));
+    for (auto& f : files) {
+      uint64_t hash = 0;
+      if (f.slice) {
+        try {
+          hash = parquet::shuffle::HashSum(*f.slice, compute_pool.get());
+        } catch (const std::exception& e) {
+          PrintError() << "Parquet error: " << e.what() << std::endl;
+          return_code = RETURN_CODE_INTERNAL_ERROR;
+        }
+        f.slice.reset();
+      } else {
+        PrintError() << "Parquet error: " << f.error << std::endl;
+        return_code = RETURN_CODE_INTERNAL_ERROR;
+      }
+      std::cout << PrintHex(hash) << " " << f.filename << std::endl;
+    }
+  }
+  return return_code;
+}
