+  const int data[] = {1, 9, 1, 9, 1, 9, 1, 9};
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  EXPECT_THAT(e.estimate(), 0);
+  EXPECT_THAT(e.flushed_estimate(), 30);
+  e.Flush();
+  EXPECT_THAT(e.estimate(), 30);
+}
+
+struct RleTestConfig {
+  int num_iterations;
+  int bit_width;
+  size_t num_values;
+  size_t max_repeat_length;
+  size_t max_literal_length;
+  std::vector<size_t> checkpoints;
+  std::map<size_t, int> new_bit_widths;
+  double expected_max_error;
+  int32_t min_encoded_size;
+  size_t batch_size;
+};
+
+std::vector<int> GenerateRleTestData(const RleTestConfig& config, unsigned int seed) {
+  std::vector<int> values;
+  values.reserve(config.num_values);
+  std::default_random_engine random_engine(seed);
+  std::uniform_int_distribution<size_t> repeat_length_gen(8, config.max_repeat_length);
+  std::uniform_int_distribution<size_t> literal_length_gen(1, config.max_literal_length);
+  std::uniform_int_distribution<int> value_gen(0, (1 << config.bit_width) - 1);
+  int state = random_engine() % 2;
+  int last_value = 0;
+  const auto gen_value = [&] {
+    while (true) {
+      const int v = value_gen(random_engine);
+      if (v != last_value) {
+        last_value = v;
+        return v;
+      }
+    }
+  };
+  while (values.size() < config.num_values) {
+    if (state == 0) {
+      const auto len = repeat_length_gen(random_engine);
+      const auto len_adj = std::min(len, config.num_values - values.size());
+      const auto val = gen_value();
+      values.insert(values.end(), len_adj, val);
+    } else {
+      const size_t len = literal_length_gen(random_engine);
+      const auto len_adj = std::min(len, config.num_values - values.size());
+      for (size_t i = 0; i < len_adj; ++i) {
+        values.emplace_back(gen_value());
+      }
+    }
+    state = 1 - state;
+  }
+  return values;
+}
+
+double CheckAccuracy(uint64_t estimate, int32_t actual, double expected_max_error) {
+  SCOPED_TRACE(Message() << "estimate = " << estimate);
+  SCOPED_TRACE(Message() << "actual = " << actual);
+  EXPECT_THAT(estimate, Ge(actual * (1 - expected_max_error)));
+  EXPECT_THAT(estimate, Le(actual * (1 + expected_max_error)));
+  const auto error = std::abs(1.0 - static_cast<double>(estimate) / actual);
+  return error;
+}
+
+void TestAccuracy(const RleTestConfig& config) {
+  double max_error = 0.0;
+  std::vector<uint8_t> buffer(config.bit_width * config.num_values / 8 * 2);
+  for (int i = 0; i < config.num_iterations; ++i) {
+    SCOPED_TRACE(Message() << "repetition = " << i);
+    const auto data = GenerateRleTestData(config, i);
+    RleSizeEstimator<int> estimator(config.bit_width);
+    auto next_checkpoint_it = config.checkpoints.begin();
+    size_t prev_checkpoint = 0;
+    int bit_width = config.bit_width;
+    while (prev_checkpoint < config.num_values) {
+      const auto checkpoint = next_checkpoint_it == config.checkpoints.end()
+                                  ? config.num_values
+                                  : *next_checkpoint_it++;
+      const auto new_bit_width_it = config.new_bit_widths.find(checkpoint);
+      if (new_bit_width_it != config.new_bit_widths.end()) {
+        bit_width = new_bit_width_it->second;
+        estimator.UpdateBitWidth(bit_width);
+      }
+      estimator.Append(
+          AsSpan(data).subspan(prev_checkpoint, checkpoint - prev_checkpoint));
+      ::arrow::util::RleEncoder encoder(buffer.data(), static_cast<int>(buffer.size()),
+                                        bit_width);
+      for (const auto v : AsSpan(data).subspan(0, checkpoint)) {
+        ASSERT_TRUE(encoder.Put(v));
+      }
+      encoder.Flush();
+      const auto estimate = estimator.flushed_estimate();
+      const auto actual = encoder.len();
+      if (actual >= config.min_encoded_size) {
+        const auto error = CheckAccuracy(estimate, actual, config.expected_max_error);
+        max_error = std::max(error, max_error);
+      }
+      prev_checkpoint = checkpoint;
+    }
+  }
+  std::cout << "max_error = " << max_error << std::endl;
+}
+
+TEST(TestRleSizeEstimator, AccuracyBitWidth4) {
+  TestAccuracy({100,
+                4,
+                100000,
+                10000,
+                2000,
+                {1000, 2000, 5000, 10000, 20000, 50000},
+                {},
+                0.05,
+                128,
+                0});
+}
+
+TEST(TestRleSizeEstimator, AccuracyBitWidth17) {
+  TestAccuracy({100,
+                17,
+                100000,
+                2000,
+                1000,
+                {1000, 2000, 5000, 10000, 20000, 50000},
+                {},
+                0.1,
+                256,
+                0});
+}
+
+TEST(TestRleSizeEstimator, AccuracyVariableBitWidth) {
+  TestAccuracy({100,
+                4,
+                100000,
+                5000,
+                2000,
+                {1000, 2000, 5000, 10000, 20000, 50000},
+                {{2000, 5}, {5000, 7}, {20000, 11}},
+                0.05,
+                256,
+                0});
+}
+
+template <typename T>
+std::vector<Span<const T>> GenerateBatchs(const std::vector<T>& data, size_t batch_size) {
+  std::vector<Span<const T>> batches;
+  batches.reserve((data.size() + batch_size - 1) / batch_size);
+  size_t next_pos = 0;
+  size_t remaining_size = data.size();
+  while (remaining_size > 0) {
+    const auto current_batch_size = std::min(batch_size, remaining_size);
+    batches.emplace_back(data.data() + next_pos, current_batch_size);
+    remaining_size -= current_batch_size;
+  }
+  return batches;
+}
+
+void TestPerformance(const RleTestConfig& config) {
+  std::vector<uint8_t> buffer(config.bit_width * config.num_values / 8 * 2);
+  double estimator_time_ns = 0.0;
+  double encoder_time_ns = 0.0;
+  for (int i = 0; i < config.num_iterations; ++i) {
+    SCOPED_TRACE(Message() << "repetition = " << i);
+    const auto data = GenerateRleTestData(config, i);
+    const auto batches = GenerateBatchs(data, config.batch_size);
+    const auto t1 = std::chrono::high_resolution_clock::now();
+    RleSizeEstimator<int> estimator(config.bit_width);
+    uint64_t estimate = 0;
+    for (const auto batch : batches) {
+      estimator.Append(batch);
+      estimator.Flush();
+      estimate = estimator.estimate();
+    }
+    const auto t2 = std::chrono::high_resolution_clock::now();
+    int32_t actual = 0;
+    for (size_t batch_end = 0; batch_end < batches.size(); ++batch_end) {
+      ::arrow::util::RleEncoder encoder(buffer.data(), static_cast<int>(buffer.size()),
+                                        config.bit_width);
+      for (size_t batch_idx = 0; batch_idx <= batch_end; ++batch_idx) {
+        for (const auto v : batches[batch_idx]) {
+          ASSERT_TRUE(encoder.Put(v));
+        }
+      }
+      encoder.Flush();
+      actual = encoder.len();
+    }
+    const auto t3 = std::chrono::high_resolution_clock::now();
+    CheckAccuracy(estimate, actual, config.expected_max_error);
+    estimator_time_ns += (t2 - t1).count();
+    encoder_time_ns += (t3 - t2).count();
+  }
+  estimator_time_ns /= config.num_iterations;
+  encoder_time_ns /= config.num_iterations;
+  EXPECT_THAT(estimator_time_ns, Le(encoder_time_ns));
+  const auto speed_up = 1 - estimator_time_ns / encoder_time_ns;
+  std::cout << "estimator_time_ns = " << estimator_time_ns
+            << ", encoder_time_ns = " << encoder_time_ns << ", speed_up = " << speed_up
+            << std::endl;
+}
+
+TEST(TestRleSizeEstimator, PerformanceBitWidth22) {
+  TestPerformance({10, 22, 10000000, 5000, 1000, {}, {}, 0.05, 0, 1000000});
+}
+
+}  // namespace test
+}  // namespace shuffle
+}  // namespace parquet
diff --git a/cpp/src/parquet/shuffle/util/exception.h b/cpp/src/parquet/shuffle/util/exception.h
new file mode 100644
index 0000000000..da0fb3038f
--- /dev/null
+++ b/cpp/src/parquet/shuffle/util/exception.h
@@ -0,0 +1,54 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include "arrow/status.h"
+#include "parquet/exception.h"
+
+namespace parquet {
+namespace shuffle {
+
+template <typename Func>
+class ExceptionStatusWrapper {
+ public:
+  explicit ExceptionStatusWrapper(Func&& func) : func_(std::move(func)) {}
+
+  template <typename... Args>
+  ::arrow::Status operator()(Args&&... args) noexcept {
+    // ::arrow::Status::<exception type>(<msg>) can throw because it allocates
+    // memory for the message.
+    try {
+      func_(std::forward<Args>(args)...);
+      return ::arrow::Status::OK();
+    } catch (parquet::ParquetStatusException& e) {
+      // Should move, because copy can throw
+      return std::move(e.status());
+    } catch (const std::bad_alloc& e) {
+      try {
+        return ::arrow::Status::OutOfMemory(e.what());
+      } catch (const std::exception&) {
+        return ::arrow::Status::OutOfMemory();
+      }
+    } catch (const std::exception& e) {
+      try {
+        return ::arrow::Status::UnknownError(e.what());
+      } catch (const std::exception&) {
+        return ::arrow::Status::UnknownError();
+      }
+    }
+  }
+
+ private:
+  Func func_;
+};
+
+// Returns a wrapper function that catches an exception and returns an
+// appropriate ::arrow::Status for the exception. If no exception is thrown,
+// it returns ::arrow::Status::OK().
+template <typename Func>
+ExceptionStatusWrapper<Func> MakeExceptionStatusWrapper(Func&& func) {
+  return ExceptionStatusWrapper<Func>{std::forward<Func>(func)};
+}
+
+}  // namespace shuffle
+}  // namespace parquet
