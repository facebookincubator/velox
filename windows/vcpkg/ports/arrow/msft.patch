+// NOLINT legal/copyright
+
+#pragma once
+
+#include "parquet/shuffle/column_data.h"
+#include "parquet/shuffle/util/span.h"
+
+namespace parquet {
+namespace shuffle {
+
+/// Analyze the columns and return a permutation vector that can be used to reorder the
+/// rows. Reordering rows can improve compression.
+class ShuffleAlgorithm {
+ public:
+  virtual ~ShuffleAlgorithm() {}
+
+  /// Analyzes the data and write a permutation sequence to the given buffer.
+  /// `permutation[i] = j` means moving a row at `j` to `i`. The implementation should
+  /// write a valid permutation sequence to the given buffer. The number of
+  /// rows in the data is the same as the size of the buffer.
+  ///
+  /// The algorithm may reorder column data passed to it during its run, and the resulting
+  /// permutation vector is for the columns that are passed to the algorithm. For columns
+  /// that are not passed to the algorithm, it must produce another permutation vector and
+  /// store it to `complete_permutation`. If the algorithm doesn't reorder data and
+  /// complete_permutation should be the same as permutation, it should assign an empty
+  /// span to complete_permutation. If an empty span is passed to `complete_permutation`
+  /// by the caller, then it means all columns have been passed to this function and there
+  /// is no need to build a separate total permutation vector.
+  ///
+  /// @param columns Input data
+  /// @param permutation Buffer where the permutation sequence will be written
+  /// @param complete_permutation Permutation for columns that were not passed to the
+  ///   algorithm
+  /// @return true if permutation is needed, false otherwise
+  virtual bool Apply(Span<ColumnData> columns, Span<int32_t> permutation,
+                     Span<int32_t>& complete_permutation) = 0;
+};
+
+}  // namespace shuffle
+}  // namespace parquet
