+struct ParquetFileReaderSliceRange {
+  int row_group_offset;
+  int row_group_count;  // 0 means unlimited
+  int64_t row_offset;
+  int64_t row_count;         // 0 means unlimited
+  std::vector<int> columns;  // empty means all
+};
+
+PARQUET_EXPORT
+std::ostream& operator<<(std::ostream& os, const ParquetFileReaderSliceRange& range);
+
+class PARQUET_EXPORT ParquetFileReaderSlice {
+ public:
+  static ParquetFileReaderSliceRange All;
+
+  static std::unique_ptr<ParquetFileReaderSlice> OpenFile(
+      std::string uri_or_path, const ParquetFileReaderSliceRange& range = All,
+      bool metadata_only = false);
+
+  static std::unique_ptr<ParquetFileReaderSlice> OpenFiles(
+      const std::vector<std::string>& uri_or_paths,
+      const ParquetFileReaderSliceRange& range = All, bool metadata_only = false,
+      ::arrow::internal::Executor* executor = nullptr);
+
+  /// Create a slice view of a Parquet file or a concatenation of multiple Parquet files.
+  ///
+  /// @param files Parquet files to read
+  /// @param pre_buffer Use PreBuffer() to improve performance for high-latency
+  ///   filesystems
+  /// @param range Used to select subset of the data
+  ParquetFileReaderSlice(std::vector<std::shared_ptr<ParquetFileReader>> files,
+                         const ParquetFileReaderSliceRange& range = All,
+                         bool metadata_only = false, bool pre_buffer = false);
+
+  ParquetFileReaderSlice(ParquetFileReaderSlice&& rhs);
+
+  ParquetFileReaderSlice& operator=(ParquetFileReaderSlice&& rhs);
+
+  ~ParquetFileReaderSlice();
+
+  bool empty() const;
+
+  int num_columns() const;
+
+  const std::vector<int>& columns() const;
+
+  int num_row_groups() const;
+
+  int64_t num_rows() const;
+
+  const SchemaDescriptor& schema() const;
+
+  std::vector<std::shared_ptr<const ::arrow::KeyValueMetadata>> key_value_metadata()
+      const;
+
+  struct RowGroupSlice {
+    int row_group_index;
+    std::shared_ptr<ParquetFileReader> reader;
+    std::shared_ptr<RowGroupReader> row_group;
+    int64_t row_offset;
+    int64_t row_count;
+  };
+
+  bool HasNextRowGroup() const;
+
+  RowGroupSlice NextRowGroup();
+
+  struct RowGroupSliceMetaData {
+    std::unique_ptr<const RowGroupMetaData> metadata;
+    int64_t row_offset;
+    int64_t row_count;
+  };
+
+  RowGroupSliceMetaData RowGroupMetadata(int i) const;
+
+ private:
+  class Impl;
+  std::unique_ptr<Impl> impl_;
+};
+
+PARQUET_EXPORT
+void Skip(ColumnReader& col_reader, int64_t row_offset);
+
