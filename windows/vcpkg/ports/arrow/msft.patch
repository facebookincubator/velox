+class TestConcurrentRowGroupWriters : public ::testing::Test {
+ public:
+  bool enable_shuffle = false;
+
+  std::unique_ptr<ParquetFileWriter> GetFileWriter(
+      std::shared_ptr<::arrow::io::OutputStream> sink) {
+    parquet::WriterProperties::Builder props_builder;
+    props_builder.enable_concurrent_row_group_writer();
+    if (enable_shuffle) {
+      props_builder.enable_shuffle();
+      auto shuffle_props = std::make_shared<shuffle::VorderShuffleProperties>();
+      // Make shuffle work for small dataset
+      shuffle_props->min_pure_frequency = 0;
+      shuffle_props->min_pure_bits = 0;
+      shuffle_props->min_pure_size = 0;
+      shuffle_props->min_partition_size = 0;
+      shuffle_props->min_partition_density = 1;
+      props_builder.shuffle_algorithm_properties(shuffle_props);
+    }
+    auto writer_props = props_builder.build();
+    schema::NodeVector fields;
+    fields.push_back(
+        PrimitiveNode::Make("col", parquet::Repetition::REQUIRED, parquet::Type::INT32));
+    auto schema = std::static_pointer_cast<GroupNode>(
+        GroupNode::Make("schema", Repetition::REQUIRED, fields));
+    return parquet::ParquetFileWriter::Open(sink, schema, writer_props);
+  }
+
+  void WriteValues(RowGroupWriter* rg_writer, std::vector<int> values) {
+    auto col_writer = static_cast<Int32Writer*>(rg_writer->column(0));
+    col_writer->WriteBatch(values.size(), nullptr, nullptr, values.data());
+  }
+
+  std::vector<std::vector<int>> GetValues(std::shared_ptr<Buffer> buffer) {
+    auto source = std::make_shared<::arrow::io::BufferReader>(buffer);
+    auto file_reader = ParquetFileReader::Open(source);
+    const auto num_row_groups = file_reader->metadata()->num_row_groups();
+    std::vector<std::vector<int>> values;
+    for (int i = 0; i < num_row_groups; ++i) {
+      auto rg_reader = file_reader->RowGroup(i);
+      auto col_reader =
+          std::static_pointer_cast<TypedColumnReader<Int32Type>>(rg_reader->Column(0));
+      values.emplace_back();
+      const auto num_rows = rg_reader->metadata()->num_rows();
+      values.back().resize(num_rows);
+      Read(col_reader.get(), num_rows, values.back().data());
+    }
+    return values;
+  }
+
+  void Read(TypedColumnReader<Int32Type>* col_reader, int64_t num_rows, int* out) {
+    while (num_rows > 0) {
+      int64_t values_read;
+      col_reader->ReadBatch(num_rows, nullptr, nullptr, out, &values_read);
+      num_rows -= values_read;
+      out += values_read;
+    }
+  }
+
+  std::vector<std::vector<int>> WriteValuesAndReadBack(
+      std::vector<std::vector<int>> values,
+      std::function<void(std::vector<RowGroupWriter*>&)> closer) {
+    auto sink = CreateOutputStream();
+    auto file_writer = GetFileWriter(sink);
+    std::vector<RowGroupWriter*> rg_writers;
+    for (size_t i = 0; i < values.size(); ++i) {
+      rg_writers.emplace_back(file_writer->AppendBufferedRowGroup());
+    }
+    std::vector<std::thread> threads;
+    threads.reserve(values.size());
+    auto write_values = [&](size_t i) { WriteValues(rg_writers[i], values[i]); };
+    for (size_t i = 0; i < values.size(); ++i) {
+      threads.emplace_back(write_values, i);
+    }
+    for (auto& thread : threads) {
+      thread.join();
+    }
+    closer(rg_writers);
+    file_writer->Close();
+    PARQUET_ASSIGN_OR_THROW(auto buffer, sink->Finish());
+    return GetValues(buffer);
+  }
+};
