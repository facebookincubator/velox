+  EXPECT_THAT(v.type_length(), 2);
+  EXPECT_THAT(v.values2(), ElementsAre());
+  EXPECT_THAT(v.capacity(), 3);
+  v.push_back(1);
+  v.push_back(2);
+  v.push_back(3);
+  v.push_back(4);
+  EXPECT_THAT(v.values2(), ElementsAre(1, 2, 3, 4));
+}
