new file mode 100644
index 0000000000..3080ff05df
--- /dev/null
+++ b/ci/pipelines/templates/stages-build-and-test-windows.yml
@@ -0,0 +1,200 @@
+# This Yaml Document has been converted by ESAI Yaml Pipeline Conversion Tool.
+# Please make sure to check all the converted content, it is your team's responsibility to make sure that the pipeline is still valid and functions as expected.
+parameters:
+  - name: compiler
+  - name: buildType
+    type: string
+    values:
+      - Debug
+      - Release
+      - RelWithDebInfo
+  - name: platform
+  - name: preset
+    default: trident-windows
+
+stages:
+  - stage: Build_${{ parameters.compiler }}_${{ parameters.buildType }}_${{ parameters.platform }}
+    dependsOn: []
+    variables:
+      - name: BUILD_NAME
+        value: ${{ parameters.compiler }}_${{ parameters.buildType }}_${{ parameters.platform }}
+    jobs:
+      - job: Build
+        timeoutInMinutes: 300
+        pool:
+          type: windows
+        variables:
+          - name: SourceArtifactsFolder
+            value: '$(Build.SourcesDirectory)\target\artifacts'
+
+          # Onebranch variables
+          - name: ob_outputDirectory
+            value: '$(Build.SourcesDirectory)\cpp\build\${{ parameters.buildType }}'
+          - name: ob_nugetPublishing_enabled
+            value: true
+          - name: NTSIGN_WATCHER_TIMEOUT_IN_SECONDS
+            value: 86400
+          - name: OBP_SIGNING_SETUP_TIMEOUT_IN_SECONDS
+            value: 1800
+
+          # Build variables
+          - name: ADDITIONAL_COMPILER_FLAGS
+            value: /guard:cf /ZH:SHA_256 /Qspectre /W3
+          - name: ADDITIONAL_LINKER_FLAGS
+            value: /guard:cf
+          - name: BUILD_DIRECTORY
+            value: $(Build.SourcesDirectory)\cpp\build
+          - name: VCPKG_OVERLAY_TRIPLETS
+            value: $(Build.SourcesDirectory)\ci\vcpkg
+          - name: VCPKG_OVERLAY_PORTS
+            value: $(Build.SourcesDirectory)\ci\vcpkg\overlayPorts
+
+          # Signing Variables
+          # Please the following links for the details (or search in eng.ms for '135020002' and '230012'):
+          #  - https://eng.ms/docs/products/onebranch/signing/containerbuildsigning/supportedfileextensions
+          #  - https://eng.ms/docs/products/onebranch/signing/containerbuildsigning/availablesigningcpcodesandoperations
+          - name: SIGNING_PROFILE
+            value: internal_azure_service
+          - name: SIGNING_CP_CODE
+            value: '135020002'                  
+
+        steps:
+          - task: PowerShell@2
+            inputs:
+              targetType: 'inline'
+              script: |
+                Set-PSDebug -Trace 1
+                New-Item -Path  "$(BUILD_DIRECTORY)" -ItemType Directory
+                Set-Location -Path  "$(BUILD_DIRECTORY)"
+                curl https://github.com/electron/rcedit/releases/download/v2.0.0/rcedit-x64.exe -L -o rcedit.exe
+              pwsh: true
+            displayName:  Install rcedit
+
+          - task: NuGetToolInstaller@1
+            displayName: Install NuGet
+            inputs:
+              versionSpec: '>=6.5'
+
+          - task: NuGetAuthenticate@1
+
+          - script: |
+              git clone https://github.com/Microsoft/vcpkg.git \usr\local\share\vcpkg
+              cd \usr\local\share\vcpkg
+              dir
+              cmd /c bootstrap-vcpkg.bat
+              git checkout 1de2026f28ead93ff1773e6e680387643e914ea1
+              vcpkg x-update-baseline "--x-manifest-root=$(SOURCE_DIR)"
+            displayName: Setup vcpkg
+
+          - task: PowerShell@2
+            inputs:
+              targetType: 'inline'
+              script: |
+                Set-PSDebug -Trace 1
+                echo on
+                git diff --no-index $(VCPKG_OVERLAY_PORTS)\orc $(Resolve-Path \usr\local\share\vcpkg\ports\orc)
+                # git diff exits with exit code != 0 if diff is not empty
+                exit 0
+              pwsh: true
+            displayName: Visualizing orc overlay port diff
+
+          - script: |
+              @echo on
+              dir "$(SOURCE_DIR)"
+              cd "$(SOURCE_DIR)"
+              cmake -B "$(BUILD_DIRECTORY)" -S . --preset ${{ parameters.preset }} ^
+                -DCMAKE_BUILD_TYPE=${{ parameters.buildType }} ^
+                -DCMAKE_TOOLCHAIN_FILE="\usr\local\share\vcpkg\scripts\buildsystems\vcpkg.cmake" ^
+                -DCMAKE_CXX_FLAGS="${{ variables.ADDITIONAL_COMPILER_FLAGS }}" ^
+                -DCMAKE_C_FLAGS="${{ variables.ADDITIONAL_COMPILER_FLAGS }}" ^
+                --log-level=VERBOSE
+            env:
+              CFLAGS: $(ADDITIONAL_COMPILER_FLAGS)
+              CXXFLAGS: $(ADDITIONAL_COMPILER_FLAGS)
+              LDFLAGS: $(ADDITIONAL_LINKER_FLAGS)
+            displayName: Init build
+            continueOnError: true
+
+          - task: PowerShell@2
+            inputs:
+              targetType: 'inline'
+              script: |
+                Write-Host "Build failed, displaying last 1000 lines of log file"
