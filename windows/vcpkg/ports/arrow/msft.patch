+template <typename DataType>
+void prepareValues(Vec<typename DataType::c_type>& values, CircularMemoryStream& cmbf,
+                   Vec<std::unique_ptr<::arrow::Buffer>>& buffers) {
+  using c_type = typename DataType::c_type;
+  cmbf.ReadByteArray(reinterpret_cast<uint8_t*>(values.data()),
+                     sizeof(c_type) * values.size());
+}
+
+template <>
+void prepareValues<parquet::BooleanType>(Vec<bool>& values, CircularMemoryStream& cmbf,
+                                         Vec<std::unique_ptr<::arrow::Buffer>>& buffers) {
+  const auto data = reinterpret_cast<uint8_t*>(values.data());
+  const auto size = values.size();
+  cmbf.ReadByteArray(data, sizeof(bool) * size);
+  std::transform(data, data + size, values.begin(),
+                 [](const uint8_t v) { return static_cast<bool>(v & 1); });
+}
+
+uint32_t readLen(CircularMemoryStream& cmbf) {
+  uint32_t len;
+  cmbf.ReadByteArray(reinterpret_cast<uint8_t*>(&len), sizeof(len));
+  // TODO: Revisit
+  return len % 100;
+}
+
+size_t getByteArraysTotalLength(CircularMemoryStream cmbf, size_t num_values) {
+  size_t result = 0;
+  for (; num_values > 0; num_values--) {
+    auto len = readLen(cmbf);
+    result += len;
+    cmbf.SkipBytes(len);
+  }
+  return result;
+}
+
+template <>
+void prepareValues<parquet::ByteArrayType>(
+    Vec<parquet::ByteArray>& values, CircularMemoryStream& cmbf,
+    Vec<std::unique_ptr<::arrow::Buffer>>& buffers) {
+  size_t totalArraysLength =
+      getByteArraysTotalLength(CircularMemoryStream(cmbf), values.size());
+  PARQUET_ASSIGN_OR_THROW(auto buffer, ::arrow::AllocateBuffer(totalArraysLength));
+  buffers.emplace_back(std::move(buffer));
+  auto currentPtr = buffers.back().get()->mutable_data();
+
+  for (auto& v : values) {
+    auto len = readLen(cmbf);
+    v.len = len;
+    v.ptr = currentPtr;
+    ASSERT_LE(currentPtr + len,
+              buffers.back().get()->mutable_data() + buffers.back().get()->size());
+
+    cmbf.ReadByteArray(currentPtr, len);
+    currentPtr += len;
+    ASSERT_LE(currentPtr,
+              buffers.back().get()->mutable_data() + buffers.back().get()->size());
+  }
+}
+
+template <>
+void prepareValues<parquet::Int96Type>(Vec<parquet::Int96>& values,
+                                       CircularMemoryStream& cmbf,
+                                       Vec<std::unique_ptr<::arrow::Buffer>>& buffers) {
+  for (auto& v : values) {
+    cmbf.ReadByteArray(reinterpret_cast<uint8_t*>(v.value), sizeof(v.value));
+  }
+}
+
+template <typename DataType>
+void prepareValues(Vec<typename DataType::c_type>& values, CircularMemoryStream& cmbf,
+                   Vec<std::unique_ptr<::arrow::Buffer>>& buffers, const int len) {
+  prepareValues<DataType>(values, cmbf, buffers);
+}
+
+template <>
+void prepareValues<parquet::FLBAType>(Vec<parquet::FixedLenByteArray>& values,
+                                      CircularMemoryStream& cmbf,
+                                      Vec<std::unique_ptr<::arrow::Buffer>>& buffers,
+                                      const int len) {
+  ASSERT_GE(len, 0);
+  PARQUET_ASSIGN_OR_THROW(auto buffer, ::arrow::AllocateBuffer(len * values.size()));
+
+  buffers.emplace_back(std::move(buffer));
+
+  auto currentPtr = buffers.back().get()->mutable_data();
+
+  for (auto& v : values) {
+    cmbf.ReadByteArray(currentPtr, len);
+    v.ptr = currentPtr;
+    currentPtr += len;
+    ASSERT_LE(currentPtr,
+              buffers.back().get()->mutable_data() + buffers.back().get()->size());
+  }
+}
+
+template <typename DataType>
+int64_t WriteBatch(parquet::TypedColumnWriter<DataType>* col_writer,
+                   const Vec<def_levels_t>& def_levels,
+                   const Vec<rep_levels_t>& rep_levels,
+                   const Vec<typename DataType::c_type>& values,
+                   const bool drop_def_levels, const bool drop_rep_levels) {
+  return col_writer->WriteBatch(
+      def_levels.size(), drop_def_levels ? nullptr : def_levels.data(),
+      drop_rep_levels ? nullptr : rep_levels.data(), values.data());
+}
+
+/// @brief Only for debugging purposes. These values are not supposed to be read.
+/// @tparam DataType DataType
+/// @param cnt cnt
+/// @return defaultValue
+template <typename DataType>
+typename DataType::c_type defaultValue(size_t cnt) {
+  return typename DataType::c_type();
+}
+
+template <>
+typename parquet::Int32Type::c_type defaultValue<typename parquet::Int32Type>(
+    size_t cnt) {
+  return static_cast<int>(cnt + 700);
+}
+
+int16_t ComputeRepeatedAncestorDefLevel(const ColumnDescriptor* descr) {
+  int16_t min_spaced_def_level = descr->max_definition_level();
+  const auto* node = descr->schema_node().get();
+  while (node != nullptr && !node->is_repeated()) {
+    if (node->is_optional()) {
+      min_spaced_def_level--;
+    }
+    node = node->parent();
+  }
+  return min_spaced_def_level;
+}
+
+template <typename DataType>
+void WriteBatchSpaced(parquet::TypedColumnWriter<DataType>* col_writer,
+                      const Vec<def_levels_t>& def_levels,
+                      const Vec<rep_levels_t>& rep_levels,
+                      const Vec<typename DataType::c_type>& values,
+                      const bool drop_def_levels, const bool drop_rep_levels,
+                      def_levels_t max_def_level) {
+  // using c_type = typename DataType::c_type;
+
+  Vec<typename DataType::c_type> spaced_values;
+  spaced_values.reserve(def_levels.size());
+  Vec<uint8_t> valid_bits;
+  valid_bits.resize(::arrow::bit_util::BytesForBits(def_levels.size()), 0);
+
+  const auto repeated_ancestor_def_level =
+      ComputeRepeatedAncestorDefLevel(col_writer->descr());
+  size_t values_cnt = 0;
+  for (auto& dl : def_levels) {
+    if (dl == max_def_level) {
+      ::arrow::bit_util::SetBit(valid_bits.data(), spaced_values.size());
+      spaced_values.emplace_back(values.at(values_cnt++));
+    } else if (dl >= repeated_ancestor_def_level) {
+      spaced_values.emplace_back(defaultValue<DataType>(spaced_values.size()));
+    }
+  }
+
+  ASSERT_EQ(values_cnt, values.size());
+
+  col_writer->WriteBatchSpaced(def_levels.size(),
+                               drop_def_levels ? nullptr : def_levels.data(),
+                               drop_rep_levels ? nullptr : rep_levels.data(),
+                               valid_bits.data(), 0, spaced_values.data());
+}
+
+template <typename DataType>
+void WriteBatch(const size_t col_index, RowGroupAggregator& agg, const RawBatch batch,
+                Vec<std::unique_ptr<::arrow::Buffer>>& buffers,
+                parquet::TypedColumnWriter<DataType>* col_writer,
+                DataPointers data_pointers) {
+  using c_type = typename DataType::c_type;
+
+  if (batch.num_rows == 0) {
+    return;
+  }
+
+  auto col_descr = col_writer->descr();
+
+  const auto max_def_level = col_descr->max_definition_level();
+  const auto max_rep_level = col_descr->max_repetition_level();
+
+  // Each rep_level of 0 corresponds to a value instance. All columns within a group
+  // must have equal rep_lelel zeroes.
+  Vec<rep_levels_t> rep_levels(batch.num_rows, 0);
+  if (!batch.drop_rep_levels && max_rep_level != 0) {
+    data_pointers.rep_levels.ReadByteArray(
+        reinterpret_cast<uint8_t*>(rep_levels.data() + 1),
+        sizeof(rep_levels_t) * (batch.num_rows - 1));
+    size_t rep_levels_padding = batch.num_rows;
+    for (rep_levels_t& rl : rep_levels) {
+      rl = std::abs(rl) % (max_rep_level + 1);
+      if (rl == 0) {
+        rep_levels_padding--;
+      }
+    }
+    // Padding missing rep_lelev zeroes to meet the total number.
+    rep_levels.resize(rep_levels_padding + rep_levels.size(), 0);
+  }
+
+  Vec<def_levels_t> def_levels(rep_levels.size(), max_def_level);
+  if (!batch.drop_def_levels && max_def_level != 0) {
+    data_pointers.def_levels.ReadByteArray(reinterpret_cast<uint8_t*>(def_levels.data()),
+                                           sizeof(def_levels_t) * def_levels.size());
+  }
+
+  // the total level of phusical values provided must be equal to number of occurances
+  // of max_ def_level values in dev_levels array.
+  size_t values_to_write = 0;
+  for (def_levels_t& dl : def_levels) {
+    dl = std::abs(dl) % (max_def_level + 1);
+    if (dl == max_def_level) {
+      values_to_write++;
+    }
+  }
+
+  auto flba_len = col_descr->type_length();
+  Vec<c_type> values(values_to_write);
+  prepareValues<DataType>(values, data_pointers.values, buffers, flba_len);
+
+  if (batch.spaced_write) {
+    WriteBatchSpaced(col_writer, def_levels, rep_levels, values, batch.drop_def_levels,
+                     batch.drop_rep_levels, max_def_level);
+  } else {
+    auto written = WriteBatch(col_writer, def_levels, rep_levels, values,
+                              batch.drop_def_levels, batch.drop_rep_levels);
+    ASSERT_EQ(written, static_cast<int64_t>(values_to_write));
+  }
+  agg.SubmitBatch<DataType, true>(col_index, def_levels, rep_levels, values);
+}
+
+template <typename DataType>
+void WriteColumn(const size_t col_index, RowGroupAggregator& agg,
+                 const Vec<RawBatch>& batches,
+                 Vec<std::unique_ptr<::arrow::Buffer>>& buffers,
+                 parquet::ColumnWriter* non_typed_col_writer, DataPointers data_pointers,
+                 size_t values_to_write) {
+  constexpr auto type = DataType::type_num;
+  ASSERT_EQ(non_typed_col_writer->type(), type);
+
+  parquet::TypedColumnWriter<DataType>* col_writer =
+      static_cast<parquet::TypedColumnWriter<DataType>*>(non_typed_col_writer);
+
+  for (const auto& n : batches) {
+    try {
+      ValidateBatch(n, non_typed_col_writer->descr());
+    } catch (const std::exception& e) {
+      std::throw_with_nested(e);
+    }
+
+    WriteBatch<DataType>(col_index, agg, n, buffers, col_writer, data_pointers);
+    values_to_write -= n.num_rows;
+  }
+
+  // Padding additional values to meet the total number to be values_to_write
+  // argument.
+  if (values_to_write > 0) {
+    WriteBatch<DataType>(col_index, agg, RawBatch(values_to_write, false, false, false),
+                         buffers, col_writer, data_pointers);
+  }
+}
