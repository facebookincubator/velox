+namespace internal {
+
+void ValidateBatch(const RawBatch& batch, const ColumnDescriptor* col_descriptor) {
+  if (col_descriptor->max_definition_level() > 1 && batch.spaced_write) {
+    throw UnsupportedTestScenarioError(
+        "Spaced writes tests are not supported for nested fields.");
+  }
+
+  if (col_descriptor->max_definition_level() == 0 && batch.spaced_write &&
+      !batch.drop_def_levels) {
+    throw UnsupportedTestScenarioError(
+        "def_levels must be null in WriteBatchSpaced if max_definition_level is "
+        "zero.");
+  }
+
+  if (col_descriptor->max_definition_level() > 0 && batch.drop_def_levels) {
+    throw UnsupportedTestScenarioError(
+        "def_levels must not be null in WriteBatch[Spaced] if max_definition_level "
+        "is greater than zero.");
+  }
+
+  if (col_descriptor->max_repetition_level() > 0 && batch.drop_rep_levels) {
+    throw UnsupportedTestScenarioError(
+        "rep_levels must not be null in WriteBatch[Spaced] if max_repetition_level "
+        "is greater than zero.");
+  }
+}
