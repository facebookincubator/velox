+  // reference code RleDecoder::GetBatch
+  DCHECK_GE(bit_width_, 0);
+  int values_read = 0;
+
+  while (values_read < batch_size) {
+    int remaining = batch_size - values_read;
+
+    if (repeat_count_ > 0) {  // Repeated value case.
+      int repeat_batch = std::min(remaining, repeat_count_);
+      repeat_count_ -= repeat_batch;
+      values_read += repeat_batch;
+      visitor.VisitConstantRange(static_cast<int32_t>(current_value_), repeat_batch);
+    } else if (literal_count_ > 0) {
+      const int literal_batch = std::min(remaining, literal_count_);
+      bit_reader_.PackedEnumerate(bit_width_, literal_batch, visitor);
+      literal_count_ -= literal_batch;
+      values_read += literal_batch;
+    } else if (!NextCounts<int32_t>()) {
+      return values_read;
+    }
+  }
+
+  return values_read;
+}
