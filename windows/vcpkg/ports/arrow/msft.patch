+    for (int i = 0; static_cast<size_t>(i) < leaves_.size(); ++i) {
+      const int field_id = Column(i)->schema_node().get()->field_id();
+      if (field_id >= 0) {
+        field_id_to_idx_.emplace(field_id, i);
+      }
+    }
+
+    field_id_to_idx_initialized_ = true;
+  });
+}
