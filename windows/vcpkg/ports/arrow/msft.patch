+#pragma once
+
+#include "dictionary_test_util.h"
+#include "parquet/properties.h"
+#include "parquet/test_e2e_util.h"
+#include "parquet/types.h"
+
+namespace parquet {
+namespace shuffle {
+namespace fuzz {
+
+using ::parquet::test::Vec;
+
+using num_rowgroups_t = uint8_t;
+using num_batch_rows_t = uint8_t;
+using num_batches_t = uint8_t;
+using num_columns_t = uint8_t;
+
+static const num_batches_t NUM_BATCHES_MASK = 0xf;
+static const num_batch_rows_t NUM_BATCH_ROWS_MASK = 0xf;
+static const num_rowgroups_t NUM_ROW_GROUPS_MASK = 0b1111;
+static const num_columns_t NUM_COLUMNS_MASK = 0b1111;
+
+static Vec<parquet::Type::type> SUPPORTED_TYPES = {
+    parquet::Type::INT32,      parquet::Type::BOOLEAN,
+    parquet::Type::INT64,      parquet::Type::INT96,
+    parquet::Type::FLOAT,      parquet::Type::DOUBLE,
+    parquet::Type::BYTE_ARRAY, parquet::Type::FIXED_LEN_BYTE_ARRAY};
+
+/// @brief VaryingLenghtUint32 Represents uint32_t with improved homogenious (not uniform
+/// though) distribution of small and big number in terms for highest bit set. Without
+/// masking the length low values have very slow chance to appear.
+/// @tparam max_len_bits_width max_len_bits_width
+template <uint8_t max_len_bits_width>
+struct VaryingLenghtUint32 {
+  static_assert(max_len_bits_width > 0, "max_len_bits_width must be positive");
+  static_assert(max_len_bits_width <= 32, "max_len_bits_width must not exceed 32");
+
+ private:
+  static constexpr int unit32_t_bits = sizeof(uint32_t) * 8;
+  static constexpr uint32_t GenerateBitMask(int b) {
+    return b ? (~0u) >> (unit32_t_bits - b) : 0;
+  }
+
+  static_assert(GenerateBitMask(1) == 1, "GenerateBitMask(1) == 1");
+  static_assert(GenerateBitMask(2) == 0b11, "GenerateBitMask(2) == 0b11");
+  static_assert(GenerateBitMask(31) == 0x7fffffff, "GenerateBitMask(31) == 0x7fffffff");
+  static_assert(GenerateBitMask(32) == 0xffffffff, "GenerateBitMask(32) == 0xffffffff");
+
+  uint_fast8_t length : 6;
+  uint32_t value;
+
+ public:
+  uint32_t operator()() const {
+    return GenerateBitMask(length % max_len_bits_width) & value;
+  }
+  void operator=(uint32_t value) {
+    this->value = value;
+    this->length = max_len_bits_width - 1;
+  }
+};
+
+struct FuzzRawColumn {
+  parquet::Type::type GetType() const {
+    return SUPPORTED_TYPES.at(type % SUPPORTED_TYPES.size());
+  }
+
+  uint8_t GetFlbaLength() const {
+    auto result = (flba_len & 0b11);
+    return result == 0 ? 1 : result;
+  }
+
+  uint16_t def_levels_offset;
+  uint16_t rep_levels_offset;
+  uint16_t values_offset;
+  /// @brief Each 2 bits represent @ref parquet::Repetition
+  uint8_t rep_spec;
+
+  //  private:
+  uint8_t type;
+  uint8_t flba_len;
+};
+
+struct FuzzRawBatch {
+ public:
+  FuzzRawBatch(num_batch_rows_t num_rows, bool write_spaced, bool drop_def_levels,
+               bool drop_rep_levels)
+      : num_rows(num_rows),
+        write_spaced(write_spaced),
+        drop_def_levels(drop_def_levels),
+        drop_rep_levels(drop_rep_levels) {}
+
+  num_batch_rows_t GetNumRows() const {
+    return static_cast<num_batch_rows_t>(num_rows & NUM_BATCH_ROWS_MASK);
+  }
+  void SetNumRows(num_batch_rows_t num_rows) { this->num_rows = num_rows; }
+
+  bool GetWriteSpaced() const { return static_cast<bool>(write_spaced & uint8_t(1)); }
+  bool GetDropDefLevels() const {
+    return static_cast<bool>(drop_def_levels & uint8_t(1));
+  }
+  bool GetDropREpLevels() const {
+    return static_cast<bool>(drop_rep_levels & uint8_t(1));
+  }
+
+ private:
+  num_batch_rows_t num_rows;
+  bool write_spaced : 1;
+  bool drop_def_levels : 1;
+  bool drop_rep_levels : 1;
+};
+
+struct FuzzRawMetadata {
+ public:
+  num_rowgroups_t GetRowGroupCount() const { return num_rowgroups & NUM_ROW_GROUPS_MASK; }
+  void SetRowGroupCount(const num_rowgroups_t& num_rowgroups) {
+    this->num_rowgroups = num_rowgroups;
+  }
+
+  num_columns_t GetColumnsCount() const { return num_columns & NUM_COLUMNS_MASK; }
+  void SetColumnsCount(const num_columns_t& num_columns) {
+    this->num_columns = num_columns;
+  }
+
+  bool GetEnableDictionary() const { return static_cast<bool>(enable_dictionary & 0b1); }
+  void SetEnableDictionary(const bool& enable_dictionary) {
+    this->enable_dictionary = enable_dictionary;
+  }
+
+  uint32_t GetDictionaryPageSizeLimit() const { return dictinary_page_size_limit(); }
+  void SetDictionaryPageSizeLimit(uint32_t dictinary_page_size_limit) {
+    this->dictinary_page_size_limit = dictinary_page_size_limit;
+  }
+
+  parquet::ParquetDataPageVersion GetParquetDataPageVersion() const {
+    switch (parquet_data_page_version & 0b1) {
+      case 0:
+        return parquet::ParquetDataPageVersion::V1;
+      case 1:
+        return parquet::ParquetDataPageVersion::V2;
+      default:
+        throw std::runtime_error("Unsupported ParquetDataPageVersion.");
+    }
+  }
+  void SetParquetDataPageVersion(uint8_t parquet_data_page_version) {
+    this->parquet_data_page_version = parquet_data_page_version;
+  }
+
+  bool GetEnableShuffle() const { return static_cast<bool>(enable_shuffle & 0b1); }
+  void SetEnableShuffle(const bool& enable_shuffle) {
+    this->enable_shuffle = enable_shuffle;
+  }
+
+  bool GetEnableShuffleAutoEncoding() const {
+    return static_cast<bool>(shuffle_auto_encoding & 0b1);
+  }
+  void SetEnableShuffleAutoEncoding(const bool& shuffle_auto_encoding) {
+    this->shuffle_auto_encoding = shuffle_auto_encoding;
+  }
+
+  uint8_t GetShuffleThreads() const {
+    return static_cast<uint8_t>(shuffle_threads & 0b11);
+  }
+  void SetShuffleThreads(const uint8_t& shuffle_threads) {
+    this->shuffle_threads = shuffle_threads;
+  }
+
+  uint32_t GetshuffleRawEncodingThreadhold() const {
+    return shuffle_raw_encoding_threadhold();
+  }
+  void SetshuffleRawEncodingThreadhold(uint32_t shuffle_raw_encoding_threadhold) {
+    this->shuffle_raw_encoding_threadhold = shuffle_raw_encoding_threadhold;
+  }
+
+  parquet::test::RawMetadata GetRawMetaData() const {
+    return parquet::test::RawMetadata{
+        GetRowGroupCount(),           GetEnableDictionary(),
+        GetDictionaryPageSizeLimit(), GetParquetDataPageVersion(),
+        GetEnableShuffle(),           GetEnableShuffleAutoEncoding(),
+        GetShuffleThreads(),          GetshuffleRawEncodingThreadhold()};
+  }
+
+ private:
+  num_rowgroups_t num_rowgroups;
+  num_columns_t num_columns;
+  VaryingLenghtUint32<32> dictinary_page_size_limit;
+  VaryingLenghtUint32<19> shuffle_raw_encoding_threadhold;
+  uint8_t shuffle_threads : 2;
+  uint8_t parquet_data_page_version : 1;
+  bool enable_dictionary : 1;
+  bool enable_shuffle : 1;
+  bool shuffle_auto_encoding : 1;
+};
+
+}  // namespace fuzz
+}  // namespace shuffle
+}  // namespace parquet
