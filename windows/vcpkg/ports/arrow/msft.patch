diff --git a/ci/pipelines/templates/stages-build-and-test.yml b/ci/pipelines/templates/stages-build-and-test.yml
new file mode 100644
index 0000000000..d9d0b2f524
--- /dev/null
+++ b/ci/pipelines/templates/stages-build-and-test.yml
@@ -0,0 +1,177 @@
+parameters:
+- name: compiler
+- name: cCompiler
+- name: cxxCompiler
+- name: buildType
+- name: platform
+- name: preset
+  default: trident
+- name: packageSuffix
+  default: ''
+- name: skipTest
+  type: boolean
+  default: false
+- name: pool
+  type: object
+  default: null
+- name: extraVariables
+  type: object
+  default: []
+- name: coverage
+  type: boolean
+  default: false
+
+stages:
+- stage: Build_${{ parameters.compiler }}_${{ parameters.buildType }}_${{ parameters.platform }}
+  dependsOn: []
+  ${{ if parameters.pool }}:
+    pool: ${{ parameters.pool }}
+  variables:
+  - name: BUILD_NAME
+    value: ${{ parameters.compiler }}_${{ parameters.buildType }}_${{ parameters.platform }}
+  - ${{ if ne(parameters.packageSuffix, '') }}:
+    - name: PACKAGE_NAME
+      value: $(ARTIFACT_ID)-$(VERSION_FULL)-${{ parameters.packageSuffix }}.tar.gz
+  - ${{ each extraVariable in parameters.extraVariables }}:
+    - ${{ extraVariable }}
+  jobs:
+  - job: Build
+    timeoutInMinutes: 300
+    steps:
+    - script: |
+        cat /etc/os-release
+        echo "Cores: $(nproc)"
+        lscpu
+        echo "Memory: $(free -h | awk '/^Mem:/ {print $2}')"
+        df -h
+        ls -l /usr/bin
+      displayName: Agent info
+    - ${{ if ne(parameters.packageSuffix, '') }}:
+      - script: |
+          sed -i \
+            's/MICROSOFT_VERSION "SNAPSHOT"/MICROSOFT_VERSION "$(RELEASE_VERSION)"/' \
+            "$(SOURCE_DIR)/CMakeLists.txt"
+          cat "$(SOURCE_DIR)/CMakeLists.txt" | grep MICROSOFT_VERSION
+        displayName: Set version
+    - script: |
+        if [ -x "$(command -v tdnf)" ]; then
+          sudo tdnf -y install \
+            build-essential cmake ninja-build flex bison pkg-config curl zip unzip tar ccache boost-devel
+        else
+          sudo apt-get update
+          sudo apt-get install -y \
+            build-essential cmake ninja-build flex bison pkg-config curl zip unzip tar ccache libboost-dev
+          sudo apt-get remove -y liblz4-dev
+        fi
+      displayName: Install packages
+    - task: Cache@2
+      inputs:
+        key: '"ccache" | "$(Agent.OS)" | "$(BUILD_NAME)"'
+        restoreKeys: |
+          "ccache" | "$(Agent.OS)"
+        path: $(CCACHE_DIR)
+      displayName: Cache ccache
+    - script: |
+        if [ ! -d "$(CCACHE_DIR)" ]; then
+          mkdir "$(CCACHE_DIR)"
+        fi
+        ccache -s
+      displayName: Init ccache
+    - task: Cache@2
+      inputs:
+        key: '"vcpkg" | "$(Agent.OS)"'
+        path: $(VCPKG_DEFAULT_BINARY_CACHE)
+      displayName: Cache vcpkg
+    - script: |
+        mkdir -p "$(VCPKG_DEFAULT_BINARY_CACHE)"
+      displayName: Create vcpkg cache dir
+    - script: |
+        mkdir -p "$(VCPKG_DOWNLOADS)"
+        mkdir -p "$(VCPKG_BUILDTREES)"
+        mkdir -p "$(VCPKG_PACKAGES)"
+        ln -s "$(VCPKG_BUILDTREES)" "$(VCPKG_INSTALLATION_ROOT)/buildtrees"
+        ln -s "$(VCPKG_PACKAGES)" "$(VCPKG_INSTALLATION_ROOT)/packages"
+      displayName: Setup vcpkg dirs if needed
+      condition: and(succeeded(), ne(variables.VCPKG_DOWNLOADS, ''))
+    - script: |
+        cd "$(SOURCE_DIR)"
+        cmake -B "$(BUILD_DIR)" -S . --preset ${{ parameters.preset }} \
+          -DCMAKE_BUILD_TYPE=${{ parameters.buildType }} \
+          -DCMAKE_C_COMPILER="$(which ${{ parameters.cCompiler }})" \
+          -DCMAKE_CXX_COMPILER="$(which ${{ parameters.cxxCompiler }})" \
+          -DCMAKE_TOOLCHAIN_FILE="$(VCPKG_INSTALLATION_ROOT)/scripts/buildsystems/vcpkg.cmake"
+      displayName: Init build
+    - script: |
+        for f in $(cat "$(BUILD_DIR)/vcpkg-manifest-install.log" | grep -o '[A-Za-z0-9_/-]*\.log'); do
+          echo "$f";
+          cat "$f";
+        done;
+      condition: failed()
+      displayName: Print logs if vcpkg fails
+    - script: |
+        cd "$(SOURCE_DIR)"
+        cmake --build "$(BUILD_DIR)" --parallel
+      displayName: Run build
+    - script: |
+        ccache -s
+      displayName: ccache stats
+    - script: |
+        cd "$(BUILD_DIR)"
+        tar cvzf "$(Pipeline.Workspace)/$(BUILD_TARBALL_NAME)" \
+          ${{ lower(parameters.buildType) }} CTestTestfile.cmake src \
+          $(find . -name '*.so*')
+      displayName: Make tarball
+    - task: PublishPipelineArtifact@1
+      displayName: Publish build
+      inputs:
+        targetPath: $(Pipeline.Workspace)/$(BUILD_TARBALL_NAME)
+        artifact: Build_$(BUILD_NAME)
+    - ${{ if ne(parameters.packageSuffix, '') }}:
+      - script: |
+          tar cvzf "$(PACKAGE_NAME)" -C "$(BUILD_DIR)/${{ lower(parameters.buildType) }}" \
+            libarrow.so.1500.1.0 libparquet.so.1500.1.0
+        displayName: Make package
+      - task: PublishPipelineArtifact@1
+        displayName: Publish package
+        inputs:
+          targetPath: $(PACKAGE_NAME)
+          artifact: Package_$(BUILD_NAME)
+  - job: Test
+    dependsOn: Build
+    condition: and(succeeded(), ${{ eq(parameters.skipTest, false) }})
+    steps:
+    - checkout: self
+      submodules: true
+    - template: steps-download-build.yml
+      parameters:
+        buildName: $(BUILD_NAME)
+    - bash: |
+        sudo npm install -g azurite
+        sudo mkdir azurite
+        sudo azurite --silent --location azurite --debug azurite\debug.log &
+      displayName: Install Azurite
+    - script: |
+        cd "$(BUILD_DIR)"
+        ctest -E '^arrow-compute-.*' --output-on-failure --force-new-ctest-process
+      displayName: Run tests
+    - ${{ if parameters.coverage }}:
+      - template: steps-coverage-report.yml
+        parameters:
+          executables: $(BUILD_DIR)/debug/*-test
+          artifactName: CoverageReport_$(BUILD_NAME)
+    - task: PublishTestResults@2
+      inputs:
+        testResultsFormat: JUnit
+        testResultsFiles: '*.xml'
+        searchFolder: $(GTEST_OUTPUT_DIR)
+        mergeTestResults: true
+        testRunTitle: $(BUILD_NAME)
+        buildConfiguration: ${{ parameters.buildType }}
+      displayName: Publish test results
+      condition: succeededOrFailed()
+    - task: PublishPipelineArtifact@1
+      displayName: Publish test logs
+      condition: succeededOrFailed()
+      inputs:
+        targetPath: $(BUILD_DIR)/build/test-logs/
+        artifact: TestLogs_$(BUILD_NAME)
diff --git a/ci/pipelines/templates/stages-fuzz.yml b/ci/pipelines/templates/stages-fuzz.yml
