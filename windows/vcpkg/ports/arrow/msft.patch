+// NOLINT legal/copyright
+
+#include "parquet/shuffle/shuffle_properties.h"
+
+#include "arrow/util/thread_pool.h"
+#include "parquet/exception.h"
+
+#include "parquet/shuffle/shuffle_algorithm_properties.h"
+
+namespace parquet {
+namespace shuffle {
+
+void ShuffleProperties::num_threads(int num_threads) {
+  if (num_threads < 0) {
+    throw ParquetException("num_threads cannot be negative");
+  }
+  num_threads_ = num_threads;
+}
+
+int ShuffleProperties::GetEffectiveNumThreads() const {
+  if (num_threads_ != 0) {
+    return num_threads_;
+  } else {
+    return std::max(::arrow::GetCpuThreadPoolCapacity() / 2, 1);
+  }
+}
+
+std::ostream& operator<<(std::ostream& os, const ShuffleProperties& properties) {
+  os << "{shuffle_algorithm=" << properties.shuffle_algorithm()
+     << ", shuffle_level=" << properties.shuffle_level()
+     << ", num_threads=" << properties.num_threads()
+     << ", verbose=" << (properties.verbose() ? "true" : "false")
+     << ", algorithm_properties=";
+  if (properties.algorithm_properties()) {
+    properties.algorithm_properties()->PrintTo(os);
+  } else {
+    os << "null";
+  }
+  return os << "}";
+}
+
+}  // namespace shuffle
+}  // namespace parquet
