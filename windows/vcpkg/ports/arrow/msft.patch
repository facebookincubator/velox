+template <typename Quantity>
+int64_t SumRowGroupQuantities(const ParquetFileReaderSlice& source, Quantity&& get) {
+  const auto num_row_groups = source.num_row_groups();
+  int64_t size = 0;
+  for (int i = 0; i < num_row_groups; ++i) {
+    auto rg_slice = source.RowGroupMetadata(i);
+    auto s = get(*rg_slice.metadata);
+    const auto num_rows = rg_slice.metadata->num_rows();
+    if (rg_slice.row_count < rg_slice.metadata->num_rows()) {
+      // We can only estimate the size
+      const auto ratio = static_cast<double>(rg_slice.row_count) / num_rows;
+      s = static_cast<int64_t>(s * ratio);
+    }
+    size += s;
+  }
+  return size;
+}
+
+int64_t GetUncompressedSize(const ParquetFileReaderSlice& source) {
+  return SumRowGroupQuantities(source, [](const RowGroupMetaData& metadata) {
+    return metadata.total_byte_size();
+  });
+}
+
+int64_t GetCompressedSize(const ParquetFileReaderSlice& source) {
+  return SumRowGroupQuantities(source, [](const RowGroupMetaData& metadata) {
+    return metadata.total_compressed_size();
+  });
+}
