+  if (offset >= 0 && offset < data_size && length >= 0 && data_size - offset >= length) {
+    ASSERT_OK_NO_THROW(WriteRecordBatch(*batch, offset, length, *rg_writer, &descriptor,
+                                        *default_arrow_writer_properties()));
+    file_writer->Close();
+    ASSERT_OK_AND_ASSIGN(auto buffer, sink->Finish());
