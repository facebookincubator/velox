+
+using namespace internal;
+
+inline void RunEndToEndTest(const RawMetadata& raw_metadata,
+                            const Vec<Vec<Vec<RawBatch>>>& batches_per_rg_column,
+                            const Vec<DataPointers>& datapointers_per_column,
+                            const parquet::schema::NodeVector& fields) {
+  if (raw_metadata.shuffle_threads.has_value() &&
+      (raw_metadata.shuffle_threads.value() < 1 ||
+       raw_metadata.shuffle_threads.value() > 2)) {
+    throw UnsupportedTestScenarioError(
+        "raw_metadata.shuffle_threads must be within [1,2].");
+  }
+
+  auto schema = std::static_pointer_cast<parquet::schema::GroupNode>(
+      parquet::schema::GroupNode::Make("schema", parquet::Repetition::REQUIRED, fields));
+  parquet::SchemaDescriptor schemaDesc;
+  schemaDesc.Init(schema);
+
+  for (const auto& rg : batches_per_rg_column) {
+    for (int ci = 0; ci < schemaDesc.num_columns(); ci++) {
+      const auto& c = schemaDesc.Column(ci);
+      for (const auto& batch : rg.at(ci)) {
+        ValidateBatch(batch, c);
+      }
+    }
+  }
+
+  parquet::WriterProperties::Builder props_builder;
+  props_builder.enable_concurrent_row_group_writer();
+
+  if (raw_metadata.enable_dictionary.has_value()) {
+    raw_metadata.enable_dictionary.value() ? props_builder.enable_dictionary()
+                                           : props_builder.disable_dictionary();
+    SCOPED_TRACE(boost::format("enable_dictionary=%1%") %
+                 raw_metadata.enable_dictionary.value());
+  }
+
+  if (raw_metadata.dictinary_page_size_limit.has_value()) {
+    props_builder.dictionary_pagesize_limit(
+        raw_metadata.dictinary_page_size_limit.value());
+    SCOPED_TRACE(boost::format("dictinary_page_size_limit=%1%") %
+                 raw_metadata.dictinary_page_size_limit.value());
+  }
+
+  if (raw_metadata.parquet_data_page_version.has_value()) {
+    props_builder.data_page_version(raw_metadata.parquet_data_page_version.value());
+    SCOPED_TRACE(boost::format("parquet_data_page_version=%1%") %
+                 (int)raw_metadata.parquet_data_page_version.value());
+  };
+
+  if (raw_metadata.enable_shuffle.has_value()) {
+    raw_metadata.enable_shuffle.value() ? props_builder.enable_shuffle()
+                                        : props_builder.disable_shuffle();
+    SCOPED_TRACE(boost::format("enable_shuffle=%1%") %
+                 raw_metadata.enable_shuffle.value());
+  }
+
+  if (raw_metadata.shuffle_auto_encoding.has_value()) {
+    props_builder.shuffle_auto_encoding(raw_metadata.shuffle_auto_encoding.value());
+    SCOPED_TRACE(boost::format("shuffle_auto_encoding=%1%") %
+                 raw_metadata.shuffle_auto_encoding.value());
+  }
+
+  if (raw_metadata.shuffle_threads.has_value()) {
+    props_builder.shuffle_threads(raw_metadata.shuffle_threads.value());
+    SCOPED_TRACE(boost::format("shuffle_threads=%1%") %
+                 +raw_metadata.shuffle_threads.value());
+  }
+
+  if (raw_metadata.shuffle_raw_encoding_threshold.has_value()) {
+    props_builder.shuffle_raw_encoding_threshold(
+        raw_metadata.shuffle_raw_encoding_threshold.value());
+    SCOPED_TRACE(boost::format("shuffle_raw_encoding_threshold=%1%") %
+                 raw_metadata.shuffle_raw_encoding_threshold.value());
+  }
+
+  auto shuffle_props = std::make_shared<parquet::shuffle::VorderShuffleProperties>();
+  props_builder.shuffle_algorithm_properties(shuffle_props);
+
+  std::shared_ptr<::arrow::io::BufferOutputStream> sink = parquet::CreateOutputStream();
+  auto writer_props = props_builder.build();
+  auto file_writer_compression = writer_props->compression();
+  auto file_writer = parquet::ParquetFileWriter::Open(sink, schema, writer_props);
+
+  Vec<std::tuple<parquet::Type::type, int>> agg_cols_spec;
+  Vec<def_levels_t> max_def_lelvels_per_column;
+  for (int ci = 0; ci < schemaDesc.num_columns(); ci++) {
+    const auto& c = schemaDesc.Column(ci);
+    auto type = c->physical_type();
+    auto flba_len = static_cast<int>(c->type_length());
+    agg_cols_spec.emplace_back(std::tuple<parquet::Type::type, int>(type, flba_len));
+    max_def_lelvels_per_column.emplace_back(c->max_definition_level());
+  }
+
+  Vec<std::unique_ptr<::arrow::Buffer>> buffers;
+  Vec<RowGroupAggregator> rgAggregators;
+
+  for (const auto& row_num_per_col_batch : batches_per_rg_column) {
+    auto rg_writer = file_writer->AppendBufferedRowGroup();
+    rgAggregators.emplace_back(
+        RowGroupAggregator(agg_cols_spec, max_def_lelvels_per_column));
+    RowGroupAggregator& agg = rgAggregators.back();
+
+    for (int ci = 0; ci < schemaDesc.num_columns(); ++ci) {
+      auto col_writer = rg_writer->column(ci);
+      ASSERT_EQ(schemaDesc.Column(ci)->physical_type(), col_writer->type());
+
+      // Parquet standard require that all columns within rowgrup must have the same
+      // number of rows (def_levels/rep_levels instances). We find max (longest
+      // columns) and later will padd other columns to make all columns equal.
+      size_t max_mun_rows_over_columns = 0;
+      for (const auto& row_num_per_batch : row_num_per_col_batch) {
+        auto num_values = std::accumulate(
+            row_num_per_batch.begin(), row_num_per_batch.end(), (size_t)0,
+            [](const size_t& curr, const RawBatch& r) { return r.num_rows + curr; });
+        max_mun_rows_over_columns = std::max(num_values, max_mun_rows_over_columns);
+      }
+
+      switch (schemaDesc.Column(ci)->physical_type()) {
+        case parquet::Type::INT32:
+          WriteColumn<parquet::Int32Type>(ci, agg, row_num_per_col_batch.at(ci), buffers,
+                                          col_writer, datapointers_per_column.at(ci),
+                                          max_mun_rows_over_columns);
+          break;
+        case parquet::Type::INT64:
+          WriteColumn<parquet::Int64Type>(ci, agg, row_num_per_col_batch.at(ci), buffers,
+                                          col_writer, datapointers_per_column.at(ci),
+                                          max_mun_rows_over_columns);
+          break;
+        case parquet::Type::INT96:
+          WriteColumn<parquet::Int96Type>(ci, agg, row_num_per_col_batch.at(ci), buffers,
+                                          col_writer, datapointers_per_column.at(ci),
+                                          max_mun_rows_over_columns);
+          break;
+        case parquet::Type::BOOLEAN:
+          WriteColumn<parquet::BooleanType>(
+              ci, agg, row_num_per_col_batch.at(ci), buffers, col_writer,
+              datapointers_per_column.at(ci), max_mun_rows_over_columns);
+          break;
+        case parquet::Type::FLOAT:
+          WriteColumn<parquet::FloatType>(ci, agg, row_num_per_col_batch.at(ci), buffers,
+                                          col_writer, datapointers_per_column.at(ci),
+                                          max_mun_rows_over_columns);
+          break;
+        case parquet::Type::DOUBLE:
+          WriteColumn<parquet::DoubleType>(ci, agg, row_num_per_col_batch.at(ci), buffers,
+                                           col_writer, datapointers_per_column.at(ci),
+                                           max_mun_rows_over_columns);
+          break;
+        case parquet::Type::BYTE_ARRAY:
+          WriteColumn<parquet::ByteArrayType>(
+              ci, agg, row_num_per_col_batch.at(ci), buffers, col_writer,
+              datapointers_per_column.at(ci), max_mun_rows_over_columns);
+          break;
+
+        case parquet::Type::FIXED_LEN_BYTE_ARRAY:
+          WriteColumn<parquet::FLBAType>(ci, agg, row_num_per_col_batch.at(ci), buffers,
+                                         col_writer, datapointers_per_column.at(ci),
+                                         max_mun_rows_over_columns);
+          break;
+        default:
+          FAIL();
+      }
+      col_writer->Close();
+    }
+    rg_writer->Close();
+  }
+  file_writer->Close();
+
+  PARQUET_ASSIGN_OR_THROW(auto file_data, sink->Finish());
+  auto reader = std::make_shared<::arrow::io::BufferReader>(std::move(file_data));
+  auto paruqet_reader = parquet::ParquetFileReader::Open(reader);
+  auto metadata = paruqet_reader->metadata();
+
+  auto actual_num_row_groups = paruqet_reader->metadata()->num_row_groups();
+
+  for (int rgi = 0; rgi < actual_num_row_groups; ++rgi) {
+    RowGroupAggregator agg(rgAggregators.at(rgi).dictionaries,
+                           max_def_lelvels_per_column);
+    Vec<Vec<uint8_t>> memoryBuffers;
+    auto rg_reader = paruqet_reader->RowGroup(rgi);
+    auto actual_rg_num_columns = rg_reader->metadata()->num_columns();
+    auto rg_metadata_num_rows = rg_reader->metadata()->num_rows();
+
+    for (int ci = 0; ci < actual_rg_num_columns; ci++) {
+      auto column_metadata = rg_reader->metadata()->ColumnChunk(ci);
+      auto column_reader = rg_reader->Column(ci);
+      ASSERT_EQ(column_metadata->compression(), file_writer_compression);
+      switch (column_reader->descr()->physical_type()) {
+        case parquet::Type::INT32:
+          ReadColumn<parquet::Int32Type>(ci, agg, column_reader, rg_metadata_num_rows,
+                                         std::move(column_metadata));
+          break;
+        case parquet::Type::INT64:
+          ReadColumn<parquet::Int64Type>(ci, agg, column_reader, rg_metadata_num_rows,
+                                         std::move(column_metadata));
+          break;
+        case parquet::Type::INT96:
+          ReadColumn<parquet::Int96Type>(ci, agg, column_reader, rg_metadata_num_rows,
+                                         std::move(column_metadata));
+          break;
+        case parquet::Type::BOOLEAN:
+          ReadColumn<parquet::BooleanType>(ci, agg, column_reader, rg_metadata_num_rows,
+                                           std::move(column_metadata));
+          break;
+        case parquet::Type::FLOAT:
+          ReadColumn<parquet::FloatType>(ci, agg, column_reader, rg_metadata_num_rows,
+                                         std::move(column_metadata));
+          break;
+        case parquet::Type::DOUBLE:
+          ReadColumn<parquet::DoubleType>(ci, agg, column_reader, rg_metadata_num_rows,
+                                          std::move(column_metadata));
+          break;
+        case parquet::Type::BYTE_ARRAY:
+          ReadColumn<parquet::ByteArrayType>(ci, agg, column_reader, rg_metadata_num_rows,
+                                             std::move(column_metadata));
+          break;
+        case parquet::Type::FIXED_LEN_BYTE_ARRAY:
+          ReadColumn<parquet::FLBAType>(ci, agg, column_reader, rg_metadata_num_rows,
+                                        std::move(column_metadata));
+          break;
+        default:
+          FAIL();
+      }
+    }
+
+    if (!schemaDesc.HasRepeatedFields()) {
+      auto actual_rows = agg.Aggregate();
+      auto expected_rows = rgAggregators.at(rgi).Aggregate();
+      std::sort(actual_rows.begin(), actual_rows.end());
+      std::sort(expected_rows.begin(), expected_rows.end());
+      ASSERT_THAT(actual_rows, testing::ContainerEq(expected_rows));
+    } else {
+      // In else branch lenghtes of columns can differ (invariant is the number of zeros
+      // in rep_levels).
+      const auto& actual_columns = agg.columns;
+      const auto& expected_columns = rgAggregators.at(rgi).columns;
+      ASSERT_EQ(actual_columns.size(), expected_columns.size());
+      for (size_t ci = 0; ci < actual_columns.size(); ci++) {
+        const auto& actual_column = actual_columns.at(ci);
+        const auto& expected_column = expected_columns.at(ci);
+        ASSERT_THAT(actual_column.def_levels, expected_column.def_levels);
+        ASSERT_THAT(actual_column.rep_levels, expected_column.rep_levels);
+        ASSERT_THAT(actual_column.dictionary_indices, expected_column.dictionary_indices);
+      }
+    }
+  }
+}
