+
+TEST(DeltaStats, JsonStruct) {
+  auto sink = CreateOutputStream();
+  schema::NodeVector fields;
+  fields.push_back(schema::Int32("required", Repetition::REQUIRED));
+  fields.push_back(schema::Int32("optional", Repetition::OPTIONAL));
+
+  auto schema = std::static_pointer_cast<schema::GroupNode>(
+      schema::GroupNode::Make("schema", Repetition::REQUIRED, fields));
+
+  auto properties = WriterProperties::Builder().enable_delta_stats()->build();
+  auto file_writer = ParquetFileWriter::Open(sink, schema, properties);
+  auto rg_writer = file_writer->AppendRowGroup();
+
+  constexpr int32_t num_rows{100};
+
+  auto required_writer = static_cast<parquet::Int32Writer*>(rg_writer->NextColumn());
+  for (int32_t i = 0; i < num_rows; i++) {
+    required_writer->WriteBatch(1, nullptr, nullptr, &i);
+  }
+
+  // Write a null value at every other row.
+  auto optional_writer = static_cast<parquet::Int32Writer*>(rg_writer->NextColumn());
+  for (int32_t i = 0; i < num_rows; i++) {
+    int16_t definition_level = i % 2 == 0 ? 1 : 0;
+    optional_writer->WriteBatch(1, &definition_level, nullptr, &i);
+  }
+
+  ASSERT_NO_THROW(file_writer->Close());
+  PARQUET_ASSIGN_OR_THROW(auto buffer, sink->Finish());
+  auto file_reader = ParquetFileReader::Open(
+      std::make_shared<::arrow::io::BufferReader>(buffer), default_reader_properties());
+
+  ASSERT_NE(nullptr, file_reader->metadata());
+  ASSERT_NE(nullptr, file_reader->metadata()->key_value_metadata());
+  auto read_kv_meta = file_reader->metadata()->key_value_metadata();
+
+  EXPECT_TRUE(read_kv_meta->Contains(DELTA_STATS_JSON_KEY));
+
+  //   {
+  //     "minValues": {
+  //         "required": 0,
+  //         "optional": 0,
+  //     },
+  //     "maxValues": {
+  //         "required": 99,
+  //         "optional": 98,
+  //     },
+  //     "nullCount": {
+  //         "required": 0,
+  //         "optional": 50,
+  //     },
+  //     "numRecords": 100
+  //   }
+
+  PARQUET_ASSIGN_OR_THROW(auto stats_str, read_kv_meta->Get(DELTA_STATS_JSON_KEY));
+
+  auto json = rapidjson::Document();
+  json.Parse(stats_str.c_str());
+  ASSERT_FALSE(json.HasParseError());
+  ASSERT_TRUE(json.IsObject());
+
+  AssertMinMaxEquals(json, stats_str, "required", 0, 99);
+  AssertMinMaxEquals(json, stats_str, "optional", 0, 98);
+
+  AssertZeroNullCount(json, stats_str, "required");
+  AssertNullCountEquals(json, stats_str, "optional", 50);
+
+  // numRecords
+  ASSERT_TRUE(json.HasMember("numRecords"));
+  ASSERT_TRUE(json["numRecords"].IsInt());
+  ASSERT_EQ(num_rows, json["numRecords"].GetInt());
+}
