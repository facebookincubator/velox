diff --git a/cpp/src/parquet/shuffle/util/string_util.h b/cpp/src/parquet/shuffle/util/string_util.h
new file mode 100644
index 0000000000..27dd3a7207
--- /dev/null
+++ b/cpp/src/parquet/shuffle/util/string_util.h
@@ -0,0 +1,85 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <iterator>
+#include <stdexcept>
+#include <string_view>
+
+namespace parquet {
+namespace shuffle {
+
+class SplitRange;
+
+class SplitIterator {
+ public:
+  using difference_type = void;
+  using value_type = std::string_view;
+  using pointer = std::string_view*;
+  using reference = std::string_view;
+  using iterator_category = std::input_iterator_tag;
+
+  SplitIterator(const SplitRange* range, size_t pos)
+      : range_(range), pos_(pos), count_(0) {
+    Next();
+  }
+
+  bool operator==(const SplitIterator& rhs) const { return pos_ == rhs.pos_; }
+  bool operator!=(const SplitIterator& rhs) const { return pos_ != rhs.pos_; }
+
+  std::string_view operator*() const;
+  SplitIterator& operator++();
+
+ private:
+  void Next();
+
+  const SplitRange* range_;
+  size_t pos_;
+  size_t count_;
+};
+
+class SplitRange {
+ public:
+  using value_type = std::string_view;
+  using const_iterator = SplitIterator;
+
+  SplitRange(std::string_view string, std::string_view delim)
+      : string_(string), delim_(delim) {
+    if (delim.empty()) {
+      throw std::runtime_error("delim must not be empty");
+    }
+  }
+
+  SplitIterator begin() const { return SplitIterator(this, 0); }
+  SplitIterator end() const {
+    return SplitIterator(this, string_.size() + delim_.size());
+  }
+
+ private:
+  std::string_view string_;
+  std::string_view delim_;
+
+  friend class SplitIterator;
+};
+
+inline std::string_view SplitIterator::operator*() const {
+  return range_->string_.substr(pos_, count_);
+}
+
+inline SplitIterator& SplitIterator::operator++() {
+  pos_ += count_ + range_->delim_.size();
+  Next();
+  return *this;
+}
+
+inline void SplitIterator::Next() {
+  const auto p = range_->string_.find(range_->delim_, pos_);
+  count_ = (p == std::string_view::npos ? range_->string_.size() : p) - pos_;
+}
+
+inline SplitRange split(std::string_view string, std::string_view delim) {
+  return {string, delim};
+}
+
+}  // namespace shuffle
+}  // namespace parquet
