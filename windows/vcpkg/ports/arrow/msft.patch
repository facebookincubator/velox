+namespace shuffle {
+namespace test {
+
+using ::testing::Ge;
+using ::testing::Le;
+using ::testing::Message;
+
+TEST(TestRleSizeEstimator, NoData) {
+  RleSizeEstimator<int> e(1);
+  EXPECT_THAT(e.estimate(), 0);
+  EXPECT_THAT(e.flushed_estimate(), 2);
+}
+
+TEST(TestRleSizeEstimator, RepeatedData) {
+  RleSizeEstimator<int> e(1);
+  const int data[] = {1, 1, 1, 1};
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  e.Append(AsSpan(data));
+  EXPECT_THAT(e.estimate(), 0);
+  EXPECT_THAT(e.flushed_estimate(), 2);
+}
+
+TEST(TestRleSizeEstimator, NonRepeatingData) {
