+// A page along with its header buffer that made it up.
+class PageCollection {
+ public:
+  PageCollection(std::unique_ptr<Buffer> header_buffer,
+                 std::size_t original_page_buffer_size, std::shared_ptr<Page> page)
+      : header_buffer_(std::move(header_buffer)),
+        original_page_buffer_size_(original_page_buffer_size),
+        page_(std::move(page)) {}
+
+  std::shared_ptr<Page> page() const { return page_; }
+
+  std::string_view header_buffer() const {
+    // Cast using the overloaded string_view operator.
+    return static_cast<std::string_view>(*(header_buffer_.get()));
+  }
+
+  std::string_view uncompressed_page_buffer() const {
+    // Cast using the overloaded string_view operator.
+    return static_cast<std::string_view>(*(page_->buffer().get()));
+  }
+
+  // @returns: the size of the buffer backing this page-with-header. the size is
+  // total of header with uncompressed/original page buffers.
+  std::size_t GetSize(bool use_uncompressed) const {
+    if (use_uncompressed) {
+      return header_buffer_->size() + page_->size();
+    } else {
+      return header_buffer_->size() + original_page_buffer_size_;
+    }
+  }
+
+ private:
+  std::unique_ptr<Buffer> header_buffer_;
+
+  std::size_t original_page_buffer_size_;
+
+  std::shared_ptr<Page> page_;
+};
+
