+    std::unique_ptr<FileReader> reader;
+    ASSERT_OK_NO_THROW(OpenFile(std::make_shared<BufferReader>(buffer),
+                                ::arrow::default_memory_pool(), &reader));
+    std::shared_ptr<::arrow::Table> actual_table;
+    ASSERT_OK_NO_THROW(reader->ReadTable(&actual_table));
+
+    ASSERT_OK_AND_ASSIGN(auto expected_table, ::arrow::Table::FromRecordBatches({batch}));
+    try {
+      ::arrow::AssertTablesEqual(*expected_table->Slice(offset, length), *actual_table);
+    } catch (const std::exception&) {
+      // We're interested in WriteRecordBatch, so any failure from other places
+      // would distract our test
+    }
+  } else {
+    ASSERT_NOT_OK(WriteRecordBatch(*batch, offset, length, *rg_writer, &descriptor,
+                                   *default_arrow_writer_properties()));
+  }
