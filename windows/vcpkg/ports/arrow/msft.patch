+            LogicalType::Timestamp(true, LogicalType::TimeUnit::MICROS), Type::INT64));
+      },
+      [&](parquet::RowGroupWriter* rg_writer) {
+        auto writer = static_cast<parquet::Int64Writer*>(rg_writer->NextColumn());
+        for (int32_t i = 0; i < num_rows; i++) {
+          int64_t value;
+          if (i % 2 == 0) {
+            value = 0;  // 1970-01-01 00:00:00
+          } else {
+            value = std::numeric_limits<int64_t>::max();
+          }
+          writer->WriteBatch(1, nullptr, nullptr, &value);
+        }
+      },
+      [](const rapidjson::Document& json, const std::string& stats_str) {
+        AssertMinMaxEquals(json, stats_str, "col_1", "1970-01-01T00:00:00.000Z",
+                           "+294247-01-10T04:00:54.775Z");
