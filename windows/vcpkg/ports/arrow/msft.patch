+void ThrowRowsMisMatchError(int col, int64_t prev, int64_t curr) {
+  std::stringstream ss;
+  ss << "Column " << col << " had " << curr << " while previous column had " << prev;
+  throw ParquetException(ss.str());
+}
+
+struct ColumnChunk {
+  int column_idx;
+  std::shared_ptr<CompactIndexVector> indices;
+  std::shared_ptr<Buffer> values_buffer;
+  std::shared_ptr<Buffer> offsets_buffer;
+  std::shared_ptr<Buffer> lengths_buffer;
+  std::shared_ptr<Buffer> complete_permutation_buffer;
+  int32_t num_indices;
+  int32_t num_values;
+  int type_length;
+
+  std::shared_ptr<Buffer> definition_levels_buffer;
+  int16_t max_definition_level;
+
+  // Special indices where -1 indicates null.
+  // Unlike indices, it has the same number of entires as rows.
+  // Null values (indices) are indicated as -1 or all-set bits.
+  std::shared_ptr<CompactIndexVector> spaced_indices;
+
+  template <typename T>
+  Span<T> values() {
+    return AsSpan<T>(*values_buffer);
+  }
+
+  Span<int32_t> offsets() {
+    if (offsets_buffer) {
+      return AsSpan<int32_t>(*offsets_buffer);
+    } else {
+      return {};
+    }
+  }
+
+  Span<int16_t> definition_levels() {
+    if (definition_levels_buffer) {
+      return AsSpan<int16_t>(*definition_levels_buffer);
+    } else {
+      return {};
+    }
+  }
+
+  void Clear() {
+    Clear1();
+    Clear2();
+  }
+
+  void Clear1(bool keep_values = false) {
+    indices.reset();
+    offsets_buffer.reset();
+    lengths_buffer.reset();
+    complete_permutation_buffer.reset();
+    if (!keep_values) {
+      values_buffer.reset();
+    }
+  }
+
+  void Clear2() {
+    values_buffer.reset();
+    definition_levels_buffer.reset();
+  }
+};
+
+template <typename DType>
+void ExecuteShufflePlainImpl(ColumnChunk& chunk,
+                             const std::shared_ptr<Buffer>& complete_permutation_buffer,
+                             MemoryPool*) {
+  DoShuffle(AsSpan<const int32_t>(*complete_permutation_buffer),
+            chunk.values<typename DType::c_type>().data());
+}
+
+template <>
+void ExecuteShufflePlainImpl<BooleanType>(ColumnChunk&, const std::shared_ptr<Buffer>&,
+                                          MemoryPool*) {
+  ParquetException::NYI();
+}
+
+template <>
+void ExecuteShufflePlainImpl<ByteArrayType>(
+    ColumnChunk& chunk, const std::shared_ptr<Buffer>& complete_permutation_buffer,
+    MemoryPool* mp) {
+  chunk.lengths_buffer = AllocateBuffer(mp, chunk.num_values * sizeof(int32_t));
+  auto lengths = AsSpan<int32_t>(*chunk.lengths_buffer);
+  auto offsets = chunk.offsets();
+  for (int32_t i = 0; i < chunk.num_values; ++i) {
+    lengths[i] = offsets[i + 1] - offsets[i];
+  }
+  const auto complete_permutation = AsSpan<const int32_t>(*complete_permutation_buffer);
+  DoShuffle(complete_permutation, offsets.data());
+  DoShuffle(complete_permutation, lengths.data());
+}
+
+template <>
+void ExecuteShufflePlainImpl<FLBAType>(
+    ColumnChunk& chunk, const std::shared_ptr<Buffer>& complete_permutation_buffer,
+    MemoryPool*) {
+  chunk.complete_permutation_buffer = complete_permutation_buffer;
+}
+
+template <typename DType>
+void FlushDictionaryImpl(TypedColumnWriter<DType>& col, ColumnChunk& chunk) {
+  col.WriteBatchWithDictionary(chunk.definition_levels(), {}, *chunk.indices,
+                               chunk.values_buffer, chunk.offsets(), chunk.num_values);
+  chunk.Clear();
+}
+
+template <typename DType>
+typename DType::c_type GetValue(ColumnChunk& chunk, int32_t index) {
+  return chunk.values<typename DType::c_type>()[index];
+}
+
+template <>
+ByteArray GetValue<ByteArrayType>(ColumnChunk& chunk, int32_t index) {
+  auto offsets = chunk.offsets();
+  return {
+      static_cast<uint32_t>(offsets[index + 1] - offsets[index]),
+      chunk.values<const uint8_t>().data() + offsets[index],
+  };
+}
+
+template <>
+FLBA GetValue<FLBAType>(ColumnChunk& chunk, int32_t index) {
+  return FLBA(chunk.values<const uint8_t>().data() +
+              static_cast<uint64_t>(index) * static_cast<uint64_t>(chunk.type_length));
+}
+
+template <typename DType, typename ValueType, typename IndexType>
+void CopyValues(Span<ValueType> dst, Span<const IndexType> indices, int32_t offset,
+                int32_t count, ColumnChunk& chunk) {
+  size_t i = 0;
+  for (const auto index :
+       indices.subspan(static_cast<size_t>(offset), static_cast<size_t>(count))) {
+    dst[i++] = GetValue<DType>(chunk, index);
+  }
+}
+
+template <typename DType>
+int32_t FlushDenseImpl(TypedColumnWriter<DType>& col, ColumnChunk& chunk,
+                       int32_t rows_to_flush, int32_t flushed_rows, int32_t num_rows,
+                       int32_t flushed_values, MemoryPool* mp) {
+  using T = typename DType::c_type;
+  const auto def_levels =
+      chunk.definition_levels().empty()
+          ? chunk.definition_levels()
+          : chunk.definition_levels().subspan(flushed_rows, rows_to_flush);
+  const auto num_values =
+      def_levels.empty()
+          ? rows_to_flush
+          : static_cast<int32_t>(std::count(def_levels.begin(), def_levels.end(),
+                                            chunk.max_definition_level));
+  auto values_buffer = AllocateBuffer(mp, num_values * sizeof(T));
+  auto values = AsSpan<T>(*values_buffer);
+  const auto& indices = *chunk.indices;
+  switch (indices.type_length()) {
+    case 1:
+      CopyValues<DType>(values, indices.values1(), flushed_values, num_values, chunk);
+      break;
+    case 2:
+      CopyValues<DType>(values, indices.values2(), flushed_values, num_values, chunk);
+      break;
+    case 3:
+      CopyValues<DType>(values, indices.values3(), flushed_values, num_values, chunk);
+      break;
+    case 4:
+      CopyValues<DType>(values, indices.values4(), flushed_values, num_values, chunk);
+      break;
+  }
+  const auto can_flush = (flushed_rows + rows_to_flush == num_rows);
+  if (can_flush) {
+    chunk.Clear1(DType::type_num == Type::BYTE_ARRAY ||
+                 DType::type_num == Type::FIXED_LEN_BYTE_ARRAY);
+  }
+  col.WriteBatch(rows_to_flush, def_levels.data(), nullptr, values.data());
+  if (can_flush) chunk.Clear2();
+  return num_values;
+}
+
+template <typename DType>
+Span<typename DType::c_type> GetValues(MemoryPool*, ColumnChunk& chunk,
+                                       std::shared_ptr<ResizableBuffer>&, int32_t offset,
+                                       int32_t count) {
+  return AsSpan<typename DType::c_type>(*chunk.values_buffer)
+      .subspan(static_cast<size_t>(offset), static_cast<size_t>(count));
+}
+
+template <>
+Span<ByteArray> GetValues<ByteArrayType>(MemoryPool* mp, ColumnChunk& chunk,
+                                         std::shared_ptr<ResizableBuffer>& buffer,
+                                         int32_t offset, int32_t count) {
+  buffer = AllocateBuffer(mp, count * sizeof(ByteArray));
+  auto values = AsSpan<ByteArray>(*buffer);
+  auto offsets = chunk.offsets();
+  if (chunk.lengths_buffer) {
+    auto lengths = AsSpan<int32_t>(*chunk.lengths_buffer);
+    for (int32_t i = 0; i < count; ++i) {
+      values[i] = ByteArray(lengths[offset + i],
+                            chunk.values<const uint8_t>().data() + offsets[offset + i]);
+    }
+  } else {
+    for (int32_t i = 0; i < count; ++i) {
+      values[i] = ByteArray(offsets[offset + i + 1] - offsets[offset + i],
+                            chunk.values<const uint8_t>().data() + offsets[offset + i]);
+    }
+  }
+  return values;
+}
+
+template <>
+Span<FLBA> GetValues<FLBAType>(MemoryPool* mp, ColumnChunk& chunk,
+                               std::shared_ptr<ResizableBuffer>& buffer, int32_t offset,
+                               int32_t count) {
+  buffer = AllocateBuffer(mp, count * sizeof(FLBA));
+  auto values = AsSpan<FLBA>(*buffer);
+  auto permutation = AsSpan<const int32_t>(*chunk.complete_permutation_buffer);
+  for (int32_t i = 0; i < count; ++i) {
+    values[i] = FLBA(chunk.values<const uint8_t>().data() +
+                     static_cast<int64_t>(permutation[offset + i]) * chunk.type_length);
+  }
+  return values;
+}
+
+template <typename DType>
+int32_t FlushPlainImpl(TypedColumnWriter<DType>& col, ColumnChunk& chunk,
+                       int32_t rows_to_flush, int32_t flushed_rows, int32_t num_rows,
+                       int32_t flushed_values, MemoryPool* mp) {
+  using T = typename DType::c_type;
+  const auto def_levels =
+      chunk.definition_levels().empty()
+          ? chunk.definition_levels()
+          : chunk.definition_levels().subspan(flushed_rows, rows_to_flush);
+  const auto num_values =
+      def_levels.empty()
+          ? rows_to_flush
+          : static_cast<int32_t>(std::count(def_levels.begin(), def_levels.end(),
+                                            chunk.max_definition_level));
+  std::shared_ptr<ResizableBuffer> values_buffer;
+  Span<T> values = GetValues<DType>(mp, chunk, values_buffer, flushed_values, num_values);
+  const auto can_flush = (flushed_rows + rows_to_flush == num_rows);
+  if (can_flush) {
+    chunk.Clear1(true);
+  }
+  col.WriteBatch(rows_to_flush, def_levels.data(), nullptr, values.data());
+  if (can_flush) chunk.Clear2();
+  return num_values;
+}
+
+int32_t GetMaxIndexForSpacedIndices(const CompactIndexVector& indices) {
+  const auto max_index = indices.max_index();
+  if (max_index == 0xff || max_index == 0xffff || max_index == 0xffffff) {
+    return max_index + 1;
+  } else {
+    return max_index;
+  }
+}
+
+template <typename T>
+void CopyIndices(CompactIndexVector& spaced_indices, Span<T> indices,
+                 Span<const int16_t> def_levels, int16_t max_def_level) {
+  const auto null_index = GetNullIndex(spaced_indices.type_length());
+  int32_t j = 0;
+  for (const auto def_level : def_levels) {
+    spaced_indices.push_back(def_level == max_def_level ? indices[j++] : null_index);
+  }
+}
+
+template <typename T>
+void CopyNonNullIndices(CompactIndexVector& indices, Span<T> spaced_indices) {
+  const auto null_index = GetNullIndex(sizeof(T));
+  for (const auto index : spaced_indices) {
+    if (index != null_index) {
+      indices.push_back(index);
+    }
+  }
+}
+
+uint64_t GetRleEncodedIndicesSizeEstimate(const CompactIndexVector& indices,
+                                          uint64_t bit_width) {
+  switch (indices.type_length()) {
+    case 1:
+      return GetRleEncodedIndicesSizeEstimate(indices.values1(), bit_width);
+    case 2:
+      return GetRleEncodedIndicesSizeEstimate(indices.values2(), bit_width);
+    case 3:
+      return GetRleEncodedIndicesSizeEstimate(indices.values3(), bit_width);
+    case 4:
+      return GetRleEncodedIndicesSizeEstimate(indices.values4(), bit_width);
+  }
+  ::arrow::Unreachable();
+}
+
+std::shared_ptr<Buffer> BuildNonNullPermutationVector(MemoryPool* mp,
+                                                      int16_t max_definition_level,
+                                                      Span<const int16_t> def_levels,
+                                                      Span<const int32_t> permutation) {
+  const auto num_rows = static_cast<int32_t>(permutation.size());
+  auto non_null_indices_buffer =
+      AllocateBuffer(mp, static_cast<int64_t>(num_rows) * sizeof(int32_t));
+  const auto non_null_indices = AsSpan<int32_t>(*non_null_indices_buffer);
+  int32_t non_null_count = 0;
+  for (int32_t i = 0; i < num_rows; ++i) {
+    non_null_indices[i] = def_levels[i] == max_definition_level ? non_null_count++ : -1;
+  }
+  DoShuffle(permutation, non_null_indices.data());
+  auto permutation_except_nulls_buffer =
+      AllocateBuffer(mp, static_cast<int64_t>(non_null_count) * sizeof(int32_t));
+  const auto permutation_except_nulls = AsSpan<int32_t>(*permutation_except_nulls_buffer);
+  int32_t i = 0;
+  for (const auto non_null_index : non_null_indices) {
+    if (non_null_index != -1) {
+      permutation_except_nulls[i++] = non_null_index;
+    }
+  }
+  DCHECK_EQ(non_null_count, i);
+  return permutation_except_nulls_buffer;
+}
+
+void ValidatePermutationVector(Span<const int32_t> permutation) {
+  std::vector<bool> seen(permutation.size(), false);
+  for (const auto i : permutation) {
+    if (i < 0 || i >= static_cast<int32_t>(permutation.size())) {
+      throw ParquetException("Invalid permutation vector (out of range)");
+    }
+    if (seen[i]) {
+      throw ParquetException("Invalid permutation vector (duplicate indices)");
+    }
+    seen[i] = true;
+  }
+}
+
+// RowGroupWriter implementation that buffers all values in a plain array or a dictionary.
+//
+// At the same time, it writes values to the underlying RowGroupWriter, so that users of
+// ParquetFileWriter API get the same statistics such as total_bytes_written() during the
+// write operation. This is to ensure that users can use AppendShuffledRowGroup() instead
+// of AppendBufferedRowGroup() without changing their code. If this compatibility is not
+// necessary (e.g., users write a fixed number of rows to a row group), then this behavior
+// can be turned off.
+//
+// When Close() is called, it invokes the shuffle implementation to get a permutation
+// vector. If the permutation vector not empty, then the buffered rows are reordered using
+// the vector. Finally, the buffered rows are written to the underlying RowGroupWriter.
+class ShuffledRowGroupSerializer : public RowGroupWriter::Contents {
+  using ReplaceSink = std::function<std::unique_ptr<RowGroupWriter>(
+      std::unique_ptr<RowGroupWriter>, bool)>;
+
+ public:
+  ShuffledRowGroupSerializer(
+      std::unique_ptr<RowGroupWriter> sink, std::unique_ptr<Shuffle> shuffle,
+      ReplaceSink replace_sink, int64_t max_row_group_length, ShuffleMetrics* metrics,
+      std::shared_ptr<const ShuffleWriterProperties> shuffle_writer_properties)
+      : mp_(shuffle->properties().memory_pool()),
+        sink_(std::move(sink)),
+        shuffle_(std::move(shuffle)),
+        replace_sink_(std::move(replace_sink)),
+        chunks_(sink_->num_columns()),
+        thread_pool_(shuffle_->properties().thread_pool()),
+        num_rows_(0),
+        max_row_group_length_(max_row_group_length > std::numeric_limits<int32_t>::max()
+                                  ? std::numeric_limits<int32_t>::max()
+                                  : static_cast<int32_t>(max_row_group_length)),
+        needs_complete_permutation_vector_(false),
+        closed_(false),
+        verbose_(shuffle_->properties().verbose()),
+        metrics_(metrics),
+        shuffle_writer_properties_(std::move(shuffle_writer_properties)) {
+    const auto num_threads = shuffle_->properties().GetEffectiveNumThreads();
+    if (num_threads > 1 && !thread_pool_) {
+      PARQUET_ASSIGN_OR_THROW(thread_pool_, ThreadPool::Make(num_threads));
+    }
+  }
+
+  int num_columns() const override { return sink_->num_columns(); }
+
+  int64_t num_rows() const override {
+    if (!closed_) {
+      CheckRowsWritten();
+    }
+    return num_rows_;
+  }
+
+  bool buffered() const override { return true; }
+
+  ColumnWriter* NextColumn() override {
+    throw ParquetException("NextColumn() is not supported for shuffle");
+  }
+
+  ColumnWriter* column(int i) override { return sink_->column(i); }
+
+  int current_column() const override { return sink_->current_column(); }
+
+  int64_t total_bytes_written() const override { return sink_->total_bytes_written(); }
+
+  int64_t total_compressed_bytes() const override {
+    return sink_->total_compressed_bytes();
+  }
+
+  int64_t total_compressed_bytes_written() const override {
+    return sink_->total_compressed_bytes_written();
+  }
+
+  int64_t estimated_size() const override { return sink_->estimated_size(); }
+
+  int64_t estimated_memory_usage() const override {
+    return sink_->estimated_memory_usage();
+  }
+
+  int64_t estimated_memory_usage(int64_t num_rows) const override {
+    return sink_->estimated_memory_usage(num_rows);
+  }
+
+  void Close() override {
+    if (closed_) return;
+    closed_ = true;
+    try {
+      CheckRowsWritten();
+      Measure(metrics_, &ShuffleMetrics::dictionary_finalize_time, [&] { Finish(); });
+      if (num_rows_ > 0) {
+        ShuffleRows();
+      }
+      Measure(metrics_, &ShuffleMetrics::sink_write_time, [&] {
+        Flush();
+        sink_->Close();
+      });
+    } catch (const std::exception& e) {
+      // Print the error because it can be silently swalloed in ~ParquetFileWriter.
+      if (verbose_) {
+        try {
+          std::cerr << "Error occurred during ShuffledRowGroupSerializer::Close(): "
+                    << e.what() << std::endl;
+        } catch (...) {
+        }
+      }
+      throw;
+    }
+  }
+
+ private:
+  void CheckRowsWritten() const {
+    if (num_columns() > 0) {
+      int64_t current_col_rows = sink_->column(0)->rows_written();
+      for (int i = 1; i < num_columns(); ++i) {
+        int64_t current_col_rows_i = sink_->column(i)->rows_written();
+        if (current_col_rows != current_col_rows_i) {
+          ThrowRowsMisMatchError(i, current_col_rows_i, current_col_rows);
+        }
+      }
+      if (current_col_rows > std::numeric_limits<int32_t>::max()) {
+        throw ParquetException("Shuffle supports at most 2147483647 rows per row group");
+      }
+      num_rows_ = static_cast<int32_t>(current_col_rows);
+    }
+  }
+
+  void Finish() {
+    if (num_rows_ > 0) {
+      FinishImpl();
+    }
+    sink_ = replace_sink_(std::move(sink_), true);
+  }
+
+  void FinishImpl() {
+    ForEachColumn([&](int i, ColumnWriter* col) {
+      auto& chunk = chunks_[i];
+      chunk.column_idx = i;
+      if (col->descr()->physical_type() == Type::BOOLEAN) {
+        FinishBoolean(*col, chunk);
+      } else {
+        auto dict_encoder = dynamic_cast<ShuffleEncoder*>(col->encoder());
+        if (dict_encoder == nullptr) {
+          throw ParquetException("Internal error: expected shuffle encoding");
+        }
+        auto dict = dict_encoder->Finish();
+        chunk.indices = std::move(dict.indices);
+        chunk.values_buffer = std::move(dict.values_buffer);
+        chunk.offsets_buffer = std::move(dict.offsets_buffer);
+        chunk.num_values = dict.num_values;
+      }
+      chunk.num_indices = chunk.indices ? chunk.indices->size() : 0;
+      chunk.type_length = col->descr()->type_length();
+      chunk.definition_levels_buffer = col->Finish().first;
+      chunk.max_definition_level = col->descr()->max_definition_level();
+      if (chunk.indices) {
+        const auto& indices = *chunk.indices;
+        if (num_rows_ > indices.size()) {
+          const auto max_index = GetMaxIndexForSpacedIndices(indices);
+          auto spaced_indices =
+              std::make_shared<CompactIndexVector>(mp_, max_index, num_rows_);
+          const auto def_levels = chunk.definition_levels();
+          const auto max_def_level = chunk.max_definition_level;
+          switch (indices.type_length()) {
+            case 1:
+              CopyIndices(*spaced_indices, indices.values1(), def_levels, max_def_level);
+              break;
+            case 2:
+              CopyIndices(*spaced_indices, indices.values2(), def_levels, max_def_level);
+              break;
+            case 3:
+              CopyIndices(*spaced_indices, indices.values3(), def_levels, max_def_level);
+              break;
+            case 4:
+              CopyIndices(*spaced_indices, indices.values4(), def_levels, max_def_level);
+              break;
+          }
+          chunk.indices.reset();
+          chunk.spaced_indices = std::move(spaced_indices);
+        } else {
+          chunk.spaced_indices = std::move(chunk.indices);
+        }
+      } else {
+        needs_complete_permutation_vector_ = true;
+      }
+      if ((chunk.spaced_indices ? chunk.num_indices : chunk.num_values) < num_rows_ &&
+          chunk.definition_levels().empty()) {
+        throw ParquetException("Internal error: definition_levels shouldn't be null");
+      }
+    });
+  }
+
+  void FinishBoolean(ColumnWriter& col, ColumnChunk& chunk) {
+    if (col.encoding() != Encoding::PLAIN) {
+      throw ParquetException("Internal error: unexpected encoding for boolean column");
+    }
+    auto bits = col.encoder()->FlushValues();
+    // Number of bits cannot exceed INT32_MAX, as we check the number of rows
+    // in CheckRowsWritten(). It can if this column was a repeated field, but
+    // then we wouldn't build a dictionary so it's safe.
+    const auto num_bits = static_cast<int32_t>(col.num_buffered_encoded_values());
+    auto bit_reader = std::make_unique<::arrow::bit_util::BitReader>(
+        bits->data(), static_cast<int>(bits->size()));
+    chunk.indices = std::make_shared<CompactIndexVector>(mp_);
+    chunk.indices->reserve(num_bits);
+    for (int32_t i = 0; i < num_bits; ++i) {
+      int32_t value;
+      bit_reader->GetValue(1, &value);
+      chunk.indices->push_back(value);
+    }
+    chunk.values_buffer = AllocateBuffer(mp_, 2 * sizeof(bool));
+    const auto values = AsSpan<bool>(*chunk.values_buffer);
+    values[0] = false;
+    values[1] = true;
+    chunk.num_values = 2;
+  }
+
+  void ShuffleRows() {
+    auto permutation_buffer = AllocateBuffer(mp_, num_rows_ * sizeof(int32_t));
+    auto permutation = AsSpan<int32_t>(*permutation_buffer);
+    std::shared_ptr<Buffer> complete_permutation_buffer;
+    auto complete_permutation = Span<int32_t>();
+    if (needs_complete_permutation_vector_) {
+      complete_permutation_buffer = AllocateBuffer(mp_, num_rows_ * sizeof(int32_t));
+      complete_permutation = AsSpan<int32_t>(*complete_permutation_buffer);
+    }
+    const auto do_shuffle = ComputeShuffle(permutation, complete_permutation);
+    if (!do_shuffle) {
+      permutation = {};
+    }
+    if (complete_permutation.empty()) {
+      complete_permutation = permutation;
+      complete_permutation_buffer = permutation_buffer;
+    }
+    if (do_shuffle && shuffle_writer_properties_->debug()) {
+      ValidatePermutationVector(permutation);
+      ValidatePermutationVector(complete_permutation);
+    }
+    ExecuteShuffle(permutation, complete_permutation_buffer);
+  }
+
+  bool ComputeShuffle(Span<int32_t> permutation, Span<int32_t>& complete_permutation) {
+    bool do_shuffle = false;
+    Measure(metrics_, &ShuffleMetrics::shuffle_compute_time, [&] {
+      auto column_data_buffer = GetColumnData(chunks_);
+      const auto column_data = AsSpan(column_data_buffer);
+      do_shuffle =
+          shuffle_->algorithm().Apply(column_data, permutation, complete_permutation);
+    });
+    return do_shuffle;
+  }
+
+  std::vector<ColumnData> GetColumnData(std::vector<ColumnChunk>& chunks) {
+    std::vector<ColumnData> column_data;
+    column_data.reserve(num_columns());
+    for (int i = 0; i < num_columns(); ++i) {
+      if (chunks[i].spaced_indices) {
+        column_data.push_back({
+            i,
+            chunks[i].spaced_indices->type_length(),
+            chunks[i].spaced_indices->data().data(),
+            chunks[i].definition_levels().data(),
+            num_rows_ - chunks[i].num_indices,
+            chunks[i].num_values,
+        });
+      }
+    }
+    return column_data;
+  }
+
+  void ExecuteShuffle(Span<const int32_t> permutation,
+                      const std::shared_ptr<Buffer>& complete_permutation_buffer) {
+    Measure(metrics_, &ShuffleMetrics::shuffle_execute_time, [&] {
+      ForEachColumn([&](int i, ColumnWriter* col) {
+        auto& chunk = chunks_[i];
+        const auto num_distinct_values = chunk.num_values;
+        if (chunk.spaced_indices) {
+          const bool has_nulls = num_rows_ > chunk.num_indices;
+          if (num_distinct_values > 1 || (num_distinct_values == 1 && has_nulls)) {
+            if (!permutation.empty()) {
+              DoShuffle(permutation, *chunk.spaced_indices);
+            }
+            if (has_nulls) {
+              auto indices = std::make_shared<CompactIndexVector>(
+                  mp_, num_distinct_values - 1, chunk.num_indices);
+              switch (chunk.spaced_indices->type_length()) {
+                case 1:
+                  CopyNonNullIndices(*indices, chunk.spaced_indices->values1());
+                  break;
+                case 2:
+                  CopyNonNullIndices(*indices, chunk.spaced_indices->values2());
+                  break;
+                case 3:
+                  CopyNonNullIndices(*indices, chunk.spaced_indices->values3());
+                  break;
+                case 4:
+                  CopyNonNullIndices(*indices, chunk.spaced_indices->values4());
+                  break;
+              }
+              chunk.spaced_indices.reset();
+              chunk.indices = std::move(indices);
+            } else {
+              chunk.indices = std::move(chunk.spaced_indices);
+            }
+          } else if (!has_nulls) {
+            chunk.indices = std::move(chunk.spaced_indices);
+          } else {
+            // If num_distinct_values == 0 and has_nulls == true, we need to
+            // create a non-null chunk.indices because it's used in Flush() to
+            // check whether this column was passed to the shuffle or not. When
+            // chunk.spaced_indices is not null, chunk.indices should be also
+            // not null to indicate that the permutation has already happened
+            // for the column.
+            chunk.indices = std::make_shared<CompactIndexVector>(mp_);
+          }
+          if (!permutation.empty() && has_nulls) {
+            DoShuffle(permutation, chunk.definition_levels().data());
+          }
+        } else if (!permutation.empty()) {
+          const bool has_nulls = num_rows_ > chunk.num_values;
+          if (has_nulls) {
+            const auto complete_permutation =
+                AsSpan<const int32_t>(*complete_permutation_buffer);
+            auto complete_permutation_except_nulls_buffer = BuildNonNullPermutationVector(
+                mp_, chunk.max_definition_level, chunk.definition_levels(),
+                complete_permutation);
+            if (shuffle_writer_properties_->debug()) {
+              ValidatePermutationVector(
+                  AsSpan<const int32_t>(*complete_permutation_except_nulls_buffer));
+            }
+            ExecuteShufflePlain(*col, chunk, complete_permutation_except_nulls_buffer);
+            DoShuffle(complete_permutation, chunk.definition_levels().data());
+          } else {
+            ExecuteShufflePlain(*col, chunk, complete_permutation_buffer);
+          }
+        }
+      });
+    });
+  }
+
+  void ExecuteShufflePlain(ColumnWriter& col, ColumnChunk& chunk,
+                           const std::shared_ptr<Buffer>& complete_permutation_buffer) {
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col.descr()->physical_type(),
+        ExecuteShufflePlainImpl<DType>(chunk, complete_permutation_buffer, mp_));
+  }
+
+  void Flush() {
+    int32_t flushed_rows = 0;
+    int32_t remaining_rows = num_rows_;
+    std::vector<int32_t> flushed_values(num_columns());
+    while (remaining_rows > 0) {
+      const auto rows_to_flush = std::min(remaining_rows, max_row_group_length_);
+      ForEachColumn([&](int i, ColumnWriter* col) {
+        flushed_values[i] +=
+            Flush(*col, chunks_[i], rows_to_flush, flushed_rows, flushed_values[i]);
+        col->Flush();
+        if (!thread_pool_) {
+          // If it's not multithreaded, we can close a ColumnWriter early as columns will
+          // be written to the output stream sequentially. Doing this early can reduce
+          // peak memory usage.
+          col->Close();
+        }
+      });
+      if (verbose_) {
+        std::cout << rows_to_flush << " rows written in a new row group" << std::endl;
+      }
+      flushed_rows += rows_to_flush;
+      remaining_rows -= rows_to_flush;
+      if (remaining_rows == 0) {
+        break;
+      }
+      sink_ = replace_sink_(std::move(sink_), false);
+    }
+  }
+
+  int32_t Flush(ColumnWriter& col, ColumnChunk& chunk, int32_t rows_to_flush,
+                int32_t flushed_rows, int32_t flushed_values) {
+    if (!chunk.indices) {
+      col.ResetEncoding(Encoding::PLAIN, false);
+      return FlushPlain(col, chunk, rows_to_flush, flushed_rows, flushed_values);
+    }
+
+    const auto dict_data_size = GetDictionarySize(col, chunk);
+    const bool use_dictionary = col.encoding() == Encoding::PLAIN_DICTIONARY ||
+                                col.encoding() == Encoding::RLE_DICTIONARY;
+    const bool write_dictionary = shuffle_writer_properties_->direct_dictionary_write();
+    const auto dictionary_pagesize_limit = col.properties()->dictionary_pagesize_limit();
+    const bool auto_encoding = shuffle_writer_properties_->auto_encoding();
+    std::optional<bool> use_plain_encoding;
+    if (use_dictionary && rows_to_flush == num_rows_ && write_dictionary &&
+        dict_data_size <= static_cast<size_t>(std::numeric_limits<int32_t>::max()) &&
+        dict_data_size <= static_cast<size_t>(dictionary_pagesize_limit)) {
+      use_plain_encoding = auto_encoding && UsePlainEncoding(dict_data_size, chunk);
+      if (!use_plain_encoding.value()) {
+        if (verbose_) {
+          std::cout << "Column " << chunk.column_idx
+                    << ": Flushing dictionary directly (uncompressed dictionary size: "
+                    << dict_data_size << ")" << std::endl;
+        }
+        FlushDictionary(col, chunk);
+        return chunk.num_values;
+      }
+    }
+
+    if (use_dictionary) {
+      if (!use_plain_encoding.has_value()) {
+        use_plain_encoding = auto_encoding && UsePlainEncoding(dict_data_size, chunk);
+      }
+      if (use_plain_encoding.value()) {
+        col.ResetEncoding(Encoding::PLAIN, false);
+      }
+    }
+    if (verbose_) {
+      std::cout << "Column " << chunk.column_idx
+                << ": Decoding dictionary before flushing (uncompressed dictionary size: "
+                << dict_data_size << ")" << std::endl;
+    }
+    return FlushDense(col, chunk, rows_to_flush, flushed_rows, flushed_values);
+  }
+
+  void FlushDictionary(ColumnWriter& col, ColumnChunk& chunk) {
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col.descr()->physical_type(),
+        FlushDictionaryImpl(static_cast<TypedColumnWriter<DType>&>(col), chunk));
+  }
+
+  int32_t FlushDense(ColumnWriter& col, ColumnChunk& chunk, int32_t rows_to_flush,
+                     int32_t flushed_rows, int32_t flushed_values) {
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col.descr()->physical_type(),
+        FlushDenseImpl(static_cast<TypedColumnWriter<DType>&>(col), chunk, rows_to_flush,
+                       flushed_rows, num_rows_, flushed_values, mp_));
+  }
+
+  int32_t FlushPlain(ColumnWriter& col, ColumnChunk& chunk, int32_t rows_to_flush,
+                     int32_t flushed_rows, int32_t flushed_values) {
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col.descr()->physical_type(),
+        FlushPlainImpl(static_cast<TypedColumnWriter<DType>&>(col), chunk, rows_to_flush,
+                       flushed_rows, num_rows_, flushed_values, mp_));
+  }
+
+  bool UsePlainEncoding(size_t dict_data_size, ColumnChunk& chunk) {
+    const uint64_t num_values = static_cast<uint64_t>(chunk.num_indices);
+    const uint64_t num_distinct_values = static_cast<uint64_t>(chunk.num_values);
+    const double avg_size_per_value =
+        static_cast<double>(dict_data_size) / num_distinct_values;
+    const double plain_encoded_size_estimate = num_values * avg_size_per_value;
+    const uint64_t index_bit_width =
+        ::arrow::bit_util::NumRequiredBits(num_distinct_values);
+    const uint64_t indices_encoded_size_estimate =
+        GetRleEncodedIndicesSizeEstimate(*chunk.indices, index_bit_width);
+    const uint64_t dict_encoded_size_estimate =
+        indices_encoded_size_estimate + dict_data_size;
+    const bool use_plain_encoding =
+        plain_encoded_size_estimate < dict_encoded_size_estimate;
+    if (verbose_) {
+      std::cout << "Column " << chunk.column_idx << ": [num_values=" << num_values
+                << ", num_distinct_values=" << num_distinct_values
+                << ", dict_data_size=" << dict_data_size
+                << ", dict_encoded_size_estimate=" << dict_encoded_size_estimate
+                << ", plain_encoded_size_estimate=" << plain_encoded_size_estimate
+                << ", use_plain_encoding=" << use_plain_encoding << "]" << std::endl;
+    }
+    return use_plain_encoding;
+  }
+
+  uint64_t GetDictionarySize(ColumnWriter& col, ColumnChunk& chunk) {
+    return chunk.values_buffer->size() + (col.descr()->physical_type() == Type::BYTE_ARRAY
+                                              ? chunk.num_values * sizeof(uint32_t)
+                                              : 0);
+  }
+
+  template <typename Fun>
+  void ForEachColumn(Fun&& fun, bool parallel = true) {
+    OptionalParallelFor(
+        sink_->num_columns(), [&](int i) { fun(i, sink_->column(i)); },
+        parallel ? thread_pool_.get() : nullptr);
+  }
+
+  template <typename RandomAccessContainer, typename Fun>
+  void ForEach(RandomAccessContainer& container, Fun&& fun, bool parallel = true) {
+    OptionalParallelFor(
+        static_cast<int>(container.size()), [&](int i) { fun(container[i]); },
+        parallel ? thread_pool_.get() : nullptr);
+  }
+
+  MemoryPool* mp_;
+  std::unique_ptr<RowGroupWriter> sink_;
+  std::unique_ptr<Shuffle> shuffle_;
+  ReplaceSink replace_sink_;
+  std::vector<ColumnChunk> chunks_;
+  std::shared_ptr<ThreadPool> thread_pool_;
+  mutable int32_t num_rows_;
+  const int32_t max_row_group_length_;
+  bool needs_complete_permutation_vector_;
+  bool closed_;
+  bool verbose_;
+  ShuffleMetrics* metrics_;
+  std::shared_ptr<const ShuffleWriterProperties> shuffle_writer_properties_;
+};
+
+std::unique_ptr<RowGroupWriter> MakeShuffledRowGroupWriter(
+    std::unique_ptr<RowGroupWriter> sink, std::unique_ptr<Shuffle> shuffle,
+    std::function<std::unique_ptr<RowGroupWriter>(std::unique_ptr<RowGroupWriter>, bool)>
+        replace_sink,
+    const WriterProperties& properties, ShuffleMetrics* metrics) {
+  std::shared_ptr<const ShuffleWriterProperties> shuffle_writer_properties =
+      properties.shuffle_writer_properties();
+  if (!shuffle_writer_properties) {
+    shuffle_writer_properties = std::make_shared<ShuffleWriterProperties>();
+  }
+  const auto max_row_group_length =
+      !shuffle_writer_properties->compatible_api() &&
+              shuffle_writer_properties->split_output_row_group()
+          ? properties.max_row_group_length()
+          : std::numeric_limits<int64_t>::max();
+  return std::make_unique<RowGroupWriter>(std::make_unique<ShuffledRowGroupSerializer>(
+      std::move(sink), std::move(shuffle), std::move(replace_sink), max_row_group_length,
+      metrics, std::move(shuffle_writer_properties)));
+}
+
+}  // namespace shuffle
+}  // namespace parquet
