+class DictionaryEncodingDistinctCountTest : public PrimitiveTypedTest<Int32Type> {
+ protected:
+  void SetValues(std::vector<std::optional<int>> values_with_nulls) {
+    values_.clear();
+    def_levels_.resize(values_with_nulls.size());
+    for (size_t i = 0; i < values_with_nulls.size(); ++i) {
+      if (values_with_nulls[i]) {
+        values_.push_back(*values_with_nulls[i]);
+        def_levels_[i] = 1;
+      } else {
+        def_levels_[i] = 0;
+      }
+    }
+    values_.shrink_to_fit();
+  }
+
+  int64_t GetNullCount() {
+    return static_cast<int64_t>(def_levels_.size() - values_.size());
+  }
+
+  int64_t GetNumValues() { return static_cast<int64_t>(values_.size()); }
+
+  std::shared_ptr<FileMetaData> GetFileMetaData(
+      std::shared_ptr<WriterProperties> properties = default_writer_properties()) {
+    auto sink = CreateOutputStream();
+    {
+      SetUpSchema(Repetition::OPTIONAL, 1);
+      auto schema = std::static_pointer_cast<GroupNode>(node_);
+      auto file_writer = ParquetFileWriter::Open(sink, schema, std::move(properties));
+      auto rg_writer = file_writer->AppendBufferedRowGroup();
+      auto col_writer = static_cast<TypedColumnWriter<Int32Type>*>(rg_writer->column(0));
+      col_writer->WriteBatch(static_cast<int64_t>(def_levels_.size()), def_levels_.data(),
+                             nullptr, values_.data());
+    }
+    PARQUET_ASSIGN_OR_THROW(auto buffer, sink->Finish());
+    auto source = std::make_shared<::arrow::io::BufferReader>(buffer);
+    auto file_reader = ParquetFileReader::Open(source);
+    return file_reader->metadata();
+  }
+
+  struct Expect {
+    int64_t null_count;
+    int64_t num_values;
+    int64_t num_pages;
+    bool fully_dictionary_encoded;
+    std::optional<int64_t> distinct_count;
+  };
+
+  void CheckColumnChunk(const ColumnChunkMetaData& chunk, const Expect& expect) {
+    ASSERT_TRUE(chunk.has_dictionary_page());
+    ASSERT_TRUE(chunk.is_stats_set());
+    std::shared_ptr<Statistics> stats = chunk.statistics();
+
+    // Check num_values and null_count
+    ASSERT_TRUE(stats != nullptr);
+    ASSERT_TRUE(stats->HasNullCount());
+    ASSERT_THAT(stats->null_count(), Eq(expect.null_count));
+    ASSERT_THAT(stats->num_values(), Eq(expect.num_values));
+
+    ASSERT_THAT(IsColumnChunkFullyDictionaryEncoded(chunk),
+                Eq(expect.fully_dictionary_encoded));
+
+    ASSERT_THAT(GetNumPages(chunk), Eq(expect.num_pages));
+
+    if (expect.distinct_count) {
+      ASSERT_TRUE(stats->HasDistinctCount());
+      ASSERT_THAT(stats->distinct_count(), Eq(*expect.distinct_count));
+    } else {
+      ASSERT_FALSE(stats->HasDistinctCount());
+    }
+  }
+
+  int64_t CountDistinct() {
+    std::set<c_type> set;
+    set.insert(values_.begin(), values_.end());
+    return static_cast<int64_t>(set.size());
+  }
+
+  bool IsColumnChunkFullyDictionaryEncoded(const ColumnChunkMetaData& chunk) {
+    const auto& encoding_stats = chunk.encoding_stats();
+    if (!(encoding_stats.size() >= 2 &&
+          encoding_stats[0].page_type == PageType::DICTIONARY_PAGE &&
+          (encoding_stats[0].encoding == Encoding::PLAIN ||
+           encoding_stats[0].encoding == Encoding::PLAIN_DICTIONARY) &&
+          encoding_stats[0].count == 1)) {
+      return false;
+    }
+    for (size_t i = 1; i < encoding_stats.size(); ++i) {
+      const auto& s = encoding_stats[i];
+      if (!((s.page_type == PageType::DATA_PAGE ||
+             s.page_type == PageType::DATA_PAGE_V2) &&
+            (s.encoding == Encoding::RLE_DICTIONARY ||
+             s.encoding == Encoding::PLAIN_DICTIONARY))) {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  int64_t GetNumPages(const ColumnChunkMetaData& chunk) {
+    int64_t num_pages = 0;
+    for (const auto& s : chunk.encoding_stats()) {
+      num_pages += s.count;
+    }
+    return num_pages;
+  }
+};
+
+TEST_F(DictionaryEncodingDistinctCountTest,
+       DistinctCountMustBeSetIfFullyDictionaryEncoded) {
+  SetValues({1, std::nullopt, 2, 3, 0, std::nullopt, 2, 3, std::nullopt});
+  auto metadata = GetFileMetaData();
+  auto chunk = metadata->RowGroup(0)->ColumnChunk(0);
+  Expect expect;
+  expect.null_count = GetNullCount();
+  expect.num_values = GetNumValues();
+  expect.num_pages = 2;
+  expect.fully_dictionary_encoded = true;
+  expect.distinct_count = CountDistinct();
+  CheckColumnChunk(*chunk, expect);
+}
+
+TEST_F(DictionaryEncodingDistinctCountTest,
+       DistinctCountMustBeSetIfFullyDictionaryEncodedWithVOrder) {
+  SetValues({1, std::nullopt, 2, 3, 0, std::nullopt, 2, 3, std::nullopt});
+  auto metadata = GetFileMetaData(WriterProperties::Builder().enable_shuffle()->build());
+  auto chunk = metadata->RowGroup(0)->ColumnChunk(0);
+  Expect expect;
+  expect.null_count = GetNullCount();
+  expect.num_values = GetNumValues();
+  expect.num_pages = 2;
+  expect.fully_dictionary_encoded = true;
+  expect.distinct_count = CountDistinct();
+  CheckColumnChunk(*chunk, expect);
+}
+
+TEST_F(DictionaryEncodingDistinctCountTest,
+       DistinctCountMustBeSetIfFullyDictionaryEncodedWithMultipleDataPages) {
+  SetValues({1, std::nullopt, 2, 3, 0, std::nullopt, 2, 3, std::nullopt});
+  auto metadata = GetFileMetaData(
+      WriterProperties::Builder().write_batch_size(1)->data_pagesize(1)->build());
+  auto chunk = metadata->RowGroup(0)->ColumnChunk(0);
+  Expect expect;
+  expect.null_count = GetNullCount();
+  expect.num_values = GetNumValues();
+  expect.num_pages = 10;  // 1 (dict page) + 9 (one page per value)
+  expect.fully_dictionary_encoded = true;
+  expect.distinct_count = CountDistinct();
+  CheckColumnChunk(*chunk, expect);
+}
+
+TEST_F(DictionaryEncodingDistinctCountTest,
+       DistinctCountMustNotBeSetIfPartiallyDictionaryEncoded) {
+  SetValues({1, std::nullopt, 2, 3, 0, std::nullopt, 2, 3, std::nullopt});
+  auto metadata = GetFileMetaData(WriterProperties::Builder()
+                                      .write_batch_size(1)
+                                      ->dictionary_pagesize_limit(1)
+                                      ->build());
+  auto chunk = metadata->RowGroup(0)->ColumnChunk(0);
+  Expect expect;
+  expect.null_count = GetNullCount();
+  expect.num_values = GetNumValues();
+  expect.num_pages = 3;
+  expect.fully_dictionary_encoded = false;
+  expect.distinct_count = std::nullopt;
+  CheckColumnChunk(*chunk, expect);
+}
+
 }  // namespace test
 }  // namespace parquet
