+                           {"foo", "bar"},
+                           {"foo", "", "bar"},
+                           {"foo", "bar", "baah", "baaaah", ""},
+                           {"", "foo"},
+                           {""},
+                           {},
+                           {"", "foo", "foo", "foo", "foo", "foo"},
+                       })}),
+                       args, props_builder.build());
+  EXPECT_THAT(GetEmptyStringDictionaryIndex(slice, key, 0), "-1");
+  EXPECT_THAT(GetEmptyStringDictionaryIndex(slice, key, 1), "1");
+  EXPECT_THAT(GetEmptyStringDictionaryIndex(slice, key, 2), "4");
+  EXPECT_THAT(GetEmptyStringDictionaryIndex(slice, key, 3), "0");
+  EXPECT_THAT(GetEmptyStringDictionaryIndex(slice, key, 4), "0");
+  EXPECT_THAT(GetEmptyStringDictionaryIndex(slice, key, 5), "-1");
