diff --git a/cpp/run_vorder_perf_tests.sh b/cpp/run_vorder_perf_tests.sh
new file mode 100755
index 0000000000..956d4359fe
--- /dev/null
+++ b/cpp/run_vorder_perf_tests.sh
@@ -0,0 +1,84 @@
+#!/bin/env bash
+set -euox pipefail
+
+PARQUET_SHUFFLE_BIN=${BUILD_DIR:-"out/release/release/parquet-shuffle"}
+STORAGE_ACCOUNT=${STORAGE_ACCOUNT:-"arrowsawu2"}
+STORAGE_CONTAINER=${STORAGE_CONTAINER:-"perf"}
+STORAGE_PATH=${STORAGE_PATH:-"vorder_perf_datasets"}
+DOWNLOAD_DIR=${DOWNLOAD_DIR:-"/tmp/vorder_perf_tests/datasets"}
+LOGGING_DIR=${LOGGING_DIR:-"/tmp/vorder_perf_tests/logs"}
+SKIP_DOWNLOAD=${SKIP_DOWNLOAD:-"false"}
+AZURE_STORAGE_SAS_TOKEN=${AZURE_STORAGE_SAS_TOKEN:-""}
+
+mkdir -p "$DOWNLOAD_DIR"
+mkdir -p "$LOGGING_DIR"
+
+if [ "$SKIP_DOWNLOAD" == "false" ]; then
+  if [ "$AZURE_STORAGE_SAS_TOKEN" == "" ]; then
+    echo "AZURE_STORAGE_SAS_TOKEN not found in environment. Generating it with Azure CLI"
+    timestamp=$(date -u -d '6 hours' '+%Y-%m-%dT%H:%MZ')
+    if command -v powershell.exe &> /dev/null; then
+      echo "Using powershell.exe to generate SAS token"
+      export AZURE_STORAGE_SAS_TOKEN=$(powershell.exe -Command "az storage container generate-sas \`
+        --account-name $STORAGE_ACCOUNT \`
+        --name $STORAGE_CONTAINER \`
+        --permissions acdlrw \`
+        --expiry '$timestamp' \`
+        --auth-mode login \`
+        --as-user \`
+        -o tsv
+      ")
+    else
+      export AZURE_STORAGE_SAS_TOKEN=$(az storage container generate-sas \
+        --account-name $STORAGE_ACCOUNT \
+        --name $STORAGE_CONTAINER \
+        --permissions acdlrw \
+        --expiry '$timestamp' \
+        --auth-mode login \
+        --as-user \
+        -o tsv
+      )
+    fi
+    if [ "$AZURE_STORAGE_SAS_TOKEN" == "" ]; then
+      echo "Failed to generate SAS token. Check if you're logged in with the correct account."
+      exit 1z
+    fi
+    echo "Generated SAS token"
+  fi
+
+  echo "Downloading datasets..."
+  az storage blob download-batch \
+    --account-name $STORAGE_ACCOUNT \
+    --source $STORAGE_CONTAINER \
+    --pattern "$STORAGE_PATH/*.parquet" \
+    --destination "$DOWNLOAD_DIR/"
+else
+  echo "Skipped downloading datasets (SKIP_DOWNLOAD=$SKIP_DOWNLOAD)"
+fi
+
+results=()
+for f in "$DOWNLOAD_DIR/$STORAGE_PATH"/*.parquet; do
+  echo "Running parquet-shuffle on parquet file: $f"
+  filename=$(basename "$f")
+  stdout_file_path="$LOGGING_DIR/logs_${filename}_stdout_$$.txt"
+  stderr_file_path="$LOGGING_DIR/logs_${filename}_stderr_$$.txt"
+  ls -al "$f" >> "$stdout_file_path"
+  /usr/bin/time -v "$PARQUET_SHUFFLE_BIN" "$f" -num_threads 1 -verbose >> "$stdout_file_path" 2>> "$stderr_file_path"
+  elapsed_time=$(cat "$stderr_file_path" | grep 'Elapsed' | sed 's/.*(h:mm:ss or m:ss): \(.*\)$/\1/')
+  max_rss_kb=$(cat "$stderr_file_path" | grep 'Maximum resident set size' | sed 's/.*Maximum resident set size (kbytes): \(.*\)$/\1/')
+  original_uncompressed_size_bytes=$(cat "$stdout_file_path" | grep -A5 'Before:' | grep 'Uncompressed' | sed 's/.*Uncompressed size: \(.*\) bytes.*/\1/')
+  original_compressed_size_bytes=$(cat "$stdout_file_path" | grep -A5 'Before:' | grep 'Compressed' | sed 's/.*Compressed size: \(.*\) bytes.*/\1/')
+  vorder_uncompressed_size_bytes=$(cat "$stdout_file_path" | grep -A5 'After:' | grep 'Uncompressed' | sed 's/.*Uncompressed size: \(.*\) bytes.*/\1/')
+  vorder_compressed_size_bytes=$(cat "$stdout_file_path" | grep -A5 'After:' | grep 'Compressed' | sed 's/.*Compressed size: \(.*\) bytes.*/\1/')
+  result='{"file":"'"$filename"'"'
+  result+=',"elapsed_time":"'"$elapsed_time"'"'
+  result+=',"max_rss_kb":'"$max_rss_kb"
+  result+=',"original_uncompressed_size_bytes":'"$original_uncompressed_size_bytes"
+  result+=',"original_compressed_size_bytes":'"$original_compressed_size_bytes"
+  result+=',"vorder_uncompressed_size_bytes":'"$vorder_uncompressed_size_bytes"
+  result+=',"vorder_compressed_size_bytes":'"$vorder_compressed_size_bytes"
+  result+='}'
+  results+=($result)
+done
+printf '[%s]\n' "$(IFS=,; echo "${results[*]}")" | jq > results.json
+echo "Results are written to $(realpath results.json)"
