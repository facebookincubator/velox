+// NOLINT legal/copyright
+
+#pragma once
+
+#include "parquet/types.h"
+
+#include "parquet/shuffle/util/span.h"
+
+namespace parquet {
+namespace shuffle {
+
+class ByteArrayView {
+ public:
+  ByteArrayView(const uint8_t* values, int64_t num_values, Span<const int32_t> offsets)
+      : values_(values), num_values_(num_values), offsets_(offsets) {}
+
+  class ByteArrayViewIterator {
+   public:
+    ByteArrayViewIterator(const ByteArrayView* view, int64_t index)
+        : view_(view), index_(index) {}
+
+    bool operator!=(const ByteArrayViewIterator& rhs) const {
+      return index_ != rhs.index_;
+    }
+
+    ByteArrayViewIterator& operator++() {
+      ++index_;
+      return *this;
+    }
+
+    ByteArray operator*() {
+      return {
+          static_cast<uint32_t>(view_->offsets_[index_ + 1] - view_->offsets_[index_]),
+          view_->values_ + view_->offsets_[index_]};
+    }
+
+   private:
+    const ByteArrayView* view_;
+    int64_t index_;
+  };
+
+  ByteArrayViewIterator begin() const { return ByteArrayViewIterator(this, 0); }
+  ByteArrayViewIterator end() const { return ByteArrayViewIterator(this, num_values_); }
+  int64_t size() const { return num_values_; }
+
+ private:
+  const uint8_t* values_;
+  int64_t num_values_;
+  Span<const int32_t> offsets_;
+};
+
+class FLBAView {
+ public:
+  FLBAView(const uint8_t* values, int64_t num_values, int type_length)
+      : values_(values), num_values_(num_values), type_length_(type_length) {}
+
+  class FLBAViewIterator {
+   public:
+    FLBAViewIterator(const FLBAView* view, int64_t index) : view_(view), index_(index) {}
+
+    bool operator!=(const FLBAViewIterator& rhs) const { return index_ != rhs.index_; }
+
+    FLBAViewIterator& operator++() {
+      ++index_;
+      return *this;
+    }
+
+    FLBA operator*() { return FLBA(view_->values_ + index_ * view_->type_length_); }
+
+   private:
+    const FLBAView* view_;
+    int64_t index_;
+  };
+
+  FLBAViewIterator begin() const { return FLBAViewIterator(this, 0); }
+  FLBAViewIterator end() const { return FLBAViewIterator(this, num_values_); }
+  int64_t size() const { return num_values_; }
+
+ private:
+  const uint8_t* values_;
+  int64_t num_values_;
+  int type_length_;
+};
+
+}  // namespace shuffle
+}  // namespace parquet
