+
+  static constexpr int rowsCount = TypeParam::rowsCount;
+  static constexpr Type::type type_num = data_type::type_num;
+  static constexpr bool dropLevelsDefinitions = TypeParam::dropLevelsDefinitions;
+
+ protected:
+  void TestSingleColumn(size_t numberOfRowGorups, size_t numberOfBatches) {
+    parquet::test::RawMetadata metadata{
+        numberOfRowGorups, nullopt, nullopt, nullopt, true, nullopt, nullopt, nullopt};
+
+    Vec<Vec<Vec<parquet::test::RawBatch>>> batches;
+    Vec<c_type> values;
+    Vec<int16_t> def_levels;
+    Vec<int16_t> rep_levels;
+    Vec<std::unique_ptr<Buffer>> byte_array_buffers;
+    for (size_t rgi = 0; rgi < numberOfRowGorups; rgi++) {
+      batches.emplace_back(Vec<Vec<parquet::test::RawBatch>>());
+      auto& rg = batches.back();
+      rg.emplace_back(Vec<parquet::test::RawBatch>{parquet::test::RawBatch(
+          rowsCount, useSpacedWrite, dropLevelsDefinitions, true)});
+      for (size_t bi = 0; bi < numberOfBatches; bi++) {
+        Vec<int16_t> cur_def_levels;
+        Vec<c_type> cur_values;
+        TypeParam::generateData(rowsCount, TypeParam::nullsFraction, cur_values,
+                                cur_def_levels, byte_array_buffers,
+                                static_cast<int>(1000 * rgi + bi));
+        Vec<int16_t> cur_rep_levels(rowsCount, 0);
+
+        def_levels.insert(def_levels.end(), cur_def_levels.begin(), cur_def_levels.end());
+        rep_levels.insert(rep_levels.end(), cur_rep_levels.begin(), cur_rep_levels.end());
+        values.insert(values.end(), cur_values.begin(), cur_values.end());
+      }
+    }
+
+    Vec<parquet::test::DataPointers> datapointers_per_column{parquet::test::DataPointers(
+        parquet::test::CircularMemoryStream(reinterpret_cast<uint8_t*>(def_levels.data()),
+                                            def_levels.size() * sizeof(int16_t), 0),
+        parquet::test::CircularMemoryStream(reinterpret_cast<uint8_t*>(rep_levels.data()),
+                                            rep_levels.size() * sizeof(int16_t), 0),
+        parquet::test::CircularMemoryStream(reinterpret_cast<uint8_t*>(values.data()),
+                                            values.size() * sizeof(c_type), 0))};
+
+    schema::NodeVector fields{schema::PrimitiveNode::Make("col", TypeParam::repetition,
+                                                          type_num, ConvertedType::NONE,
+                                                          TypeParam::byteArrayLength)};
+
+    parquet::test::RunEndToEndTest(metadata, batches, datapointers_per_column, fields);
+  }
+
+  void TestMultipleColumns(const size_t columnsCount) {
+    Vec<std::unique_ptr<Buffer>> byte_array_buffers;
+
+    parquet::test::RawMetadata metadata{1,    nullopt, nullopt, nullopt,
+                                        true, nullopt, nullopt, nullopt};
+
+    Vec<Vec<Vec<parquet::test::RawBatch>>> batches{Vec<Vec<parquet::test::RawBatch>>()};
+    auto& rg = batches.back();
+    for (size_t ci = 0; ci < columnsCount; ci++) {
+      rg.emplace_back(Vec<parquet::test::RawBatch>{parquet::test::RawBatch(
+          rowsCount, useSpacedWrite, dropLevelsDefinitions, true)});
+    }
+
+    Vec<c_type> values;
+    Vec<int16_t> def_levels;
+    Vec<int16_t> rep_levels(rowsCount, 0);
+    TypeParam::generateData(rowsCount, TypeParam::nullsFraction, values, def_levels,
+                            byte_array_buffers, 0);
+
+    schema::NodeVector fields;
+    Vec<parquet::test::DataPointers> datapointers_per_column;
+    for (size_t col = 0; col < columnsCount; col++) {
+      fields.emplace_back(schema::PrimitiveNode::Make(
+          "col" + std::to_string(col), TypeParam::repetition, type_num,
+          ConvertedType::NONE, TypeParam::byteArrayLength));
+      datapointers_per_column.emplace_back(parquet::test::DataPointers(
+          parquet::test::CircularMemoryStream(
+              reinterpret_cast<uint8_t*>(def_levels.data()),
+              def_levels.size() * sizeof(int16_t), 0),
+          parquet::test::CircularMemoryStream(
+              reinterpret_cast<uint8_t*>(rep_levels.data()),
+              rep_levels.size() * sizeof(int16_t), 0),
+          parquet::test::CircularMemoryStream(reinterpret_cast<uint8_t*>(values.data()),
+                                              values.size() * sizeof(c_type), 0)));
+    }
+    parquet::test::RunEndToEndTest(metadata, batches, datapointers_per_column, fields);
+  }
+};
