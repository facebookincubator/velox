+template <typename ArrowType, typename T = typename ::arrow::TypeTraits<ArrowType>::CType>
+std::shared_ptr<::arrow::Array> MakeArray(
+    std::shared_ptr<::arrow::DataType> type,
+    const std::vector<std::optional<T>>& nullable_values) {
+  std::vector<bool> is_valid;
+  std::vector<T> values;
+  for (const auto& v : nullable_values) {
+    if (v.has_value()) {
+      is_valid.emplace_back(true);
+      values.emplace_back(v.value());
+    } else {
+      is_valid.emplace_back(false);
+      values.emplace_back();
+    }
+  }
+  std::shared_ptr<::arrow::Array> array;
+  ::arrow::ArrayFromVector<ArrowType, T>(type, is_valid, values, &array);
+  return array;
+}
+
+template <typename DType>
+schema::NodePtr CreateField(std::string name,
+                            std::shared_ptr<const LogicalType> logical_type) {
+  const auto primitive_length =
+      logical_type && logical_type->is_decimal()
+          ? ::arrow::DecimalType::DecimalSize(
+                static_cast<const DecimalLogicalType&>(*logical_type).precision())
+          : -1;
+  return schema::PrimitiveNode::Make(name, Repetition::OPTIONAL, logical_type,
+                                     DType::type_num, primitive_length, -1);
+}
+
+template <typename DType>
+std::shared_ptr<schema::GroupNode> CreateSingleColumnSchema(
+    std::string col_name, std::shared_ptr<const LogicalType> logical_type) {
+  schema::NodeVector fields;
+  fields.emplace_back(CreateField<DType>(col_name, logical_type));
+  return std::static_pointer_cast<schema::GroupNode>(schema::GroupNode::Make(
+      "schema", Repetition::REQUIRED, fields, ConvertedType::NONE, 0));
+}
+
+template <typename DType>
+std::shared_ptr<const KeyValueMetadata> WriteAndGetKeyValueMetadata(
+    std::string col_name, std::shared_ptr<const LogicalType> logical_type,
+    std::function<void(ParquetFileWriter&)> write_callback,
+    int string_prefix_length = 32) {
+  std::shared_ptr<::arrow::Buffer> data;
+  {
+    auto out = CreateOutputStream();
+    auto writer = ParquetFileWriter::Open(
+        out, CreateSingleColumnSchema<DType>(col_name, logical_type),
+        WriterProperties::Builder()
+            .enable_delta_stats()
+            ->delta_stats_string_prefix_length(string_prefix_length)
+            ->build());
+    write_callback(*writer);
+    writer->Close();
+    PARQUET_ASSIGN_OR_THROW(data, out->Finish());
+  }
+  auto reader =
+      ParquetFileReader::Open(std::make_shared<::arrow::io::BufferReader>(data));
+  return reader->metadata()->key_value_metadata();
+}
+
+template <typename DType>
+std::shared_ptr<const KeyValueMetadata> WriteAndGetKeyValueMetadata(
+    std::string col_name, std::vector<typename DType::c_type> values,
+    std::shared_ptr<const LogicalType> logical_type = nullptr,
+    int string_prefix_length = 32) {
+  return WriteAndGetKeyValueMetadata<DType>(
+      col_name, logical_type,
+      [&](ParquetFileWriter& writer) {
+        auto rg_writer = writer.AppendBufferedRowGroup();
+        auto& col_writer = static_cast<TypedColumnWriter<DType>&>(*rg_writer->column(0));
+        col_writer.WriteBatch(static_cast<int64_t>(values.size()), nullptr, nullptr,
+                              values.data());
+        col_writer.Close();
+        rg_writer->Close();
+      },
+      string_prefix_length);
+}
+
+template <typename DType>
+std::shared_ptr<const KeyValueMetadata> WriteAndGetKeyValueMetadata(
+    std::string col_name, std::shared_ptr<::arrow::Array> values,
+    std::shared_ptr<const LogicalType> logical_type = nullptr,
+    int string_prefix_length = 32) {
+  return WriteAndGetKeyValueMetadata<DType>(
+      col_name, logical_type,
+      [&](ParquetFileWriter& writer) {
+        auto arrow_writer_properties = ArrowWriterProperties::Builder().build();
+        auto field = ::arrow::field(col_name, values->type(), /*nullable=*/true);
+        auto schema = ::arrow::schema({field});
+        auto batch = ::arrow::RecordBatch::Make(schema, values->length(), {values});
+        auto rg_writer = writer.AppendBufferedRowGroup();
+        PARQUET_THROW_NOT_OK(arrow::WriteRecordBatch(*batch, 0, batch->num_rows(),
+                                                     *rg_writer, writer.schema(),
+                                                     *arrow_writer_properties));
+        rg_writer->Close();
+      },
+      string_prefix_length);
+}
+
+std::shared_ptr<const FileMetaData> WriteAndGetMetadata(
+    std::shared_ptr<WriterProperties> properties, std::shared_ptr<::arrow::Schema> schema,
+    std::string json) {
+  auto sink = CreateOutputStream();
+  {
+    auto arrow_properties = default_arrow_writer_properties();
+    std::shared_ptr<SchemaDescriptor> parquet_schema;
+    PARQUET_THROW_NOT_OK(arrow::ToParquetSchema(schema.get(), *properties,
+                                                *arrow_properties, &parquet_schema));
+    auto schema_node =
+        std::static_pointer_cast<schema::GroupNode>(parquet_schema->schema_root());
+    auto writer = ParquetFileWriter::Open(sink, schema_node, properties);
+    auto table = ::arrow::TableFromJSON(schema, {json});
+    std::shared_ptr<::arrow::RecordBatch> record_batch;
+    PARQUET_THROW_NOT_OK(::arrow::TableBatchReader(table).ReadNext(&record_batch));
+    const auto max_row_group_length = properties->max_row_group_length();
+    auto offset = 0;
+    while (offset < record_batch->num_rows()) {
+      const auto rows_to_write =
+          std::min(record_batch->num_rows() - offset, max_row_group_length);
+      auto rg_writer = writer->AppendBufferedRowGroup();
+      PARQUET_THROW_NOT_OK(arrow::WriteRecordBatch(*record_batch, offset, rows_to_write,
+                                                   *rg_writer, parquet_schema.get(),
+                                                   *arrow_properties));
+      rg_writer->Close();
+      offset += rows_to_write;
+    }
+    writer->Close();
+  }
+  std::shared_ptr<::arrow::Buffer> data;
+  PARQUET_ASSIGN_OR_THROW(data, sink->Finish());
+  auto reader =
+      ParquetFileReader::Open(std::make_shared<::arrow::io::BufferReader>(data));
+  return reader->metadata();
+}
+
+std::shared_ptr<const KeyValueMetadata> WriteAndGetKeyValueMetadata(
+    std::shared_ptr<::arrow::Schema> schema, std::string json) {
+  auto properties =
+      WriterProperties::Builder().enable_delta_stats()->max_row_group_length(3)->build();
+  return WriteAndGetMetadata(properties, schema, json)->key_value_metadata();
+}
