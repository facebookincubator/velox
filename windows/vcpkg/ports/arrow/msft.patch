+// NOLINT legal/copyright
+
+#include <jni.h>
+
+#include <iostream>
+
+#include "arrow/array.h"
+#include "arrow/filesystem/filesystem.h"
+#include "arrow/filesystem/path_util.h"
+#include "arrow/io/file.h"
+#include "arrow/io/memory.h"
+#include "arrow/ipc/reader.h"
+#include "arrow/util/compression.h"
+#include "arrow/util/io_util.h"
+#include "arrow/util/key_value_metadata.h"
+#include "parquet/api/writer.h"
+#include "parquet/arrow/schema.h"
+#include "parquet/arrow/writer.h"
+#include "parquet/platform.h"
+#include "parquet/schema_util.h"
+
+namespace parquet {
+namespace jni {
+
+using ::arrow::RecordBatch;
+using ::arrow::Schema;
+using ::arrow::fs::FileSystemFromUri;
+using ::arrow::io::BufferReader;
+using ::arrow::ipc::IpcReadOptions;
+using ::arrow::ipc::ReadRecordBatch;
+using ::arrow::ipc::ReadSchema;
+
+// Should be in sync with SparkNativeParquetWriter
+enum ParquetOutputTimestampType {
+  INT96 = 0,
+  TIMESTAMP_MICROS = 1,
+  TIMESTAMP_MILLIS = 2,
+};
+
+struct ParquetWriterContext {
+  std::unique_ptr<ParquetFileWriter> file_writer;
+  RowGroupWriter* rg_writer;
+  std::shared_ptr<Schema> arrow_schema;
+  std::shared_ptr<ArrowWriterProperties> arrow_properties;
+  int64_t block_size;
+  int64_t max_buffered_bytes;
+  ParquetOutputTimestampType output_timestamp_type;
+  bool verbose;
+};
+
+class JavaStringUTFChars {
+ public:
+  JavaStringUTFChars(JNIEnv* jenv, jstring jstring)
+      : jenv_(jenv), jstring_(jstring), utf_(jenv->GetStringUTFChars(jstring, nullptr)) {}
+
+  ~JavaStringUTFChars() { jenv_->ReleaseStringUTFChars(jstring_, utf_); }
+
+  const char* get() const { return utf_; }
+
+ private:
+  JNIEnv* jenv_;
+  jstring jstring_;
+  const char* utf_;
+};
+
+JavaStringUTFChars GetStringUTFChars(JNIEnv* jenv, jstring jstring) {
+  return {jenv, jstring};
+}
+
+// Note: During the lifetime of this object, JNI calls should not be made, if
+// GetPrimitiveArrayCritical is used. Check out GetPrimitiveArrayCritical for more
+// information.
+template <typename ArrayTraits>
+class JavaArray {
+ public:
+  using ArrayType = typename ArrayTraits::ArrayType;
+  using ElementType = typename ArrayTraits::ElementType;
+
+  JavaArray(JNIEnv* jenv, ArrayType jarray)
+      : JavaArray(jenv, jarray, jenv->GetArrayLength(jarray)) {}
+
+  JavaArray(JNIEnv* jenv, ArrayType jarray, jsize length)
+      : jenv_(jenv),
+        jarray_(jarray),
+        size_(length),
+        elements_(
+            static_cast<ElementType*>((jenv->*ArrayTraits::get)(jarray_, nullptr))) {
+    if (elements_ == nullptr) {
+      throw ParquetException("GetPrimitiveArrayCritical returned null");
+    }
+  }
+
+  ~JavaArray() { (jenv_->*ArrayTraits::release)(jarray_, elements_, JNI_ABORT); }
+
+  Buffer get() const { return {reinterpret_cast<const uint8_t*>(elements_), size_}; }
+
+  const ElementType* data() const { return elements_; }
+
+  jsize size() const { return size_; }
+
+ private:
+  JNIEnv* jenv_;
+  ArrayType jarray_;
+  jsize size_;
+  ElementType* elements_;
+};
+
+struct BooleanArrayCriticalTraits {
+  using ArrayType = jbooleanArray;
+  using ElementType = jboolean;
+  static constexpr auto get = &JNIEnv::GetPrimitiveArrayCritical;
+  static constexpr auto release = &JNIEnv::ReleasePrimitiveArrayCritical;
+};
+
+struct ByteArrayCriticalTraits {
+  using ArrayType = jbyteArray;
+  using ElementType = jbyte;
+  static constexpr auto get = &JNIEnv::GetPrimitiveArrayCritical;
+  static constexpr auto release = &JNIEnv::ReleasePrimitiveArrayCritical;
+};
+
+using JavaBooleanArrayCritical = JavaArray<BooleanArrayCriticalTraits>;
+using JavaByteArrayCritical = JavaArray<ByteArrayCriticalTraits>;
+
+JavaBooleanArrayCritical GetBooleanArrayCritical(JNIEnv* jenv, jbooleanArray jarray) {
+  return {jenv, jarray};
+}
+
+JavaByteArrayCritical GetByteArrayCritical(JNIEnv* jenv, jbyteArray jarray, jint length) {
+  return {jenv, jarray, static_cast<jsize>(length)};
+}
+
+std::shared_ptr<Schema> GetSchema(JNIEnv* jenv, jbyteArray jarrow_schema, jint length) {
+  auto arrow_schema_bytes = GetByteArrayCritical(jenv, jarrow_schema, length);
+  BufferReader reader(arrow_schema_bytes.get());
+  PARQUET_ASSIGN_OR_THROW(auto arrow_schema, ReadSchema(&reader, nullptr));
+  return arrow_schema;
+}
+
+// RecordBatch should outlive the content of the buffer
+std::shared_ptr<RecordBatch> GetRecordBatch(JNIEnv* jenv, const Buffer& buffer,
+                                            const std::shared_ptr<Schema>& schema) {
+  BufferReader reader(buffer);
+  PARQUET_ASSIGN_OR_THROW(
+      auto record_batch,
+      ReadRecordBatch(schema, nullptr, IpcReadOptions::Defaults(), &reader));
+  return record_batch;
+}
+
+std::shared_ptr<ArrowWriterProperties> GetArrowProperties(
+    ParquetOutputTimestampType output_timestamp_type) {
+  ArrowWriterProperties::Builder arrow_props_builder;
+  if (output_timestamp_type == INT96) {
+    arrow_props_builder.enable_deprecated_int96_timestamps();
+  } else if (output_timestamp_type == TIMESTAMP_MICROS) {
+    arrow_props_builder.coerce_timestamps(::arrow::TimeUnit::MICRO);
+  } else if (output_timestamp_type == TIMESTAMP_MILLIS) {
+    arrow_props_builder.coerce_timestamps(::arrow::TimeUnit::MILLI);
+    arrow_props_builder.allow_truncated_timestamps();
+    arrow_props_builder.use_spark_timestamp_truncation();
+  }
+  return arrow_props_builder.build();
+}
+
+std::shared_ptr<schema::GroupNode> GetParquetSchema(JNIEnv* jenv,
+                                                    jbyteArray jparquet_schema,
+                                                    jint length) {
+  auto parquet_schema_bytes = GetByteArrayCritical(jenv, jparquet_schema, length);
+  uint32_t len = static_cast<uint32_t>(length);
+  return util::DeserializeSchema(Buffer(parquet_schema_bytes.get().data(), len));
+}
+
+std::shared_ptr<ArrowOutputStream> OpenOutputStream(const std::string& path) {
+  std::string fs_path;
+  PARQUET_ASSIGN_OR_THROW(auto fs, FileSystemFromUri(path, &fs_path));
+  PARQUET_ASSIGN_OR_THROW(auto fi, fs->GetFileInfo(fs_path));
+  PARQUET_THROW_NOT_OK(fs->CreateDir(fi.dir_name()));
+  PARQUET_ASSIGN_OR_THROW(auto out, fs->OpenOutputStream(fs_path));
+  return out;
+}
+
+Compression::type GetCompressionType(const std::string& name) {
+  if (name == "SNAPPY") {
+    return Compression::SNAPPY;
+  } else if (name == "UNCOMPRESSED") {
+    return Compression::UNCOMPRESSED;
+  } else if (name == "GZIP") {
+    return Compression::GZIP;
+  } else if (name == "ZSTD") {
+    return Compression::ZSTD;
+  } else if (name == "BROTLI") {
+    return Compression::BROTLI;
+  } else if (name == "LZO") {
+    return Compression::LZO;
+  } else if (name == "LZ4") {
+    return Compression::LZ4_HADOOP;
+  } else {
+    throw ParquetException("Unrecognized compression type: " + name);
+  }
+}
+
+ParquetVersion::type GetWriterVersion(int writer_version) {
+  switch (writer_version) {
+    case 1:
+      return ParquetVersion::PARQUET_1_0;
+    case 2:
+      return ParquetVersion::PARQUET_2_LATEST;
+    default:
+      throw ParquetException("Unrecognized writer verseion: " +
+                             std::to_string(writer_version));
+  }
+}
+
+std::shared_ptr<const KeyValueMetadata> BuildKeyValueMetadata(
+    JNIEnv* jenv, jobjectArray jextra_metadata_keys,
+    jobjectArray jextra_metadata_values) {
+  auto metadata = std::make_shared<KeyValueMetadata>();
+  const auto length = jenv->GetArrayLength(jextra_metadata_keys);
+  if (length != jenv->GetArrayLength(jextra_metadata_values)) {
+    throw ParquetException("Number of metadata keys and values don't match");
+  }
+  for (jsize i = 0; i < length; ++i) {
+    auto key = jenv->GetObjectArrayElement(jextra_metadata_keys, i);
+    auto value = jenv->GetObjectArrayElement(jextra_metadata_values, i);
+    auto key_utf_chars = GetStringUTFChars(jenv, static_cast<jstring>(key));
+    auto value_utf_chars = GetStringUTFChars(jenv, static_cast<jstring>(value));
+    metadata->Append(key_utf_chars.get(), value_utf_chars.get());
+  }
+  return metadata;
+}
+
+ParquetWriterContext* GetParquetWriterContext(JNIEnv* jenv, jobject jwriter) {
+  auto jclass = jenv->GetObjectClass(jwriter);
+  auto jfield = jenv->GetFieldID(jclass, "ptr", "J");
+  const auto ptr = jenv->GetLongField(jwriter, jfield);
+  return reinterpret_cast<ParquetWriterContext*>(ptr);
+}
+
+void SetDictionaryEnabledPerColumn(JNIEnv* jenv,
+                                   jobjectArray jdictionary_enabled_map_paths,
+                                   jbooleanArray jdictionary_enabled_map_values,
+                                   WriterProperties::Builder& props_builder) {
+  const auto length = jenv->GetArrayLength(jdictionary_enabled_map_paths);
+  auto dictionary_enabled = GetBooleanArrayCritical(jenv, jdictionary_enabled_map_values);
+  if (length != dictionary_enabled.size()) {
+    throw ParquetException(
+        "Number of column paths and dictionary enabled values don't match");
+  }
+  const auto values = dictionary_enabled.data();
+  for (jsize i = 0; i < length; ++i) {
+    auto path_str = jenv->GetObjectArrayElement(jdictionary_enabled_map_paths, i);
+    auto path_utf_chars = GetStringUTFChars(jenv, static_cast<jstring>(path_str));
+    auto path = schema::ColumnPath::FromDotString(path_utf_chars.get());
+    if (values[i]) {
+      props_builder.enable_dictionary(path);
+    } else {
+      props_builder.disable_dictionary(path);
+    }
+  }
+}
+
+void ResetParquetWriterContext(JNIEnv* jenv, jobject jwriter) {
+  auto jclass = jenv->GetObjectClass(jwriter);
+  auto jfield = jenv->GetFieldID(jclass, "ptr", "J");
+  jenv->SetLongField(jwriter, jfield, 0);
+}
+
+void ThrowJavaException(JNIEnv* jenv, const char* type, const char* message) {
+  jclass cls = jenv->FindClass(type);
+  if (cls != nullptr) {
+    jenv->ThrowNew(cls, message);
+  }
+}
+
+jlong InitImpl(JNIEnv* jenv, jobject, jstring jpath, jbyteArray jparquet_schema,
+               jint parquet_schema_len, jbyteArray jarrow_schema, jint arrow_schema_len,
+               jint num_threads, jboolean enable_shuffle, jint shuffle_level,
+               jboolean shuffle_auto_encoding, jlong block_size,
+               jint output_timestamp_type, jlong max_buffered_bytes,
+               jint dictionary_page_size, jstring jcompression, jint page_size,
+               jint statistics_truncate_length, jboolean dictionary_enabled,
+               jobjectArray jdictionary_enabled_map_paths,
+               jbooleanArray jdictionary_enabled_map_values, jint writer_version,
+               jobjectArray jextra_metadata_keys, jobjectArray jextra_metadata_values,
+               jboolean verbose) {
+  auto path_utf_chars = GetStringUTFChars(jenv, jpath);
+  auto out = OpenOutputStream(path_utf_chars.get());
+
+  WriterProperties::Builder props_builder;
+  if (enable_shuffle) {
+    props_builder.enable_shuffle();
+    props_builder.shuffle_level(shuffle_level);
+    props_builder.shuffle_threads(static_cast<uint16_t>(num_threads));
+    props_builder.shuffle_auto_encoding(static_cast<bool>(shuffle_auto_encoding));
+  } else {
+    props_builder.disable_shuffle();
+  }
+  props_builder.dictionary_pagesize_limit(dictionary_page_size);
+  auto compression_utf_chars = GetStringUTFChars(jenv, jcompression);
+  props_builder.compression(GetCompressionType(compression_utf_chars.get()));
+  props_builder.data_pagesize(page_size);
+  props_builder.max_statistics_size(statistics_truncate_length);
+  if (dictionary_enabled) {
+    props_builder.enable_dictionary();
+  } else {
+    props_builder.disable_dictionary();
+  }
+  SetDictionaryEnabledPerColumn(jenv, jdictionary_enabled_map_paths,
+                                jdictionary_enabled_map_values, props_builder);
+  props_builder.version(GetWriterVersion(writer_version));
+  auto properties = props_builder.build();
+
+  auto arrow_schema = GetSchema(jenv, jarrow_schema, arrow_schema_len);
+  auto arrow_properties =
+      GetArrowProperties(static_cast<ParquetOutputTimestampType>(output_timestamp_type));
+  auto schema = GetParquetSchema(jenv, jparquet_schema, parquet_schema_len);
+  auto key_value_metadata =
+      BuildKeyValueMetadata(jenv, jextra_metadata_keys, jextra_metadata_values);
+  auto file_writer =
+      ParquetFileWriter::Open(std::move(out), std::move(schema), std::move(properties),
+                              std::move(key_value_metadata));
+  return reinterpret_cast<jlong>(new ParquetWriterContext{
+      std::move(file_writer), nullptr, std::move(arrow_schema),
+      std::move(arrow_properties), block_size, max_buffered_bytes,
+      static_cast<ParquetOutputTimestampType>(output_timestamp_type),
+      static_cast<bool>(verbose)});
+}
+
+void PrintDebugInfo(const ParquetWriterContext& ctx) {
+  std::cout << "ctx=" << &ctx << ", rg_writer=" << ctx.rg_writer;
+  if (ctx.rg_writer != nullptr) {
+    std::cout << ", num_rows()=" << ctx.rg_writer->num_rows()
+              << ", total_compressed_bytes()=" << ctx.rg_writer->total_compressed_bytes()
+              << ", total_bytes_written()=" << ctx.rg_writer->total_bytes_written()
+              << ", estimated_size()=" << ctx.rg_writer->estimated_size()
+              << ", estimated_memory_usage()=" << ctx.rg_writer->estimated_memory_usage()
+              << std::endl;
+  } else {
+    std::cout << std::endl;
+  }
+}
+
+void WriteImpl(JNIEnv* jenv, jobject jwriter, jbyteArray jarrow_record_batch,
+               jint arrow_record_batch_length) {
+  auto ctx = GetParquetWriterContext(jenv, jwriter);
+  if (ctx == nullptr) {
+    throw ParquetException("Writer is uninitialized or closed");
+  }
+  auto arrow_record_batch_bytes =
+      GetByteArrayCritical(jenv, jarrow_record_batch, arrow_record_batch_length);
+  auto record_batch =
+      GetRecordBatch(jenv, arrow_record_batch_bytes.get(), ctx->arrow_schema);
+  if (ctx->rg_writer == nullptr) {
+    ctx->rg_writer = ctx->file_writer->AppendBufferedRowGroup();
+  } else {
+    const bool should_close = ctx->rg_writer->estimated_memory_usage(
+                                  record_batch->num_rows()) >= ctx->max_buffered_bytes ||
+                              ctx->rg_writer->estimated_size() >= ctx->block_size;
+    if (should_close) {
+      if (ctx->verbose) {
+        PrintDebugInfo(*ctx);
+      }
+      ctx->rg_writer->Close();
+      ctx->rg_writer = ctx->file_writer->AppendBufferedRowGroup();
+    }
+  }
+  PARQUET_THROW_NOT_OK(arrow::WriteRecordBatch(*record_batch, *ctx->rg_writer,
+                                               ctx->file_writer->schema(),
+                                               *ctx->arrow_properties));
+}
+
+void CloseImpl(JNIEnv* jenv, jobject jwriter) {
+  // TODO write metadata
+  auto ctx = GetParquetWriterContext(jenv, jwriter);
+  if (ctx != nullptr) {
+    if (ctx->verbose) {
+      PrintDebugInfo(*ctx);
+    }
+    if (ctx->rg_writer != nullptr) {
+      ctx->rg_writer->Close();
+      ctx->rg_writer = nullptr;
+    }
+    ctx->file_writer->Close();
+    delete ctx;
+    ResetParquetWriterContext(jenv, jwriter);
+  }
+}
+
+jboolean IsSupportedPathImpl(JNIEnv* jenv, jstring jpath) {
+  auto path_utf_chars = GetStringUTFChars(jenv, jpath);
+  auto result = FileSystemFromUri(path_utf_chars.get());
+  return result.ok();
+}
+
+}  // namespace jni
+}  // namespace parquet
+
+extern "C" {
+
+using namespace parquet::jni;
+
+#define BEGIN_JNI_CATCH_EXCEPTIONS try {
+#define END_JNI_CATCH_EXCEPTIONS                                                    \
+  }                                                                                 \
+  catch (const std::bad_alloc& e) {                                                 \
+    parquet::jni::ThrowJavaException(jenv, "java/lang/OutOfMemoryError", e.what()); \
+  }                                                                                 \
+  catch (const std::ios_base::failure& e) {                                         \
+    parquet::jni::ThrowJavaException(jenv, "java/io/IOException", e.what());        \
+  }                                                                                 \
+  catch (const std::exception& e) {                                                 \
+    parquet::jni::ThrowJavaException(jenv, "java/lang/RuntimeException", e.what()); \
+  }                                                                                 \
+  catch (...) {                                                                     \
+    parquet::jni::ThrowJavaException(jenv, "java/lang/RuntimeException",            \
+                                     "unknown exception");                          \
+  }
+
+JNIEXPORT jlong JNICALL
+Java_org_apache_spark_sql_execution_datasources_parquet_NativeParquetOutputWriterJni_init(
+    JNIEnv* jenv, jobject jwriter, jstring jpath, jbyteArray jparquet_schema,
+    jint parquet_schema_len, jbyteArray jarrow_schema, jint arrow_schema_len,
+    jint num_threads, jboolean enable_shuffle, jint shuffle_level,
+    jboolean shuffle_auto_encoding, jlong block_size, jint output_timestamp_type,
+    jlong max_buffered_bytes, jint dictionary_page_size, jstring jcompression,
+    jint page_size, jint statistics_truncate_length, jboolean dictionary_enabled,
+    jobjectArray jdictionary_enabled_map_paths,
+    jbooleanArray jdictionary_enabled_map_values, jint writer_version,
+    jobjectArray jextra_metadata_keys, jobjectArray jextra_metadata_values,
+    jboolean verbose) {
+  BEGIN_JNI_CATCH_EXCEPTIONS
+  return InitImpl(jenv, jwriter, jpath, jparquet_schema, parquet_schema_len,
+                  jarrow_schema, arrow_schema_len, num_threads, enable_shuffle,
+                  shuffle_level, shuffle_auto_encoding, block_size, output_timestamp_type,
+                  max_buffered_bytes, dictionary_page_size, jcompression, page_size,
+                  statistics_truncate_length, dictionary_enabled,
+                  jdictionary_enabled_map_paths, jdictionary_enabled_map_values,
+                  writer_version, jextra_metadata_keys, jextra_metadata_values, verbose);
+  END_JNI_CATCH_EXCEPTIONS
+  return 0;
+}
+
+JNIEXPORT void JNICALL
+Java_org_apache_spark_sql_execution_datasources_parquet_NativeParquetOutputWriterJni_write(
+    JNIEnv* jenv, jobject jwriter, jbyteArray jarrow_record_batch,
+    jint arrow_record_batch_length) {
+  BEGIN_JNI_CATCH_EXCEPTIONS
+  return WriteImpl(jenv, jwriter, jarrow_record_batch, arrow_record_batch_length);
+  END_JNI_CATCH_EXCEPTIONS
+}
+
+JNIEXPORT void JNICALL
+Java_org_apache_spark_sql_execution_datasources_parquet_NativeParquetOutputWriterJni_close(
+    JNIEnv* jenv, jobject jwriter) {
+  BEGIN_JNI_CATCH_EXCEPTIONS
+  return CloseImpl(jenv, jwriter);
+  END_JNI_CATCH_EXCEPTIONS
+}
+
+JNIEXPORT jboolean JNICALL
+Java_org_apache_spark_sql_execution_datasources_parquet_NativeParquetOutputWriterJniHelper_isSupportedPath(
+    JNIEnv* jenv, jobject, jstring jpath) {
+  BEGIN_JNI_CATCH_EXCEPTIONS
+  return IsSupportedPathImpl(jenv, jpath);
+  END_JNI_CATCH_EXCEPTIONS
+  return false;
+}
+}
diff --git a/cpp/src/parquet/shuffle/metrics.h b/cpp/src/parquet/shuffle/metrics.h
new file mode 100644
index 0000000000..20eaaac0a2
--- /dev/null
+++ b/cpp/src/parquet/shuffle/metrics.h
@@ -0,0 +1,37 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <chrono>
+
+#include "parquet/platform.h"
+
+namespace parquet {
+namespace shuffle {
+
+struct PARQUET_EXPORT ShuffleMetrics {
+  double dictionary_build_time = 0;
+  double dictionary_finalize_time = 0;
+  double shuffle_compute_time = 0;
+  double shuffle_execute_time = 0;
+  double sink_write_time = 0;
+  double row_group_close_time = 0;
+  double elapsed_time = 0;
+  double uncompressed_size = 0;
+  double compressed_size = 0;
+};
+
+template <typename Fun>
+void Measure(ShuffleMetrics* metrics, double ShuffleMetrics::*kind, Fun&& fun) {
+  if (metrics != nullptr) {
+    const auto start = std::chrono::high_resolution_clock::now();
+    fun();
+    const auto end = std::chrono::high_resolution_clock::now();
+    (metrics->*kind) += static_cast<std::chrono::duration<double>>(end - start).count();
+  } else {
+    fun();
+  }
+}
+
+}  // namespace shuffle
+}  // namespace parquet
