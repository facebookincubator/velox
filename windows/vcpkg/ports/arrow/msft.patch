+constexpr int RETURN_CODE_OK = 0;
+constexpr int RETURN_CODE_USAGE_ERROR = 1;
+constexpr int RETURN_CODE_INTERNAL_ERROR = 2;
+
+void SetUsageMessage() {
+  std::stringstream ss;
+  ss << "[<options>] <file>..." << std::endl
+     << std::endl
+     << "Read Parquet file(s), shuffle the rows, and write a new Parquet file.";
+  gflags::SetUsageMessage(ss.str());
+}
+
+void SetShuffleFileArgs(parquet::shuffle::ShuffleFileArgs& args) {
+  args.num_threads = FLAGS_num_threads;
+  args.verbose = FLAGS_verbose;
+  args.shuffle_row_group_wise =
+      FLAGS_batch_size > 0 || FLAGS_row_group_check_batch_size > 0 ? false
+                                                                   : FLAGS_row_group_wise;
+  args.shuffle_batch_size = FLAGS_row_group_check_batch_size > 0 ? 0 : FLAGS_batch_size;
+  args.row_group_target_size = FLAGS_row_group_target_size;
+  args.row_group_writer_memory_threshold = FLAGS_row_group_writer_memory_threshold;
+  args.row_group_check_batch_size = FLAGS_row_group_check_batch_size;
+  args.read_dictionary = FLAGS_read_dictionary;
+  args.read_batch_size = FLAGS_read_batch_size;
+  args.write_empty_row_group = FLAGS_write_empty_row_group;
+  args.output_filename = FLAGS_o;
+}
+
+std::shared_ptr<parquet::WriterProperties> BuildWriterProperties() {
+  parquet::WriterProperties::Builder props_builder;
+  props_builder.shuffle_threads(FLAGS_num_threads);
+  if (FLAGS_num_threads > 1) {
+    PARQUET_ASSIGN_OR_THROW(auto compute_pool,
+                            arrow::internal::ThreadPool::Make(FLAGS_num_threads));
+    props_builder.shuffle_thread_pool(std::move(compute_pool));
+  }
+  props_builder.shuffle_verbose(FLAGS_verbose);
+  props_builder.version(ParseParquetVersion(FLAGS_write_version).ValueUnsafe());
+  props_builder.dictionary_pagesize_limit(FLAGS_dictionary_pagesize_limit);
+  props_builder.compression(
+      parquet::Codec::GetCompressionType(FLAGS_compression).ValueUnsafe());
+  props_builder.compression_level(FLAGS_compression_level);
+  FLAGS_use_dictionary ? props_builder.enable_dictionary()
+                       : props_builder.disable_dictionary();
+  props_builder.shuffle_direct_dictionary_write(FLAGS_write_dictionary);
+  props_builder.write_batch_size(FLAGS_write_batch_size);
+  if (FLAGS_output_row_group_size > 0) {
+    props_builder.max_row_group_length(FLAGS_output_row_group_size);
+    props_builder.shuffle_split_output_row_group(true);
+  }
+  FLAGS_shuffle ? props_builder.enable_shuffle() : props_builder.disable_shuffle();
+  props_builder.shuffle_algorithm(FLAGS_shuffle_algorithm);
+  props_builder.shuffle_compatible_api(FLAGS_compatible_api);
+  props_builder.shuffle_auto_encoding(FLAGS_auto_encoding);
+  props_builder.shuffle_debug(FLAGS_debug);
+  props_builder.shuffle_raw_encoding_threshold(FLAGS_raw_encoding_threshold);
+  if (!gflags::GetCommandLineFlagInfoOrDie("trailing_zeros_key").is_default) {
+    props_builder.trailing_zeros_key(FLAGS_trailing_zeros_key);
+  }
+  if (!gflags::GetCommandLineFlagInfoOrDie("empty_string_dictionary_index_key")
+           .is_default) {
+    props_builder.empty_string_dictionary_index_key(
+        FLAGS_empty_string_dictionary_index_key);
+  }
+
+  if (FLAGS_shuffle_level !=
+      parquet::shuffle::ShuffleProperties::UseDefaultShuffleLevel()) {
+    props_builder.shuffle_level(FLAGS_shuffle_level);
+  } else {
+    auto vorder_props_builder =
+        std::make_shared<parquet::shuffle::VorderShuffleProperties>();
+    vorder_props_builder->min_pure_frequency = FLAGS_vorder_min_pure_frequency;
+    vorder_props_builder->min_pure_bits = FLAGS_vorder_min_pure_bits;
+    vorder_props_builder->min_pure_size = FLAGS_vorder_min_pure_size;
+    vorder_props_builder->min_partition_size = FLAGS_vorder_min_partition_size;
+    vorder_props_builder->min_partition_density = FLAGS_vorder_min_partition_density;
+    vorder_props_builder->sample_size = FLAGS_vorder_sample_size;
+    vorder_props_builder->dense_histogram_width = FLAGS_vorder_dense_histogram_width;
+    vorder_props_builder->dense_histogram_scratch_size =
+        FLAGS_vorder_dense_histogram_scratch_size;
+    vorder_props_builder->depth_first_threshold = FLAGS_vorder_depth_first_threshold;
+    vorder_props_builder->use_adjusted_column_widths =
+        FLAGS_vorder_use_adjusted_column_widths;
+    props_builder.shuffle_algorithm_properties(std::move(vorder_props_builder));
+  }
+
+  return props_builder.build();
+}
+
+std::unique_ptr<parquet::ParquetFileWriter> OpenWriter(
+    std::string uri_or_path, const parquet::SchemaDescriptor& schema,
+    std::shared_ptr<parquet::WriterProperties> properties,
+    std::shared_ptr<const parquet::KeyValueMetadata> key_value_metadata = nullptr) {
+  std::shared_ptr<arrow::io::OutputStream> out;
+#ifdef ARROW_FILESYSTEM
+  if (arrow::fs::internal::IsLikelyUri(uri_or_path)) {
+    std::string out_path;
+    PARQUET_ASSIGN_OR_THROW(auto fs,
+                            arrow::fs::FileSystemFromUri(uri_or_path, &out_path));
+    PARQUET_ASSIGN_OR_THROW(out, fs->OpenOutputStream(out_path));
+  } else {
+    PARQUET_ASSIGN_OR_THROW(out, arrow::io::FileOutputStream::Open(uri_or_path));
+  }
+#else
+  PARQUET_ASSIGN_OR_THROW(out, arrow::io::FileOutputStream::Open(uri_or_path));
+#endif
+  return parquet::ParquetFileWriter::Open(
+      std::move(out), parquet::shuffle::CopySchema(schema), std::move(properties),
+      std::move(key_value_metadata));
+}
+
+void PrintMetrics(const std::string& metric_types,
+                  const parquet::shuffle::ShuffleMetrics& metrics) {
+  parquet::shuffle::StreamFormattingGuard guard(std::cout);
+  bool first = true;
+  for (const auto metric_type : parquet::shuffle::split(metric_types, ",")) {
+    if (first) {
+      first = false;
+    } else {
+      std::cout << ',';
+    }
+    if (metric_type == "elapsed_time") {
+      std::cout << std::setprecision(6) << metrics.elapsed_time;
+    } else if (metric_type == "shuffle_compute_time") {
+      std::cout << std::setprecision(6) << metrics.shuffle_compute_time;
+    } else if (metric_type == "shuffle_execute_time") {
+      std::cout << std::setprecision(6) << metrics.shuffle_execute_time;
+    } else if (metric_type == "uncompressed_size") {
+      std::cout << std::setprecision(12) << metrics.uncompressed_size;
+    } else if (metric_type == "compressed_size") {
+      std::cout << std::setprecision(12) << metrics.compressed_size;
+    } else {
+      std::cout << "<unrecognized metric:" << metric_type << ">";
+    }
+  }
+  std::cout << std::endl;
+}
+
+void PrintSummaryMetrics(
+    const std::string& metric_types, const std::string& summary_types,
+    const std::vector<parquet::shuffle::ShuffleMetrics>& metrics_vector) {
+  for (const auto summary_type : parquet::shuffle::split(summary_types, ",")) {
+    std::cout << summary_type << ',';
+    if (summary_type == "mean") {
+      PrintMetrics(metric_types, Mean(metrics_vector));
+    } else if (summary_type == "sd") {
+      PrintMetrics(metric_types, Stddev(metrics_vector));
+    } else if (summary_type == "min") {
+      PrintMetrics(metric_types, Min(metrics_vector));
+    } else if (summary_type == "median") {
+      PrintMetrics(metric_types, Median(metrics_vector));
+    } else if (summary_type == "max") {
+      PrintMetrics(metric_types, Max(metrics_vector));
+    } else {
+      std::cout << "<unrecognized summary_type>";
+    }
+  }
+}
+
+int main(int argc, char** argv) {
+  SetUsageMessage();
+  gflags::SetVersionString(ARROW_VERSION_STRING);
+  gflags::ParseCommandLineNonHelpFlags(&argc, &argv, true);
+
+  if (FLAGS_help) {
+    gflags::ShowUsageWithFlags(argv[0]);
+    return RETURN_CODE_OK;
+  }
+  if (argc < 2) {
+    PrintError() << "file is not specified" << std::endl;
+    return RETURN_CODE_USAGE_ERROR;
+  }
+
+  parquet::shuffle::ShuffleFileArgs args;
+  SetShuffleFileArgs(args);
+  if (args.output_filename.empty()) {
+    const std::string first_input_filename(argv[1]);
+    args.output_filename = first_input_filename + ".out";
+  }
+  const auto writer_properties = BuildWriterProperties();
+  const auto range = GetParquetFileSliceRange();
+  if (!range) {
+    return RETURN_CODE_USAGE_ERROR;
+  }
+
+  try {
+    std::vector<std::string> filenames;
+    filenames.reserve(argc - 1);
+    for (int i = 1; i < argc; ++i) {
+      const auto filename = argv[i];
+      filenames.emplace_back(argv[i]);
+      if (filename == args.output_filename) {
+        PrintError() << "Output filename is same as input filename" << std::endl;
+        return RETURN_CODE_USAGE_ERROR;
+      }
+    }
+    PARQUET_ASSIGN_OR_THROW(auto io_pool,
+                            arrow::internal::ThreadPool::Make(std::min(argc - 1, 32)));
+    std::vector<parquet::shuffle::ShuffleMetrics> metrics_vector;
+    metrics_vector.reserve(FLAGS_metrics_repeat);
+    for (int i = 0; i < FLAGS_metrics_repeat; ++i) {
+      auto input = parquet::shuffle::ParquetFileReaderSlice::OpenFiles(
+          filenames, *range, false, io_pool.get());
+      std::shared_ptr<const arrow::KeyValueMetadata> key_value_metadata;
+      if (FLAGS_copy_key_value_metadata) {
+        if (filenames.size() > 1 &&
+            !gflags::GetCommandLineFlagInfoOrDie("copy_key_value_metadata").is_default) {
+          PrintError()
+              << "-copy_key_value_metadata flag cannot be used with multiple input files"
+              << std::endl;
+          return RETURN_CODE_USAGE_ERROR;
+        }
+        key_value_metadata = input->key_value_metadata()[0];
+      }
+      auto writer = OpenWriter(args.output_filename, input->schema(), writer_properties,
+                               key_value_metadata);
+      parquet::shuffle::ShuffleMetrics* metrics = nullptr;
+      if (args.verbose || !FLAGS_metrics.empty()) {
+        metrics_vector.emplace_back();
+        metrics = &metrics_vector.back();
+      }
+      ShuffleFile(*input, *writer, args, metrics);
+    }
+    if (!FLAGS_metrics.empty()) {
+      if (FLAGS_metrics_repeat == 1) {
+        PrintMetrics(FLAGS_metrics, metrics_vector[0]);
+      } else {
+        PrintSummaryMetrics(FLAGS_metrics, FLAGS_metrics_summary, metrics_vector);
+      }
+    }
+  } catch (const std::exception& e) {
+    PrintError() << "Parquet error: " << e.what() << std::endl;
+    return RETURN_CODE_INTERNAL_ERROR;
+  }
+  return RETURN_CODE_OK;
+}
