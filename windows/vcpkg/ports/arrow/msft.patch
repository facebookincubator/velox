diff --git a/cpp/src/parquet/shuffle/util/u24.h b/cpp/src/parquet/shuffle/util/u24.h
new file mode 100644
index 0000000000..81144ec8c7
--- /dev/null
+++ b/cpp/src/parquet/shuffle/util/u24.h
@@ -0,0 +1,70 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <cstdint>
+
+namespace parquet {
+namespace shuffle {
+
+#pragma pack(push, 1)
+
+struct u24 {
+  u24() {}
+
+  template <typename T>
+  explicit u24(T v) {
+    assign(v);
+  }
+
+  template <typename T>
+  u24& operator=(T v) {
+    assign(v);
+    return *this;
+  }
+
+  operator int32_t() const { return value(); }
+
+  u24 operator+(int x) const { return u24(value() + x); }
+
+#ifndef _MSC_VER
+  uint32_t data : 24;
+
+  template <typename T>
+  void assign(T v) {
+    data = static_cast<uint32_t>(0x00ffffff & v);
+  }
+
+  int32_t value() const { return static_cast<int32_t>(data); }
+#else
+  uint8_t data[3];
+
+  template <typename T>
+  void assign(T v) {
+    data[0] = static_cast<uint8_t>(0x000000ff & v);
+    data[1] = static_cast<uint8_t>((0x0000ff00 & v) >> 8);
+    data[2] = static_cast<uint8_t>((0x00ff0000 & v) >> 16);
+  }
+
+  void assign(uint8_t v) {
+    data[0] = v;
+    data[1] = data[2] = 0;
+  }
+
+  void assign(uint16_t v) {
+    data[0] = (0x00ff & v);
+    data[1] = (0xff00 & v) >> 8;
+    data[2] = 0;
+  }
+
+  int32_t value() const { return data[0] | (data[1] << 8) | (data[2] << 16); }
+#endif
+};
+
+#pragma pack(pop)
+
+static_assert(sizeof(u24) == 3, "u24 is supposed to be 3 bytes!!");
+static_assert(alignof(u24) == 1, "u24 should have 1-byte alignment!!");
+
+}  // namespace shuffle
+}  // namespace parquet
