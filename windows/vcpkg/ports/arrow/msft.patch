+// NOLINT legal/copyright
+
+#pragma once
+
+#include <cstdint>
+
+namespace parquet {
+namespace shuffle {
+
+/// Column data is dictionary encoded and only the dictionary indices are exposed to
+/// ShuffleAlgorithm.
+struct ColumnData {
+  /// Index of the column (field) in the schema. Not all columns of a schema
+  /// may be passed to ShuffleAlgorithm.
+  int column_idx;
+
+  /// Number of bytes per value ID. Can be 1, 2, 3, or 4.
+  int type_length;
+
+  /// The starting address of the data. This pointer must be casted to the appropriate
+  /// type before being used. The first value is at data, the second value is at data +
+  /// type_length, and so on.
+  ///
+  /// Null indices are indicated by all bits set. For example, if type_length is 3,
+  /// the null index can be represented as 0xffffff. Note that this is only the case
+  /// when null_count is not 0.
+  uint8_t* data;
+
+  int16_t* def_levels;
+
+  /// Number of null rows. null_count <= num_rows
+  int32_t null_count;
+
+  /// Number of non-null distinct values. num_distinct_values + null_count <= num_rows
+  /// Maximum non-null dictionary index is num_distinct_values - 1.
+  int32_t num_distinct_values;
+};
+
+inline int32_t GetNullIndex(int type_length) {
+  return static_cast<int32_t>((1ULL << (type_length << 3)) - 1);
+}
+
+}  // namespace shuffle
+}  // namespace parquet
