diff --git a/cpp/src/parquet/shuffle/util/encoding_util.h b/cpp/src/parquet/shuffle/util/encoding_util.h
new file mode 100644
index 0000000000..62840c122c
--- /dev/null
+++ b/cpp/src/parquet/shuffle/util/encoding_util.h
@@ -0,0 +1,163 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <cmath>
+#include <cstdint>
+
+#include "arrow/util/bit_stream_utils.h"
+
+#include "parquet/shuffle/util/span.h"
+
+namespace parquet {
+namespace shuffle {
+
+template <typename T>
+class RleSizeEstimator {
+  constexpr static uint64_t kMinRepeatCount = 8;
+
+ public:
+  explicit RleSizeEstimator(uint64_t bit_width);
+
+  void Reset(uint64_t bit_width);
+
+  void UpdateBitWidth(uint64_t bit_width);
+
+  template <typename U>
+  void Append(Span<U> values);
+
+  void Flush() { FlushImpl(data_); }
+
+  uint64_t bit_width() const { return bit_width_; };
+
+  uint64_t count() const { return count_; }
+
+  uint64_t estimate() const {
+    return data_.estimate0 + data_.estimate1 + data_.estimate2;
+  }
+
+  uint64_t flushed_estimate() const {
+    Data data = data_;
+    FlushImpl(data);
+    return data.estimate0 + data.estimate1 + data.estimate2;
+  }
+
+ private:
+  struct Data {
+    uint64_t literal_count;
+    uint64_t repeat_count;
+    uint64_t estimate0;
+    uint64_t estimate1;
+    uint64_t estimate2;
+  };
+
+  void FlushImpl(Data& data) const;
+  void FlushOrExtendLiterals(Data& data) const;
+  void FlushLiterals(Data& data) const;
+  void FlushRepeats(Data& data) const;
+
+  uint64_t bit_width_;
+  uint64_t bytes_width_;
+  uint64_t count_;
+  Data data_;
+  T prev_value_;
+};
+
+template <typename T>
+RleSizeEstimator<T>::RleSizeEstimator(uint64_t bit_width) {
+  Reset(bit_width);
+}
+
+template <typename T>
+void RleSizeEstimator<T>::Reset(uint64_t bit_width) {
+  bit_width = std::max<uint64_t>(bit_width, 1);
+  bit_width_ = bit_width;
+  bytes_width_ = ::arrow::bit_util::BytesForBits(bit_width);
+  count_ = 0;
+  data_.literal_count = 0;
+  data_.repeat_count = 1;
+  data_.estimate0 = 0;
+  data_.estimate1 = 0;
+  data_.estimate2 = 0;
+}
+
+template <typename T>
+void RleSizeEstimator<T>::UpdateBitWidth(uint64_t bit_width) {
+  bit_width = std::max<uint64_t>(bit_width, 1);
+  if (bit_width_ != bit_width) {
+    const uint64_t bytes_width = ::arrow::bit_util::BytesForBits(bit_width);
+    if (bytes_width != bytes_width_) {
+      data_.estimate2 = data_.estimate2 / bytes_width_ * bytes_width;
+    }
+    data_.estimate1 = data_.estimate1 / bit_width_ * bit_width;
+    bit_width_ = bit_width;
+    bytes_width_ = bytes_width;
+  }
+}
+
+template <typename T>
+template <typename U>
+void RleSizeEstimator<T>::Append(Span<U> values) {
+  const auto last = values.end();
+  auto first = values.begin();
+  if (first == last) return;
+  if (count_ == 0) {
+    prev_value_ = static_cast<T>(*first);
+  }
+  while (++first != last) {
+    const auto value = static_cast<T>(*first);
+    if (value == prev_value_) {
+      ++data_.repeat_count;
+    } else {
+      FlushOrExtendLiterals(data_);
+      prev_value_ = value;
+      data_.repeat_count = 1;
+    }
+    ++count_;
+  }
+}
+
+template <typename T>
+void RleSizeEstimator<T>::FlushImpl(Data& data) const {
+  FlushOrExtendLiterals(data);
+  FlushLiterals(data);
+}
+
+template <typename T>
+void RleSizeEstimator<T>::FlushOrExtendLiterals(Data& data) const {
+  if (data.repeat_count > kMinRepeatCount) {
+    FlushRepeats(data);
+  } else {
+    data.literal_count += data.repeat_count;
+  }
+}
+
+template <typename T>
+void RleSizeEstimator<T>::FlushLiterals(Data& data) const {
+  data.estimate0 += ::arrow::bit_util::BytesForBits(
+      ::arrow::bit_util::NumRequiredBits(data.literal_count));
+  data.estimate1 += ::arrow::bit_util::BytesForBits(data.literal_count * bit_width_);
+  data.literal_count = 0;
+}
+
+template <typename T>
+void RleSizeEstimator<T>::FlushRepeats(Data& data) const {
+  if (data.literal_count > 0) {
+    FlushLiterals(data);
+  }
+  data.estimate0 += ::arrow::bit_util::BytesForBits(
+      ::arrow::bit_util::NumRequiredBits(data.repeat_count));
+  data.estimate2 += bytes_width_;
+  data.repeat_count = 0;
+}
+
+template <typename T>
+uint64_t GetRleEncodedIndicesSizeEstimate(Span<T> indices, uint64_t bit_width) {
+  RleSizeEstimator<int32_t> estimator(bit_width);
+  estimator.Append(indices);
+  estimator.Flush();
+  return estimator.estimate();
+}
+
+}  // namespace shuffle
+}  // namespace parquet
