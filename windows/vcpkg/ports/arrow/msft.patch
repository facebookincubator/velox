@@ -0,0 +1,218 @@
+#include "parquet/shuffle/util/compact_index_vector.h"
+
+#include <algorithm>
+#include <limits>
+
+#include "arrow/util/bit_util.h"
+
+#include "parquet/exception.h"
+
+namespace parquet {
+namespace shuffle {
+
+constexpr const int32_t kColumnIndexVectorInitialCapacity = 64;
+
+CompactIndexVector::CompactIndexVector(MemoryPool* pool) : pool_(pool) {
+  ResetImpl(1, 0);
+}
+
+CompactIndexVector::CompactIndexVector(MemoryPool* pool, int32_t max_index,
+                                       int32_t capacity)
+    : pool_(pool) {
+  ResetImpl(GetTypeLength(max_index), capacity);
+}
+
+CompactIndexVector::CompactIndexVector(CompactIndexVector&& rhs) {
+  *this = std::move(rhs);
+}
+
+CompactIndexVector& CompactIndexVector::operator=(CompactIndexVector&& rhs) {
+  pool_ = rhs.pool_;
+  buffer_ = std::move(rhs.buffer_);
+  size_ = rhs.size_;
+  capacity_ = rhs.capacity_;
+  max_index_ = rhs.max_index_;
+  type_length_ = rhs.type_length_;
+  rhs.size_ = 0;
+  rhs.capacity_ = 0;
+  rhs.max_index_ = 0;
+  return *this;
+}
+
+void CompactIndexVector::ResetImpl(int type_length, int32_t capacity) {
+  if (ARROW_PREDICT_FALSE(type_length <= 0 || type_length > 4)) {
+    throw std::runtime_error("invalid type_length");
+  }
+  if (ARROW_PREDICT_FALSE(capacity < 0)) {
+    throw std::runtime_error("invalid capacity");
+  }
+  if (capacity > 0) {
+    buffer_ = AllocateBuffer(pool_, static_cast<int64_t>(type_length) * capacity);
+  } else {
+    buffer_.reset();
+  }
+  size_ = 0;
+  capacity_ = capacity;
+  max_index_ = 0;
+  type_length_ = type_length;
+}
+
+void CompactIndexVector::clear() {
+  size_ = 0;
+  max_index_ = 0;
+}
+
+void CompactIndexVector::reserve(int32_t size) {
+  if (size > capacity_) {
+    Enlarge(size);
+  }
+}
+
+void CompactIndexVector::push_back(int32_t index) {
+  ARROW_DCHECK_GE(index, 0);
+  if (ARROW_PREDICT_FALSE(size_ == std::numeric_limits<int32_t>::max())) {
+    throw std::runtime_error("max capacity reached (INT32_MAX)");
+  }
+  const auto type_length = GetTypeLength(index);
+  const auto capacity = size_ == capacity_ ? GetNextCapacity() : capacity_;
+  if (type_length > type_length_) {
+    UpdateTypeLength(type_length, capacity);
+  } else if (capacity > capacity_) {
+    Enlarge(capacity);
+  }
+  switch (type_length_) {
+    case 1:
+      values1()[size_++] = static_cast<uint8_t>(index);
+      break;
+    case 2:
+      values2()[size_++] = static_cast<uint16_t>(index);
+      break;
+    case 3:
+      values3()[size_++] = index;
+      break;
+    case 4:
+      values4()[size_++] = index;
+      break;
+  }
+  max_index_ = std::max(max_index_, index);
+}
+
+int32_t CompactIndexVector::GetNextCapacity() const {
+  if (capacity_ == 0) {
+    return kColumnIndexVectorInitialCapacity;
+  } else if (capacity_ <= std::numeric_limits<int32_t>::max() / 2) {
+    return capacity_ * 2;
+  } else {
+    return std::numeric_limits<int32_t>::max();
+  }
+}
+
+namespace {
+
+template <typename To, typename From>
+void Copy(uint8_t* dst, Span<From> src) {
+  std::copy(src.begin(), src.end(), reinterpret_cast<To*>(dst));
+}
+
+}  // namespace
+
+void CompactIndexVector::UpdateTypeLength(int new_type_length, int32_t capacity) {
+  auto new_buffer = AllocateBuffer(pool_, new_type_length * capacity);
+  switch (new_type_length) {
+    case 2:
+      Copy<uint16_t>(new_buffer->mutable_data(), values1());
+      break;
+    case 3:
+      switch (type_length_) {
+        case 1:
+          Copy<u24>(new_buffer->mutable_data(), values1());
+          break;
+        case 2:
+          Copy<u24>(new_buffer->mutable_data(), values2());
+          break;
+      }
+      break;
+    case 4:
+      switch (type_length_) {
+        case 1:
+          Copy<int32_t>(new_buffer->mutable_data(), values1());
+          break;
+        case 2:
+          Copy<int32_t>(new_buffer->mutable_data(), values2());
+          break;
+        case 3:
+          Copy<int32_t>(new_buffer->mutable_data(), values3());
+          break;
+      }
+      break;
+  }
+  buffer_ = std::move(new_buffer);
+  type_length_ = new_type_length;
+  if (capacity > capacity_) {
+    capacity_ = capacity;
+  }
+}
+
+void CompactIndexVector::Enlarge(int32_t new_capacity) {
+  if (capacity_ == 0) {
+    buffer_ = AllocateBuffer(pool_, static_cast<int64_t>(type_length_) * new_capacity);
+  } else {
+    PARQUET_THROW_NOT_OK(
+        buffer_->Resize(static_cast<int64_t>(type_length_) * new_capacity));
+  }
+  capacity_ = new_capacity;
+}
+
+int64_t CompactIndexVector::estimated_memory_usage(double estimation_factor) const {
+  const auto new_max_index_i64 =
+      max_index_ + static_cast<int64_t>(size_ * (estimation_factor - 1));
+  const auto new_max_index_i32 = static_cast<int32_t>(
+      std::min<int64_t>(new_max_index_i64, std::numeric_limits<int32_t>::max()));
+  const auto new_type_length = GetTypeLength(new_max_index_i32);
+  if (new_type_length == type_length_) {
+    return static_cast<int64_t>(size_ * estimation_factor);
+  } else {
+    return static_cast<int64_t>(size_ * estimation_factor * new_type_length /
+                                type_length_);
+  }
+}
+
+namespace {
+template <typename T>
+void PrintIntegers(std::ostream& os, Span<const T> values) {
+  bool first = true;
+  for (const auto v : values) {
+    if (first) {
+      first = false;
+    } else {
+      os << ", ";
+    }
+    os << static_cast<int32_t>(v);
+  }
+}
+
+}  // namespace
+
+std::ostream& operator<<(std::ostream& os, const CompactIndexVector& v) {
+  os << "{";
+  if (!v.empty()) {
+    switch (v.type_length()) {
+      case 1:
+        PrintIntegers(os, v.values1());
+        break;
+      case 2:
+        PrintIntegers(os, v.values2());
+        break;
+      case 3:
+        PrintIntegers(os, v.values3());
+        break;
+      case 4:
+        PrintIntegers(os, v.values4());
+        break;
+    }
+  }
+  return os << "}";
+}
+
+}  // namespace shuffle
+}  // namespace parquet
diff --git a/cpp/src/parquet/shuffle/util/compact_index_vector.h b/cpp/src/parquet/shuffle/util/compact_index_vector.h
new file mode 100644
index 0000000000..52a2bd1191
--- /dev/null
+++ b/cpp/src/parquet/shuffle/util/compact_index_vector.h
@@ -0,0 +1,225 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <ios>
+#include <memory>
+
+#include "arrow/util/bit_util.h"
+#include "arrow/util/logging.h"
+
+#include "parquet/platform.h"
+#include "parquet/shuffle/util/span.h"
+#include "parquet/shuffle/util/u24.h"
+
+namespace parquet {
+namespace shuffle {
+
+// Append-only vector for indices, which are integers that can range from 0 to INT32_MAX.
+// It is designed to be memory efficient for dictionary indices. If the number of
+// entries in the dictionary (number of dictinct values) is small, it will use smaller
+// space to store the indices. For example, if the dictionary has only 200 distinct
+// values, the maximum index will be 199 and it will only require 1 byte per index.
+// As the number of entries grows and indices increase, it will switch the internal
+// representation of the data to use 2 or more bytes per index.
+//
+// It can store at most INT32_MAX number of indices. It will throw an exception if this
+// limit is to be exceeded.
+//
+// The index is represented typically as int32_t, but it must be non-negative.
+class PARQUET_EXPORT CompactIndexVector {
+  // Returns the number of bytes to use for the specified maximum index.
+  static constexpr int GetTypeLength(int32_t max_index) {
+    const auto type_length = max_index == 0 ? 1
+                                            : 4 - (::arrow::bit_util::CountLeadingZeros(
+                                                       static_cast<uint32_t>(max_index)) /
+                                                   8);
+
+    // Allowing unaligned access is a space-vs-speed trade-off:
+    //
+    // - **Space win** – If the maximum index falls between 65 536 and
+    //   16 777 215, each entry fits in 3 bytes, saving 1 byte per element.
+    //
+    // - **Speed loss** – Accessing 3-byte elements is slower than 4-byte
+    //   elements unless you read them in groups of four (to regain
+    //   alignment). Four-byte elements are naturally aligned and therefore
+    //   faster.
+    //
+    // We leave the 3-byte path behind the
+    // `COMPACT_INDEX_VECTOR_ALLOW_UNALIGNED_ACCESS` switch so we can
+    // easily revisit this trade-off in the future.
+#ifdef COMPACT_INDEX_VECTOR_ALLOW_UNALIGNED_ACCESS
+    return type_length;
+#else
+    return type_length == 3 ? 4 : type_length;
+#endif
+  }
+
+ public:
+  explicit CompactIndexVector(MemoryPool* pool);
+
+  CompactIndexVector(MemoryPool* pool, int32_t max_index, int32_t capacity);
+
+  CompactIndexVector(const CompactIndexVector&) = delete;
+
+  CompactIndexVector& operator=(const CompactIndexVector&) = delete;
+
+  CompactIndexVector(CompactIndexVector&& rhs);
+
+  CompactIndexVector& operator=(CompactIndexVector&& rhs);
+
+  void clear();
+
+  void reserve(int32_t size);
+
+  // Append an index to this vector. The index must be non-negative.
+  void push_back(int32_t index);
+
+  template <typename T>
+  void push_back(Span<T> indices);
+
+  int32_t max_index() const { return max_index_; }
+
+  // Return the number of bytes for the underlying type.
+  // It will be either 1, 2, 3, or 4.
+  int type_length() const { return type_length_; }
+
+  // Return the number of indices in this vector.
+  int32_t size() const { return size_; }
+
+  int32_t capacity() const { return capacity_; };
+
+  // Return true if this vector is empty, false if not.
+  bool empty() const { return size_ == 0; }
+
+  int64_t size_bytes() const { return static_cast<int64_t>(type_length_) * size_; }
+
+  int64_t capacity_bytes() const { return buffer_->capacity(); }
+
+  int64_t estimated_memory_usage(double estimation_factor) const;
+
+  Span<uint8_t> data() { return AsSpan<uint8_t>(*buffer_); }
+
+  Span<uint8_t> values1() { return GetValuesImpl<uint8_t>(); }
+
+  Span<const uint8_t> values1() const { return GetValuesImpl<const uint8_t>(); }
+
+  Span<uint16_t> values2() { return GetValuesImpl<uint16_t>(); }
+
+  Span<const uint16_t> values2() const { return GetValuesImpl<const uint16_t>(); }
+
+  Span<u24> values3() { return GetValuesImpl<u24>(); }
+
+  Span<const u24> values3() const { return GetValuesImpl<const u24>(); }
+
+  Span<int32_t> values4() { return GetValuesImpl<int32_t>(); }
+
+  Span<const int32_t> values4() const { return GetValuesImpl<const int32_t>(); }
+
+ private:
+  void ResetImpl(int type_length, int32_t capacity);
+
+  template <typename T>
+  Span<T> GetValuesImpl() const {
+    ARROW_DCHECK_EQ(sizeof(T), type_length_);
+    return capacity_ == 0 ? Span<T>()
+                          : Span<T>(reinterpret_cast<T*>(buffer_->mutable_data()), size_);
+  }
+
+  int32_t GetNextCapacity() const;
+
+  void UpdateTypeLength(int new_type_length, int32_t capacity);
+
+  void Enlarge(int32_t new_capacity);
+
+  MemoryPool* pool_;
+  std::shared_ptr<ResizableBuffer> buffer_;
+  int32_t size_;
+  int32_t capacity_;
+  int32_t max_index_;
+  int type_length_;
+};
+
+PARQUET_EXPORT
+std::ostream& operator<<(std::ostream& os, const CompactIndexVector& v);
+
+namespace internal {
+
+template <typename To, typename From>
+void CopyIndices(To* dst, Span<From> src) {
+  std::transform(src.begin(), src.end(), dst,
+                 [](From index) { return static_cast<To>(index); });
+}
+
+}  // namespace internal
+
+template <typename T>
+void CompactIndexVector::push_back(Span<T> indices) {
+  if (indices.empty()) return;
+  const auto max_index =
+      static_cast<int32_t>(*std::max_element(indices.begin(), indices.end()));
+  const auto new_size = static_cast<size_t>(size_) + indices.size();
+  if (ARROW_PREDICT_FALSE(new_size >
+                          static_cast<size_t>(std::numeric_limits<int32_t>::max()))) {
+    throw std::runtime_error("max capacity reached (INT32_MAX)");
+  }
+  const auto new_size_i32 = static_cast<int32_t>(new_size);
+  const auto type_length = GetTypeLength(max_index);
+  const auto capacity = new_size_i32 > capacity_ ? new_size_i32 : capacity_;
+  if (type_length > type_length_) {
+    UpdateTypeLength(type_length, capacity);
+  } else if (capacity > capacity_) {
+    Enlarge(capacity);
+  }
+  switch (type_length_) {
+    case 1:
+      internal::CopyIndices(values1().end(), indices);
+      break;
+    case 2:
+      internal::CopyIndices(values2().end(), indices);
+      break;
+    case 3:
+      internal::CopyIndices(values3().end(), indices);
+      break;
+    case 4:
+      internal::CopyIndices(values4().end(), indices);
+      break;
+  }
+  size_ = new_size_i32;
+  max_index_ = std::max(max_index_, max_index);
+}
+
+template <typename Visitor>
+decltype(std::declval<Visitor>()(std::declval<const CompactIndexVector&>().values1()))
+Visit(const CompactIndexVector& vec, Visitor&& visitor) {
+  switch (vec.type_length()) {
+    case 1:
+      return visitor(vec.values1());
+    case 2:
+      return visitor(vec.values2());
+    case 3:
+      return visitor(vec.values3());
+    case 4:
+      return visitor(vec.values4());
+  }
+  throw std::runtime_error("invalid type_length");
+}
+
+template <typename Visitor>
+decltype(std::declval<Visitor>()(std::declval<CompactIndexVector&>().values1())) Visit(
+    CompactIndexVector& vec, Visitor&& visitor) {
+  switch (vec.type_length()) {
+    case 1:
+      return visitor(vec.values1());
+    case 2:
+      return visitor(vec.values2());
+    case 3:
+      return visitor(vec.values3());
+    case 4:
+      return visitor(vec.values4());
+  }
+  throw std::runtime_error("invalid type_length");
+}
+
+}  // namespace shuffle
+}  // namespace parquet
