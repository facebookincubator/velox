+/// @brief Unlimited (self-looped) memory stream.
+class CircularMemoryStream {
+ public:
+  CircularMemoryStream(const uint8_t* first, const size_t& length, const size_t& offset)
+      : first(first), length(length), offset(length == 0 ? 0 : offset % length) {}
+
+  const uint8_t* first;
+  const size_t length;
+  size_t offset;
+
+  void SkipBytes(const size_t n) {
+    if (n > 0 && length == 0) {
+      throw std::runtime_error("Stream is empty (length=0).");
+    }
+
+    offset = (offset + n) % length;
+  }
+
+  void ReadByteArray(uint8_t* const dest, size_t n) {
+    if (n > 0 && length == 0) {
+      throw std::runtime_error("Stream is empty (length=0).");
+    }
+    auto dest_end = dest + n;
+    auto curr_dest = dest;
+    size_t current_offset = offset;
+    while (n > 0) {
+      size_t bytes_to_copy = std::min(n, length - current_offset);
+      ASSERT_LE(curr_dest + bytes_to_copy, dest_end);
+
+      std::memcpy(static_cast<void*>(curr_dest),
+                  static_cast<const void*>(first + current_offset), bytes_to_copy);
+
+      n -= bytes_to_copy;
+      current_offset += bytes_to_copy;
+      curr_dest += bytes_to_copy;
+
+      if (current_offset == length) {
+        current_offset = 0;
+      }
+    }
+
+    ASSERT_THAT(n, 0);
+    offset = current_offset;
+  }
+};
