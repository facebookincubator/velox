+std::shared_ptr<VorderShuffleProperties> vorder_full() {
+  auto props = std::make_shared<shuffle::VorderShuffleProperties>();
+  props->min_pure_frequency = 0;
+  props->min_pure_bits = 0;
+  props->min_pure_size = 0;
+  props->min_partition_size = 0;
+  props->min_partition_density = 1;
+  return props;
+}
+
+template <typename T>
+std::vector<int16_t> GenerateDefLevels(Span<T> indices, bool has_nulls) {
+  if (has_nulls) {
+    std::vector<int16_t> def_levels(indices.size());
+    const auto null_index = GetNullIndex(sizeof(T));
+    for (size_t i = 0; i < indices.size(); ++i) {
+      def_levels[i] = indices[i] == null_index ? 0 : 1;
+    }
+    return def_levels;
+  } else {
+    return std::vector<int16_t>(indices.size(), 1);
+  }
+}
+
+template <typename RandomEngine, typename T>
+void SprinkleNulls(RandomEngine& r, Span<T> indices, int32_t null_count) {
+  if (null_count > 0) {
+    const auto n = indices.size();
+    const auto null_index = GetNullIndex(sizeof(T));
+    for (size_t i = 0; i < n && null_count > 0; ++i) {
+      std::uniform_int_distribution<int32_t> d(0, static_cast<int32_t>(n - 1 - i));
+      if (d(r) < null_count) {
+        indices[i] = null_index;
+        null_count -= 1;
+      }
+    }
+    ASSERT_THAT(null_count, Eq(0));
+  }
+}
+
+// TODO: Replace with generic lambda function in C++14 and above
+class SprinkleNullsVisitor {
+ public:
+  SprinkleNullsVisitor(std::default_random_engine& r, int32_t null_count)
+      : r_(r), null_count_(null_count) {}
+
+  template <typename T>
+  void operator()(Span<T> indices) {
+    SprinkleNulls(r_, indices, null_count_);
+  }
+
+ private:
+  std::default_random_engine& r_;
+  int32_t null_count_;
+};
+
+// TODO: Replace with generic lambda function in C++14 and above
+class GenerateDefLevelsVisitor {
+ public:
+  explicit GenerateDefLevelsVisitor(bool has_nulls) : has_nulls_(has_nulls) {}
+
+  template <typename T>
+  std::vector<int16_t> operator()(Span<T> indices) {
+    return GenerateDefLevels(indices, has_nulls_);
+  }
+
+ private:
+  bool has_nulls_;
+};
+
+std::pair<CompactIndexVector, std::vector<int16_t>> GenerateColumnData(
+    unsigned long seed, int32_t num_rows, int32_t null_count,
+    int32_t num_distinct_values) {
+  num_distinct_values = std::max(num_distinct_values, 1);
+  std::default_random_engine r(seed);
+  std::uniform_int_distribution<int32_t> d(0, num_distinct_values - 1);
+  CompactIndexVector indices(::arrow::default_memory_pool(),
+                             num_distinct_values + (null_count > 0 ? 1 : 0), 16);
+  for (int32_t i = 0; i < num_rows; ++i) {
+    indices.push_back(d(r));
+  }
+  Visit(indices, SprinkleNullsVisitor(r, null_count));
+  auto def_levels = Visit(indices, GenerateDefLevelsVisitor(null_count > 0));
+  return {std::move(indices), def_levels};
+}
+
+struct Data {
+  int32_t num_rows;
+  std::vector<CompactIndexVector> indices;
+  std::vector<std::vector<int16_t>> def_levels;
+  std::vector<ColumnData> columns;
+};
+
+Data GenerateData(unsigned int seed, int32_t num_rows,
+                  std::vector<std::pair<double, double>> nc_ndv) {
+  std::default_random_engine r(seed);
+  std::vector<CompactIndexVector> indices;
+  std::vector<std::vector<int16_t>> def_levels;
+  std::vector<ColumnData> columns;
+  for (size_t i = 0; i < nc_ndv.size(); ++i) {
+    const auto null_count = static_cast<int32_t>(nc_ndv[i].first * num_rows);
+    const auto num_distinct_values = static_cast<int32_t>(nc_ndv[i].second * num_rows);
+    auto column_data = GenerateColumnData(r(), num_rows, null_count, num_distinct_values);
+    indices.push_back(std::move(column_data.first));
+    def_levels.push_back(std::move(column_data.second));
+    columns.push_back({static_cast<int32_t>(i), indices.back().type_length(),
+                       indices.back().data().data(), def_levels.back().data(), null_count,
+                       num_distinct_values});
+  }
+  return {num_rows, std::move(indices), std::move(def_levels), columns};
+}
+
+std::vector<int32_t> GetPermutationVector(int32_t num_rows) {
+  std::vector<int32_t> permutation(num_rows);
+  std::iota(permutation.begin(), permutation.end(), 0);
+  return permutation;
+}
+
+void CheckDataIntegrity(const Data& data) {
+  for (size_t i = 0; i < data.columns.size(); ++i) {
+    SCOPED_TRACE(Message() << "Column " << i);
+    EXPECT_THAT(
+        data.def_levels[i],
+        Visit(data.indices[i], GenerateDefLevelsVisitor(data.columns[i].null_count > 0)));
+  }
+}
+
+void Shuffle(Data& data, const std::vector<int32_t>& permutation) {
+  for (size_t i = 0; i < data.columns.size(); ++i) {
+    DoShuffle(AsSpan(permutation), data.indices[i].data().data(),
+              data.indices[i].type_length());
+    DoShuffle(AsSpan(permutation), data.def_levels[i].data());
+  }
+}
+
+template <typename T>
+std::vector<int32_t> GetNonNullIndices(Span<T> indices) {
+  std::vector<int32_t> non_null_indices;
+  for (size_t i = 0; i < indices.size(); ++i) {
+    if (indices[i] >= 0) {
+      non_null_indices.push_back(indices[i]);
+    }
+  }
+  return non_null_indices;
+}
+
+uint64_t GetBitWidth(int32_t num_distinct_values) {
+  return ::arrow::bit_util::NumRequiredBits(num_distinct_values);
+}
+
+// TODO: Replace with generic lambda function in C++14 and above
+struct GetNonNullIndicesVisitor {
+  template <typename T>
+  std::vector<int32_t> operator()(Span<T> indices) {
+    return GetNonNullIndices(indices);
+  }
+};
+
+uint64_t ComputeSize(const Data& data) {
+  uint64_t size = 0;
+  for (size_t i = 0; i < data.columns.size(); ++i) {
+    auto non_null_indices = Visit(data.indices[i], GetNonNullIndicesVisitor());
+    size += GetRleEncodedIndicesSizeEstimate(
+        AsSpan(non_null_indices), GetBitWidth(data.columns[i].num_distinct_values));
+  }
+  return size;
+}
+
+void TestVorderShuffle(unsigned int seed, int32_t num_rows,
+                       std::vector<std::pair<double, double>> nc_ndv) {
+  auto data = GenerateData(seed, num_rows, nc_ndv);
+  const auto size_before_shuffle = ComputeSize(data);
+  auto permutation = GetPermutationVector(data.num_rows);
+  ShuffleProperties properties;
+  properties.algorithm_properties(vorder_full());
+  VorderShuffle shuffle(properties);
+  auto complete_permutation = Span<int32_t>();
+  shuffle.Apply(AsSpan(data.columns), AsSpan(permutation), complete_permutation);
+  CheckDataIntegrity(data);
+  Shuffle(data, permutation);
+  const auto size_after_shuffle = ComputeSize(data);
+  std::cout << "before = " << size_before_shuffle << std::endl;
+  std::cout << "after = " << size_after_shuffle << std::endl;
+  EXPECT_THAT(size_after_shuffle, Le(size_before_shuffle));
+}
+
