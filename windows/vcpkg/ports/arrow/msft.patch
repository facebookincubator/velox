+::arrow::Result<std::string> DecimalToString(int64_t value,
+                                             const DecimalLogicalType& type) {
+  return DecimalToString(::arrow::Decimal128{value}, type.scale());
+}
+
+::arrow::Result<std::string> DecimalToString(const uint8_t* ptr, int len,
+                                             const DecimalLogicalType& type) {
+  ARROW_ASSIGN_OR_RAISE(const auto val, ::arrow::Decimal128::FromBigEndian(ptr, len));
+  return DecimalToString(val, type.scale());
+}
