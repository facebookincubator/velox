+/// @brief Fuzzer callback function: https://llvm.org/docs/LibFuzzer.html#id39
+/// @param data data
+/// @param size size
+/// @return non-zero if input rejected.
+extern "C" int LLVMFuzzerTestOneInput(const uint8_t* data, size_t size) {
+  return parquet::shuffle::fuzz::LLVMFuzzerTestOneInput(data, size);
+}
