+std::string DecimalToString(const ::arrow::Decimal128& value, int32_t scale) {
+  auto result = value.ToString(scale);
+  const auto pos = result.find(".E");
+  if (pos != std::string::npos) {
+    result.replace(pos, 2, "E");
+  }
+  return result;
+}
