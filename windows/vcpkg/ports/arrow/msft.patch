+::arrow::Result<int64_t> GetScale(LogicalType::TimeUnit::unit unit) {
+  switch (unit) {
+    case LogicalType::TimeUnit::MILLIS:
+      return 1'000;
+    case LogicalType::TimeUnit::MICROS:
+      return 1'000'000;
+    case LogicalType::TimeUnit::NANOS:
+      return 1'000'000'000;
+    default:
+      return ::arrow::Status::NotImplemented("unknown time unit", unit);
+  }
+}
