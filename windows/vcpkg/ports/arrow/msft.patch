+/// @brief Fuzzer callback function: https://llvm.org/docs/LibFuzzer.html#id39
+/// @param argc args
+/// @param argv argv
+/// @return return
+extern "C" int LLVMFuzzerInitialize(int* argc, const char*** argv) {
+  return parquet::shuffle::fuzz::LLVMFuzzerInitialize(argc, argv);
+}
