+TEST(TestU24, Assignment_Int32T) {
+  u24 u;
+  u = static_cast<int32_t>(1);
+  EXPECT_THAT(u.value(), 1);
+  u = static_cast<int32_t>(-1);
+  EXPECT_THAT(u.value(), 16777215);
+}
+
+TEST(TestU24, Addition) {
+  u24 u(200);
+  EXPECT_THAT((u + 1).value(), 201);
+  EXPECT_THAT((u + 55).value(), 255);
+  EXPECT_THAT((u + 56).value(), 256);
+  EXPECT_THAT((u + 70000).value(), 70200);
+  EXPECT_THAT((u + 16777015).value(), 16777215);
+  EXPECT_THAT((u + 16777016).value(), 0);
+  EXPECT_THAT(((u + 56) + 70000).value(), 70256);
+  EXPECT_THAT(((u + 56) + 16777000).value(), 40);
+  EXPECT_THAT(((u + 70000) + 16707216).value(), 200);
+  EXPECT_THAT(((u + 16777016) + 1).value(), 1);
+  EXPECT_THAT((u24(255) + 1).value(), 256);
+  EXPECT_THAT((u24(65535) + 1).value(), 65536);
+  EXPECT_THAT((u24(16777215) + 1).value(), 0);
+}
+
