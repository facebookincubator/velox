+          artifactName: drop_Build_msvc_Release_windows_Build
+      - script: |
+          FILE=$(Pipeline.Workspace)/$(ARTIFACT_ID)-$(VERSION_FULL)-${{ build.packageSuffix }}.tar.gz
+          if [ ! -s deploy-file ]; then
+            echo -n "$FILE" >> deploy-file
+            echo -n "${{ build.packageSuffix }}" >> deploy-classifier
+          else
+            if [ ! -s deploy-files ]; then
+              echo -n "$FILE" >> deploy-files
+              echo -n "${{ build.packageSuffix }}" >> deploy-classifiers
+              echo -n "tar.gz" >> deploy-types
+            else
+              echo -n ",$FILE" >> deploy-files
