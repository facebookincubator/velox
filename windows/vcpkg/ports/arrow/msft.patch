+    if (curr_len >= s.size()) {
+      // Return the original string if we have reached the end of the string
+      return ::arrow::util::UTF16StringToUTF8(r);
+    } else if (curr_len + 1 < r.size() && r.substr(curr_len, 2) == kUnicodeMaxCharacter) {
+      // Skip the max character. It occupies two characters in UTF-16.
+      curr_len += 2;
+    } else if (r[curr_len] < kAsciiMaxCharacter) {
+      return ::arrow::util::UTF16StringToUTF8(std::move(s).substr(0, curr_len) +
+                                              kAsciiMaxCharacter);
+    } else {
+      return ::arrow::util::UTF16StringToUTF8(std::move(s).substr(0, curr_len) +
+                                              kUnicodeMaxCharacter);
+    }
+  }
+  return ::arrow::Status::Invalid("string too long");
