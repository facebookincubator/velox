+#include "parquet/shuffle/util/type_macros.h"
+
+namespace parquet {
+namespace shuffle {
+
+using ::arrow::internal::Executor;
+
+template <typename T>
+uint64_t ComputeHash(const T& value, int = 0) {
+  return ::arrow::internal::ScalarHelper<T, 0>::ComputeHash(value);
+}
+
+template <>
+uint64_t ComputeHash(const ByteArray& value, int) {
+  return ::arrow::internal::ComputeStringHash<0>(value.ptr, value.len);
+}
+
+template <>
+uint64_t ComputeHash(const FLBA& value, int length) {
+  return ::arrow::internal::ComputeStringHash<0>(value.ptr, length);
+}
+
+template <>
+uint64_t ComputeHash(const std::string& value, int) {
+  return ::arrow::internal::ComputeStringHash<0>(value.data(), value.size());
+}
+
+void CombineHash(uint64_t& h1, uint64_t h2) {
+  ::arrow::internal::detail::hash_combine_impl(h1, h2);
+}
+
+class BufferedColumnReader {
+ public:
+  BufferedColumnReader(std::shared_ptr<ColumnReader> col_reader, int64_t batch_size,
+                       MemoryPool* mp)
+      : col_reader_(std::move(col_reader)),
+        values_(AllocateBuffer(mp, batch_size * GetTypeByteSize(col_reader_->type()))),
+        values_ptr_(values_->mutable_data()),
+        def_levels_ptr_(nullptr),
+        rep_levels_ptr_(nullptr),
+        batch_size_(batch_size),
+        values_read_(0),
+        next_value_index_(0),
+        levels_read_(0),
+        next_level_index_(0),
+        max_definition_level_(col_reader_->descr()->max_definition_level()),
+        max_repetition_level_(col_reader_->descr()->max_repetition_level()),
+        exhausted_(false) {
+    if (max_definition_level_ > 0) {
+      def_levels_ = AllocateBuffer(mp, batch_size * sizeof(int16_t));
+      def_levels_ptr_ = reinterpret_cast<int16_t*>(def_levels_->mutable_data());
+      std::memset(def_levels_ptr_, 0, batch_size * sizeof(int16_t));
+    }
+    if (max_repetition_level_ > 0) {
+      rep_levels_ = AllocateBuffer(mp, batch_size * sizeof(int16_t));
+      rep_levels_ptr_ = reinterpret_cast<int16_t*>(rep_levels_->mutable_data());
+      std::memset(rep_levels_ptr_, 0, batch_size * sizeof(int16_t));
+    }
+  }
+
+  Type::type type() const { return col_reader_->type(); }
+
+  int GetTypeLength() const { return col_reader_->descr()->type_length(); }
+
+  bool IsRequired() const { return max_definition_level_ == 0; }
+
+  bool IsOptional() const {
+    return max_definition_level_ > 0 && max_repetition_level_ == 0;
+  }
+
+  bool IsRepeated() const { return max_repetition_level_ > 0; }
+
+  template <typename DType, typename Handler>
+  bool NextRowRequired(Handler handler) {
+    DCHECK_EQ(max_definition_level_, 0);
+    using T = typename DType::c_type;
+    if (!EnsureNext<DType>()) return false;
+    handler(static_cast<const T*>(values_ptr_)[next_level_index_++]);
+    return true;
+  }
+
+  template <typename DType, typename Handler>
+  bool NextRowOptional(Handler handler) {
+    DCHECK_GT(max_definition_level_, 0);
+    DCHECK_EQ(max_repetition_level_, 0);
+    using T = typename DType::c_type;
+    if (!EnsureNext<DType>()) return false;
+    const int16_t def_level = def_levels_ptr_[next_level_index_++];
+    const T* value = def_level == max_definition_level_
+                         ? static_cast<const T*>(values_ptr_) + next_value_index_++
+                         : nullptr;
+    handler(value, def_level);
+    return true;
+  }
+
+  template <typename DType, typename Handler>
+  bool NextRowRepeated(Handler handler) {
+    DCHECK_GT(max_repetition_level_, 0);
+    using T = typename DType::c_type;
+    if (!EnsureNext<DType>()) return false;
+    int16_t rep_level = rep_levels_ptr_[next_level_index_];
+    int16_t def_level = def_levels_ptr_[next_level_index_];
+    ++next_level_index_;
+    const T* value = def_level == max_definition_level_
+                         ? static_cast<const T*>(values_ptr_) + next_value_index_++
+                         : nullptr;
+    handler(value, def_level, rep_level);
+    while (EnsureNext<DType>() && (rep_level = rep_levels_ptr_[next_level_index_]) != 0) {
+      int16_t def_level = def_levels_ptr_[next_level_index_];
+      ++next_level_index_;
+      const T* value = def_level == max_definition_level_
+                           ? static_cast<const T*>(values_ptr_) + next_value_index_++
+                           : nullptr;
+      handler(value, def_level, rep_level);
+    }
+    return true;
+  }
+
+ private:
+  template <typename DType>
+  bool EnsureNext() {
+    if (exhausted_) return false;
+    if (next_level_index_ < levels_read_) return true;
+    NextBatch<DType>();
+    return !exhausted_;
+  }
+
+  template <typename DType>
+  void NextBatch() {
+    using T = typename DType::c_type;
+    levels_read_ = static_cast<TypedColumnReader<DType>*>(col_reader_.get())
+                       ->ReadBatch(batch_size_, def_levels_ptr_, rep_levels_ptr_,
+                                   static_cast<T*>(values_ptr_), &values_read_);
+    next_value_index_ = 0;
+    next_level_index_ = 0;
+    if (levels_read_ == 0) {
+      exhausted_ = true;
+    }
+  }
+
+  std::shared_ptr<ColumnReader> col_reader_;
+  std::shared_ptr<ResizableBuffer> values_;
+  std::shared_ptr<ResizableBuffer> def_levels_;
+  std::shared_ptr<ResizableBuffer> rep_levels_;
+  void* values_ptr_;
+  int16_t* def_levels_ptr_;
+  int16_t* rep_levels_ptr_;
+  const int64_t batch_size_;
+  int64_t values_read_;
+  int64_t next_value_index_;
+  int64_t levels_read_;
+  int64_t next_level_index_;
+  const int16_t max_definition_level_;
+  const int16_t max_repetition_level_;
+  bool exhausted_;
+};
+
+template <typename DType>
+void UpdateRowHashesRequired(BufferedColumnReader& col_reader,
+                             std::vector<uint64_t>& row_hashes) {
+  using T = typename DType::c_type;
+  const auto type_length = col_reader.GetTypeLength();
+  const auto rows_to_read = row_hashes.size();
+  for (size_t rows_read = 0; rows_read < rows_to_read; ++rows_read) {
+    uint64_t h = 0;
+    const bool value_read = col_reader.NextRowRequired<DType>(
+        [&](const T& value) { h = ComputeHash(value, type_length); });
+    DCHECK(value_read);
+    CombineHash(row_hashes[rows_read], h);
+  }
+}
+
+template <typename DType>
+void UpdateRowHashesOptional(BufferedColumnReader& col_reader,
+                             std::vector<uint64_t>& row_hashes) {
+  using T = typename DType::c_type;
+  const auto type_length = col_reader.GetTypeLength();
+  const auto rows_to_read = row_hashes.size();
+  for (size_t rows_read = 0; rows_read < rows_to_read; ++rows_read) {
+    uint64_t h = 0;
+    const bool value_read =
+        col_reader.NextRowOptional<DType>([&](const T* value, int16_t def_level) {
+          if (value != nullptr) {
+            h = ComputeHash(*value, type_length);
+          }
+          CombineHash(h, ComputeHash(def_level));
+        });
+    DCHECK(value_read);
+    CombineHash(row_hashes[rows_read], h);
+  }
+}
+
+template <typename DType>
+void UpdateRowHashesRepeated(BufferedColumnReader& col_reader,
+                             std::vector<uint64_t>& row_hashes) {
+  using T = typename DType::c_type;
+  const auto type_length = col_reader.GetTypeLength();
+  const auto rows_to_read = row_hashes.size();
+  for (size_t rows_read = 0; rows_read < rows_to_read; ++rows_read) {
+    uint64_t h = 0;
+    const bool value_read = col_reader.NextRowRepeated<DType>(
+        [&](const T* value, int16_t def_level, int16_t rep_level) {
+          if (value != nullptr) {
+            h = ComputeHash(*value, type_length);
+          }
+          CombineHash(h, ComputeHash(def_level));
+          CombineHash(h, ComputeHash(rep_level));
+        });
+    DCHECK(value_read);
+    CombineHash(row_hashes[rows_read], h);
+  }
+}
+
+void UpdateRowHashes(BufferedColumnReader& col_reader,
+                     std::vector<uint64_t>& row_hashes) {
+  if (col_reader.IsRequired()) {
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col_reader.type(), UpdateRowHashesRequired<DType>(col_reader, row_hashes));
+  } else if (col_reader.IsOptional()) {
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col_reader.type(), UpdateRowHashesOptional<DType>(col_reader, row_hashes));
+  } else {
+    DCHECK(col_reader.IsRepeated());
+    PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+        col_reader.type(), UpdateRowHashesRepeated<DType>(col_reader, row_hashes));
+  }
+}
+
+uint64_t HashSum(RowGroupReader& rg_reader, int64_t row_offset, int64_t row_count,
+                 const std::vector<int>& columns) {
+  const int64_t batch_size = 65536;
+  std::vector<BufferedColumnReader> col_readers;
+  col_readers.reserve(columns.size());
+  for (const auto col : columns) {
+    auto col_reader = rg_reader.Column(col);
+    Skip(*col_reader, row_offset);
+    col_readers.emplace_back(std::move(col_reader), batch_size,
+                             ::arrow::default_memory_pool());
+  }
+  int64_t remaining_rows = row_count;
+  std::vector<uint64_t> row_hashes;
+  uint64_t sum = 0;
+  while (remaining_rows > 0) {
+    const auto rows_to_read = std::min(batch_size, remaining_rows);
+    row_hashes.clear();
+    row_hashes.resize(rows_to_read, 0);
+    for (auto& col_reader : col_readers) {
+      UpdateRowHashes(col_reader, row_hashes);
+    }
+    sum += std::accumulate(row_hashes.begin(), row_hashes.end(), 0ull);
+    remaining_rows -= rows_to_read;
+  }
+  return sum;
+}
+
+uint64_t HashSum(ParquetFileReaderSlice& source, Executor* executor) {
+  const auto num_row_groups = source.num_row_groups();
+  if (num_row_groups > std::numeric_limits<int>::max()) {
+    throw ParquetException("Too many row groups");
+  }
+  std::atomic<uint64_t> sum{0};
+  OptionalParallelFor(
+      static_cast<int>(num_row_groups),
+      [&](int) {
+        auto rg_slice = source.NextRowGroup();
+        sum += HashSum(*rg_slice.row_group, rg_slice.row_offset, rg_slice.row_count,
+                       source.columns());
+      },
+      executor);
+  uint64_t h = sum.load();
+  return h;
+}
