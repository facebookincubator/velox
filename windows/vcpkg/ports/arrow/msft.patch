+std::string Node::path_as_dot_string() const {
+  size_t total_size = 0;
+  const Node* cursor = this;
+  // The schema node is not part of the ColumnPath
+  while (cursor->parent()) {
+    total_size += 1 + cursor->name().length();
+    cursor = cursor->parent();
+  }
+
+  std::string path_str;
+  path_str.resize(total_size - 1);
+
+  size_t curr = total_size - 1;
+  cursor = this;
+  while (cursor->parent()) {
+    if (cursor != this) {
+      path_str.replace(--curr, 1, ".");
+    }
+
+    size_t currentLen = cursor->name().length();
+    path_str.replace(curr - currentLen, currentLen, cursor->name());
+    curr -= currentLen;
+    cursor = cursor->parent();
+  }
+
+  return path_str;
+}
