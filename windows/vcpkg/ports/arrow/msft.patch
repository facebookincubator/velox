+  // Start with a valid prefix
+  auto curr_len = utf8::internal::is_lead_surrogate(s[prefix_len - 1]) &&
+                          utf8::internal::is_trail_surrogate(s[prefix_len])
+                      ? prefix_len + 1
+                      : prefix_len;
