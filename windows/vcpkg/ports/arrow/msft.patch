+std::shared_ptr<schema::GroupNode> CopySchema(const SchemaDescriptor& schema) {
+  const auto& group_node = *schema.group_node();
+  schema::NodeVector fields(group_node.field_count());
+  const auto num_fields = static_cast<int>(fields.size());
+  for (int i = 0; i < num_fields; ++i) {
+    fields[i] = group_node.field(i);
+  }
+  return std::static_pointer_cast<schema::GroupNode>(
+      schema::GroupNode::Make(group_node.name(), group_node.repetition(), fields, nullptr,
+                              group_node.field_id()));
+}
