+      // TODO OSS: Nested data conversions not implemented for chunked array outputs
+      "large_string_map.brotli.parquet",
+      "nation.dict-malformed.parquet",  // PreBuffer fails
+  };
+  auto fs_and_files = test::get_data_files();
+  auto& fs = *fs_and_files.first;
+  for (const auto& file : fs_and_files.second) {
+    SCOPED_TRACE(::testing::Message() << "file = " << file.path());
+    if (skipped_files.find(file.base_name()) != skipped_files.end()) {
+      std::cout << "Skipping " << file.base_name() << std::endl;
+      continue;
+    }
+    std::unique_ptr<FileReader> arrow_reader;
+    std::shared_ptr<::arrow::Table> expected_table;
+    std::shared_ptr<::arrow::RecordBatchReader> expected_rb_reader;
+    std::shared_ptr<FileMetaData> metadata;
+    {
+      PARQUET_ASSIGN_OR_THROW(auto in, fs.OpenInputFile(file.path()));
+      auto reader = ParquetFileReader::Open(in);
+      metadata = reader->metadata();
+      if (!metadata->can_decompress()) {
+        std::cout << "Skipping " << file.base_name() << ": unsupported compression"
+                  << std::endl;
+        continue;
+      }
+      auto pool = ::arrow::default_memory_pool();
+      ASSERT_OK_NO_THROW(FileReader::Make(pool, std::move(reader), &arrow_reader));
+      ASSERT_OK_NO_THROW(arrow_reader->ReadTable(&expected_table));
+      ASSERT_OK_NO_THROW(arrow_reader->GetRecordBatchReader(&expected_rb_reader));
+    }
+    std::shared_ptr<Buffer> buffer;
+    {
+      ::arrow::TableBatchReader table_reader(*expected_table);
+      std::shared_ptr<::arrow::RecordBatch> record_batch;
+      ASSERT_OK(table_reader.ReadNext(&record_batch));
+      auto sink = CreateOutputStream();
+      auto write_props = WriterProperties::Builder().build();
+      auto writer = ParquetFileWriter::Open(
+          sink, std::static_pointer_cast<GroupNode>(metadata->schema()->schema_root()));
+      auto rg_writer = writer->AppendBufferedRowGroup();
+      auto arrow_properties = default_arrow_writer_properties();
+      // Write RecordBatch in 10 mini-batches to test offset/length params
+      const int64_t batch_rowcount = record_batch->num_rows();
+      const int64_t minibatch_size = (batch_rowcount + 9) / 10;
+      for (int64_t offset = 0; offset < batch_rowcount; offset += minibatch_size) {
+        const int64_t length = std::min(minibatch_size, batch_rowcount - offset);
+        ASSERT_OK_NO_THROW(WriteRecordBatch(*record_batch, offset, length, *rg_writer,
+                                            metadata->schema(), *arrow_properties));
+      }
+      rg_writer->Close();
+      writer->Close();
+      ASSERT_OK_AND_ASSIGN(buffer, sink->Finish());
+    }
+    std::unique_ptr<FileReader> actual_reader;
+    std::shared_ptr<::arrow::RecordBatchReader> actual_rb_reader;
+    {
+      ASSERT_OK_NO_THROW(OpenFile(std::make_shared<BufferReader>(buffer),
+                                  ::arrow::default_memory_pool(), &actual_reader));
+      ASSERT_OK_NO_THROW(actual_reader->GetRecordBatchReader(&actual_rb_reader));
+    }
+    while (true) {
+      std::shared_ptr<::arrow::RecordBatch> expected_rb;
+      std::shared_ptr<::arrow::RecordBatch> actual_rb;
+      ASSERT_OK(expected_rb_reader->ReadNext(&expected_rb));
+      ASSERT_OK(actual_rb_reader->ReadNext(&actual_rb));
+      if (expected_rb == NULLPTR && actual_rb == NULLPTR) {
+        break;
+      }
+      ASSERT_TRUE(static_cast<bool>(expected_rb));
+      ASSERT_TRUE(static_cast<bool>(actual_rb));
+      ::arrow::AssertBatchesEqual(*expected_rb, *actual_rb);
+    }
