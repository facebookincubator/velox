+Status WriteRecordBatch(const ::arrow::RecordBatch& record_batch, int64_t offset,
+                        int64_t length, parquet::RowGroupWriter& row_group_writer,
+                        const SchemaDescriptor* schema,
+                        const ArrowWriterProperties& arrow_writer_properties) {
+  const auto num_rows = record_batch.num_rows();
+  if (offset < 0 || offset >= num_rows || length < 0 || num_rows - offset < length) {
+    return Status::IndexError("offset ", offset, " and/or length ", length,
+                              " is out of range [0, ", num_rows, ")");
+  }
+  const int num_columns = record_batch.num_columns();
+  SchemaManifest schema_manifest;
+  RETURN_NOT_OK(SchemaManifest::Make(schema, /*schema_metadata=*/nullptr,
+                                     default_arrow_reader_properties(),
+                                     &schema_manifest));
+  ArrowWriteContext column_write_context(::arrow::default_memory_pool(),
+                                         &arrow_writer_properties);
+  int leaf_index = 0;
+  for (int i = 0; i < num_columns; ++i) {
+    ::arrow::ChunkedArray array(record_batch.column(i));
+    ARROW_ASSIGN_OR_RAISE(auto arrow_writer, ArrowColumnWriterV2::Make(
+                                                 array, offset, length, schema_manifest,
+                                                 &row_group_writer, leaf_index));
+    RETURN_NOT_OK(arrow_writer->Write(&column_write_context));
+    leaf_index += arrow_writer->leaf_count();
+  }
+  return Status::OK();
+}
