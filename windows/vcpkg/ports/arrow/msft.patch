+
+template <typename TypeParam>
+class TestShuffledRowGroupWriter : public ::testing::Test {
+ protected:
+  using ShuffleType = typename TypeParam::shuffle_type;
+  using DType = typename TypeParam::data_type;
+  using CType = typename DType::c_type;
+
+  std::unique_ptr<MemoryPool> mp = MemoryPool::CreateDefault();
+  std::shared_ptr<ShuffleProperties> props = std::make_shared<ShuffleProperties>();
+  std::shared_ptr<BufferOutputStream> sink = CreateOutputStream();
+  schema::NodeVector fields;
+
+  void TestSingleColumn(std::shared_ptr<WriterProperties> properties) {
+    props->memory_pool(mp.get());
+    auto file_data = Write(std::move(properties));
+    const auto expected = BuildExpected();
+    Vec<std::unique_ptr<Buffer>> byte_array_buffers;
+    Vec<CType> out(expected.first.size());
+    Vec<int16_t> def_levels_out(expected.second.size());
+    int64_t values_read = 0;
+    std::shared_ptr<FileMetaData> metadata;
+    Read(std::make_shared<BufferReader>(std::move(file_data)), out, def_levels_out,
+         values_read, byte_array_buffers, metadata);
+    ASSERT_THAT(values_read, expected.first.size());
+    EXPECT_THAT(def_levels_out, ElementsAreArray(expected.second));
+    ExpectEqualElements(out, expected.first, TypeParam::length);
+    CheckStatistics(*metadata, expected.first, expected.second);
+  }
+
+  std::shared_ptr<Buffer> Write(std::shared_ptr<WriterProperties> properties) {
+    fields.emplace_back(PrimitiveNode::Make("col", TypeParam::repetition, DType::type_num,
+                                            ConvertedType::NONE, TypeParam::length));
+    auto schema = std::static_pointer_cast<GroupNode>(
+        GroupNode::Make("schema", Repetition::REQUIRED, fields));
+    auto file_writer = ParquetFileWriter::Open(sink, schema, std::move(properties));
+    auto shuffle_algorithm = ShuffleType::Make(*props);
+    auto rg_writer = file_writer->AppendShuffledRowGroup(
+        std::make_unique<Shuffle>(props, std::move(shuffle_algorithm)));
+    auto col_writer = static_cast<TypedColumnWriter<DType>*>(rg_writer->column(0));
+    const auto in = TypeParam::in();
+    const auto def_levels = TypeParam::def_levels();
+    const auto num_rows = std::max(in.size(), def_levels.size());
+    if (num_rows > 0) {
+      col_writer->WriteBatch(num_rows, def_levels.data(), nullptr,
+                             reinterpret_cast<const CType*>(in.data()));
+    }
+    TypeParam::EraseData();
+    rg_writer->Close();
+    file_writer->Close();
+    PARQUET_ASSIGN_OR_THROW(auto file_data, sink->Finish());
+    return file_data;
+  }
+
+  void Read(std::shared_ptr<BufferReader> source, Vec<CType>& out,
+            Vec<int16_t>& def_levels_out, int64_t& values_read,
+            Vec<std::unique_ptr<Buffer>>& byte_array_buffers,
+            std::shared_ptr<FileMetaData>& metadata) {
+    auto file_reader = ParquetFileReader::Open(source);
+    metadata = file_reader->metadata();
+    int64_t levels_read = 0;
+    for (int i = 0; i < file_reader->metadata()->num_row_groups(); ++i) {
+      auto rg_reader = file_reader->RowGroup(i);
+      ASSERT_EQ(1, rg_reader->metadata()->num_columns());
+      auto col_reader =
+          std::static_pointer_cast<TypedColumnReader<DType>>(rg_reader->Column(0));
+      while (col_reader->HasNext()) {
+        const auto batch_size =
+            std::max(def_levels_out.size() - levels_read, out.size() - values_read);
+        ASSERT_GT(batch_size, 0);
+        int64_t curr_values_read = 0;
+        int64_t curr_levels_read = col_reader->ReadBatch(
+            batch_size,
+            def_levels_out.empty() ? nullptr : def_levels_out.data() + levels_read,
+            nullptr, reinterpret_cast<CType*>(out.data()) + values_read,
+            &curr_values_read);
+        CopyByteArrayData(byte_array_buffers, out.data() + values_read, curr_values_read,
+                          TypeParam::length);
+        values_read += curr_values_read;
+        if (!def_levels_out.empty()) levels_read += curr_levels_read;
+      }
+    }
+  }
+
+  void CheckStatistics(const FileMetaData& metadata, const Vec<CType>& values,
+                       const Vec<int16_t>& def_levels) {
+    const auto row_count =
+        static_cast<int64_t>(std::max(def_levels.size(), values.size()));
+    const auto null_count = std::count(def_levels.begin(), def_levels.end(), 0);
+    EXPECT_THAT(metadata.num_columns(), 1);
+    EXPECT_THAT(metadata.num_row_groups(), 1);
+    EXPECT_THAT(metadata.num_rows(), row_count);
+    const auto rg = metadata.RowGroup(0);
+    EXPECT_THAT(rg->num_columns(), 1);
+    EXPECT_THAT(rg->num_rows(), row_count);
+    const auto col = rg->ColumnChunk(0);
+    EXPECT_THAT(col->num_values(), row_count);
+    if (row_count > 0 && !std::is_same<CType, Int96>::value) {
+      EXPECT_TRUE(col->is_stats_set());
+      EXPECT_TRUE(col->is_null_count_set());
+      const auto stats = col->statistics();
+      EXPECT_TRUE(stats->HasNullCount());
+      EXPECT_THAT(stats->null_count(), null_count);
+    }
+  }
+
+  std::pair<Vec<CType>, Vec<int16_t>> BuildExpected() {
+    auto expected = TypeParam::in();
+    auto def_levels = TypeParam::def_levels();
+    const auto num_rows = std::max(expected.size(), def_levels.size());
+    Vec<CType> dict;
+    Vec<int32_t> indices(num_rows);
+    Encode(expected, def_levels, indices, dict);
+    ColumnData column_data{0,
+                           4,
+                           reinterpret_cast<uint8_t*>(indices.data()),
+                           def_levels.data(),
+                           static_cast<int32_t>(expected.size()),
+                           static_cast<int32_t>(dict.size())};
+    std::vector<int32_t> permutation_buffer(num_rows);
+    auto permutation = AsSpan(permutation_buffer);
+    auto complete_permutation = Span<int32_t>();
+    const bool do_shuffle = ShuffleType::Make(*props)->Apply(
+        Span<ColumnData>{&column_data, 1}, permutation, complete_permutation);
+    if (do_shuffle) {
+      DoShuffle(permutation, indices.data());
+      if (!def_levels.empty()) {
+        DoShuffle(permutation, def_levels.data());
+      }
+      Decode(expected, indices, dict);
+    }
+    return {expected, def_levels};
+  }
+
+  void Encode(const Vec<CType>& values, const Vec<int16_t>& def_levels,
+              Vec<int32_t>& indices, Vec<CType>& dict) {
+    std::unordered_map<CType, int32_t, Hash<CType>, EqualTo<CType>> map(
+        1, Hash<CType>(TypeParam::length), EqualTo<CType>(TypeParam::length));
+    if (def_levels.empty()) {
+      EncodeRequired(values, indices, map);
+    } else {
+      EncodeOptional(values, def_levels, indices, map);
+    }
+    CopyValues(dict, map);
+  }
+
+  template <typename Map>
+  void EncodeRequired(const Vec<CType>& values, Vec<int32_t>& indices, Map& map) {
+    for (size_t i = 0; i < values.size(); ++i) {
+      indices[i] = GetOrInsert(map, values[i]);
+    }
+  }
+
+  template <typename Map>
+  void EncodeOptional(const Vec<CType>& values, const Vec<int16_t>& def_levels,
+                      Vec<int32_t>& indices, Map& map) {
+    for (size_t i = 0, j = 0; i < def_levels.size(); ++i) {
+      indices[i] = def_levels[i] == 1 ? GetOrInsert(map, values[j++]) : -1;
+    }
+  }
+
+  template <typename Map>
+  int32_t GetOrInsert(Map& map, CType value) {
+    return map.emplace(value, static_cast<int32_t>(map.size())).first->second;
+  }
+
+  template <typename Map>
+  void CopyValues(Vec<CType>& dict, Map& map) {
+    dict.resize(map.size());
+    for (const auto& entry : map) {
+      dict[entry.second] = entry.first;
+    }
+  }
+
+  void Decode(Vec<CType>& out, const Vec<int32_t>& indices, const Vec<CType>& dict) {
+    size_t i = 0;
+    for (const auto index : indices) {
+      if (index >= 0) {
+        out[i++] = dict[index];
+      }
+    }
+  }
+};
