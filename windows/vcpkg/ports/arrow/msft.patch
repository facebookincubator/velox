+bool ParquetFileReaderSlice::Impl::empty() const { return num_rows_ == 0; }
+
+int ParquetFileReaderSlice::Impl::num_columns() const {
+  return static_cast<int>(cols_.size());
+}
+
+const std::vector<int>& ParquetFileReaderSlice::Impl::columns() const { return cols_; }
+
+int ParquetFileReaderSlice::Impl::num_row_groups() const {
+  return row_group_indices_.back();
+}
+
+int64_t ParquetFileReaderSlice::Impl::num_rows() const { return num_rows_; }
+
+const SchemaDescriptor& ParquetFileReaderSlice::Impl::schema() const {
+  return schema_ ? *schema_ : *metadata_[0]->schema();
+}
+
+std::vector<std::shared_ptr<const ::arrow::KeyValueMetadata>>
+ParquetFileReaderSlice::Impl::key_value_metadata() const {
+  std::vector<std::shared_ptr<const ::arrow::KeyValueMetadata>> ret;
+  ret.reserve(metadata_.size());
+  for (const auto& metadata : metadata_) {
+    ret.emplace_back(metadata->key_value_metadata());
+  }
+  return ret;
+}
+
+void ParquetFileReaderSlice::Impl::RemoveEmptyFiles() {
+  auto it = std::remove_if(files_.begin(), files_.end(),
+                           [](const std::shared_ptr<ParquetFileReader>& file) {
+                             return file->metadata()->num_row_groups() == 0;
+                           });
+  files_.erase(it, files_.end());
+}
+
+void ParquetFileReaderSlice::Impl::SkipRowGroups(ParquetFileReaderSliceRange& r) {
+  int num_skipped_row_groups = 0;
+  for (size_t i = 0; i < files_.size(); ++i) {
+    const auto n = files_[i]->metadata()->num_row_groups();
+    if (num_skipped_row_groups + n > r.row_group_offset) {
+      files_.erase(files_.begin(), files_.begin() + i);
+      r.row_group_offset -= num_skipped_row_groups;
+      return;
+    }
+    num_skipped_row_groups += n;
+  }
+  files_.clear();
+}
+
+void ParquetFileReaderSlice::Impl::DropRowGroups(ParquetFileReaderSliceRange& r,
+                                                 int& last_file_row_group_count) {
+  int row_group_count = -r.row_group_offset;
+  for (size_t i = 0; i < files_.size(); ++i) {
+    const auto n = files_[i]->metadata()->num_row_groups();
+    if (row_group_count + n >= r.row_group_count) {
+      files_.erase(files_.begin() + i + 1, files_.end());
+      last_file_row_group_count = r.row_group_count - row_group_count;
+      return;
+    }
+    row_group_count += n;
+  }
+  r.row_group_count = row_group_count;
+}
+
+class RowGroupIterator {
+ public:
+  RowGroupIterator(const std::vector<std::shared_ptr<ParquetFileReader>>& files,
+                   int row_group_offset, int row_group_count, int64_t row_offset)
+      : files_(files),
+        row_group_count_(row_group_count),
+        row_offset_(row_offset),
+        row_group_index_(0),
+        file_index_(0),
+        file_row_group_index_(row_group_offset),
+        file_num_row_groups_(files[0]->metadata()->num_row_groups()) {}
+
+  bool HasRowGroup() const {
+    return file_index_ < files_.size() &&
+           (row_group_count_ == 0 || row_group_index_ < row_group_count_);
+  }
+
+  int GetRowGroupIndex() const { return row_group_index_; }
+
+  size_t GetFileIndex() const { return file_index_; }
+
+  int GetFileRowGroupIndex() const { return file_row_group_index_; }
+
+  int64_t GetRowGroupSize() const {
+    const auto num_rows =
+        files_[file_index_]->metadata()->RowGroup(file_row_group_index_)->num_rows();
+    return row_group_index_ == 0 ? num_rows - row_offset_ : num_rows;
+  }
+
+  void NextRowGroup() {
+    ++row_group_index_;
+    if (++file_row_group_index_ == file_num_row_groups_) {
+      if (++file_index_ < files_.size()) {
+        file_row_group_index_ = 0;
+        file_num_row_groups_ = files_[file_index_]->metadata()->num_row_groups();
+      }
+    }
+  }
+
+ private:
+  const std::vector<std::shared_ptr<ParquetFileReader>>& files_;
+  const int row_group_count_;
+  const int64_t row_offset_;
+  int row_group_index_;
+  size_t file_index_;
+  int file_row_group_index_;
+  int file_num_row_groups_;
+};
+
+void ParquetFileReaderSlice::Impl::SkipRows(ParquetFileReaderSliceRange& r) {
+  RowGroupIterator iter(files_, r.row_group_offset, r.row_group_count, 0);
+  int64_t row_count = 0;
+  while (iter.HasRowGroup()) {
+    const int64_t n = iter.GetRowGroupSize();
+    if (row_count + n > r.row_offset) {
+      files_.erase(files_.begin(), files_.begin() + iter.GetFileIndex());
+      r.row_group_offset = iter.GetFileRowGroupIndex();
+      if (r.row_group_count > 0) r.row_group_count -= iter.GetRowGroupIndex();
+      r.row_offset -= row_count;
+      return;
+    }
+    row_count += n;
+    iter.NextRowGroup();
+  }
+  files_.clear();
+}
+
+void ParquetFileReaderSlice::Impl::DropRows(ParquetFileReaderSliceRange& r,
+                                            int& last_file_row_group_count,
+                                            int64_t& last_row_group_row_count) {
+  RowGroupIterator iter(files_, r.row_group_offset, r.row_group_count, r.row_offset);
+  int64_t row_count = 0;
+  while (iter.HasRowGroup()) {
+    const int64_t n = iter.GetRowGroupSize();
+    if (row_count + n >= r.row_count) {
+      files_.erase(files_.begin() + iter.GetFileIndex() + 1, files_.end());
+      r.row_group_count = iter.GetRowGroupIndex() + 1;
+      last_file_row_group_count =
+          iter.GetFileIndex() == 0 ? iter.GetFileRowGroupIndex() + 1 - r.row_group_offset
+                                   : iter.GetFileRowGroupIndex() + 1;
+      last_row_group_row_count = r.row_count - row_count;
+      return;
+    }
+    row_count += n;
+    iter.NextRowGroup();
+  }
+  r.row_count = row_count;
+}
+
+std::pair<int, int> ParquetFileReaderSlice::Impl::ConvertRowGroupIndex(int i) const {
+  const auto file_index =
+      std::upper_bound(row_group_indices_.begin() + 1, row_group_indices_.end(), i) -
+      row_group_indices_.begin() - 1;
+  const auto row_group_index = i - row_group_indices_[file_index];
+  return {static_cast<int>(file_index), row_group_index};
+}
+
+std::pair<int64_t, int64_t> ParquetFileReaderSlice::Impl::GetRowOffsetCount(
+    int i, int64_t num_rows) const {
+  const auto row_offset = i == 0 ? first_row_group_row_offset_ : 0;
+  const auto row_count = i == num_row_groups() - 1 && last_row_group_row_count_ > 0
+                             ? last_row_group_row_count_
+                             : num_rows - row_offset;
+  return {row_offset, row_count};
+}
+
+void ParquetFileReaderSlice::Impl::PreBuffer(ParquetFileReader& file, int row_group_count,
+                                             int row_group_index) {
+  std::vector<int> row_groups(row_group_count);
+  std::iota(row_groups.begin(), row_groups.end(), row_group_index);
+  file.PreBuffer(row_groups, cols_, ::arrow::io::default_io_context(),
+                 ::arrow::io::CacheOptions::Defaults());
+}
+
+bool ParquetFileReaderSlice::Impl::HasNextRowGroup() const {
+  return curr_row_group_index_ < num_row_groups();
+}
+
+ParquetFileReaderSlice::RowGroupSlice ParquetFileReaderSlice::Impl::NextRowGroup() {
+  RowGroupSlice row_group;
+  int row_group_index;
+  {
+    std::unique_lock<std::mutex> lock(mutex_);
+    if (curr_row_group_index_ == num_row_groups()) {
+      throw ParquetException("No more row groups");
+    }
+    if (files_.empty()) {
+      throw ParquetException(
+          "This ParquetFileReaderSlice was created with metadata only");
+    }
+    const auto i = curr_row_group_index_++;
+    const auto file_row_group_index = ConvertRowGroupIndex(i);
+    const auto file_index = file_row_group_index.first;
+    row_group_index = file_row_group_index.second;
+    auto file = files_[file_index];
+    const auto file_row_group_count =
+        row_group_indices_[file_index + 1] - row_group_indices_[file_index];
+    if (row_group_index == file_row_group_count - 1) {
+      // If we are reading the file for the last time, release the handle
+      // so that it can be destroyed when the last RowGroupSlice holding the handle goes
+      // out of scope. It is necessary to release pre-buffered data.
+      files_[file_index].reset();
+    }
+    if (pre_buffer_) {
+      // If we are reading the file for the first time, call PreBuffer()
+      if (i != 0 && row_group_index == 0) {
+        PreBuffer(*file, file_row_group_count, row_group_index);
+      }
+    }
+    auto rg = file->RowGroup(row_group_index);
+    const auto row_offset_count = GetRowOffsetCount(i, rg->metadata()->num_rows());
+    row_group = {i, std::move(file), std::move(rg), row_offset_count.first,
+                 row_offset_count.second};
+  }
+  if (pre_buffer_) {
+    // Wait for the buffer
+    row_group.reader->WhenBuffered({row_group_index}, cols_).Wait();
+  }
+  return row_group;
+}
+
+ParquetFileReaderSlice::RowGroupSliceMetaData
+ParquetFileReaderSlice::Impl::RowGroupMetadata(int i) const {
+  const auto file_row_group_index = ConvertRowGroupIndex(i);
+  const auto file_index = file_row_group_index.first;
+  const auto row_group_index = file_row_group_index.second;
+  auto rg = metadata_[file_index]->RowGroup(row_group_index);
+  const auto row_offset_count = GetRowOffsetCount(i, rg->num_rows());
+  return {std::move(rg), row_offset_count.first, row_offset_count.second};
+}
+
+#ifdef ARROW_FILESYSTEM
+
+struct FileSystemCache {
+  std::mutex mutex;
+  std::map<std::string, std::shared_ptr<::arrow::fs::FileSystem>> map;
+};
+
+::arrow::fs::FileSystem& GetOrCreateFileSystem(FileSystemCache& fs_cache,
+                                               const ::arrow::internal::Uri& uri) {
+  std::unique_lock<std::mutex> lock(fs_cache.mutex);
+  const auto it = fs_cache.map.find(uri.scheme());
+  if (it != fs_cache.map.end()) return *it->second;
+  PARQUET_ASSIGN_OR_THROW(auto fs, ::arrow::fs::FileSystemFromUri(uri.ToString()));
+  fs_cache.map.emplace(uri.scheme(), fs);
+  return *fs;
+}
+
+std::pair<std::shared_ptr<ParquetFileReader>, bool> OpenFileFromUriOrPath(
+    FileSystemCache& fs_cache, std::string uri_or_path) {
+  if (::arrow::fs::internal::IsLikelyUri(uri_or_path)) {
+    ::arrow::internal::Uri uri;
+    PARQUET_THROW_NOT_OK(uri.Parse(uri_or_path));
+    auto& fs = GetOrCreateFileSystem(fs_cache, uri);
+    PARQUET_ASSIGN_OR_THROW(auto path, fs.PathFromUri(uri_or_path));
+    PARQUET_ASSIGN_OR_THROW(auto file, fs.OpenInputFile(path));
+    return {ParquetFileReader::Open(std::move(file)), uri.scheme() != "local"};
+  } else {
+    return {ParquetFileReader::OpenFile(uri_or_path, false), false};
+  }
+}
+
+#else
+
+struct FileSystemCache {};
+
+std::pair<std::shared_ptr<ParquetFileReader>, bool> OpenFileFromUriOrPath(
+    FileSystemCache&, std::string uri_or_path) {
+  return {ParquetFileReader::OpenFile(uri_or_path, false), false};
+}
+
+#endif
+
+std::unique_ptr<ParquetFileReaderSlice> ParquetFileReaderSlice::OpenFile(
+    std::string uri_or_path, const ParquetFileReaderSliceRange& range,
+    bool metadata_only) {
+  FileSystemCache fs_cache;
+  auto reader_and_pre_buffer = OpenFileFromUriOrPath(fs_cache, std::move(uri_or_path));
+  return std::make_unique<ParquetFileReaderSlice>(
+      std::vector<std::shared_ptr<ParquetFileReader>>{
+          std::move(reader_and_pre_buffer.first)},
+      range, metadata_only, reader_and_pre_buffer.second);
+}
+
+std::unique_ptr<ParquetFileReaderSlice> ParquetFileReaderSlice::OpenFiles(
+    const std::vector<std::string>& uri_or_paths,
+    const ParquetFileReaderSliceRange& range, bool metadata_only, Executor* executor) {
+  FileSystemCache fs_cache;
+  std::vector<std::shared_ptr<ParquetFileReader>> readers(uri_or_paths.size());
+  std::atomic<bool> pre_buffer(false);
+  OptionalParallelFor(
+      static_cast<int>(uri_or_paths.size()),
+      [&](int i) {
+        const auto& uri_or_path = uri_or_paths[i];
+        auto reader_and_pre_buffer = OpenFileFromUriOrPath(fs_cache, uri_or_path);
+        readers[i] = std::move(reader_and_pre_buffer.first);
+        pre_buffer = pre_buffer | reader_and_pre_buffer.second;
+      },
+      executor);
+  return std::make_unique<ParquetFileReaderSlice>(std::move(readers), range,
+                                                  metadata_only, pre_buffer);
+}
+
+template <typename DType>
+void Skip(TypedColumnReader<DType>& col_reader, int64_t row_offset) {
+  col_reader.Skip(static_cast<int64_t>(row_offset));
+}
+
+void Skip(ColumnReader& col_reader, int64_t row_offset) {
+  CheckNonNegative(row_offset);
+  PARQUET_FOR_EACH_TYPE_RETURN_TYPED(
+      col_reader.type(),
+      Skip<DType>(dynamic_cast<TypedColumnReader<DType>&>(col_reader), row_offset));
+}
+
+}  // namespace shuffle
+}  // namespace parquet
