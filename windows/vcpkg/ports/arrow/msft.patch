+::arrow::Result<std::string> FormatDate(int32_t value) {
+  const auto [year, month, day] = GetYearMonthDay(value);
+  char buf[16];
+  const auto format = year >= 0 && year <= 9999 ? "%04d-%02d-%02d" : "%+05d-%02d-%02d";
+  const auto len = snprintf(buf, sizeof(buf), format, year, month, day);
+  if (len < 0 || len >= static_cast<int>(sizeof(buf))) {
+    return ::arrow::Status::UnknownError("snprintf failed: ", len);
+  } else {
+    return std::string(buf, len);
+  }
+}
