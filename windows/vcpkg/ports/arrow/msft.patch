diff --git a/cpp/src/parquet/shuffle/shuffle_encoder.cc b/cpp/src/parquet/shuffle/shuffle_encoder.cc
new file mode 100644
index 0000000000..cc0b80f185
--- /dev/null
+++ b/cpp/src/parquet/shuffle/shuffle_encoder.cc
@@ -0,0 +1,512 @@
+#include "parquet/shuffle/shuffle_encoder.h"
+
+#include "arrow/util/bit_util.h"
+#include "arrow/util/checked_cast.h"
+#include "arrow/util/hashing.h"
+#include "arrow/util/macros.h"
+#include "arrow/util/rle_encoding.h"
+#include "arrow/visit_data_inline.h"
+#include "parquet/schema.h"
+
+#include "parquet/shuffle/shuffle_writer_properties.h"
+#include "parquet/shuffle/util/compact_index_vector.h"
+#include "parquet/shuffle/util/encoding_util.h"
+
+using arrow::Status;
+using arrow::internal::checked_cast;
+
+namespace parquet {
+namespace shuffle {
+
+constexpr size_t kMaxByteArraySize = std::numeric_limits<int32_t>::max();
+
+template <typename Payload>
+using HashTable = ::arrow::internal::HashTableBase<Payload, uint32_t>;
+
+template <typename DType>
+struct TypedShuffleEncoderTraits {
+  using c_type = typename DType::c_type;
+  using MemoTableType = ::arrow::internal::ScalarMemoTable<c_type, HashTable>;
+};
+
+template <>
+struct TypedShuffleEncoderTraits<ByteArrayType> {
+  using MemoTableType =
+      ::arrow::internal::BinaryMemoTable<::arrow::BinaryBuilder, HashTable>;
+};
+
+template <>
+struct TypedShuffleEncoderTraits<FLBAType> {
+  using MemoTableType =
+      ::arrow::internal::BinaryMemoTable<::arrow::BinaryBuilder, HashTable>;
+};
+
+static constexpr int32_t kInitialHashTableSize = 1 << 10;
+
+template <typename DType>
+class TypedShuffleEncoderImpl : public TypedShuffleEncoder<DType> {
+  using MemoTableType = typename TypedShuffleEncoderTraits<DType>::MemoTableType;
+
+ public:
+  typedef typename DType::c_type T;
+
+  TypedShuffleEncoderImpl(const ColumnDescriptor* descr, bool use_dictionary,
+                          MemoryPool* pool, const ShuffleWriterProperties* writer_props)
+      : pool_(pool),
+        type_length_(descr ? descr->type_length() : -1),
+        raw_encoding_threshold_(writer_props != nullptr
+                                    ? writer_props->raw_encoding_threshold()
+                                    : kRawEncodingThreshold),
+        memo_table_(std::make_shared<MemoTableType>(pool, kInitialHashTableSize)),
+        buffered_indices_(std::make_shared<shuffle::CompactIndexVector>(pool)),
+        rle_estimator_(1),
+        num_values_(0),
+        values_size_(0) {
+    if (!use_dictionary) {
+      SwitchToPlain();
+    }
+  }
+
+  ShuffleEncoder::Data Finish() override;
+
+  using TypedEncoder<DType>::Put;
+
+  void Put(const ::arrow::Array& values) override;
+
+  void Put(const T* src, int num_values) override {
+    for (int32_t i = 0; i < num_values; i++) {
+      Put(src[i]);
+    }
+  }
+
+  void PutSpaced(const T* src, int num_values, const uint8_t* valid_bits,
+                 int64_t valid_bits_offset) override {
+    ::arrow::internal::VisitSetBitRunsVoid(valid_bits, valid_bits_offset, num_values,
+                                           [&](int64_t position, int64_t length) {
+                                             for (int64_t i = 0; i < length; i++) {
+                                               Put(src[i + position]);
+                                             }
+                                           });
+  }
+
+  std::shared_ptr<Buffer> FlushValues() override { ParquetException::NYI(); }
+
+  Encoding::type encoding() const override { return Encoding::UNDEFINED; }
+
+  MemoryPool* memory_pool() const override { return pool_; }
+
+  int64_t EstimatedDataEncodedSize() const override {
+    if (HasDictionary()) {
+      return GetDictionaryEstimatedDataEncodedSize();
+    } else {
+      return GetPlainEstimatedDataEncodedSize();
+    }
+  }
+
+  int64_t estimated_size() override {
+    if (HasDictionary()) {
+      return GetDictionaryEstimatedSize();
+    } else {
+      return GetPlainEstimatedSize();
+    }
+  }
+
+  int64_t estimated_memory_usage(double estimation_factor) override {
+    if (HasDictionary()) {
+      if (ShouldSwitchToPlain()) {
+        SwitchToPlain();
+      } else {
+        return GetDictionaryEstimatedMemoryUsage(estimation_factor);
+      }
+    }
+    return GetPlainEstimatedMemoryUsage(estimation_factor);
+  }
+
+ private:
+  int num_entries() const { return memo_table_->size(); }
+
+  int bit_width() const {
+    if (ARROW_PREDICT_FALSE(num_entries() == 0)) return 0;
+    if (ARROW_PREDICT_FALSE(num_entries() == 1)) return 1;
+    return ::arrow::bit_util::Log2(num_entries());
+  }
+
+  void Put(const T& value);
+
+  void PutByteArray(const void* ptr, int32_t length);
+
+  template <typename ArrayType>
+  void PutBinaryArray(const ArrayType& array) {
+    PARQUET_THROW_NOT_OK(::arrow::VisitArraySpanInline<typename ArrayType::TypeClass>(
+        *array.data(),
+        [&](std::string_view view) {
+          if (ARROW_PREDICT_FALSE(view.size() > kMaxByteArraySize)) {
+            return Status::Invalid("Parquet cannot store strings with size 2GB or more");
+          }
+          PutByteArray(view.data(), static_cast<uint32_t>(view.size()));
+          return Status::OK();
+        },
+        []() { return Status::OK(); }));
+  }
+
+  bool IsByteArrayType() const;
+
+  bool HasDictionary() const { return static_cast<bool>(memo_table_); }
+
+  /// Returns a conservative estimate of the number of bytes needed to encode the
+  /// buffered indices. Used to size the buffer passed to WriteIndices().
+  int64_t GetDictionaryEstimatedDataEncodedSize() const {
+    // Note: because of the way RleEncoder::CheckBufferFull() is called, we have to
+    // reserve
+    // an extra "RleEncoder::MinBufferSize" bytes. These extra bytes won't be used
+    // but not reserving them would cause the encoder to fail.
+    return 1 +
+           ::arrow::util::RleEncoder::MaxBufferSize(
+               bit_width(), static_cast<int>(buffered_indices_->size())) +
+           ::arrow::util::RleEncoder::MinBufferSize(bit_width());
+  }
+
+  int64_t GetDictionaryEstimatedSize() {
+    rle_estimator_.UpdateBitWidth(bit_width());
+    const auto& indices = *buffered_indices_;
+    switch (indices.type_length()) {
+      case 1:
+        rle_estimator_.Append(indices.values1().subspan(rle_estimator_.count()));
+        break;
+      case 2:
+        rle_estimator_.Append(indices.values2().subspan(rle_estimator_.count()));
+        break;
+      case 3:
+        rle_estimator_.Append(indices.values3().subspan(rle_estimator_.count()));
+        break;
+      case 4:
+        rle_estimator_.Append(indices.values4().subspan(rle_estimator_.count()));
+        break;
+    }
+    return memo_table_->data_size() + rle_estimator_.flushed_estimate();
+  }
+
+  int64_t GetDictionaryEstimatedMemoryUsage(double estimation_factor) const {
+    return static_cast<int64_t>(memo_table_->estimated_memory_usage(estimation_factor)) +
+           buffered_indices_->estimated_memory_usage(estimation_factor);
+  }
+
+  bool ShouldSwitchToPlain() const {
+    const auto num_distinct_values = num_entries();
+    const auto num_values = buffered_indices_->size();
+    return num_distinct_values == num_values && num_values >= raw_encoding_threshold_;
+  }
+
+  void SwitchToPlain() {
+    auto data = Finish();
+    values_buffer_ = std::move(data.values_buffer);
+    offsets_buffer_ = std::move(data.offsets_buffer);
+    num_values_ = data.num_values;
+    if (IsByteArrayType()) {
+      values_size_ = values_buffer_->size();
+    }
+    memo_table_.reset();
+    buffered_indices_.reset();
+  }
+
+  int64_t GetPlainDataSize() const {
+    return values_buffer_->size() + (offsets_buffer_ ? offsets_buffer_->size() : 0);
+  }
+
+  int64_t GetPlainEstimatedDataEncodedSize() const { return GetPlainDataSize(); }
+
+  int64_t GetPlainEstimatedSize() const { return GetPlainDataSize(); }
+
+  int64_t GetPlainEstimatedMemoryUsage(double estimation_factor) const {
+    return static_cast<int64_t>(GetPlainDataSize() * estimation_factor);
+  }
+
+  MemoryPool* pool_;
+  int type_length_;
+  int32_t raw_encoding_threshold_;
+
+  std::shared_ptr<MemoTableType> memo_table_;
+  std::shared_ptr<shuffle::CompactIndexVector> buffered_indices_;
+  shuffle::RleSizeEstimator<int32_t> rle_estimator_;
+
+  std::shared_ptr<ResizableBuffer> values_buffer_;
+  std::shared_ptr<ResizableBuffer> offsets_buffer_;
+  int32_t num_values_;
+  int64_t values_size_;
+};
+
+template <typename DType>
+bool TypedShuffleEncoderImpl<DType>::IsByteArrayType() const {
+  return false;
+}
+
+template <>
+bool TypedShuffleEncoderImpl<ByteArrayType>::IsByteArrayType() const {
+  return true;
+}
+
+template <>
+bool TypedShuffleEncoderImpl<FLBAType>::IsByteArrayType() const {
+  return true;
+}
+
+template <typename DType>
+ShuffleEncoder::Data TypedShuffleEncoderImpl<DType>::Finish() {
+  std::shared_ptr<ResizableBuffer> values_buffer;
+  int32_t num_values;
+  if (HasDictionary()) {
+    num_values = memo_table_->size();
+    values_buffer = AllocateBuffer(this->pool_, num_values * sizeof(T));
+    if (num_values > 0) {
+      memo_table_->CopyValues(reinterpret_cast<T*>(values_buffer->mutable_data()));
+    }
+    memo_table_.reset();
+  } else {
+    num_values = num_values_;
+    values_buffer = std::move(values_buffer_);
+    PARQUET_THROW_NOT_OK(values_buffer->Resize(num_values * sizeof(T), true));
+  }
+  return {
+      std::move(buffered_indices_),
+      std::move(values_buffer),
+      nullptr,
+      num_values,
+  };
+}
+
+template <>
+ShuffleEncoder::Data TypedShuffleEncoderImpl<ByteArrayType>::Finish() {
+  using OffsetType = typename MemoTableType::builder_offset_type;
+  std::shared_ptr<ResizableBuffer> values_buffer;
+  std::shared_ptr<ResizableBuffer> offsets_buffer;
+  int32_t num_values;
+  if (HasDictionary()) {
+    num_values = memo_table_->size();
+    values_buffer = AllocateBuffer(pool_, memo_table_->values_size());
+    offsets_buffer = AllocateBuffer(pool_, (num_values + 1) * sizeof(OffsetType));
+    if (num_values > 0) {
+      memo_table_->CopyValues(values_buffer->mutable_data());
+      memo_table_->CopyOffsets(
+          reinterpret_cast<OffsetType*>(offsets_buffer->mutable_data()));
+    } else {
+      AsSpan<OffsetType>(*offsets_buffer)[0] = 0;
+    }
+    memo_table_.reset();
+  } else {
+    num_values = num_values_;
+    values_buffer = std::move(values_buffer_);
+    PARQUET_THROW_NOT_OK(values_buffer->Resize(values_size_, true));
+    offsets_buffer = std::move(offsets_buffer_);
+    PARQUET_THROW_NOT_OK(
+        offsets_buffer->Resize((num_values + 1) * sizeof(OffsetType), true));
+  }
+  return {
+      std::move(buffered_indices_),
+      std::move(values_buffer),
+      std::move(offsets_buffer),
+      num_values,
+  };
+}
+
+template <>
+ShuffleEncoder::Data TypedShuffleEncoderImpl<FLBAType>::Finish() {
+  std::shared_ptr<ResizableBuffer> values_buffer;
+  int32_t num_values;
+  if (HasDictionary()) {
+    num_values = memo_table_->size();
+    values_buffer = AllocateBuffer(pool_, memo_table_->values_size());
+    if (num_values > 0) {
+      memo_table_->CopyFixedWidthValues(0, type_length_, memo_table_->values_size(),
+                                        values_buffer->mutable_data());
+    }
+    memo_table_.reset();
+  } else {
+    num_values = num_values_;
+    values_buffer = std::move(values_buffer_);
+    PARQUET_THROW_NOT_OK(values_buffer->Resize(values_size_, true));
+  }
+  return {
+      std::move(buffered_indices_),
+      std::move(values_buffer),
+      nullptr,
+      num_values,
+  };
+}
+
+void EnlargeIfNecessary(ResizableBuffer& buffer, int64_t current_size,
+                        int64_t additional_size) {
+  if (buffer.size() < current_size + additional_size) {
+    int64_t new_size = current_size == 0 ? 64 : current_size * 2;
+    while (new_size < current_size + additional_size) {
+      new_size *= 2;
+    }
+    PARQUET_THROW_NOT_OK(buffer.Resize(new_size));
+  }
+}
+
+template <typename DType>
+void TypedShuffleEncoderImpl<DType>::Put(const T& v) {
+  if (HasDictionary()) {
+    int32_t memo_index;
+    PARQUET_THROW_NOT_OK(memo_table_->GetOrInsert(v, &memo_index));
+    buffered_indices_->push_back(memo_index);
+  } else {
+    EnlargeIfNecessary(*values_buffer_, num_values_ * sizeof(T), sizeof(T));
+    AsSpan<T>(*values_buffer_)[num_values_++] = v;
+  }
+}
+
+template <typename DType>
+void TypedShuffleEncoderImpl<DType>::PutByteArray(const void* ptr, int32_t length) {
+  ParquetException::NYI();
+}
+
+template <>
+inline void TypedShuffleEncoderImpl<ByteArrayType>::PutByteArray(const void* ptr,
+                                                                 int32_t length) {
+  using OffsetType = typename MemoTableType::builder_offset_type;
+  if (HasDictionary()) {
+    static const uint8_t empty[] = {0};
+    DCHECK(ptr != nullptr || length == 0);
+    ptr = (ptr != nullptr) ? ptr : empty;
+    int32_t memo_index;
+    PARQUET_THROW_NOT_OK(memo_table_->GetOrInsert(ptr, length, &memo_index));
+    buffered_indices_->push_back(memo_index);
+  } else {
+    EnlargeIfNecessary(*values_buffer_, values_size_, length);
+    EnlargeIfNecessary(*offsets_buffer_, (num_values_ + 1) * sizeof(OffsetType),
+                       sizeof(OffsetType));
+    std::memcpy(values_buffer_->mutable_data() + values_size_, ptr, length);
+    auto offsets = AsSpan<OffsetType>(*offsets_buffer_);
+    offsets[num_values_ + 1] = offsets[num_values_] + length;
+    num_values_ += 1;
+    values_size_ += length;
+  }
+}
+
+template <>
+inline void TypedShuffleEncoderImpl<ByteArrayType>::Put(const ByteArray& val) {
+  return PutByteArray(val.ptr, static_cast<int32_t>(val.len));
+}
+
+template <>
+inline void TypedShuffleEncoderImpl<FLBAType>::Put(const FixedLenByteArray& v) {
+  if (HasDictionary()) {
+    static const uint8_t empty[] = {0};
+    DCHECK(v.ptr != nullptr || type_length_ == 0);
+    const void* ptr = (v.ptr != nullptr) ? v.ptr : empty;
+    int32_t memo_index;
+    PARQUET_THROW_NOT_OK(memo_table_->GetOrInsert(ptr, type_length_, &memo_index));
+    buffered_indices_->push_back(memo_index);
+  } else {
+    EnlargeIfNecessary(*values_buffer_, values_size_, type_length_);
+    std::memcpy(values_buffer_->mutable_data() + values_size_, v.ptr, type_length_);
+    num_values_ += 1;
+    values_size_ += type_length_;
+  }
+}
+
+template <>
+void TypedShuffleEncoderImpl<Int96Type>::Put(const ::arrow::Array& values) {
+  ParquetException::NYI("Direct put to Int96");
+}
+
+template <typename DType>
+void TypedShuffleEncoderImpl<DType>::Put(const ::arrow::Array& values) {
+  using ArrayType = typename ::arrow::CTypeTraits<typename DType::c_type>::ArrayType;
+  const auto& data = checked_cast<const ArrayType&>(values);
+  if (data.null_count() == 0) {
+    // no nulls, just dump the data
+    for (int64_t i = 0; i < data.length(); i++) {
+      Put(data.Value(i));
+    }
+  } else {
+    for (int64_t i = 0; i < data.length(); i++) {
+      if (data.IsValid(i)) {
+        Put(data.Value(i));
+      }
+    }
+  }
+}
+
+void AssertFixedSizeBinary(const ::arrow::Array& values, int type_length) {
+  if (values.type_id() != ::arrow::Type::FIXED_SIZE_BINARY &&
+      values.type_id() != ::arrow::Type::DECIMAL) {
+    throw ParquetException("Only FixedSizeBinaryArray and subclasses supported");
+  }
+  if (checked_cast<const ::arrow::FixedSizeBinaryType&>(*values.type()).byte_width() !=
+      type_length) {
+    throw ParquetException("Size mismatch: " + values.type()->ToString() +
+                           " should have been " + std::to_string(type_length) + " wide");
+  }
+}
+
+template <>
+void TypedShuffleEncoderImpl<FLBAType>::Put(const ::arrow::Array& values) {
+  AssertFixedSizeBinary(values, type_length_);
+  const auto& data = checked_cast<const ::arrow::FixedSizeBinaryArray&>(values);
+  if (data.null_count() == 0) {
+    // no nulls, just dump the data
+    for (int64_t i = 0; i < data.length(); i++) {
+      Put(FixedLenByteArray(data.Value(i)));
+    }
+  } else {
+    std::vector<uint8_t> empty(type_length_, 0);
+    for (int64_t i = 0; i < data.length(); i++) {
+      if (data.IsValid(i)) {
+        Put(FixedLenByteArray(data.Value(i)));
+      }
+    }
+  }
+}
+
+void AssertBaseBinary(const ::arrow::Array& values) {
+  if (!::arrow::is_base_binary_like(values.type_id())) {
+    throw ParquetException("Only BaseBinaryArray and subclasses supported");
+  }
+}
+
+template <>
+void TypedShuffleEncoderImpl<ByteArrayType>::Put(const ::arrow::Array& values) {
+  AssertBaseBinary(values);
+  if (::arrow::is_binary_like(values.type_id())) {
+    PutBinaryArray(checked_cast<const ::arrow::BinaryArray&>(values));
+  } else {
+    DCHECK(::arrow::is_large_binary_like(values.type_id()));
+    PutBinaryArray(checked_cast<const ::arrow::LargeBinaryArray&>(values));
+  }
+}
+
+std::unique_ptr<Encoder> MakeShuffleEncoder(Type::type type_num, bool use_dictionary,
+                                            const ColumnDescriptor* descr,
+                                            MemoryPool* pool,
+                                            const ShuffleWriterProperties* writer_props) {
+  switch (type_num) {
+    case Type::INT32:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<Int32Type>(
+          descr, use_dictionary, pool, writer_props));
+    case Type::INT64:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<Int64Type>(
+          descr, use_dictionary, pool, writer_props));
+    case Type::INT96:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<Int96Type>(
+          descr, use_dictionary, pool, writer_props));
+    case Type::FLOAT:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<FloatType>(
+          descr, use_dictionary, pool, writer_props));
+    case Type::DOUBLE:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<DoubleType>(
+          descr, use_dictionary, pool, writer_props));
+    case Type::BYTE_ARRAY:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<ByteArrayType>(
+          descr, use_dictionary, pool, writer_props));
+    case Type::FIXED_LEN_BYTE_ARRAY:
+      return std::unique_ptr<Encoder>(new TypedShuffleEncoderImpl<FLBAType>(
+          descr, use_dictionary, pool, writer_props));
+    default:
+      throw ParquetException("Invalid type");
+  }
+}
+
+}  // namespace shuffle
+}  // namespace parquet
