+template <class... Ts>
+struct overload : Ts... {
+  using Ts::operator()...;
+};
+
+template <class... Ts>
+overload(Ts...) -> overload<Ts...>;
+
+std::optional<std::shared_ptr<Statistics>> MakeStatistics(const ColumnDescriptor* descr,
+                                                          ::arrow::MemoryPool* pool) {
+  try {
+    switch (descr->physical_type()) {
+      case Type::BOOLEAN:
+        return ::parquet::MakeStatistics<BooleanType>(descr, pool);
+      case Type::INT32:
+        return ::parquet::MakeStatistics<Int32Type>(descr, pool);
+      case Type::INT64:
+        return ::parquet::MakeStatistics<Int64Type>(descr, pool);
+      case Type::FLOAT:
+        return ::parquet::MakeStatistics<FloatType>(descr, pool);
+      case Type::DOUBLE:
+        return ::parquet::MakeStatistics<DoubleType>(descr, pool);
+      case Type::BYTE_ARRAY:
+        return ::parquet::MakeStatistics<ByteArrayType>(descr, pool);
+      case Type::FIXED_LEN_BYTE_ARRAY:
+        return ::parquet::MakeStatistics<FLBAType>(descr, pool);
+      default:
+        return std::nullopt;
+    }
+  } catch (const std::exception& e) {
+    ARROW_LOG(INFO) << "failed to make Statistics: " << e.what();
+    return std::nullopt;
+  }
+}
+
+std::optional<const schema::Node*> FindTopLevelCollection(const ColumnDescriptor& descr) {
+  std::optional<const schema::Node*> last_collection;
+  const schema::Node* curr = descr.schema_node().get();
+  while (curr != nullptr) {
+    if (curr->logical_type()->is_list() || curr->logical_type()->is_map()) {
+      last_collection = curr;
+    }
+    curr = curr->parent();
+  }
+  return last_collection;
+}
+
+int16_t GetDefinitionLevel(const schema::Node& node) {
+  int16_t def_level = 0;
+  const schema::Node* curr = &node;
+  while (curr != nullptr) {
+    if (curr->is_optional()) {
+      def_level += 1;
+    }
+    curr = curr->parent();
+  }
+  return def_level;
+}
+
+size_t FindCommonPrefix(const std::vector<std::string>& a,
+                        const std::vector<std::string>& b) {
+  auto [a_it, b_it] = std::mismatch(a.begin(), a.end(), b.begin(), b.end());
+  return std::distance(a.begin(), a_it);
+}
+
+bool IsPrefix(const std::vector<std::string>& prefix,
+              const std::vector<std::string>& value) {
+  return FindCommonPrefix(prefix, value) == prefix.size();
+}
+
+bool IsColumnSelected(const std::vector<std::vector<std::string>>& sorted_column_paths,
+                      std::vector<bool>& column_paths_matched,
+                      const std::vector<std::string>& column_path) {
+  // If column paths are not specified, all columns are eligible for stats
+  if (sorted_column_paths.empty()) {
+    return true;
+  }
+  auto it = std::lower_bound(sorted_column_paths.begin(), sorted_column_paths.end(),
+                             column_path);
+  // Exact match
+  if (it != sorted_column_paths.end() && *it == column_path) {
+    column_paths_matched[std::distance(sorted_column_paths.begin(), it)] = true;
+    return true;
+  }
+  // There's no prefix for this column path in the list
+  if (it == sorted_column_paths.begin()) {
+    return false;
+  }
+  --it;
+  // If the found column path in the list is a prefix, collect stats.
+  // For example, specifying "a" will collect stats for all nested columns
+  // if "a" is a struct.
+  if (IsPrefix(*it, column_path)) {
+    column_paths_matched[std::distance(sorted_column_paths.begin(), it)] = true;
+    return true;
+  } else {
+    return false;
+  }
+}
+
+std::optional<ColumnStatistics> InitStatistics(
+    const ColumnDescriptor& descr, ::arrow::MemoryPool* pool,
+    const std::vector<std::vector<std::string>>& sorted_column_paths,
+    std::vector<bool>& column_paths_matched,
+    std::unordered_set<const schema::Node*>& top_level_collections) {
+  if (descr.max_repetition_level() == 0) {
+    if (IsColumnSelected(sorted_column_paths, column_paths_matched,
+                         descr.path()->ToDotVector())) {
+      return MakeStatistics(&descr, pool);
+    }
+  } else {
+    const auto top_level_collection_opt = FindTopLevelCollection(descr);
+    if (top_level_collection_opt.has_value()) {
+      const auto top_level_collection = top_level_collection_opt.value();
+      const auto it = top_level_collections.find(top_level_collection);
+      if (it == top_level_collections.end()) {
+        top_level_collections.emplace(top_level_collection);
+        auto path = top_level_collection->path()->ToDotVector();
+        if (IsColumnSelected(sorted_column_paths, column_paths_matched, path)) {
+          auto stats = std::make_shared<CollectionTypeStatistics>();
+          stats->path = std::move(path);
+          stats->def_level = GetDefinitionLevel(*top_level_collection);
+          stats->null_count = 0;
+          return stats;
+        }
+      }
+    }
+  }
+  return std::nullopt;
+}
+
+}  // namespace
+
+std::shared_ptr<DeltaStatsCollector> MakeDeltaStatsCollector(
+    const SchemaDescriptor* schema, ::arrow::MemoryPool* pool,
+    const WriterProperties& properties) {
+  const auto n = schema->num_columns();
+  std::vector<std::optional<ColumnStatistics>> file_stats(n);
+  std::unordered_set<const schema::Node*> top_level_collections;
+  auto column_paths = properties.delta_stats_column_paths();
+  std::sort(column_paths.begin(), column_paths.end());
+  std::vector<bool> column_paths_matched(column_paths.size(), false);
+  for (int i = 0; i < n; ++i) {
+    const auto& descr = *schema->Column(i);
+    file_stats[i] = InitStatistics(descr, pool, column_paths, column_paths_matched,
+                                   top_level_collections);
+  }
+  auto collector = std::make_shared<DeltaStatsCollector>();
+  collector->schema = schema;
+  collector->column_paths = std::move(column_paths);
+  collector->column_paths_matched = std::move(column_paths_matched);
+  collector->string_prefix_length = properties.delta_stats_string_prefix_length();
+  collector->add_tight_bounds = properties.delta_stats_add_tight_bounds();
+  collector->columns = std::move(file_stats);
+  return collector;
+}
+
+std::optional<shuffle::ColumnStatistics*> GetColumn(DeltaStatsCollector& collector,
+                                                    int col_index) {
+  auto& col_stats_opt = collector.columns[static_cast<size_t>(col_index)];
+  if (col_stats_opt.has_value()) {
+    return &col_stats_opt.value();
+  } else {
+    return std::nullopt;
+  }
+}
+
+bool ShouldCollectStatistics(const ColumnStatistics& file_stats) {
+  return std::holds_alternative<std::shared_ptr<Statistics>>(file_stats);
+}
+
+bool ShouldCollectCollectionTypeStatistics(const ColumnStatistics& file_stats) {
+  return std::holds_alternative<std::shared_ptr<CollectionTypeStatistics>>(file_stats);
+}
+
+template <typename DType>
+void UpdateStatistics(ColumnStatistics& file_stats,
+                      const TypedStatistics<DType>& chunk_stats) {
+  std::visit(overload{
+                 [&](const std::shared_ptr<Statistics>& stats) {
+                   static_cast<TypedStatistics<DType>&>(*stats).Merge(chunk_stats);
+                 },
+                 [](const std::shared_ptr<shuffle::CollectionTypeStatistics>& stats) {
+                   // Nothing to do
+                 },
+             },
+             file_stats);
+}
+
+template void UpdateStatistics(ColumnStatistics& file_stats,
+                               const TypedStatistics<BooleanType>& chunk_stats);
+template void UpdateStatistics(ColumnStatistics& file_stats,
+                               const TypedStatistics<Int32Type>& chunk_stats);
+template void UpdateStatistics(ColumnStatistics& file_stats,
+                               const TypedStatistics<Int64Type>& chunk_stats);
+template void UpdateStatistics(ColumnStatistics& file_stats,
+                               const TypedStatistics<Int96Type>& chunk_stats);
