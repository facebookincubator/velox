+// Reference: org.apache.spark.sql.delta.stats.StatisticsCollection.truncateMaxStringAgg
+// Helper method to truncate the input string `input` to the given `string_prefix_length`,
+// while also ensuring that any value in this column is less than or equal to the
+// truncated max in UTF-8 encoding.
+::arrow::Result<std::string> TruncateMaxString(std::string value,
+                                               int string_prefix_length) {
+  if (string_prefix_length <= 0) {
+    return ::arrow::Status::Invalid("prefix length should be positive");
+  }
+  const auto prefix_len = static_cast<size_t>(string_prefix_length);
+  ARROW_ASSIGN_OR_RAISE(auto s, ::arrow::util::UTF8StringToUTF16(value));
+  if (s.size() <= prefix_len) {
+    return value;
+  }
+
+  // Grab the prefix. We want to append max Unicode code point `\uDBFF\uDFFF` as a
+  // tie-breaker, but that is only safe if the character we truncated was smaller in UTF-8
+  // encoded binary comparison. Keep extending the prefix until that condition holds, or
+  // we run off the end of the string. We also try to use the ASCII max character `\u007F`
+  // as a tie-breaker if possible.
+  const auto max_len = 2 * prefix_len;
