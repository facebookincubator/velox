+template <typename DType>
+void DictEncoderImpl<DType>::PutRawDictionary(std::shared_ptr<Buffer> values_buffer,
+                                              shuffle::Span<const int32_t>,
+                                              int32_t num_values) {
+  if (dict_buffer_ || memo_table_.size() > 0) {
+    throw ParquetException("Can only call PutRawDictionary on an empty DictEncoder");
+  }
+  dict_buffer_ = std::move(values_buffer);
+  dict_encoded_size_ += static_cast<int>(dict_buffer_->size());
+  dict_len_ = num_values;
+}
+
+template <>
+void DictEncoderImpl<ByteArrayType>::PutRawDictionary(
+    std::shared_ptr<Buffer> values_buffer, shuffle::Span<const int32_t> offsets,
+    int32_t num_values) {
+  if (dict_buffer_ || memo_table_.size() > 0) {
+    throw ParquetException("Can only call PutRawDictionary on an empty DictEncoder");
+  }
+  auto src = values_buffer->data();
+  dict_buffer_ =
+      AllocateBuffer(this->pool_, values_buffer->size() + num_values * sizeof(uint32_t));
+  auto buffer = dict_buffer_->mutable_data();
+  for (int32_t i = 0; i < num_values; ++i) {
+    uint32_t len = static_cast<uint32_t>(offsets[i + 1] - offsets[i]);
+    memcpy(buffer, &len, sizeof(len));
+    buffer += sizeof(len);
+    memcpy(buffer, src + offsets[i], len);
+    buffer += len;
+    if (len == 0) empty_string_dictionary_index_ = i;
+  }
+  dict_encoded_size_ += static_cast<int>(dict_buffer_->size());
+  dict_len_ = num_values;
+}
+
+template <typename DType>
+void DictEncoderImpl<DType>::PutRawIndices(const shuffle::CompactIndexVector& indices,
+                                           int64_t index_offset, int64_t num_indices) {
+  const auto offset = static_cast<size_t>(index_offset);
+  const auto count = static_cast<size_t>(num_indices);
+  switch (indices.type_length()) {
+    case 1:
+      buffered_indices_->push_back(indices.values1().subspan(offset, count));
+      break;
+    case 2:
+      buffered_indices_->push_back(indices.values2().subspan(offset, count));
+      break;
+    case 3:
+      buffered_indices_->push_back(indices.values3().subspan(offset, count));
+      break;
+    case 4:
+      buffered_indices_->push_back(indices.values4().subspan(offset, count));
+      break;
+  }
+}
