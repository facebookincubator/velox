diff --git a/cpp/src/parquet/shuffle/shuffle_util.h b/cpp/src/parquet/shuffle/shuffle_util.h
new file mode 100644
index 0000000000..839354181f
--- /dev/null
+++ b/cpp/src/parquet/shuffle/shuffle_util.h
@@ -0,0 +1,138 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#if defined(ARROW_HAVE_AVX2)
+#include <immintrin.h>
+#endif
+
+#include <vector>
+
+#include "parquet/shuffle/util/compact_index_util.h"
+#include "parquet/shuffle/util/compact_index_vector.h"
+#include "parquet/shuffle/util/span.h"
+
+namespace parquet {
+namespace shuffle {
+
+template <typename T>
+void CopyWithPermutationSeq(T* dst, const T* src, const int32_t* permutation,
+                            size_t count) {
+  auto p = permutation;
+  const auto end = permutation + count;
+  while (p < end) {
+    *dst++ = src[*p++];
+  }
+}
+
+template <typename T>
+void DoShuffle(Span<const int32_t> permutation, T* data) {
+  const auto count = permutation.size();
+  std::vector<T> shuffled(count);
+  CopyWithPermutationSeq(shuffled.data(), data, permutation.data(), count);
+  std::copy(shuffled.begin(), shuffled.end(), data);
+}
+
+#if defined(ARROW_HAVE_AVX2)
+
+inline void CopyWithPermutationAvx2_128(int32_t* dst, const int32_t* src,
+                                        const int32_t* permutation, size_t count) {
+  constexpr auto n = 128 / 32;
+  constexpr auto m = 2;
+  auto p = permutation;
+  const auto r = count % (n * m);
+  const auto end = permutation + (count - r);
+  while (p < end) {
+    __m128i v[m];
+    for (int i = 0; i < m; ++i) {
+      v[i] = _mm_loadu_si128(reinterpret_cast<const __m128i*>(p + i * n));
+      v[i] = _mm_i32gather_epi32(src, v[i], 4);
+      _mm_store_si128(reinterpret_cast<__m128i*>(dst + i * n), v[i]);
+    }
+    p += n * m;
+    dst += n * m;
+  }
+  CopyWithPermutationSeq(dst, src, p, r);
+}
+
+inline void CopyWithPermutationAvx2_256(int32_t* dst, const int32_t* src,
+                                        const int32_t* permutation, size_t count) {
+  constexpr auto n = 256 / 32;
+  constexpr auto m = 1;
+  auto p = permutation;
+  const auto r = count % (n * m);
+  const auto end = permutation + (count - r);
+  while (p < end) {
+    __m256i v[m];
+    for (int i = 0; i < m; ++i) {
+      v[i] = _mm256_loadu_si256(reinterpret_cast<const __m256i*>(p + i * n));
+      v[i] = _mm256_i32gather_epi32(src, v[i], 4);
+      _mm256_store_si256(reinterpret_cast<__m256i*>(dst + i * n), v[i]);
+    }
+    p += n * m;
+    dst += n * m;
+  }
+  CopyWithPermutationSeq(dst, src, p, r);
+}
+
+inline bool IsAligned(const void* ptr, size_t alignment) {
+  return (reinterpret_cast<uintptr_t>(ptr) & (alignment - 1)) == 0;
+}
+
+template <typename T>
+void DoShuffleAvx2(Span<const int32_t> permutation, T* data) {
+  const auto count = permutation.size();
+  std::vector<T> shuffled(count);
+  if (IsAligned(permutation.data(), 32) && IsAligned(shuffled.data(), 32)) {
+    CopyWithPermutationAvx2_256(shuffled.data(), data, permutation.data(), count);
+  } else if (IsAligned(permutation.data(), 16) && IsAligned(shuffled.data(), 16)) {
+    CopyWithPermutationAvx2_128(shuffled.data(), data, permutation.data(), count);
+  } else {
+    CopyWithPermutationSeq(shuffled.data(), data, permutation.data(), count);
+  }
+  std::copy(shuffled.begin(), shuffled.end(), data);
+}
+
+inline void DoShuffle(Span<const int32_t> permutation, int32_t* data) {
+  DoShuffleAvx2(permutation, data);
+}
+
+#endif
+
+inline void DoShuffle(Span<const int32_t> permutation, CompactIndexVector& indices) {
+  switch (indices.type_length()) {
+    case 1:
+      DoShuffle(permutation, indices.values1().data());
+      break;
+    case 2:
+      DoShuffle(permutation, indices.values2().data());
+      break;
+    case 3:
+      DoShuffle(permutation, indices.values3().data());
+      break;
+    case 4:
+      DoShuffle(permutation, indices.values4().data());
+      break;
+  }
+}
+
+inline void DoShuffle(Span<const int32_t> permutation, uint8_t* indices,
+                      int type_length) {
+  switch (type_length) {
+    case 1:
+      DoShuffle(permutation, indices);
+      break;
+    case 2:
+      DoShuffle(permutation, As2ByteArray(indices));
+      break;
+    case 3:
+      DoShuffle(permutation, As3ByteArray(indices));
+      break;
+    case 4:
+      DoShuffle(permutation, As4ByteArray(indices));
+      break;
+  }
+}
