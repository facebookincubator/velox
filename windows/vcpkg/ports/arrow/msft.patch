+++ b/ci/pipelines/templates/stages-fuzz.yml
@@ -0,0 +1,59 @@
+parameters:
+- name: buildName
+- name: fuzzDurationSec
+  type: number
+  default: 3600
+- name: extraBuildSteps
+  type: object
+  default: []
+
+stages:
+- stage: Fuzz
+  jobs:
+  - job: Fuzz
+    timeoutInMinutes: 120
+    steps:
+    - ${{ each extraBuildStep in parameters.extraBuildSteps }}:
+      - ${{ extraBuildStep }}
+    - checkout: self
+      submodules: true
+    - template: steps-download-build.yml
+      parameters:
+        buildName: ${{ parameters.buildName }}
+    - task: Cache@2
+      inputs:
+        key: '"fuzz_corpus" | "${{ parameters.buildName }}" | "$(Agent.OS)"'
+        path: $(FUZZ_DIR)/corpus
+      displayName: Cache corpus
+    - script: |
+        if [ ! -d "$(FUZZ_DIR)/corpus" ]; then
+          mkdir -p "$(FUZZ_DIR)/corpus"
+        fi
+      displayName: Init corpus
+    - script: |
+        cd "$(FUZZ_DIR)"
+        mkdir new_corpus
+        "$(BUILD_DIR)/debug/parquet-shuffle-fuzz" -merge=1 new_corpus corpus
+        rm -rf corpus
+        mv new_corpus corpus
+      displayName: Optimize corpus
+    - script: |
+        cd "$(FUZZ_DIR)"
+        mkdir logs
+        cd logs
+        "$(BUILD_DIR)/debug/parquet-shuffle-fuzz" \
+          -max_total_time=${{ parameters.fuzzDurationSec }} \
+          -rss_limit_mb=8192 \
+          -jobs=$(($(grep -c processor /proc/cpuinfo) / 2)) \
+          ../corpus
+      displayName: Run fuzzer
+    - template: steps-coverage-report.yml
+      parameters:
+        executables: $(BUILD_DIR)/debug/parquet-shuffle-fuzz
+        artifactName: CoverageReport_Fuzz
+    - task: PublishPipelineArtifact@1
+      displayName: Publish logs
+      inputs:
+        targetPath: $(FUZZ_DIR)/logs
+        artifact: FuzzLogs
+      condition: succeededOrFailed()
