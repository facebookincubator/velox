+void UpdateStatistics(ColumnStatistics& file_stats, const int16_t* def_levels,
+                      int64_t num_values) {
+  std::visit(overload{
+                 [](const std::shared_ptr<Statistics>& stats) {
+                   // Nothing to do
+                 },
+                 [&](const std::shared_ptr<shuffle::CollectionTypeStatistics>& stats) {
+                   const auto collection_def_level = stats->def_level;
+                   const auto null_count =
+                       std::count_if(def_levels, def_levels + num_values,
+                                     [collection_def_level](int16_t def_level) {
+                                       return def_level < collection_def_level;
+                                     });
+                   stats->null_count += null_count;
+                 },
+             },
+             file_stats);
+}
