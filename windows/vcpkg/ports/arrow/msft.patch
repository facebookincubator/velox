+}
+
+std::string GetEmptyStringDictionaryIndex(const ParquetFileReaderSlice& slice,
+                                          const std::string& key, int row_group_index,
+                                          int column_index = 0) {
+  auto kv = slice.RowGroupMetadata(row_group_index)
+                .metadata->ColumnChunk(column_index)
+                ->key_value_metadata();
+  if (kv) {
+    PARQUET_ASSIGN_OR_THROW(auto index, kv->Get(key));
