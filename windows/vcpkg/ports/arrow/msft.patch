+
+namespace parquet {
+
+inline void PrintTo(const ByteArray& value, ::std::ostream* os) {
+  *os << "ByteArray(ptr=" << static_cast<const void*>(value.ptr) << ", len=" << value.len
+      << ")[";
+  for (uint32_t i = 0; i < value.len; ++i) {
+    *os << std::setw(2) << std::setfill('0') << std::hex
+        << static_cast<uint32_t>(value.ptr[i]);
+  }
+  *os << "]";
+}
+
+namespace shuffle {
+
+// Return a temporary span. It must be immediately passed to a function which doesn't save
+// the passed span. This is exploiting the temporary lifetime rule: A temporary bound to a
+// reference parameter in a function call ([expr.call]) persists until the completion of
+// the full-expression containing the call.
+template <typename T>
+Span<const T> AsSpan(const std::initializer_list<T>& list) {
+  return {list.begin(), list.size()};
+}
+
+namespace test {
+
+using ::arrow::AllocateBuffer;
+using ::parquet::test::Vec;
+using ::testing::ElementsAreArray;
+using ::testing::Pointwise;
+
+// Matcher for FLBA equality
+MATCHER_P(EqFlbaPair, len, "has equal FLBA values") {
+  const auto& lhs = std::get<0>(arg);
+  const auto& rhs = std::get<1>(arg);
+  return std::equal(lhs.ptr, lhs.ptr + len, rhs.ptr);
+}
+
+MATCHER_P(FlbaEq, value, "is equal to") {
+  std::string s(value);
+  return std::strncmp(reinterpret_cast<const char*>(arg.ptr), s.data(), s.size()) == 0;
+}
+
+template <size_t BufferSize = 1024>
+class ByteArrayFactory {
+ public:
+  char buffer[BufferSize];
+  size_t buffer_pos = 0;
+
+  ByteArray B(const std::string& value) {
+    if (buffer_pos + value.size() > sizeof(buffer)) {
+      throw std::runtime_error("buffer full");
+    }
+    std::memcpy(buffer + buffer_pos, value.data(), value.size());
+    auto pos = buffer_pos;
+    buffer_pos += value.size();
+    return {static_cast<uint32_t>(value.size()),
+            reinterpret_cast<const uint8_t*>(buffer + pos)};
+  }
+
+  FLBA F(const std::string& value) { return FLBA(B(value).ptr); }
+
+  void ClearBuffer() {
+    std::fill(std::begin(buffer), std::end(buffer), '\0');
+    buffer_pos = 0;
+  }
+};
+
+template <typename T>
+inline void ExpectEqualElements(const std::vector<T>& actual,
+                                const std::vector<T>& expected, int) {
+  EXPECT_THAT(actual, ElementsAreArray(expected));
+}
+
+template <>
+inline void ExpectEqualElements(const std::vector<FLBA>& actual,
+                                const std::vector<FLBA>& expected, int len) {
+  EXPECT_THAT(actual, Pointwise(test::EqFlbaPair(len), expected));
+}
+
+// Similar to Java/C# private.
+namespace copy_bytearray_internal {
+
+inline int GetLength(const ByteArray& value, int defaultArrayLength) { return value.len; }
+inline int GetLength(const FixedLenByteArray&, int defaultArrayLength) {
+  return defaultArrayLength;
+}
+
+/// @brief Merges array of ByteArrays/FLBAS into consolidated byte arrays if they are
+/// consequtive. Example: [0x24...0x31],[0x32...0xDE] will be merged into [0x24...0xDE].
+/// @tparam VarType value type
+/// @param values values
+/// @param count number of values
+/// @param defaultArrayLength default array length
+/// @return merged array
+template <typename VarType>
+inline Vec<std::pair<const uint8_t*, const uint8_t*>> Merge(VarType* values,
+                                                            int64_t count,
+                                                            int defaultArrayLength) {
+  Vec<std::pair<const uint8_t*, const uint8_t*>> merged;
+  for (int64_t i = 0; i < count; ++i) {
+    const auto& v = values[i];
+    if (merged.empty()) {
+      merged.emplace_back(v.ptr, v.ptr + GetLength(v, defaultArrayLength));
+    } else {
+      auto& s = merged.back();
+      if (v.ptr >= s.first && v.ptr <= s.second) {
+        s.second = std::max(s.second, v.ptr + GetLength(v, defaultArrayLength));
+      } else if (s.first >= v.ptr &&
+                 s.first <= v.ptr + GetLength(v, defaultArrayLength)) {
+        s.first = v.ptr;
+      } else {
+        merged.emplace_back(v.ptr, v.ptr + GetLength(v, defaultArrayLength));
+      }
+    }
+  }
+  return merged;
+}
+
+template <typename VarType>
+inline void CopyByteArrayDataImpl(Vec<std::unique_ptr<Buffer>>& byte_array_buffers,
+                                  VarType* values, int64_t count,
+                                  int defaultArrayLength) {
+  const auto merged = Merge(values, count, defaultArrayLength);
+  int64_t i = 0;
+  size_t j = 0;
+  Buffer* current_buffer = nullptr;
+  while (i < count && j < merged.size()) {
+    auto& v = values[i];
+    const auto& s = merged[j];
+    if (current_buffer == nullptr) {
+      ASSERT_OK_AND_ASSIGN(auto buffer, AllocateBuffer(s.second - s.first));
+      std::memcpy(buffer->mutable_data(), s.first, s.second - s.first);
+      byte_array_buffers.emplace_back(std::move(buffer));
+      current_buffer = byte_array_buffers.back().get();
+    } else if (!(v.ptr >= s.first &&
+                 v.ptr + GetLength(v, defaultArrayLength) <= s.second)) {
+      current_buffer = nullptr;
+      ++j;
+      continue;
+    }
+    v.ptr = current_buffer->data() + (v.ptr - s.first);
+    ++i;
+  }
+}
+
+}  // namespace copy_bytearray_internal
+
+inline void CopyByteArrayData(Vec<std::unique_ptr<Buffer>>& byte_array_buffers,
+                              void* values, int64_t, int) {}
+
+/// @brief Backups byte array data to managed memory buffers: byte_array_buffers. Makes a
+/// surgery on values array items by substituting array pointers.
+/// @param byte_array_buffers byte array buffers
+/// @param values values
+/// @param count number of values
+/// @param defaultArrayLength ignored.
+inline void CopyByteArrayData(Vec<std::unique_ptr<Buffer>>& byte_array_buffers,
+                              ByteArray* values, int64_t count, int defaultArrayLength) {
+  copy_bytearray_internal::CopyByteArrayDataImpl(byte_array_buffers, values, count,
+                                                 defaultArrayLength);
+}
+
+/// @brief Backups byte array data to managed memory buffers: byte_array_buffers. Makes a
+/// surgery on values array items by substituting array pointers.
+/// @param byte_array_buffers byte array buffers
+/// @param values values
+/// @param count number of values
+/// @param defaultArrayLength length of the byte arrays within values (fixed for all
+/// items).
+inline void CopyByteArrayData(Vec<std::unique_ptr<Buffer>>& byte_array_buffers,
+                              FixedLenByteArray* values, int64_t count,
+                              int defaultArrayLength) {
+  copy_bytearray_internal::CopyByteArrayDataImpl(byte_array_buffers, values, count,
+                                                 defaultArrayLength);
+}
+
+// Represents a list of types.
+// Example: List<A, B>
+template <typename... T>
+struct List {};
+
+// Concatenates two or more Lists.
+// Example: Concat<List<A, B>, List<C, D>>::type == List<A, B, C, D>
+template <typename... T>
+struct Concat;
+
+template <typename... T, typename... U>
+struct Concat<List<T...>, List<U...>> {
+  using type = List<T..., U...>;
+};
+
+template <typename T, typename... U>
+struct Concat<T, U...> {
+  using type = typename Concat<T, typename Concat<U...>::type>::type;
+};
+
+// Applies T to each element of U, which is List
+// Example: Apply<X, List<A, B>>::type == List<X<A>::type, X<B>::type>
+template <template <typename> class T, typename U>
+struct Apply;
+
+template <template <typename> class T, typename... U>
+struct Apply<T, List<U...>> {
+  using type = List<typename T<U>::type...>;
+};
+
+// Converts std::tuple<T, std::tuple<U...>> into std::tuple<T, U...>
+// Example: TuplePrepend<std::tuple<A, std::tuple<B, C>>>::type == std::tuple<A, B, C>
+template <typename T>
+struct TuplePrepend;
+
+template <typename T, typename... U>
+struct TuplePrepend<std::tuple<T, std::tuple<U...>>> {
+  using type = std::tuple<T, U...>;
+};
+
+// Returns a cartesian product of two or more lists
+// Example: Product<List<A, B>, List<C, D>>::type == List<std::tuple<A, C>, std::tuple<A,
+// D>, std::tuple<B, C>, std::tuple<B, D>>
+template <typename... T>
+struct Product;
+
+template <typename... T>
+struct Product<List<>, List<T...>> {
+  using type = List<>;
+};
+
+template <typename T, typename... U, typename... V>
+struct Product<List<T, U...>, List<V...>> {
+  using type = typename Concat<List<std::tuple<T, V>...>,
+                               typename Product<List<U...>, List<V...>>::type>::type;
+};
+
+template <typename T, typename... U>
+struct Product<T, U...> {
+  using type =
+      typename Apply<TuplePrepend,
+                     typename Product<T, typename Product<U...>::type>::type>::type;
+};
+
+// Converts a list of types to ::testing::Types
+// Example: MakeTypes<List<A, B>>::type == ::testing::Types<A, B>
+template <typename T>
+struct MakeTypes;
+
+template <typename... T>
+struct MakeTypes<List<T...>> {
+  using type = ::testing::Types<T...>;
+};
+
+}  // namespace test
+}  // namespace shuffle
+}  // namespace parquet
diff --git a/cpp/src/parquet/shuffle/trailing_zeros.h b/cpp/src/parquet/shuffle/trailing_zeros.h
new file mode 100644
index 0000000000..61b112001f
--- /dev/null
+++ b/cpp/src/parquet/shuffle/trailing_zeros.h
@@ -0,0 +1,67 @@
+// NOLINT legal/copyright
+
+#pragma once
+
+#include <algorithm>
+#include <cmath>
+#include <limits>
+#include <optional>
+#include <utility>
+
+#include "parquet/shuffle/util/span.h"
+
+namespace parquet {
+namespace shuffle {
+
+// Return (z, 10^z) where z is the number of trailing zeros of the value in base 10.
+inline std::pair<int, uint64_t> CountTrailingZeros(uint64_t value) {
+  int trailing_zeros = 0;
+  uint64_t d = 1;
+  while (value >= 10 && value % 10 == 0) {
+    ++trailing_zeros;
+    d *= 10;
+    value /= 10;
+  }
+  return {trailing_zeros, d};
+}
+
+inline bool IsMinimumTrailingZeros(const std::pair<int, uint64_t>& trailing_zeros) {
+  return trailing_zeros.first == 0;
+}
+
+inline void UpdateTrailingZeros(std::pair<int, uint64_t>& trailing_zeros,
+                                uint64_t value) {
+  while (trailing_zeros.first > 0 && value % trailing_zeros.second != 0) {
+    --trailing_zeros.first;
+    trailing_zeros.second /= 10;
+  }
+}
+
+template <typename ComputeType, typename T>
+std::optional<int> ComputeTrailingZeros(Span<const T> values, T min_value, T max_value) {
+  if (values.empty()) return std::nullopt;
+  const auto max_range =
+      static_cast<ComputeType>(max_value) - static_cast<ComputeType>(min_value);
+  auto trailing_zeros = CountTrailingZeros(max_range);
+  if (!IsMinimumTrailingZeros(trailing_zeros)) {
+    for (const T value : values) {
+      const auto range =
+          static_cast<ComputeType>(value) - static_cast<ComputeType>(min_value);
+      UpdateTrailingZeros(trailing_zeros, range);
+      if (IsMinimumTrailingZeros(trailing_zeros)) break;
+    }
+  }
+  return trailing_zeros.first;
+}
+
+template <typename ComputeType, typename T>
+std::optional<int> ComputeTrailingZeros(Span<const T> values) {
+  if (values.empty()) return std::nullopt;
+  const auto min_max = std::minmax_element(values.begin(), values.end());
+  const T min_value = *min_max.first;
+  const T max_value = *min_max.second;
+  return ComputeTrailingZeros<ComputeType>(values, min_value, max_value);
+}
+
+}  // namespace shuffle
+}  // namespace parquet
