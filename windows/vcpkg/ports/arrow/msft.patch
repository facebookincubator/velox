+static void TestStatisticsJson(
+    int num_rows, std::function<void(schema::NodeVector&)>&& createSchema,
+    std::function<void(parquet::RowGroupWriter*)>&& populateData,
+    std::function<void(const rapidjson::Document&, const std::string&)>&& verifyJson) {
+  auto sink = CreateOutputStream();
+
+  schema::NodeVector fields;
+  createSchema(fields);
+
+  auto schema = std::static_pointer_cast<schema::GroupNode>(
+      schema::GroupNode::Make("schema", Repetition::REQUIRED, fields));
+
+  auto properties = WriterProperties::Builder().enable_delta_stats()->build();
+  auto file_writer = ParquetFileWriter::Open(sink, schema, properties);
+  auto rg_writer = file_writer->AppendRowGroup();
+
+  populateData(rg_writer);
+
+  ASSERT_NO_THROW(file_writer->Close());
+  PARQUET_ASSIGN_OR_THROW(auto buffer, sink->Finish());
+  auto file_reader = ParquetFileReader::Open(
+      std::make_shared<::arrow::io::BufferReader>(buffer), default_reader_properties());
+
+  ASSERT_NE(nullptr, file_reader->metadata());
+  ASSERT_NE(nullptr, file_reader->metadata()->key_value_metadata());
+  auto read_kv_meta = file_reader->metadata()->key_value_metadata();
+
+  EXPECT_TRUE(read_kv_meta->Contains(DELTA_STATS_JSON_KEY));
+
+  PARQUET_ASSIGN_OR_THROW(auto stats_str, read_kv_meta->Get(DELTA_STATS_JSON_KEY));
+
+  auto json = rapidjson::Document();
+  json.Parse(stats_str.c_str());
+  ASSERT_FALSE(json.HasParseError()) << "Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json.IsObject()) << "Statistics JSON: " << stats_str;
+
+  ASSERT_TRUE(json.HasMember("minValues")) << "Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json["minValues"].IsObject()) << "Statistics JSON: " << stats_str;
+
+  ASSERT_TRUE(json.HasMember("maxValues")) << "Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json["maxValues"].IsObject()) << "Statistics JSON: " << stats_str;
+
+  ASSERT_TRUE(json.HasMember("nullCount")) << "Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json["nullCount"].IsObject()) << "Statistics JSON: " << stats_str;
+
+  ASSERT_TRUE(json.HasMember("numRecords")) << "Statistics JSON: " << stats_str;
+  ASSERT_TRUE(json["numRecords"].IsInt()) << "Statistics JSON: " << stats_str;
+  ASSERT_EQ(num_rows, json["numRecords"].GetInt()) << "Statistics JSON: " << stats_str;
+
+  verifyJson(json, stats_str);
+}
