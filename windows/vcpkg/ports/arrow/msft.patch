+
+ShuffleMetrics& operator+=(ShuffleMetrics& lhs, const ShuffleMetrics& rhs) {
+  lhs.dictionary_build_time += rhs.dictionary_build_time;
+  lhs.dictionary_finalize_time += rhs.dictionary_finalize_time;
+  lhs.shuffle_compute_time += rhs.shuffle_compute_time;
+  lhs.shuffle_execute_time += rhs.shuffle_execute_time;
+  lhs.sink_write_time += rhs.sink_write_time;
+  lhs.row_group_close_time += rhs.row_group_close_time;
+  lhs.elapsed_time += rhs.elapsed_time;
+  lhs.uncompressed_size += rhs.uncompressed_size;
+  lhs.compressed_size += rhs.compressed_size;
+  return lhs;
+}
+
+ShuffleMetrics& operator-=(ShuffleMetrics& lhs, const ShuffleMetrics& rhs) {
+  lhs.dictionary_build_time -= rhs.dictionary_build_time;
+  lhs.dictionary_finalize_time -= rhs.dictionary_finalize_time;
+  lhs.shuffle_compute_time -= rhs.shuffle_compute_time;
+  lhs.shuffle_execute_time -= rhs.shuffle_execute_time;
+  lhs.sink_write_time -= rhs.sink_write_time;
+  lhs.row_group_close_time -= rhs.row_group_close_time;
+  lhs.elapsed_time -= rhs.elapsed_time;
+  lhs.uncompressed_size -= rhs.uncompressed_size;
+  lhs.compressed_size -= rhs.compressed_size;
+  return lhs;
+}
+
+ShuffleMetrics operator-(const ShuffleMetrics& lhs, const ShuffleMetrics& rhs) {
+  ShuffleMetrics res = lhs;
+  res -= rhs;
+  return res;
+}
+
+ShuffleMetrics& operator*=(ShuffleMetrics& lhs, const ShuffleMetrics& rhs) {
+  lhs.dictionary_build_time *= rhs.dictionary_build_time;
+  lhs.dictionary_finalize_time *= rhs.dictionary_finalize_time;
+  lhs.shuffle_compute_time *= rhs.shuffle_compute_time;
+  lhs.shuffle_execute_time *= rhs.shuffle_execute_time;
+  lhs.sink_write_time *= rhs.sink_write_time;
+  lhs.row_group_close_time *= rhs.row_group_close_time;
+  lhs.elapsed_time *= rhs.elapsed_time;
+  lhs.uncompressed_size *= rhs.uncompressed_size;
+  lhs.compressed_size *= rhs.compressed_size;
+  return lhs;
+}
+
+ShuffleMetrics operator*(const ShuffleMetrics& lhs, const ShuffleMetrics& rhs) {
+  ShuffleMetrics res = lhs;
+  res *= rhs;
+  return res;
+}
+
+ShuffleMetrics& operator/=(ShuffleMetrics& lhs, uint64_t rhs) {
+  lhs.dictionary_build_time /= rhs;
+  lhs.dictionary_finalize_time /= rhs;
+  lhs.shuffle_compute_time /= rhs;
+  lhs.shuffle_execute_time /= rhs;
+  lhs.sink_write_time /= rhs;
+  lhs.row_group_close_time /= rhs;
+  lhs.elapsed_time /= rhs;
+  lhs.uncompressed_size /= rhs;
+  lhs.compressed_size /= rhs;
+  return lhs;
+}
+
+ShuffleMetrics Sqrt(const ShuffleMetrics& m) {
+  ShuffleMetrics res;
+  res.dictionary_build_time = std::sqrt(m.dictionary_build_time);
+  res.dictionary_finalize_time = std::sqrt(m.dictionary_finalize_time);
+  res.shuffle_compute_time = std::sqrt(m.shuffle_compute_time);
+  res.shuffle_execute_time = std::sqrt(m.shuffle_execute_time);
+  res.sink_write_time = std::sqrt(m.sink_write_time);
+  res.row_group_close_time = std::sqrt(m.row_group_close_time);
+  res.elapsed_time = std::sqrt(m.elapsed_time);
+  res.uncompressed_size = std::sqrt(m.uncompressed_size);
+  res.compressed_size = std::sqrt(m.compressed_size);
+  return res;
+}
+
+std::vector<double> AsVector(const ShuffleMetrics& metrics) {
+  return {
+      metrics.dictionary_build_time, metrics.dictionary_finalize_time,
+      metrics.shuffle_compute_time,  metrics.shuffle_execute_time,
+      metrics.sink_write_time,       metrics.row_group_close_time,
+      metrics.elapsed_time,          metrics.uncompressed_size,
+      metrics.compressed_size,
+  };
+}
+
+ShuffleMetrics AsMetrics(const std::vector<double>& values) {
+  ShuffleMetrics metrics;
+  metrics.dictionary_build_time = values[0];
+  metrics.dictionary_finalize_time = values[1];
+  metrics.shuffle_compute_time = values[2];
+  metrics.shuffle_execute_time = values[3];
+  metrics.sink_write_time = values[4];
+  metrics.row_group_close_time = values[5];
+  metrics.elapsed_time = values[6];
+  metrics.uncompressed_size = values[7];
+  metrics.compressed_size = values[8];
+  return metrics;
+}
+
+std::vector<std::vector<double>> Transpose(const std::vector<ShuffleMetrics>& metrics) {
+  std::vector<std::vector<double>> t;
+  for (const auto& m : metrics) {
+    const auto v = AsVector(m);
+    if (t.empty()) {
+      t.resize(v.size());
+    }
+    for (size_t i = 0; i < v.size(); ++i) {
+      t[i].push_back(v[i]);
+    }
+  }
+  return t;
+}
+
+template <typename Func>
+ShuffleMetrics Reduce(const std::vector<ShuffleMetrics>& metrics, Func&& func) {
+  auto t = Transpose(metrics);
+  std::vector<double> values(t.size());
+  std::transform(t.begin(), t.end(), values.begin(), std::forward<Func>(func));
+  return AsMetrics(values);
+}
+
+ShuffleMetrics Mean(const std::vector<ShuffleMetrics>& metrics) {
+  ShuffleMetrics mean;
+  for (const auto& m : metrics) {
+    mean += m;
+  }
+  mean /= metrics.size();
+  return mean;
+}
+
+ShuffleMetrics Stddev(const std::vector<ShuffleMetrics>& metrics) {
+  const auto mean = Mean(metrics);
+  ShuffleMetrics stddev;
+  for (const auto& m : metrics) {
+    const auto d = m - mean;
+    stddev += d * d;
+  }
+  stddev /= metrics.size();
+  return Sqrt(stddev);
+}
+
+ShuffleMetrics Min(const std::vector<ShuffleMetrics>& metrics) {
+  return Reduce(metrics, [](const std::vector<double>& values) {
+    return *std::min_element(values.begin(), values.end());
+  });
+}
+
+ShuffleMetrics Max(const std::vector<ShuffleMetrics>& metrics) {
+  return Reduce(metrics, [](const std::vector<double>& values) {
+    return *std::max_element(values.begin(), values.end());
+  });
+}
+
+ShuffleMetrics Median(const std::vector<ShuffleMetrics>& metrics) {
+  return Reduce(metrics, [](std::vector<double>& values) {
+    const auto median = values.size() / 2;
+    std::nth_element(values.begin(), values.begin() + median, values.end());
+    return values[median];
+  });
+}
+
+}  // namespace shuffle
+}  // namespace parquet
