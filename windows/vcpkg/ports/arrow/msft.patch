+static_assert_(sizeof(VaryingLenghtUint32<32>) == 8);
+static_assert_(sizeof(FuzzRawMetadata) == 24);
+/// @brief Parses input data provided froom fuzzer (generated in memory or from corpus
+/// file) and kicks off test execution. data hase the following binary format:
+/// struct File {
+///   struct FuzzRawMetadata {  // 24 bytes
+///   uint8_t num_rowgroups; -------------------------------------------------- ----|
+///   uint8_t num_columns; ----------------------------------------------------|    |
+///   VaryingLenghtUint32<32> dictinary_page_size_limit; // 8 bytes            |    |
+///   VaryingLenghtUint32<19> shuffle_raw_encoding_threadhold; // 8 bytes      |    |
+///   uint8_t shuffle_threads : 2;                                             |    |
+///   uint8_t parquet_data_page_version : 1;                                   |    |
+///   bool enable_dictionary : 1;                                              |    |
+///   bool enable_shuffle : 1;                                                 |    |
+///   bool shuffle_auto_encoding : 1;                                          |    |
+///   } metadata;                                                              |    |
+///                                                                            |    |
+///   struct FuzzRawColumn {  // 10 bytes                                      |    |
+///     uint16_t def_levels_offset;                                            |    |
+///     uint16_t rep_levels_offset;                                            |    |
+///     uint16_t values_offset;                                                |    |
+///     uint8_t rep_spec;  // Each 2 bits represent @ref parquet::Repetition   |    |
+///     uint8_t type;                                                          |    |
+///     uint8_t flba_len;                                                      |    |
+///   } columns[num_columns]; <------------------------------------------------|    |
+///                                                                            |    |
+///   struct {                                                                 |    |
+///     uint8_t num_batches;  // 1 byte   -------                              |    |
+///     struct FuzzRawBatch {  // 2 bytes       |                              |    |
+///       uint8_t num_rows;                     |                              |    |
+///       bool write_spaced : 1;                |                              |    |
+///       bool drop_def_levels : 1;             |                              |    |
+///       bool drop_rep_levels : 1;             |                              |    |
+///     } batches[num_batches]; <----------------                              |    |
+///   } batches[num_rowgroups][num_columns]; <------------------------------------<-|
+///
+///   // total offset: ~ 2 + num_columns * (10 + 3 * num_rowgroups * <num_batches>)
+///   // num_batches is not constant.
+///   uint8_t* values_data; // the remaining data, treated as infinite cyclic buffer
+// };
+/// @param data data
+/// @param size size
+/// @return non zero if rejecting input as invalid.
+int LLVMFuzzerTestOneInput(const uint8_t* data, size_t size);
+
+namespace internal {
+// ThrowListener gtest feilures into exceptions.
+class ThrowListener : public testing::EmptyTestEventListener {
+  void OnTestPartResult(const testing::TestPartResult& result) override {
+    if (result.type() == testing::TestPartResult::kFatalFailure) {
+      throw testing::AssertionException(result);
+    }
+  }
+};
+
+const std::string gen_folder_prefix = "-gen_folder=";
+
+ThrowListener* throw_listener = new ThrowListener();
+}  // namespace internal
+using namespace internal;
+
+class MemoryStreamEndException : public std::range_error {
+ public:
+  MemoryStreamEndException(const std::string message) : std::range_error(message) {}
+};
+
+class InputDataException : public std::runtime_error {
+ public:
+  InputDataException(const std::string message) : std::runtime_error(message) {}
+};
+
+/// @brief MemoryStream wraps arrays of bytes and allows to read from it several kind of
+/// values.
+class MemoryStream {
+ public:
+  MemoryStream(const uint8_t* first, const size_t length)
+      : current(first), last(first + length) {}
+
+  const uint8_t* current;
+  const uint8_t* last;
+
+ private:
+  const MemoryStreamEndException BuildMemoryStreamEndException(
+      const std::string& context) const {
+    std::stringstream ss;
+    ss << "End of memory stream reached. Context: " << context;
+    return MemoryStreamEndException(ss.str());
+  }
+
+ public:
+  template <typename T>
+  const T* Read(int n, const std::string& context) {
+    auto newCurrent = current + sizeof(T) * n;
+    if (newCurrent <= last) {
+      auto result = current;
+      current = newCurrent;
+      return reinterpret_cast<const T*>(result);
+    }
+
+    throw BuildMemoryStreamEndException(context);
+  }
+
+  const uint8_t* ReadRemainingBytes(size_t& n, const std::string context) {
+    if (current < last) {
+      auto result = current;
+      n = last - current;
+      current = last;
+      return result;
+    }
+
+    throw BuildMemoryStreamEndException(context);
+  }
+};
+
+/// @brief Generates content for fuzz corpus file for single column, single rowgroup and
+/// single batch.
+/// @param repetitions_spec each pair of nits encodes a repetion type according to @ref
+/// parquet::Repetition::type
+/// @param size size
+/// @return return
+std::tuple<std::unique_ptr<::arrow::Buffer>, std::string> Generate(
+    int seed, std::default_random_engine& re, const uint8_t repetitions_spec,
+    size_t num_rows, const size_t size) {
+  using random_bytes_engine =
+      std::independent_bits_engine<std::default_random_engine,
+                                   std::numeric_limits<uint8_t>::digits, uint16_t>;
+
+  PARQUET_ASSIGN_OR_THROW(auto buffer, ::arrow::AllocateBuffer(size));
+  random_bytes_engine rbe(re);
+
+  std::generate(buffer->mutable_data(), buffer->mutable_data() + buffer->size(),
+                [&rbe]() { return static_cast<std::uint8_t>(rbe()); });
+
+  MemoryStream ms(buffer->mutable_data(), buffer->size());
+  auto md = const_cast<FuzzRawMetadata*>(ms.Read<const FuzzRawMetadata>(1, ""));
+  md->SetColumnsCount(1);
+  md->SetRowGroupCount(1);
+  if (md->GetShuffleThreads() < 1) {
+    md->SetShuffleThreads(1);
+  } else if (md->GetShuffleThreads() > 2) {
+    md->SetShuffleThreads(2);
+  }
+  md->SetshuffleRawEncodingThreadhold(100000);
+  auto column = const_cast<FuzzRawColumn*>(ms.Read<const FuzzRawColumn>(1, ""));
+  column->rep_spec = repetitions_spec;
+
+  auto num_batches = const_cast<num_batches_t*>(
+      ms.Read<num_batches_t>(1, "reading rowgroup batches num"));
+  *num_batches = 1;
+
+  auto batches =
+      const_cast<FuzzRawBatch*>(ms.Read<FuzzRawBatch>(1, "reading batches rows num"));
+  batches[0].SetNumRows(num_rows);
+
+  std::stringstream file_name_builder;
+  file_name_builder << "_corpus_" << seed << "_" << column->GetType() << "_"
+                    << std::bitset<8>(column->rep_spec) << "_"
+                    << batches[0].GetWriteSpaced() << "_" << batches[0].GetDropREpLevels()
+                    << "_" << batches[0].GetDropDefLevels() << "_"
+                    << static_cast<int>(md->GetParquetDataPageVersion()) << "_"
+                    << (+(md->GetShuffleThreads())) << "_" << md->GetEnableDictionary()
+                    << "_" << md->GetEnableShuffle() << "_"
+                    << md->GetEnableShuffleAutoEncoding() << "_" << (+num_rows);
+
+  return {std::move(buffer), file_name_builder.str()};
+}
+
+/// @brief Constructs a schema column node for the column.
+/// @tparam T T
+/// @param index index
+/// @param rep_spec each pair of nits encodes a repetion type according to @ref
+/// parquet::Repetition::type
+/// @param type type
+/// @param flba_len flba_len
+/// @return return
+template <typename T>
+parquet::schema::NodePtr MakeColumn(const uint index, T rep_spec,
+                                    const parquet::Type::type type,
+                                    const uint16_t flba_len) {
+  auto repetition = static_cast<parquet::Repetition::type>(rep_spec & 0b11);
+  repetition = (repetition == parquet::Repetition::UNDEFINED)
+                   ? parquet::Repetition::REQUIRED
+                   : repetition;
+  uint depth = 0;
+
+  parquet::schema::NodePtr current = parquet::schema::PrimitiveNode::Make(
+      "col_" + std::to_string(index) + "_" + std::to_string(depth), repetition, type,
+      parquet::ConvertedType::NONE,
+      (type == parquet::Type::FIXED_LEN_BYTE_ARRAY) ? static_cast<int>(flba_len) : -1);
+
+  depth++;
+  rep_spec >>= 2;
+  for (; depth < sizeof(T) * 4; depth++, rep_spec >>= 2) {
+    repetition = static_cast<parquet::Repetition::type>(rep_spec & 0b11);
+    if (repetition == parquet::Repetition::UNDEFINED) {
+      break;
+    }
+
+    current = parquet::schema::GroupNode::Make(
+        "col_" + std::to_string(index) + "_" + std::to_string(depth), repetition,
+        parquet::schema::NodeVector{current});
+  }
+
+  return current;
+}
+
+/// @brief Makes the surgery on command line arguments and performs custom operations
+/// provided by custom arguments. Currently -gen-folder only supported.
+/// @param argc argc
+/// @param argv argv
+/// @return 0
+int LLVMFuzzerInitialize(int* argc, const char*** argv) {
+  testing::UnitTest::GetInstance()->listeners().Append(internal::throw_listener);
+
+  const char* gen_folder_arg = nullptr;
+  auto last = std::remove_if(*argv, *argv + *argc, [&gen_folder_arg](const char* it) {
+    if (std::strncmp(it, gen_folder_prefix.c_str(), gen_folder_prefix.length()) == 0) {
+      if (gen_folder_arg != nullptr) {
+        throw std::runtime_error("Duplicated argument: '" + internal::gen_folder_prefix +
+                                 "'");
+      } else {
+        gen_folder_arg = it;
+      }
+      return true;
+    }
+    return false;
+  });
+  *argc = static_cast<int>(last - *argv);
+
+  if (gen_folder_arg != nullptr) {
+    auto gen_folder_val = gen_folder_arg + gen_folder_prefix.length();
+
+    Vec<uint8_t> repetition_specs = {0b11111100, 0b11111101, 0b11111110, 0b11110000,
+                                     0b11110001, 0b11110010, 0b11110100, 0b11110101,
+                                     0b11110110, 0b11111000, 0b11111001, 0b11111010};
+    Vec<uint8_t> num_rowss = {1, 10, 100};
+    auto repetition_spec_distribution = std::uniform_int_distribution<int>(
+        0, static_cast<int>(repetition_specs.size() - 1));
+
+    auto num_rows_distribution =
+        std::uniform_int_distribution<int>(0, static_cast<int>(num_rowss.size() - 1));
+
+    for (size_t seed = 0, cnt = 0; cnt < 4096; ++seed) {
+      std::default_random_engine dre(seed);
+      repetition_spec_distribution(dre);  // dry run
+      auto generated = Generate(static_cast<int>(seed), dre,
+                                repetition_specs.at(repetition_spec_distribution(dre)),
+                                num_rowss.at(num_rows_distribution(dre)), 4 * 1024);
+
+      if (LLVMFuzzerTestOneInput(std::get<0>(generated)->data(), 4 * 1024) != 0) {
+        continue;
+      }
+
+      ++cnt;
+      std::stringstream file_name_builder;
+      file_name_builder << gen_folder_val << "/" << std::get<1>(generated);
+      const std::string file_name = file_name_builder.str();
+
+      std::ofstream ofs(file_name, std::ios::binary | std::ios::trunc);
+      ofs.write(reinterpret_cast<const char*>(std::get<0>(generated)->mutable_data()),
+                std::get<0>(generated)->size());
+
+      ofs.flush();
+      ofs.close();
+    }
+  }
+
+  return 0;
+}
+
+const char* GetEnvOrElse(const char* var, const char* default_value) {
+  const auto value = std::getenv(var);
+  return value != nullptr ? value : default_value;
+}
+
+int GetPid() {
+#ifdef _WIN32
+  return GetCurrentProcessId();
+#else
+  return getpid();
+#endif
+}
+
+std::string FormatLogPath(std::string input) {
+  const auto pos = input.find("%p");
+  if (pos == std::string::npos) {
+    return input;
+  } else {
+    const auto pid = GetPid();
+    return input.substr(0, pos) + std::to_string(pid) + input.substr(pos + 2);
+  }
+}
+
+const std::string log_path(GetEnvOrElse("PARQUET_SHUFFLE_FUZZ_LOG_PATH",
+                                        "parquet_shuffle_fuzz_log.%p.out"));
+
+const std::string log_time_format(GetEnvOrElse("PARQUET_SHUFFLE_FUZZ_LOG_TIME_FORMAT",
+                                               "%Y-%m-%d %H:%M:%S"));
+
+template <typename Clock, typename Duration>
+std::string FormatTime(const std::chrono::time_point<Clock, Duration>& tp) {
+  const auto tt = Clock::to_time_t(tp);
+  const auto utc_tm = std::gmtime(&tt);
+  char formatted_time[100];
+  std::strftime(formatted_time, sizeof(formatted_time), log_time_format.c_str(), utc_tm);
+  return formatted_time;
+}
+
+void LogException(std::ostream& os, const std::exception& ex) {
+  const auto now = std::chrono::system_clock::now();
+  os << FormatTime(now) << " " << ::testing::internal::GetTypeName(typeid(ex)) << " "
+     << ex.what() << std::endl;
+}
+
+int LLVMFuzzerTestOneInput(const uint8_t* data, size_t size) {
+  static std::ofstream log(FormatLogPath(log_path), std::ios::app);
+  MemoryStream dataMs(data, size);
+
+  const FuzzRawMetadata* raw_metadata;
+  const FuzzRawColumn* columns;
+  Vec<Vec<Vec<test::RawBatch>>> batches;
+  const uint8_t* start_of_data;
+  size_t data_len;
+
+  try {
+    raw_metadata =
+        dataMs.Read<const FuzzRawMetadata>(1, std::string("reading RawMetadata"));
+    columns = dataMs.Read<const FuzzRawColumn>(raw_metadata->GetColumnsCount(),
+                                               std::string("Reading RawColumns"));
+
+    for (size_t rgi = 0; rgi < raw_metadata->GetRowGroupCount(); rgi++) {
+      batches.emplace_back(Vec<Vec<test::RawBatch>>());
+      auto& rg = batches.back();
+
+      for (size_t coli = 0; coli < raw_metadata->GetColumnsCount(); coli++) {
+        rg.emplace_back(Vec<test::RawBatch>());
+        auto& col = rg.back();
+        auto num_batches =
+            (*dataMs.Read<num_batches_t>(1, "reading rowgroup batches num")) &
+            NUM_BATCHES_MASK;
+        col.reserve(num_batches);
+        auto batches = dataMs.Read<FuzzRawBatch>(num_batches, "reading batches rows num");
+
+        std::transform(
+            batches, batches + num_batches, std::back_inserter(col), [](FuzzRawBatch x) {
+              return test::RawBatch(x.GetNumRows(), x.GetWriteSpaced(),
+                                    x.GetDropDefLevels(), x.GetDropREpLevels());
+            });
+      }
+    }
+
+    start_of_data =
+        dataMs.ReadRemainingBytes(data_len, std::string("reading binary data (tail)"));
+  } catch (const MemoryStreamEndException& mme) {
+    LogException(log, mme);
+    return -1;
+  } catch (const InputDataException& ide) {
+    LogException(log, ide);
+    return -1;
+  }
+
+  Vec<test::DataPointers> data_pointers_per_column;
+
+  for (int col = 0; col < raw_metadata->GetColumnsCount(); col++) {
+    data_pointers_per_column.emplace_back(test::DataPointers(
+        test::CircularMemoryStream(start_of_data, data_len,
+                                   columns[col].def_levels_offset),
+        test::CircularMemoryStream(start_of_data, data_len,
+                                   columns[col].rep_levels_offset),
+        test::CircularMemoryStream(start_of_data, data_len, columns[col].values_offset)));
+  }
+
+  parquet::schema::NodeVector fields;
+
+  for (size_t ci = 0; ci < raw_metadata->GetColumnsCount(); ++ci) {
+    fields.emplace_back(MakeColumn(static_cast<uint>(ci), columns[ci].rep_spec,
+                                   columns[ci].GetType(), columns[ci].GetFlbaLength()));
+  }
+
+  try {
+    parquet::test::RunEndToEndTest(raw_metadata->GetRawMetaData(), batches,
+                                   data_pointers_per_column, fields);
+  } catch (const parquet::test::UnsupportedTestScenarioError& e) {
+    LogException(log, e);
+    return -1;
+  }
+  return 0;
+}
