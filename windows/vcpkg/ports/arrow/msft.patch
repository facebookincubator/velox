+::arrow::Result<std::string> ToString(int64_t value, const ColumnDescriptor& descr) {
+  const auto logical_type = descr.logical_type();
+  if (logical_type->is_none()) {
+    return std::to_string(value);
+  } else if (logical_type->is_decimal()) {
+    return internal::DecimalToString(value, AsDecimalType(*logical_type));
+  } else if (logical_type->is_timestamp()) {
+    return internal::TimestampToString(
+        value, static_cast<const TimestampLogicalType&>(*logical_type),
+        /*legacy_mode=*/false);
+  }
+  return ::arrow::Status::Invalid("unsupported logical type for INT64: " +
+                                  logical_type->ToString());
