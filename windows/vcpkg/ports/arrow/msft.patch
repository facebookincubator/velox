+template <typename Func>
+void OptionalParallelFor(int num_tasks, Func&& func,
+                         ::arrow::internal::Executor* executor) {
+  if (executor != nullptr) {
+    PARQUET_THROW_NOT_OK(::arrow::internal::ParallelFor(
+        num_tasks, MakeExceptionStatusWrapper(std::forward<Func>(func)), executor));
