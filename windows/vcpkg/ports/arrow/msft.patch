+std::function<std::ostream&(std::ostream&)> PrintBytes(int64_t bytes) {
+  return [bytes](std::ostream& os) -> std::ostream& {
+    os << bytes << " bytes";
+    const auto bytes_as_double = static_cast<double>(bytes);
+    const auto n = std::log2(bytes_as_double);
+    if (n < 10) return os;
+    os << std::setprecision(4) << " (";
+    if (n >= 30) {
+      os << bytes_as_double / 1024 / 1024 / 1024 << " GiB";
+    } else if (n >= 20) {
+      os << bytes_as_double / 1024 / 1024 << " MiB";
+    } else if (n >= 10) {
+      os << bytes_as_double / 1024 << " KiB";
+    }
+    return os << ")";
+  };
+}
