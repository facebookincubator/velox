+  }
+
+  bool Apply(Span<ColumnData>, Span<int32_t> permutation,
+             Span<int32_t>& complete_permutation) override {
+    std::iota(permutation.begin(), permutation.end(), 0);
+    std::reverse(permutation.begin(), permutation.end());
