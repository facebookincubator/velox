+
+namespace parquet {
+namespace shuffle {
+
+class ShuffleAlgorithmProperties;
+
+static constexpr int kUseDefaultShuffleLevel = std::numeric_limits<int>::min();
+static constexpr const char* kDefaultShuffleAlgorithm = "vorder";
+
+class PARQUET_EXPORT ShuffleProperties {
+ public:
+  static constexpr int UseDefaultShuffleLevel() { return kUseDefaultShuffleLevel; }
+
+  static constexpr const char* DefaultShuffleAlgorithm() {
+    return kDefaultShuffleAlgorithm;
+  }
+
+  ShuffleProperties()
+      : shuffle_algorithm_(DefaultShuffleAlgorithm()),
+        shuffle_level_(UseDefaultShuffleLevel()),
+        num_threads_(0),
+        verbose_(false),
+        memory_pool_(nullptr) {}
+
+  void shuffle_algorithm(std::string shuffle_algorithm) {
+    shuffle_algorithm_ = std::move(shuffle_algorithm);
+  }
+
+  const std::string shuffle_algorithm() const { return shuffle_algorithm_; }
+
+  void shuffle_level(int shuffle_level) { shuffle_level_ = shuffle_level; }
+
+  int shuffle_level() const { return shuffle_level_; }
+
+  void num_threads(int num_threads);
+
+  int num_threads() const { return num_threads_; }
+
+  int GetEffectiveNumThreads() const;
+
+  void verbose(bool verbose) { verbose_ = verbose; }
+
+  bool verbose() const { return verbose_; }
+
+  void algorithm_properties(
+      std::shared_ptr<ShuffleAlgorithmProperties> algorithm_properties) {
+    algorithm_properties_ = std::move(algorithm_properties);
+  }
+
+  const ShuffleAlgorithmProperties* algorithm_properties() const {
+    return algorithm_properties_.get();
+  }
+
+  void memory_pool(MemoryPool* memory_pool) { memory_pool_ = memory_pool; }
+
+  MemoryPool* memory_pool() const { return memory_pool_; }
+
+  void thread_pool(std::shared_ptr<::arrow::internal::ThreadPool> thread_pool) {
+    thread_pool_ = std::move(thread_pool);
+  }
+
+  std::shared_ptr<::arrow::internal::ThreadPool> thread_pool() const {
+    return thread_pool_;
+  }
+
+ private:
+  std::string shuffle_algorithm_;
+  int shuffle_level_;
+  int num_threads_;
+  bool verbose_;
+  std::shared_ptr<ShuffleAlgorithmProperties> algorithm_properties_;
+  MemoryPool* memory_pool_;
+  std::shared_ptr<::arrow::internal::ThreadPool> thread_pool_;
+};
+
+PARQUET_EXPORT
+std::ostream& operator<<(std::ostream& os, const ShuffleProperties& properties);
+
+}  // namespace shuffle
+}  // namespace parquet
