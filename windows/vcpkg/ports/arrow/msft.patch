+class TestTruncateString
+    : public ::testing::TestWithParam<std::tuple<
+          ::arrow::Result<std::string> (*)(std::string, int), TruncateStringParam>> {};
+
+TEST_P(TestTruncateString, Test) {
+  const auto func_ptr = std::get<0>(GetParam());
+  const auto& args = std::get<1>(GetParam());
+  const auto result = (*func_ptr)(std::get<0>(args), std::get<1>(args));
+  const auto expected = std::get<2>(args);
+  if (expected) {
+    ASSERT_TRUE(result.ok());
+    EXPECT_THAT(result.ValueOrDie(), StrEq(*expected));
+  } else {
+    ASSERT_FALSE(result.ok()) << "expected error, got: " << result.ValueOrDie();
+  }
+}
