<?xml version="1.0" encoding="utf-8"?>
<!-- Pre-cached vcpkg tool downloads (MSYS2 packages, pkgconf, etc.) for OneBranch builds.
     These are blocked by OneBranch network isolation and must be pre-populated
     in VCPKG_DOWNLOADS before cmake configure runs. -->
<packages>
  <package id="Vcpkg.Tools.Cache" version="2.3.0" />
</packages>
