@PACKAGE_INIT@

# Velox Windows CMake config file
# Generated by configure_package_config_file()

include(CMakeFindDependencyMacro)

# Find required dependencies
find_dependency(Threads REQUIRED)

# Set the velox library path
set(VELOX_LIBRARY "${PACKAGE_PREFIX_DIR}/lib/velox.lib")

if(EXISTS "${VELOX_LIBRARY}")
  if(NOT TARGET velox::velox)
    add_library(velox::velox STATIC IMPORTED)
    set_target_properties(velox::velox PROPERTIES
      IMPORTED_LOCATION "${VELOX_LIBRARY}"
    )
  endif()
endif()

check_required_components(velox-windows)
